      "c-product-featured-v2": {
        "type": "c-product-featured-v2",
        "blocks": {
          "key_ingredients_eYQJNW": {
            "type": "key_ingredients",
            "settings": {
              "title": "Key Ingredients",
              "ingredient_1_icon": "shopify://shop_images/c-ing-img-3_5ed91ea9-b62d-4dd3-ad7a-7ffdad483d79.webp",
              "ingredient_1_name": "BEETROOT EXTRACT & NITRATE BLEND",
              "ingredient_1_description": "A potent source of dietary nitrates that is broken down in the body to form Nitric Oxide. Two of our capsules has the dietary nitrate equivalent of 7oz of beetroot.",
              "ingredient_2_icon": "shopify://shop_images/c-ing-img-1_6f013a8a-d450-4190-9e78-0f7d34cdc952.webp",
              "ingredient_2_name": "VITAMIN C",
              "ingredient_2_description": "An essential vitamin and potent antioxidant, Vitamin C helps convert nitrite to nitric oxide.",
              "ingredient_3_icon": "shopify://shop_images/circle-img-5.webp",
              "ingredient_3_name": "MAGNESIUM",
              "ingredient_3_description": "A crucial mineral respected for its ability to relax blood vessels; sufficient magnesium intake is important for cardiovascular health."
            }
          },
          "proven_results_tabs_BPVMNm": {
            "type": "proven_results_tabs",
            "settings": {
              "tab1_title": "Is This Right for Me?",
              "tab2_title": "How to Use",
              "tab1_fallback_content": "",
              "usage_title": "",
              "usage_subtitle": "",
              "usage_text": "<p>Take two capsules once a day with water after food. This dosage boosts Nitric Oxide levels throughout for up to 24 hours. Do not exceed the recommended daily intake unless under the direction of your physician. Use with Berkeley Nitric Oxide Test Strips to establish nitrite levels and oral microbiome health.<br/>Suitable for vegetarians and vegans. Made without most allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soy). Gluten and gelatin free.<br/><br/></p>"
            }
          }
        },
