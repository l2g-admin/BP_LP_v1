gnup","blocks":{"button_wDCNrc":{"type":"button","settings":{"button_text":"Shop Nitric Oxide Support","button_url":"#product_feature","button_class":"banner__button"}}},"block_order":["button_wDCNrc"],"name":"C Banner Signup","settings":{"background_image":"shopify:\/\/shop_images\/CTA_v2_a2742d31-67fb-4566-b299-d5a86c5f2e9f.png","title":"Reclaim {accent}Performance{\/accent}. Support Circulation.","subtitle":"Built on clinical research. Designed for men who want to feel confident at any age.","description":"","show_email_form":false,"use_klaviyo_form":false,"klaviyo_form_id":"Wre23A","placeholder_text":"Enter your email","button_text":"Sign Up for First Look","customer_tag":"newsletter","card_bg":"linear-gradient(180deg, rgba(27, 28, 41, 0.5), rgba(27, 28, 41, 0.5) 100%)","card_border_color":"#1b1c29","text_color":"#ffffff","accent_color":"#00b5b5","input_bg":"#ffffff","input_text_color":"#333333","button_bg":"#d44f2f","button_text_color":"#ffffff","padding_top":4,"padding_bottom":4}},"c_faq_tabs_UWK6UP":{"type":"c-faq-tabs","blocks":{"faq_tab_KiT3gi":{"type":"faq_tab","settings":{"tab_id":"medications","label":"Medications"}},"faq_tab_etakFe":{"type":"faq_tab","settings":{"tab_id":"safety","label":"Safety"}},"faq_tab_MYKAeV":{"type":"faq_tab","settings":{"tab_id":"dosage","label":"Dosage"}},"faq_tab_meebRQ":{"type":"faq_tab","settings":{"tab_id":"shipping","label":"Shipping"}},"faq_item_WLYpJt":{"type":"faq_item","settings":{"tab_id":"medications","question":"Can Berkeley Life be taken with blood pressure or ED medications?","answer":"<p>Yes. Berkeley Life is safe and well-tolerated with no known contraindications. However, we recommend speaking with your healthcare provider to ensure the right combination of medication and supplementation.<\/p>","open_by_default":false}},"faq_item_Jq8UMr":{"type":"faq_item","settings":{"tab_id":"medications","question":"Are there any contraindication to using Berkeley Life?","answer":"<p>There are no known contraindications or reported adverse events. A good rule of thumb: if you can eat a leafy green salad, you can take Berkeley Life.<\/p>","open_by_default":false}},"faq_item_ALFx3G":{"type":"faq_item","settings":{"tab_id":"medications","question":"Is it safe for people with oxalate sensitivities?","answer":"<p>Yes. The oxalate content is extremely low—less than a single spinach leaf. Even individuals with sensitivities generally tolerate it well.<\/p>","open_by_default":false}},"faq_item_eahpwT":{"type":"faq_item","settings":{"tab_id":"medications","question":"Should I talk to my healthcare provider before starting Berkeley Life?","answer":"<p>No. Berkeley Life supports nitric oxide production through dietary nitrates instead. L-Arginine works through an enzymatic pathway that is often impaired, so it’s not as reliable.<\/p>","open_by_default":false}},"faq_item_xcBFPr":{"type":"faq_item","settings":{"tab_id":"safety","question":"Is Berkeley Life safe for daily use?","answer":"<p>Yes. Berkeley Life is manufactured in the United States under FDA-registered, GMP-certified facilities, and undergoes rigorous internal and third-party testing to ensure safety and potency.<\/p>","open_by_default":false}},"faq_item_DeG7X4":{"type":"faq_item","settings":{"tab_id":"safety","question":"What quality standards do you follow?","answer":"<p>Every ingredient is tested for identity, potency, and microbiological safety before use. Finished products undergo comprehensive quality checks and third-party testing before being released.<\/p>","open_by_default":false}},"faq_item_QctQnH":{"type":"faq_item","settings":{"tab_id":"safety","question":"Can I validate that Berkeley Life is working for me?","answer":"<p>Yes. You can use the Nitric Oxide Test Strips before and 90 minutes after taking the supplement to confirm effectiveness.<\/p>","open_by_default":false}},"faq_item_QjPgkr":{"type":"faq_item","settings":{"tab_id":"safety","question":"Where is Berkeley Life made?","answer":"<p>Supplements are manufactured in the USA, and test strips are produced in Europe.<\/p>","open_by_default":false}},"faq_item_aNRGdk":{"type":"faq_item","settings":{"tab_id":"dosage","question":"How much should I take daily?","answer":"<p>Take two capsules daily with water, preferably after a meal.<\/p>","open_by_default":false}},"faq_item_gCKxeV":{"type":"faq_item","settings":{"tab_id":"dosage","question":"How long do I need to take Berkeley Life before I see results?","answer":"<p>Results vary, some notice a difference right away, while others see benefits after about a month. Consistency is key, and test strips can validate improvements quickly.<\/p>","open_by_default":false}},"faq_item_KAmrV7":{"type":"faq_item","settings":{"tab_id":"dosage","question":"How long should I continue taking Nitric Oxide support?","answer":"<p>Since natural nitric oxide production declines with age, ongoing daily support through diet or supplementation is recommended.<\/p>","open_by_default":false}},"faq_item_CCyhPB":{"type":"faq_item","settings":{"tab_id":"dosage","question":"What if my test strip doesn’t change color?","answer":"<p>If you recently ate or drank, saliva may be diluted, causing a false negative. In rare cases, low oral bacteria levels may impact conversion. We recommend discussing ways to support your oral microbiome with your healthcare provider.<\/p>","open_by_default":false}},"faq_item_JXpr3L":{"type":"faq_item","settings":{"tab_id":"shipping","question":"How long will it take to get my order?","answer":"<p>Orders placed before 2 PM EST ship the same day and typically arrive in 3–7 business days within the US. Canadian orders may take 7–16 days.<\/p>","open_by_default":false}},"faq_item_xBjmM8":{"type":"faq_item","settings":{"tab_id":"shipping","question":"Do you ship internationally?","answer":"<p>We currently ship to the US and Canada. Customers in the UK and Europe can purchase Berkeley Life through our trusted partner, Healf.<\/p>","open_by_default":false}},"faq_item_zXJCWh":{"type":"faq_item","settings":{"tab_id":"shipping","question":"How do I manage my subscription?","answer":"<p>You can manage your subscription by logging into your account. If you have trouble, contact help@berkeleylife.com or call 844-517-1327 (Mon–Fri, 9 AM–5 PM EST).<\/p>","open_by_default":false}}},"block_order":["faq_tab_KiT3gi","faq_tab_etakFe","faq_tab_MYKAeV","faq_tab_meebRQ","faq_item_WLYpJt","faq_item_Jq8UMr","faq_item_ALFx3G","faq_item_eahpwT","faq_item_xcBFPr","faq_item_DeG7X4","faq_item_QctQnH","faq_item_QjPgkr","faq_item_aNRGdk","faq_item_gCKxeV","faq_item_KAmrV7","faq_item_CCyhPB","faq_item_JXpr3L","faq_item_xBjmM8","faq_item_zXJCWh"],"name":"C FAQ Tabs","settings":{"default_active_tab":"medications","faq_title":"Your Questions,\n**Answered**","faq_subtitle":"We’ve gathered the most common concerns so you can feel confident starting your Berkeley Life journey.","bg_color":"#ffffff","faq_accent":"#d44f2f","faq_border":"#eaeaea","faq_text":"#0b0b0b","padding_top":2,"padding_bottom":2}}},"order":["main","sticky_product_pKfVLz","c_header_banner_gwQKG9","c_hero_upsell_banner_ayHFTj","c_logos_RGzxzB","interactive_graph_hTNU6W","c_product_featured_GzNr8L","c_grid_slider_CWMpWa","c_new_benefits_yNHViA","c_collapsible_content_N8WT7n","c_banner_signup_TWUXdn","c_faq_tabs_UWK6UP"]}