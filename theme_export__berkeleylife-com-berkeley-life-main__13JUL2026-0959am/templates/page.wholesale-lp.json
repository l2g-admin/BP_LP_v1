          }
        },
        "testimonial_xCeaVQ": {
          "type": "testimonial",
          "settings": {
            "title": "",
            "name": "Dr. Jeremy Gray",
            "stars": 5,
            "quote": "<p>We encourage all of our patients using GAINSWave for Erectile Dysfunction to use Berkeley Life Nitric Oxide Supplements with treatment. It seems to be the missing link to finding successful improvements with many of our patients.</p>"
          }
        },
        "testimonial_6YUzDt": {
