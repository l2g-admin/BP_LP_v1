<div class="max-w-screen-sm px-8 py-12 mx-auto">

  <div id="recover" class="target:block peer hidden">
    <h1 class="h2 mb-8 text-center" tabindex="-1">
      {{ 'customer.recover_password.title' | t }}
    </h1>
    <div class="space-y-4">
      <p class="text-center">
        {{ 'customer.recover_password.subtext' | t }}
      </p>
      {%- form 'recover_customer_password', class: 'grid grid-cols-1 gap-4' -%}
        {% assign recover_success = form.posted_successfully? %}
        <div class="space-y-2 text-left">
          <label class="block cursor-pointer" for="RecoverEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
          <input type="email"
            value=""
            name="email"
            id="RecoverEmail"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            class="w-full"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="RecoverEmail-email-error"
            {% endif %}
            placeholder="{{ 'customer.login_page.email' | t }}"
          >
        </div>
        {%- if form.errors -%}
          <small id="RecoverEmail-email-error" class="flex gap-2">
            <svg class="w-4 h-4" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13">
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
            </svg>
            {{ form.errors.messages['form'] }}
          </small>
        {%- endif -%}


        <button class="button button--primary">
          {{- 'customer.login_page.submit' | t -}}
        </button>

        <a href="#login" class="mx-auto text-xs font-bold tracking-widest text-gray-500 underline uppercase">
          {{ 'customer.login_page.cancel' | t }}
        </a>
      {%- endform -%}
    </div>
  </div>

  <div id="login" class="peer-target:hidden">
    <h1 class="h2 mb-8 text-center capitalize" tabindex="-1">
      {{ 'customer.login_page.title' | t }}
    </h1>
    <p class="mb-8 text-center">
      {{ 'customer.login_page.subtext' | t }}
    </p>
    <div>
      {%- if recover_success == true -%}
        <h3 class="flex gap-2">
          <svg class="w-5 h-5" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13">
            <path d="M6.5 12.35C9.73087 12.35 12.35 9.73086 12.35 6.5C12.35 3.26913 9.73087 0.65 6.5 0.65C3.26913 0.65 0.65 3.26913 0.65 6.5C0.65 9.73086 3.26913 12.35 6.5 12.35Z" fill="#428445" stroke="white" stroke-width="0.7"/>
            <path d="M5.53271 8.66357L9.25213 4.68197" stroke="white"/>
            <path d="M4.10645 6.7688L6.13766 8.62553" stroke="white">
          </svg>
          {{ 'customer.recover_password.success' | t }}
        </h3>
      {%- endif -%}
      {%- form 'customer_login', novalidate: 'novalidate', class: 'grid grid-cols-1 gap-4' -%}
        {%- if form.errors -%}
          <h2 class="flex gap-2">
            <span class="sr-only">{{ 'accessibility.error' | t }} </span>
            <svg class="w-4 h-4" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13">
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
            </svg>
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
          {{ form.errors | default_errors }}
        {%- endif -%}

        <div class="space-y-2 text-left">
          <label class="block cursor-pointer" for="CustomerEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
          <input
          class="w-full"
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
            placeholder="{{ 'customer.login_page.email' | t }}"
          >
        </div>

        {%- if form.password_needed -%}
          <div class="space-y-2 text-left">
            <label class="block cursor-pointer" for="CustomerPassword">
              {{ 'customer.login_page.password' | t }}
            </label>
            <input
              class="w-full"
              type="password"
              value=""
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              {% if form.errors contains 'form' %}
                aria-invalid="true"
              {% endif %}
              placeholder="{{ 'customer.login_page.password' | t }}"
            >
          </div>
        <div class="flex flex-wrap justify-between">
            <div class="col-span-full md:mt-0 md:w-1/2 md:pr-1 flex justify-center w-full mt-2">
              <button class="button button--primary w-full max-w-full">
                {{- 'customer.login_page.sign_in' | t -}}
              </button>
            </div>
            <div class="col-span-full md:mt-0 md:w-1/2 md:pl-1 flex justify-center w-full mt-2">
              <a href="{{ routes.account_register_url }}" class="button button--secondary w-full max-w-full">
                {{ 'customer.login_page.create_account' | t }}
              </a>
            </div>
         </div>

        <a href="#recover" class="mx-auto text-xs font-bold tracking-widest text-gray-500 underline uppercase">
          {{ 'customer.login_page.forgot_password' | t }}
        </a>
      {%- endif -%}


      {%- endform -%}
    </div>
  </div>

  {%- if shop.checkout.guest_login -%}
    <div>
      <hr>
      <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

      {%- form 'guest_login' -%}
        <button>
          {{ 'customer.login_page.guest_continue' | t }}
        </button>
      {%- endform -%}
    </div>
  {%- endif -%}
</div>
