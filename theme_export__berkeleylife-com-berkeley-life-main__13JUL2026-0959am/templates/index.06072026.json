    "c_faqs_Tc9N9E": {
      "type": "c-faqs",
      "blocks": {
        "faq_GCQHNw": {
          "type": "faq",
          "settings": {
            "question": "What is Berkeley Life?",
            "answer": "<p>Berkeley Life is a practitioner-grade Nitric Oxide support company focused on vascular health, circulation, and healthy aging.<br/>Our products are designed to support Nitric Oxide production — a critical molecule involved in blood flow, cardiovascular function, energy production, and cellular signaling.<br/><br/></p>"
          }
        },
        "faq_F8te3a": {
          "type": "faq",
          "settings": {
            "question": "What is Nitric Oxide and why is it important?",
            "answer": "<p>Nitric Oxide is a signaling molecule produced in the body that helps:</p><ul><li>Relax and dilate blood vessels</li><li>Regulate blood pressure</li><li>Improve circulation</li><li>Deliver oxygen and nutrients to tissues</li><li>Support mitochondrial energy production</li><li>Maintain endothelial function</li></ul><p></p><p>Nitric Oxide production naturally declines with age.</p>"
          }
        },
        "faq_NMjDJX": {
          "type": "faq",
          "settings": {
            "question": "Why does Nitric Oxide decline as we age?",
            "answer": "<p>Nitric Oxide declines due to:</p><ul><li>Reduced endothelial Nitric Oxide synthase (eNOS) activity</li><li>Oxidative stress</li><li>Chronic inflammation</li><li>Insulin resistance</li><li>Hormonal changes</li><li>Poor oral microbiome health</li></ul><p></p><p>By age 40–50, Nitric Oxide production may be significantly reduced compared to early adulthood.</p>"
          }
        },
        "faq_ghEM3M": {
          "type": "faq",
          "settings": {
            "question": "How are Berkeley Life products different from other Nitric Oxide supplements?",
            "answer": "<p>Many Nitric Oxide supplements use L-arginine or L-citrulline.<br/>Berkeley Life uses dietary nitrates, which:</p><ul><li>Bypass age-related decline in the arginine pathway</li><li>Work independently of eNOS</li><li>Have strong clinical validation</li><li>Provide more consistent Nitric Oxide production</li></ul><p></p><p>Our formulas are clinically studied and practitioner-trusted.</p>"
          }
        },
        "faq_9yNxTC": {
          "type": "faq",
          "settings": {
            "question": "Is potassium nitrate safe?",
            "answer": "<p>Berkeley Life uses food-grade potassium nitrate.<br/>It is chemically identical to the nitrate naturally found in leafy green vegetables.<br/>It is not the same as industrial-grade nitrates used in fertilizers or explosives.<br/><br/></p>"
          }
        },
        "faq_zN946m": {
          "type": "faq",
          "settings": {
            "question": "Can Nitric Oxide become harmful?",
            "answer": "<p>Nitric Oxide is a natural signaling molecule essential for vascular health.</p><p>In conditions of extreme oxidative stress, reactive nitrogen species may form. Maintaining a healthy diet and lifestyle helps support balanced Nitric Oxide activity.</p><p>Dietary nitrates from vegetables and Berkeley Life formulas are considered safe for daily use in healthy adults.</p>"
          }
        }
      },
