    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px",
      "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number / Value",
          "default": "12.5 mmHg",
          "info": "Large headline value (e.g. '378%', '28%', 'Reductions')."
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Label",
          "default": "reduction in systolic blood pressure",
          "info": "Italic accent label displayed beneath the number."
        },
        {
          "type": "text",
          "id": "stat_description",
          "label": "Stat Description",
          "default": "Supporting healthier cardiovascular function"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C B Clinical Research",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_number": "12.5 mmHg",
