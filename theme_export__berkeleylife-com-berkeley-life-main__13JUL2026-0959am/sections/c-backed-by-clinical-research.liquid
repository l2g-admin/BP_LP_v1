      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#080b2b"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d54f2f"
    },
    {
      "type": "color",
      "id": "pill_bg_color",
      "label": "Pill Badge Background",
      "default": "#f6f3f0"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_plain",
      "label": "Heading — Plain Text",
      "default": "Backed By"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading — Italic Accent",
      "info": "Displayed in Cormorant Garamond italic, in the accent color.",
      "default": "Clinical Research"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "In a randomized, placebo-controlled clinical trial, participants taking Nitric Oxide Support experienced:"
    },
    {
      "type": "text",
