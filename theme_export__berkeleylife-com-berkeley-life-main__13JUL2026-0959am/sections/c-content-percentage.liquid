      "default": "#f6f4f2"
    },
    {
      "type": "color",
      "id": "signs_bg",
      "label": "Signs Box Background",
      "default": "rgba(28, 29, 36, 0.95)"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE PROBLEM"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Nitric Oxide Is Your\n<span>Body's Miracle</span> Molecule. And It's Disappearing.",
      "info": "Wrap text in <span></span> to apply the italic serif font and accent color."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Starting at 30, men lose 10-12% of their Nitric Oxide production every decade. NO is the signaling molecule that controls blood vessel dilation, oxygen delivery, hormone communication, and sexual function. When it drops, everything follows.</p>"
    },
    {
      "type": "header",
      "content": "Percentage Box Content"
    },
    {
      "type": "text",
      "id": "highlight_num",
      "label": "Percentage Text",
      "default": "~50%"
    },
    {
      "type": "richtext",
      "id": "highlight_text",
      "label": "Percentage Description",
      "default": "<p><strong>Decline in NO production</strong> between ages 40 and 70 — the primary driver of cardiovascular and performance issues in aging men.</p>",
      "info": "Use the editor to add bold formatting."
    },
    {
      "type": "header",
      "content": "Image & Overlay"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "signs_title",
      "label": "Signs Box Title",
      "default": "SIGNS OF LOW NO LEVELS"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px",
      "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "sign",
      "name": "Sign List Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item Text",
          "default": "Low energy & fatigue"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C content percentage",
      "blocks": [
        { "type": "sign", "settings": { "text": "Low energy & fatigue" } },
        { "type": "sign", "settings": { "text": "Poor circulation" } },
        { "type": "sign", "settings": { "text": "ED & low drive" } },
