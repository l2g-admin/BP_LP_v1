<style>
  #{{ section.id }} {
    width: 100%;
    box-sizing: border-box;
    padding-top: {{ section.settings.padding_top }}rem;
    padding-bottom: {{ section.settings.padding_bottom }}rem;
    background-color: {{ section.settings.bg_color }};
    font-family: inherit;
    color: {{ section.settings.text_color }};
  }

  #{{ section.id }} .faq__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* --- HEADER --- */
  #{{ section.id }} .faq__header {
    text-align: center;
    width: 100%;
  }

  #{{ section.id }} .faq__heading {
    margin: 0;
    color: inherit;
  }

  /* --- CARD CONTAINER --- */
  #{{ section.id }} .faq__card {
    width: 100%;
    background-color: {{ section.settings.card_bg_color }};
    border-radius: 28px;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    #{{ section.id }} .faq__card {
      padding: 3rem 4rem;
    }
  }

  /* --- FAQ ITEM --- */
  #{{ section.id }} .faq__item {
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  #{{ section.id }} .faq__item:last-child {
    border-bottom: none;
  }

  /* --- TRIGGER BUTTON --- */
  #{{ section.id }} .faq__trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    padding: 1.5rem 0;
    cursor: pointer;
    text-align: left;
    color: {{ section.settings.question_color }};
    font-family: inherit;
    transition: color 0.3s ease;
  }

  #{{ section.id }} .faq__question {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding-right: 2rem;
    line-height: 1.4;
  }

  /* Active State Color */
  #{{ section.id }} .faq__trigger[aria-expanded="true"] {
    color: {{ section.settings.active_color }};
  }

  /* --- DYNAMIC ICON (+ / -) --- */
  #{{ section.id }} .faq__icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  #{{ section.id }} .faq__icon::before,
  #{{ section.id }} .faq__icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Horizontal line */
  #{{ section.id }} .faq__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }

  /* Vertical line */
  #{{ section.id }} .faq__icon::after {
    top: 0;
    left: 50%;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }

  /* Morph to Minus when open */
  #{{ section.id }} .faq__trigger[aria-expanded="true"] .faq__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  /* --- ACCORDION BODY --- */
  #{{ section.id }} .faq__content-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  #{{ section.id }} .faq__trigger[aria-expanded="true"] + .faq__content-wrapper {
    grid-template-rows: 1fr;
  }

  #{{ section.id }} .faq__content-inner {
    overflow: hidden;
  }

  #{{ section.id }} .faq__answer {
    padding-bottom: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: {{ section.settings.answer_color }};
    opacity: 0.9;
  }

  #{{ section.id }} .faq__answer p {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  #{{ section.id }} .faq__answer p:last-child {
    margin-bottom: 0;
  }
</style>

<section id="{{ section.id }}" class="c-faq-section">
  <div class="container-sl">
    <div class="faq__container">
    
    <header class="faq__header">
      <h2 class="faq__heading c-title">{{ section.settings.heading }}</h2>
    </header>

    <div class="faq__card">
      {%- for block in section.blocks -%}
        <div class="faq__item" {{ block.shopify_attributes }}>
          
          <button class="faq__trigger" aria-expanded="{% if forloop.first and section.settings.open_first %}true{% else %}false{% endif %}" aria-controls="faq-content-{{ block.id }}">
            <span class="faq__question">{{ block.settings.question }}</span>
            <span class="faq__icon"></span>
          </button>
          
          <div id="faq-content-{{ block.id }}" class="faq__content-wrapper">
            <div class="faq__content-inner">
              <div class="faq__answer">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

    </div>
  </div>
</section>

{% if request.page_type == 'index' and section.blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign comma = false -%}
    {%- for block in section.blocks -%}

      {%- assign question = block.settings.question | default: block.settings.title | default: block.settings.heading | strip_html | strip -%}

      {%- capture answer -%}
        {{ block.settings.answer | default: block.settings.content | default: block.settings.text | strip_html | strip }}
      {%- endcapture -%}

      {%- if question != blank and answer != blank -%}
        {%- if comma -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ answer | replace: '\n', ' ' | replace: '\r', ' ' | strip | json }}
          }
        }
        {%- assign comma = true -%}
      {%- endif -%}

    {%- endfor -%}
  ]
}
</script>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('{{ section.id }}');
    if (!section) return;

    const triggers = section.querySelectorAll('.faq__trigger');
    const allowMultiple = {{ section.settings.allow_multiple | json }};

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        if (!allowMultiple && !isExpanded) {
          triggers.forEach(t => {
            if (t !== trigger) t.setAttribute('aria-expanded', 'false');
          });
        }

        trigger.setAttribute('aria-expanded', !isExpanded);
      });
    });

    document.addEventListener('shopify:block:select', (event) => {
      if (section.contains(event.target)) {
        const blockTrigger = event.target.querySelector('.faq__trigger');
        if (blockTrigger) {
          if (!allowMultiple) {
             triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
          }
          blockTrigger.setAttribute('aria-expanded', 'true');
        }
      }
    });
  });
</script>

