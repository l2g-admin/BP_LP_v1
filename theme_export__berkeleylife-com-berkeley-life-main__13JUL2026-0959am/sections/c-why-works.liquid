<style>
  #{{section.id}} {
      {%- assign half_padding_top = section.settings.padding_top | divided_by: 2.0 -%}
      {%- assign half_padding_bottom = section.settings.padding_bottom | divided_by: 2.0 -%}
    padding-top: {{ half_padding_top }}em;
    padding-bottom: {{ half_padding_bottom }}em;
    border-radius: 40px 40px 0 0;
    background: linear-gradient(0deg, rgba(190, 70, 42, 0.70) 0%, rgba(190, 70, 42, 0.70) 100%), linear-gradient(0deg, #BE462A 0%, #BE462A 100%), url('{{ section.settings.bg_texture | image_url: width: 1800 }}') lightgray 50% / cover no-repeat;
    background-blend-mode: normal, multiply, normal;
    position: relative;
    overflow: hidden;

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: url('{{ section.settings.bg_texture | image_url: width: 1800 }}');
      background-size: cover;
      background-position: center;
      opacity: 0.1;
      z-index: 1;
    }

    & * {
        color: {{ section.settings.text_color }};
        position: relative;
        z-index: 2;
    }

    & *:not(.hero__title) {
        font-family: 'Inter', sans-serif;
    }

    & .flex-c-c {
      display: flex;
      align-items: center;
      justify-content: center;
    }

  

    & .why-works__section {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      border-radius: 64px;
    background: rgba(246, 242, 239, 0.05);

    padding: 40px 20px;
    }

    & .why-works__hero {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    & .hero__span {
      font-weight: 700;
      font-size: 14px !important;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    & .hero__title {
      margin: 0;
      font-size: clamp(32px, 6vw + 1rem, 54px);

      line-height: 110%;
      font-weight: 600;
      & * {
        font-size: clamp(32px, 6vw + 1rem, 54px);
        line-height: 110%;
        font-weight: 600;
      }

      & .orange__span {
        font-family: "Cormorant Garamond";
        font-style: italic;
        font-weight: 500;
        line-height: 100%;
        color: #FCD5CC;
        }
    }

    & .hero__description {
      margin: 0;
      font-size: 1rem;
      line-height: 1.6;
      max-width: 600px;
      margin-inline: auto;
    }

    & .benefits__grid {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    & .benefit__card {

      border-radius: 16px;
      padding: 1.5rem;

      display: flex;
        
      gap: 1rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;

     
      & .container__header {
        display: flex;
        flex-direction: column;
      }

      & .container__text {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
    }

    & .benefit__icon {

      display: flex;
      place-items: flex-start;
      margin-bottom: 0.5rem;

      & svg {
        width: 48px;
        height: 48px;
        fill: currentColor;
      }
    }

    & .benefit__title {
      margin: 0;
      font-size: 18px;
      font-weight: 500;
      line-height: 1.3;
      text-transform: capitalize;
      letter-spacing: 0.5px;
    }

    & .benefit__description {
      margin: 0;
      font-size: 14px;
      line-height: 1.5;
      opacity: 0.9;
    }

    & .benefit__dots {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0.5rem 0;
      opacity: 0.6;
    }

    & .dot {
      width: 4px;
      height: 4px;
      background-color: currentColor;
      border-radius: 50%;
    }
  }

  @media screen and (width >= 1200px) {
    #{{section.id}} {
      padding-top: {{ section.settings.padding_top }}em;
      padding-bottom: {{ section.settings.padding_bottom }}em;
      border-radius: 80px 80px 0 0;
      & .benefits__grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
      }

    

      & .benefit__card {
        padding: 2rem;

        & .container__header {
          flex-direction: row;
          gap: 0.5rem;
        }
      }

      & .benefit__icon {
        & svg {
            width: 56px;
            height: 56px;
        }
      }

      & .benefit__title {
        font-size: 20px;
      }

      & .benefit__description {
        font-size: 16px;
      }
    }
  }

  @media screen and (width >= 1024px) {
    #{{section.id}} {
      & .why-works__section {
        gap: 4rem;
         padding: 80px;
      }

      & .hero__description {
        font-size: 18px;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="container-sl">
    <div class="why-works__section">
      <div class="why-works__hero container__process">
        {% if section.settings.hero_title != blank %}
          <h2 class="hero__title">{{ section.settings.hero_title }}</h2>
        {% endif %}

        {% if section.settings.hero_description != blank %}
          <p class="hero__description">{{ section.settings.hero_description }}</p>
        {% endif %}
      </div>

      <div class="benefits__grid container__process">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'benefit' %}
              <div class="benefit__card" {{ block.shopify_attributes }}>
                {% if block.settings.icon != blank %}
                  <div class="benefit__icon">
                    {{ block.settings.icon }}
                  </div>
                {% endif %}
                <div class="container__text">
                  <div class="container__header">
                    {% if block.settings.title != blank %}
                      <h3 class="benefit__title">{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.show_dots %}
                      <div class="benefit__dots">
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                      </div>
                    {% endif %}
                  </div>

                  {% if block.settings.description != blank %}
                    <p class="benefit__description">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Why It Works",
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (SVG)",
          "info": "Paste SVG code here"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "Restore & Recharge"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Benefit Description",
          "default": "Supports beneficial oral bacteria that convert nitrates into Nitric Oxide, restoring balance to your oral microbiome for better circulation, energy, and daily vitality."
        },
        {
          "type": "checkbox",
          "id": "show_dots",
          "label": "Show decorative dots",
          "default": true
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "hero_span",
      "label": "Top Span Text",
      "default": "Why Balance Gum"
    },
    {
      "type": "textarea",
      "id": "hero_title",
      "label": "Main Title",
      "default": "Works"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Unlike most supplements, you don't have to just believe it's working. You can test, track, and see your progress."
    },
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "color",
      "id": "bg_gradient_start",
      "label": "Background Gradient Start",
      "default": "#D95D39"
    },
    {
      "type": "color",
      "id": "bg_gradient_end",
      "label": "Background Gradient End",
      "default": "#E8A06C"
    },
    {
      "type": "image_picker",
      "id": "bg_texture",
      "label": "Background Texture (optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    }
  ],
  "presets": [
    {
      "name": "C Why It Works",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Restore & Recharge",
            "description": "Supports beneficial oral bacteria that convert nitrates into Nitric Oxide, restoring balance to your oral microbiome for better circulation, energy, and daily vitality."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Simple & Effective",
            "description": "A convenient, sugar-free habit that fits seamlessly into your routine—no pills or powders, just a simple chew designed for everyday oral and whole-body wellness."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Clinically Grounded",
            "description": "Powered by clinically researched nitrates, probiotics, and nutrients, each ingredient supports Nitric Oxide production and oral health, trusted by healthcare professionals."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Supports Oral + Whole-Body Health",
            "description": "Promotes healthy gums, fresher breath, and improved circulation by feeding good bacteria and reducing harmful microbes for complete mouth and body wellness."
          }
        }
      ]
    }
  ]
}
{% endschema %}
