03007 9.35945 5.04721 9.43906 5.08038C9.51867 5.11355 9.59096 5.16208 9.6518 5.2232Z" fill="#D54F2F"/>
                    </svg>
                    <span>{{ clean_benefit }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign cta_block = section.blocks | where: 'type', 'cta_button' | first -%}
    {%- if cta_block != blank and cta_block.settings.cta_label != blank -%}
      <div class="c-whats-included-system__cta-wrap" {{ cta_block.shopify_attributes }}>
        <a
          class="c-whats-included-system__cta-btn"
          href="{{ cta_block.settings.cta_link | default: '#' }}"
        >
          {{ cta_block.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "C What's Included System",
  "tag": "section",
  "class": "c-whats-included-system-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "Anchor ID",
      "info": "HTML anchor for internal navigation"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHAT'S INCLUDED"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Two products."
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Accent title",
      "default": "One complete system."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#f6f3f0"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ebe8e6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1b1c29"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body color",
      "default": "#1b1c29"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#d54f2f"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
