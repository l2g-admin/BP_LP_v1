{%- unless section.settings.video_file == blank -%}
<div class="bg-bg" style="--color-text: {{ section.settings.text_color | default: '#000000' }}; --color-bg: {{ section.settings.bg_color | default: '#FFFFFF' }}">
  <div class="{% unless section.settings.full_width %}max-w-screen-lg mx-auto px-8 py-12 md:py-20{% endunless %} bg-bg text-text">
    <div class="">
      <div class="flex flex-col justify-center p-8 space-y-6 {{ section.settings.text_align | default: 'text-left' }}">
        {%- assign first_heading = true -%}
        {%- for block in section.blocks -%}
          {% case block.type %}
            {%- when 'heading' -%}
              {%- if first_heading -%}
                <h2 class="{{ block.settings.heading_style }}" {{ block.shopify_attributes }}>
                  {{- block.settings.heading -}}
                </h2>
              {%- else -%}
                <div class="{{ block.settings.heading_style }}" {{ block.shopify_attributes }}>
                  {{- block.settings.heading -}}
                </div>
              {%- endif -%}
              {%- assign first_heading = false -%}
            {%- when 'text' -%}
              <div class="rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
            {%- when 'button' -%}
              {%- if block.settings.button_label != blank -%}
              <div class="{{ section.settings.text_align | default: 'text-left' }}">
                <a {%- if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% endif %} class="{{ block.settings.button_style }} w-80 max-w-full"{% if block.settings.button_link == blank %} aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                  {{ block.settings.button_label | escape }}
                </a>
              </div>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
      <div class="relative" {% unless section.settings.autoplay %}data-simple-video{% endunless %}>
        <div class="{{ section.settings.image_ratio }} relative bg-black/5">
          {%- if section.settings.autoplay -%}
            {% render 'video-autoplay', id: section.id, video: section.settings.video_file, image: section.settings.image %}
          {%- else -%}
            <video class="object-cover w-full h-full" preload="none" {% if section.settings.image != blank %} poster="{{ section.settings.image | image_url: width: 1600 }}" {% endif %}>
              {% comment %}theme-check-disable RemoteAsset{% endcomment %}
              <source src="{{ section.settings.video_file }}" type="video/mp4">
              {% comment %}theme-check-enable RemoteAsset{% endcomment %}
            </video>
            <button type="button" class="left-1/2 top-1/2 hover:scale-110 absolute flex items-center justify-center w-24 h-24 text-black transition-transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-full" data-simple-button>
              <span class="sr-only">Play Video</span>
              <span class="w-8 h-8">{%- render 'icon-play' -%}</span>
            </button>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{%- unless section.settings.autoplay -%}
  <script type="module">
    import { videoSimple } from "{{ 'video-simple.js' | asset_url }}";
    const element = document.querySelector("#shopify-section-{{ section.id }} [data-simple-video]");
    videoSimple(element)
  </script>
{%- endunless -%}

{%- endunless -%}

{% schema %}
{
  "name": "Video from File",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "video_file",
      "label": "Video",
      "info": "This file, which you can upload to the [file page](/admin/settings/files)."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay?",
      "default": false,
      "info": "Video will play automatically, and muted."
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "aspect-video",
          "label": "Wider"
        },
        {
          "value": "aspect-[4/3]",
          "label": "Wide"
        },
        {
          "value": "aspect-[3/4]",
          "label": "Portrait"
        },
        {
          "value": "aspect-square",
          "label": "Square"
        },
        {
          "value": "aspect-square rounded-full",
          "label": "Circle"
        }
      ],
      "default": "aspect-video",
      "label": "Image Ratio"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Align Text",
      "options": [
        {
          "value": "text-center",
          "label": "Center all"
        },
        {
          "value": "text-left",
          "label": "Left all"
        },
        {
          "value": "text-right",
          "label": "Right all"
        },
        {
          "value": "text-center md:text-left",
          "label": "Desktop left, Mobile center"
        },
        {
          "value": "text-center md:text-right",
          "label": "Desktop right, Mobile center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width?",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Lorem Heading",
          "label": "t:sections.image-with-text.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_style",
          "label": "Heading Style",
          "default": "h3",
          "options": [
            {
              "value": "h1",
              "label": "Heading 1"
            },
            {
              "value": "h2",
              "label": "Heading 2"
            },
            {
              "value": "h3",
              "label": "Heading 3"
            },
            {
              "value": "h4",
              "label": "Heading 4"
            },
            {
              "value": "h5",
              "label": "Heading 5"
            },
            {
              "value": "subhead",
              "label": "Small Caps"
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.image-with-text.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
          "label": "t:sections.image-with-text.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.image-with-text.blocks.button.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "t:sections.image-with-text.blocks.button.settings.button_label.label",
          "info": "t:sections.image-with-text.blocks.button.settings.button_label.info"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.image-with-text.blocks.button.settings.button_link.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "default": "button button--primary",
          "options": [
            {
              "value": "button button--primary",
              "label": "Primary Button"
            },
            {
              "value": "button button--secondary",
              "label": "Secondary Button"
            },
            {
              "value": "button button--tertiary",
              "label": "Tertiary Button"
            },
            {
              "value": "button--text",
              "label": "Text Link"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video from File",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
