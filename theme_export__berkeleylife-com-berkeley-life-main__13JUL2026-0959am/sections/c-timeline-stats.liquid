      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d25435"
    },
    {
      "type": "header",
      "content": "Header Text"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE JOURNEY"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "What to <span>Expect</span>",
      "info": "Wrap text in <span></span> to apply the italic serif font."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Start Today"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "timeline_phase",
      "name": "Timeline Phase",
      "settings": [
        {
          "type": "text",
          "id": "day_text",
          "label": "Day Label",
          "default": "DAY 7"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "IGNITION"
        },
        {
          "type": "text",
          "id": "phase_title",
          "label": "Phase Title",
          "default": "First Signals"
        },
        {
          "type": "richtext",
          "id": "benefits",
          "label": "Benefits List",
          "info": "Use a bulleted list. Each item will display with an orange '+' marker."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Phase Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Timeline Stats",
      "blocks": [
        {
          "type": "timeline_phase",
          "settings": {
            "day_text": "DAY 7",
            "badge_text": "IGNITION",
            "phase_title": "First Signals",
            "benefits": "<ul><li>Steadier energy through the day</li><li>Workouts start to feel different</li><li>Morning fog begins to lift</li><li>Measurable improvement on test strips</li></ul>"
          }
        },
        {
          "type": "timeline_phase",
