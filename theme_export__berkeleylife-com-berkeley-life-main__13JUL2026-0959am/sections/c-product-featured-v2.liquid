                  }

                  #{{ section_id }} .c-proven-tab-content.active {
                    display: block;
                  }

                  #{{ section_id }} .c-proven-results-title {
                    color: {{ section.settings.accent_color }};
                    font-family: "Cormorant Garamond", serif;
                    font-style: italic;
                    font-size: 32px;
                    font-weight: 400;
                    margin: 0 0 16px 0;
                    line-height: 1.2;
                  }

                  #{{ section_id }} .c-proven-results-subtitle {
