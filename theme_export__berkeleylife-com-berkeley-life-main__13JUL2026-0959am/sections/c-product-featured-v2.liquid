                    font-size: 20px;
                    font-weight: 600;
                    margin: 0 0 20px 0;
                    line-height: 1.3;
                  }

                  #{{ section_id }} .c-proven-results-text {
                    color: {{ section.settings.text_color }};
                    font-size: 16px;
                    line-height: 1.6;
                    margin-bottom: 20px;
                    opacity: 0.85;
                  }

                  #{{ section_id }} .c-proven-results-list {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                  }

                  #{{ section_id }} .c-proven-results-list li,
                  #{{ section_id }} .c-proven-results-item {
                    color: {{ section.settings.text_color }};
                    font-size: 16px;
                    line-height: 1.5;
                    margin-bottom: 12px;
                    padding-left: 24px;
                    position: relative;
                  }

                  @keyframes cProvenFadeIn-{{ section_id }} {
                    from { opacity: 0; transform: translateY(10px); }
                    to { opacity: 1; transform: translateY(0); }
                  }

                  @media (max-width: 768px) {
                    #{{ section_id }} .c-proven-results-container {
                      padding: 0;
                    }

                    #{{ section_id }} .c-proven-tab {
                      padding: 12px 16px;
                      font-size: 12px;
                    }

                    #{{ section_id }} .c-proven-tab.active {
                      font-size: 20px;
                    }

                    #{{ section_id }} .c-proven-results-title {
                      font-size: 28px;
                    }

                    #{{ section_id }} .c-proven-results-subtitle {
                      font-size: 18px;
                    }
                  }
                </style>

                <div class="c-proven-results-tabs">
                  <button class="c-proven-tab active" data-tab="results-{{ section_id }}">
                    {{ block.settings.tab1_title | default: "Is This Right for Me?" }}
                  </button>
                  <button class="c-proven-tab" data-tab="usage-{{ section_id }}">
                    {{ block.settings.tab2_title | default: "How to Use" }}
                  </button>
                </div>

                <!-- Tab 1: Proven Results -->
                <div class="c-proven-tab-content active" data-content="results-{{ section_id }}">
                  {%- if selected_product.metafields.custom.clinically_proven_benefits != blank -%}
                    {% assign results = selected_product.metafields.custom.clinically_proven_benefits.value %}
                    <div class="c-proven-results-list">
                      {% for result in results %}
                        <div class="c-proven-results-item">{{ result }}</div>
                      {% endfor %}
                    </div>
                  {%- elsif block.settings.tab1_fallback_content != blank -%}
                    <div class="c-proven-results-text">{{ block.settings.tab1_fallback_content }}</div>
                  {%- endif -%}
                </div>

                <!-- Tab 2: How to Use -->
                <div class="c-proven-tab-content" data-content="usage-{{ section_id }}">
                  {%- if block.settings.usage_title != blank -%}
                    <h3 class="c-proven-results-title">{{ block.settings.usage_title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.usage_subtitle != blank -%}
                    <h4 class="c-proven-results-subtitle">{{ block.settings.usage_subtitle }}</h4>
                  {%- endif -%}
                  {%- if block.settings.usage_text != blank -%}
                    <div class="c-proven-results-text">{{ block.settings.usage_text }}</div>
                  {%- endif -%}
                </div>

                <script>
                  (function() {
                    const sectionId = '{{ section_id }}';
                    const container = document.getElementById(sectionId);
                    if (!container) return;

                    const tabs = container.querySelectorAll('.c-proven-tab');
                    const contents = container.querySelectorAll('.c-proven-tab-content');

                    tabs.forEach(tab => {
                      tab.addEventListener('click', function() {
                        const targetTab = this.getAttribute('data-tab');
                        
                        // Remove active class from all tabs and contents within this section
                        tabs.forEach(t => t.classList.remove('active'));
                        contents.forEach(c => c.classList.remove('active'));
                        
                        // Add active class to clicked tab and corresponding content
                        this.classList.add('active');
                        container.querySelector(`[data-content="${targetTab}"]`).classList.add('active');
                      });
                    });
                  })();
                </script>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{%- comment -%} JavaScript for variant/selling plan selection {%- endcomment -%}
<script type="application/json" id="ProductVariantsJson-{{ section_id }}">
  {{ selected_product.variants | json }}
</script>

<script>
  (function () {
    // Store variants globally for this section
    const sectionId = '{{ section_id }}';
    window.productVariantsBySection = window.productVariantsBySection || {};

    try {
      const variantsJson = document.getElementById('ProductVariantsJson-' + sectionId);
      if (variantsJson) {
        window.productVariantsBySection[sectionId] = JSON.parse(variantsJson.textContent);
      }
    } catch (e) {
      console.error('Error parsing variants:', e);
    }
  })();

  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section_id }}';
    const container = document.getElementById(sectionId);
    if (!container) return;

    // ========================
    // IMAGE GALLERY / SWIPER
    // ========================
    const swiperWrapper = container.querySelector('[data-swiper-wrapper]');
    const thumbnails = container.querySelectorAll('[data-thumbnail-index]');
    const bullets = container.querySelectorAll('[data-bullet-index]');
    const slides = container.querySelectorAll('[data-slide-index]');
    let currentIndex = 0;
    let startX = 0;
    let isDragging = false;

    function goToSlide(index) {
      if (index < 0 || index >= slides.length) return;
      currentIndex = index;
      
      // Update swiper position
      if (swiperWrapper) {
        swiperWrapper.style.transform = `translateX(-${index * 100}%)`;
      }

      // Update thumbnails
      thumbnails.forEach((thumb, i) => {
        thumb.classList.toggle('active', i === index);
      });

      // Update bullets
      bullets.forEach((bullet, i) => {
        bullet.classList.toggle('active', i === index);
      });
    }

    // Thumbnail click handlers
    thumbnails.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.dataset.thumbnailIndex, 10);
        goToSlide(index);
      });
    });

    // Bullet click handlers
    bullets.forEach((bullet) => {
      bullet.addEventListener('click', () => {
        const index = parseInt(bullet.dataset.bulletIndex, 10);
        goToSlide(index);
      });
    });

    // Touch/Swipe support for mobile
    const swiperContainer = container.querySelector('[data-swiper]');
    if (swiperContainer) {
      swiperContainer.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
      }, { passive: true });

      swiperContainer.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
      }, { passive: true });

      swiperContainer.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;

        if (Math.abs(diff) > 50) {
          if (diff > 0 && currentIndex < slides.length - 1) {
            goToSlide(currentIndex + 1);
          } else if (diff < 0 && currentIndex > 0) {
            goToSlide(currentIndex - 1);
          }
        }
      }, { passive: true });
    }

    // ========================
    // VARIANT/SELLING PLAN LOGIC
    // ========================
    const variantRadios = container.querySelectorAll("input[name='variant_selling_plan']");
    const variantInput = container.querySelector('#SelectedVariantId-{{ section_id }}');
    const sellingPlanInput = container.querySelector('#SelectedSellingPlan-{{ section_id }}');
    const addToCartButton = container.querySelector('.product-form__submit');
    const priceDisplay = container.querySelector('[data-product-price]');
    const optionContainers = container.querySelectorAll('.option-container');

    // Get product variants from global store
    const productVariants = window.productVariantsBySection[sectionId] || [];

    function updateSelected() {
      optionContainers.forEach((option) => {
        const radio = option.querySelector('input[type="radio"]');
        if (radio && radio.checked) {
          option.classList.add('selected');
        } else {
          option.classList.remove('selected');
        }
      });
    }

    function updateSellingPlan(event) {
      if (!event.target.value) return;

      // Parse the value into variantId and sellingPlanId (same as main-product)
      const [variantId, sellingPlanId] = event.target.value.split('-');

      if (variantInput) {
        variantInput.value = variantId;
      }

      if (sellingPlanInput) {
        if (sellingPlanId === 'otp') {
          sellingPlanInput.value = '';
        } else {
          sellingPlanInput.value = sellingPlanId;
        }
      }

      // Find the selected variant
      const selectedVariant = productVariants.find((v) => v.id == variantId);

      if (selectedVariant) {
        setTimeout(() => {
          if (selectedVariant.available) {
            // Update button text based on selection
            if (sellingPlanId === 'otp') {
              addToCartButton.innerText = "{{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}";
            } else if (sellingPlanId) {
              addToCartButton.innerText = "{{ 'products.product.subscribe' | t | default: 'Subscribe' }}";
            } else {
              addToCartButton.innerText = "{{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}";
            }

            // Update the button's data attribute with the variant ID
            addToCartButton.dataset.productId = variantId;
            addToCartButton.disabled = false;
          } else {
            addToCartButton.innerText = "{{ 'products.product.sold_out' | t | default: 'Unavailable' }}";
            addToCartButton.disabled = true;
          }

          // Update price display
          if (priceDisplay) {
            const formattedPrice = Shopify.formatMoney
              ? Shopify.formatMoney(selectedVariant.price)
              : '$' + (selectedVariant.price / 100).toFixed(2);
            priceDisplay.textContent = formattedPrice;
          }
        }, 10);
      }

      updateSelected();
    }

    // Attach change event to variant radios
    variantRadios.forEach((radio) => {
      radio.addEventListener('change', updateSellingPlan);
    });

    // Select first radio if none selected and run initial update
    function initializeSelection() {
      const checkedRadio = container.querySelector('input[name="variant_selling_plan"]:checked');
      if (checkedRadio) {
        updateSellingPlan({ target: checkedRadio });
      } else {
        const firstRadio = container.querySelector('input[name="variant_selling_plan"]');
        if (firstRadio) {
          firstRadio.checked = true;
          updateSellingPlan({ target: firstRadio });
        }
      }
    }

    // Initialize
    initializeSelection();
    updateSelected();

    // Custom Add to Cart handler for this section
    const addToCartBtn = document.getElementById('AddToCart-{{ section_id }}');
    const productForm = container.querySelector('form[data-type="add-to-cart-form"]');

    if (addToCartBtn && productForm) {
      addToCartBtn.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        if (addToCartBtn.disabled || addToCartBtn.classList.contains('loading')) return;

        addToCartBtn.classList.add('loading');
        addToCartBtn.setAttribute('aria-disabled', 'true');

        const formData = new FormData(productForm);

        fetch(window.routes?.cart_add_url || '/cart/add.js', {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            Accept: 'application/json',
          },
          body: formData,
        })
          .then((response) => response.json())
          .then((response) => {
            if (response.status) {
              console.error('Error adding to cart:', response.description);
              return;
            }

            // Open the cart drawer
            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer) {
              cartDrawer.render();
              cartDrawer.open();
            }
          })
          .catch((error) => console.error('Add to cart failed:', error))
          .finally(() => {
            addToCartBtn.classList.remove('loading');
            addToCartBtn.removeAttribute('aria-disabled');
          });
      });
    }
  });
</script>

