<style>
  #{{ section.id }} {
    width: 100%;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}em;
    padding-bottom: {{ section.settings.padding_bottom }}em;
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}

    & * {
      color: {{ section.settings.text_color }};
    }

    & .products__container {
    }

    & .c-buttons-div {
       display: flex;
       justify-content: center;
       margin-top: 3rem;
    }

    & .section__header {
      text-align: center;
      margin-bottom: 4rem;

      & .section__title {
        font-size: clamp(24px, 4vw, 40px);
        font-weight: 700;
        line-height: 1.2;
        margin: 0;
        color: {{ section.settings.title_color }};
      }

      & .section__subtitle {
        font-size: clamp(16px, 2vw, 20px);
        font-weight: 400;
        line-height: 1.4;
        margin-top: 1rem;
        color: {{ section.settings.subtitle_color }};
      }
    }

    & .products__grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
    }

    & .product__card {
      background: {{ section.settings.card_bg_color }};
      border-radius: 16px;
      padding: 1.75rem;
      display: flex;
    flex-direction: column;
    justify-content: space-between;

    & .yotpo-sr-bottom-line-summary {
        flex-direction: row !important;
      }

      & .container__product__top {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

      & .product__image {
        width: 100%;
        height: auto;
        max-height: 382px;
        border-radius: 12px;
        overflow: hidden;

        & img {
          width: 100%;
          height: 100%;
          object-fit: contain;
        }
      }

      & .product__rating {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin: 0 !important;

        & .stars {
          display: flex;
          gap: 0.25rem;

          & svg {
            width: 16px;
            height: 16px;
            fill: {{ section.settings.star_color }};
          }
        }

        & .reviews-count {
          font-size: 14px;
          color: {{ section.settings.reviews_color }};
          font-weight: 500;
        }
      }

      & .product__title {
        font-size: clamp(18px, 2.5vw, 24px);
        font-weight: 700;
        margin: 0 !important;
        color: {{ section.settings.product_title_color }};
      }

      & .product__options {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;

        & .option__group {
          text-align: left;

          & .option__label {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            color: {{ section.settings.label_color }};
          }

          & .option__select {
            width: 100%;
            padding: 5px 10px;
            border: 1px solid {{ section.settings.border_color }};
            border-radius: 20px;
            background: {{ section.settings.select_bg_color }};
            color: {{ section.settings.select_text_color }};
            font-size: 14px;
            font-weight: 500;
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 12px center;
            background-repeat: no-repeat;
            background-size: 16px;
            cursor: pointer;

            &:focus {
              outline: none;
              border-color: {{ section.settings.focus_border_color }};
            }
          }
        }
      }

      /* Schedule/Subscription Options */
      & .schedule__options {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.5rem;

        & .schedule__label {
          font-size: 14px;
          font-weight: 600;
          text-transform: uppercase;
          color: {{ section.settings.label_color }};
          margin-bottom: 0.25rem;
        }

        & .schedule__option {
          display: flex;
          align-items: center;
          gap: 0.75rem;
          padding: 12px 16px;
          border: 2px solid {{ section.settings.border_color }};
          border-radius: 10px;
          cursor: pointer;
          transition: all 0.2s ease;
          background: {{ section.settings.select_bg_color }};

          &:hover {
            border-color: {{ section.settings.focus_border_color }};
          }

          &.active {
            border-color: {{ section.settings.focus_border_color }};
          }

          & input[type="radio"] {
            width: 20px;
            height: 20px;
            accent-color: {{ section.settings.focus_border_color }};
            cursor: pointer;
            margin: 0;
          }

          & .schedule__option-content {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;

            & .schedule__price {
              font-weight: 600;
              font-size: 15px;
              color: {{ section.settings.product_title_color }};
            }

            & .schedule__text {
              font-size: 14px;
              color: {{ section.settings.text_color }};
              text-transform: uppercase;
              font-weight: 500;
            }

            & .schedule__badge {
              background: {{ section.settings.subscription_badge_bg | default: '#FFA726' }};
              color: {{ section.settings.subscription_badge_text | default: '#000000' }};
              font-size: 11px;
              font-weight: 700;
              padding: 3px 8px;
              border-radius: 12px;
              text-transform: uppercase;
             
            }
          }
        }

        & .schedule__option-wrapper {
          border: 2px solid {{ section.settings.border_color }};
          border-radius: 10px;
          background: {{ section.settings.select_bg_color }};
          transition: all 0.2s ease;
          overflow: hidden;
          display: flex;
          flex-direction: column;

          &:hover {
            border-color: {{ section.settings.focus_border_color }};
          }

          &.active {
            border-color: {{ section.settings.focus_border_color }};
          }

          & .schedule__option {
            border: none;
            border-radius: 0;
            background: transparent;

            &:hover {
              border-color: transparent;
            }
          }
        }

        & .delivery__schedule {
          display: flex;
          align-items: center;
          gap: 0.8rem;
          
          padding: 0 16px 12px 16px;

          & .delivery__label {
            font-size: 14px;
            font-weight: 500;
            color: {{ section.settings.label_color }};
            white-space: nowrap;
          }

          & .delivery__select {
            flex: 1;
            padding: 5px 16px;
            border: 1px solid {{ section.settings.border_color }};
            border-radius: 20px;
            background: {{ section.settings.select_bg_color }};
            color: {{ section.settings.select_text_color }};
            font-size: 14px;
            font-weight: 500;
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 12px center;
            background-repeat: no-repeat;
            background-size: 16px;
            cursor: pointer;

            &:focus {
              outline: none;
              border-color: {{ section.settings.focus_border_color }};
            }
          }
        }
      }

      & .product__cta {
        & .new-c-b1 {
           width: 100%;
        }

        & button[disabled] {
          opacity: 0.5;
          cursor: not-allowed;
        }
      }
    }

    @media (max-width: 992px) {
      & .products__container {
        padding: 0 1rem;
      }

      & .section__header {
        margin-bottom: 3rem;
      }

      & .delivery__schedule {
        flex-direction: column !important;
        align-items: flex-start !important;
        & * {
          width: 100% !important;
        }
      }

      & .schedule__option-wrapper {
        position: relative;
        overflow: visible !important;
        
        & .schedule__badge {
          position: absolute;
          top: -9px;
          right: -6px;
        }
      }

      & .products__grid {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      & .product__card {
        padding: 1.5rem;
        & .product__image {
          max-height: unset;}
      }
    }


  }
</style>

<section id="{{ section.id }}">
  <div class="container">
    {% if section.settings.section_title != blank or section.settings.section_subtitle != blank %}
      <div class="section__header">
        {% if section.settings.section_title != blank %}
          <h2 class="section__title">
            {{ section.settings.section_title }}
          </h2>
        {% endif %}
        {% if section.settings.section_subtitle != blank %}
          <p class="section__subtitle">
            {{ section.settings.section_subtitle }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="products__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'product_card' %}
            <div class="product__card" {{ block.shopify_attributes }}>
              <div class="container__product__top">
                {% assign selected_product = block.settings.product %}
                {%- capture form_id -%}product_form_{{ section.id }}_{{ selected_product.id }}_{{ forloop.index }}{%- endcapture -%}
                {% if selected_product and selected_product.featured_image %}
                  <div class="product__image">
                    <img
                      src="{{ selected_product.featured_image | image_url: width: 1200 }}"
                      alt="{{ selected_product.featured_image.alt | default: selected_product.title }}"
                      width="400"
                      height="300"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
                <div class="container__product__text">
                  {% if block.settings.show_rating and selected_product %}
                    <div
                      class="yotpo-widget-instance"
                      data-yotpo-instance-id="591879"
                      data-yotpo-product-id="{{ selected_product.id }}"
                      data-yotpo-cart-product-id="{{ selected_product.id }}"
                      data-yotpo-section-id="{{ template.name }}"
                    ></div>
                  {% endif %}

                  {% if selected_product %}
                    <h3 class="product__title">
                      {% if block.settings.use_custom_title and block.settings.custom_title != blank %}
                        {{ block.settings.custom_title }}
                      {% else %}
                        {{ selected_product.title }}
                      {% endif %}
                    </h3>
                  {% endif %}

                  {% if section.settings.enable_cart_functionality
                    and selected_product
                    and selected_product.options_with_values.size > 0
                    and selected_product.has_only_default_variant == false
                  %}
                    <div class="product__options">
                      {%- assign available_variants = selected_product.variants | where: 'available', true -%}
                      {%- assign option1_name = selected_product.options[0] | default: 'Option 1' -%}
                      {%- assign option2_name = selected_product.options[1] -%}
                      {%- assign o1_values = available_variants | map: 'option1' | uniq -%}
                      {%- assign initial_o1 = selected_product.selected_or_first_available_variant.option1 -%}
                      {%- assign o2_values_initial = available_variants
                        | where: 'option1', initial_o1
                        | map: 'option2'
                        | uniq
                      -%}

                      <product-variants
                        handle="{{ selected_product.handle }}"
                        form-id="{{ form_id }}"
                        class="product-variant-selects"
                        data-block-index="{{ forloop.index }}"
                      >
                        {%- if o1_values.size > 0 -%}
                          <div class="option__group">
                            <div class="option__label">SELECT {{ option1_name | upcase }}:</div>
                            <select
                              name="option1"
                              form="{{ form_id }}"
                              class="option__select"
                              aria-label="{{ option1_name }}"
                            >
                              {%- for val in o1_values -%}
                                <option
                                  value="{{ val | escape }}"
                                  {%- if val == initial_o1 -%}
                                    selected
                                  {%- endif -%}
                                >
                                  {{- val -}}
                                </option>
                              {%- endfor -%}
                            </select>
                          </div>
                        {%- endif -%}

                        {%- if option2_name != blank -%}
                          <div class="option__group">
                            <div class="option__label">SELECT {{ option2_name | upcase }}:</div>
                            <select
                              name="option2"
                              form="{{ form_id }}"
                              class="option__select"
                              aria-label="{{ option2_name }}"
                            >
                              {%- for val in o2_values_initial -%}
                                <option
                                  value="{{ val | escape }}"
                                  {%- if val == selected_product.selected_or_first_available_variant.option2 -%}
                                    selected
                                  {%- endif -%}
                                >
                                  {{- val -}}
                                </option>
                              {%- endfor -%}
                            </select>
                          </div>
                        {%- endif -%}
                      </product-variants>

                      {%- comment -%} Variants JSON Data {%- endcomment -%}
                      <script type="application/json" id="product-variants-{{ section.id }}-{{ forloop.index }}">
                        [
                        {%- for v in selected_product.variants -%}
                          {%- if v.available -%}
                            {%- unless forloop.first -%},{%- endunless -%}
                            {
                              "id": {{ v.id }},
                              "option1": {{ v.option1 | json }}{% if selected_product.options.size > 1 %},
                              "option2": {{ v.option2 | json }}{% else %},
                              "option2": ""{% endif %},
                              "price": {{ v.price | json }},
                              "compare_at_price": {{ v.compare_at_price | json }},
                              "available": true
                            }
                          {%- endif -%}
                        {%- endfor -%}
                        ]
                      </script>
                    </div>
                  {% endif %}

                  {%- comment -%} Subscription / Schedule Options {%- endcomment -%}
                  {% if section.settings.enable_cart_functionality and selected_product %}
                    {%- assign has_selling_plans = false -%}
                    {%- assign selling_plan_groups = selected_product.selling_plan_groups -%}
                    {%- if selling_plan_groups.size > 0 -%}
                      {%- assign has_selling_plans = true -%}
                    {%- endif -%}

                    {% if has_selling_plans %}
                      {%- assign current_variant = selected_product.selected_or_first_available_variant -%}
                      {%- assign current_price = current_variant.price -%}
                      {%- assign first_selling_plan = selling_plan_groups[0].selling_plans[0] -%}
                      {%- assign subscription_price = current_price -%}
                      {%- assign discount_percentage = 0 -%}

                      {%- for price_adjustment in first_selling_plan.price_adjustments -%}
                        {%- if price_adjustment.value_type == 'percentage' -%}
                          {%- assign discount_percentage = price_adjustment.value -%}
                          {%- assign discount_amount = current_price | times: price_adjustment.value | divided_by: 100 -%}
                          {%- assign subscription_price = current_price | minus: discount_amount -%}
                        {%- elsif price_adjustment.value_type == 'fixed_amount' -%}
                          {%- assign subscription_price = current_price | minus: price_adjustment.value -%}
                        {%- elsif price_adjustment.value_type == 'price' -%}
                          {%- assign subscription_price = price_adjustment.value -%}
                        {%- endif -%}
                      {%- endfor -%}

                      <div class="schedule__options" data-card-index="{{ forloop.index }}">
                        <div class="schedule__label">SELECT SCHEDULE:</div>
                        
                        {%- comment -%} One-time purchase option {%- endcomment -%}
                        <label class="schedule__option" data-schedule-type="onetime">
                          <input 
                            type="radio" 
                            name="schedule_{{ section.id }}_{{ forloop.index }}" 
                            value="onetime" 
                            data-selling-plan=""
                          >
                          <div class="schedule__option-content">
                            <span class="schedule__price" data-onetime-price="{{ current_price }}">{{ current_price | money }}</span>
                            <span class="schedule__text">Get it once</span>
                          </div>
                        </label>

                        {%- comment -%} Subscribe & Save option with delivery schedule inside {%- endcomment -%}
                        <div class="schedule__option-wrapper active" data-schedule-type="subscribe">
                          <label class="schedule__option">
                            <input 
                              type="radio" 
                              name="schedule_{{ section.id }}_{{ forloop.index }}" 
                              value="subscribe"
                              checked
                              data-selling-plan="{{ first_selling_plan.id }}"
                            >
                            <div class="schedule__option-content">
                              <span class="schedule__price" data-subscribe-price="{{ subscription_price }}">{{ subscription_price | money }}</span>
                              <span class="schedule__text">Subscribe & Save</span>
                              <span class="schedule__badge" data-discount-percentage="{{ discount_percentage }}" {% if discount_percentage == 0 %}style="display: none;"{% endif %}>Save {{ discount_percentage }}%</span>
                            </div>
                          </label>

                          {%- comment -%} Delivery schedule dropdown - always visible inside subscribe option {%- endcomment -%}
                          <div class="delivery__schedule">
                            <span class="delivery__label">Delivery Schedule:</span>
                            <select class="delivery__select" aria-label="Delivery Schedule">
                              {%- for group in selling_plan_groups -%}
                                {%- for plan in group.selling_plans -%}
                                  <option 
                                    value="{{ plan.id }}"
                                    data-plan-name="{{ plan.name }}"
                                    {% if forloop.parentloop.first and forloop.first %}selected{% endif %}
                                  >
                                    {{ plan.name }}
                                  </option>
                                {%- endfor -%}
                              {%- endfor -%}
                            </select>
                          </div>
                        </div>
                      </div>

                      {%- comment -%} Selling Plans JSON Data {%- endcomment -%}
                      <script type="application/json" id="selling-plans-{{ section.id }}-{{ forloop.index }}">
                        {
                          "groups": [
                            {%- for group in selling_plan_groups -%}
                              {%- unless forloop.first -%},{%- endunless -%}
                              {
                                "name": {{ group.name | json }},
                                "plans": [
                                  {%- for plan in group.selling_plans -%}
                                    {%- unless forloop.first -%},{%- endunless -%}
                                    {
                                      "id": {{ plan.id }},
                                      "name": {{ plan.name | json }},
                                      "price_adjustments": [
                                        {%- for adj in plan.price_adjustments -%}
                                          {%- unless forloop.first -%},{%- endunless -%}
                                          {
                                            "value_type": {{ adj.value_type | json }},
                                            "value": {{ adj.value }}
                                          }
                                        {%- endfor -%}
                                      ]
                                    }
                                  {%- endfor -%}
                                ]
                              }
                            {%- endfor -%}
                          ]
                        }
                      </script>
                    {% endif %}
                  {% endif %}
                </div>
              </div>

              {% if selected_product %}
                <div class="product__cta">
                  {%- if selected_product.available -%}
                    {% if section.settings.enable_cart_functionality %}
                      {%- form 'product',
                        selected_product,
                        is: 'product-form',
                        id: form_id,
                        class: 'product-selection__form'
                      -%}
                        <input
                          type="hidden"
                          name="id"
                          value="{{ selected_product.selected_or_first_available_variant.id }}"
                        >
                        <input type="hidden" name="quantity" value="1">
                        <input type="hidden" name="selling_plan" value="">

                        <button
                          is="loader-button"
                          type="submit"
                          class="{{ section.settings.button_style }}"
                        >
                          {{ block.settings.button_text | default: 'Add to Cart' }}
                        </button>
                      {%- endform -%}
                    {% else %}
                      <a href="{{ selected_product.url }}" class="{{ section.settings.button_style }}">
                        {{ block.settings.button_text | default: 'View Product' }}
                      </a>
                    {% endif %}
                  {%- else -%}
                    <button
                      type="button"
                      class="{{ section.settings.button_style }}"
                      disabled
                      aria-disabled="true"
                    >
                      {{ 'collection.product.sold_out' | t | default: 'Sold Out' }}
                    </button>
                  {%- endif -%}
                </div>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    {%- assign primary_buttons_count = section.blocks | where: 'type', 'primary-button' | size -%}
    {%- if primary_buttons_count > 0 -%}
      <div class="c-buttons-div">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'primary-button' -%}
              {%- if block.settings.button_text != blank -%}
                <a class="c-button {{ block.settings.button_style }}" href="{{ block.settings.button_url }}">
                  {{ block.settings.button_text }}
                </a>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
{% if section.settings.enable_cart_functionality %}
document.addEventListener('DOMContentLoaded', function() {
  // Variant handling for each product card
  const productCards = document.querySelectorAll('#{{ section.id }} .product__card');
  
  productCards.forEach((card, cardIndex) => {
    const blockIndex = cardIndex + 1;
    const o1 = card.querySelector('select[name="option1"]');
    const o2 = card.querySelector('select[name="option2"]');
    
    const allIdInputs = Array.from(card.querySelectorAll('input[name="id"]'));
    if (allIdInputs.length > 1) {
      allIdInputs.slice(1).forEach(n => n.remove());
    }
    const idInput = card.querySelector('input[name="id"].js-variant-id') || card.querySelector('input[name="id"]');
    const sellingPlanInput = card.querySelector('input[name="selling_plan"]');
    
    const storeEl = card.querySelector('#product-variants-{{ section.id }}-' + blockIndex);
    const sellingPlansEl = card.querySelector('#selling-plans-{{ section.id }}-' + blockIndex);
    const formEl = card.querySelector('form.product-selection__form');
    
    if (!idInput || !formEl) return;
    
    const variants = storeEl ? JSON.parse(storeEl.textContent || '[]') : [];
    const sellingPlansData = sellingPlansEl ? JSON.parse(sellingPlansEl.textContent || '{}') : {};
    
    // Schedule/Subscription handling
    const scheduleOptions = card.querySelectorAll('.schedule__option');
    const deliverySchedule = card.querySelector('.delivery__schedule');
    const deliverySelect = card.querySelector('.delivery__select');
    const onetimePriceEl = card.querySelector('[data-onetime-price]');
    const subscribePriceEl = card.querySelector('[data-subscribe-price]');
    
    function findMatch(currentO1, currentO2) {
      return variants.find(v => v.available && v.option1 === currentO1 && (o2 ? v.option2 === currentO2 : true))
          || variants.find(v => v.available && v.option1 === currentO1)
          || null;
    }
    
    function updateVariantId() {
      if (variants.length === 0) return null;
      const currentO1 = o1 ? o1.value : (variants[0]?.option1 || '');
      const currentO2 = o2 ? o2.value : (variants.find(v => v.option1 === currentO1)?.option2 || '');
      const match = findMatch(currentO1, currentO2);
      if (match) {
        idInput.value = match.id;
        // Update prices and badge when variant changes
        updatePricesAndBadge(match.price);
      }
      return match;
    }
    
    function updatePricesAndBadge(variantPrice) {
      if (!onetimePriceEl || !subscribePriceEl) return;
      
      // Update one-time price
      onetimePriceEl.textContent = formatMoney(variantPrice);
      onetimePriceEl.dataset.onetimePrice = variantPrice;
      
      // Calculate subscription price and discount based on selected selling plan
      const selectedPlanId = deliverySelect ? parseInt(deliverySelect.value) : null;
      let subscriptionPrice = variantPrice;
      let discountPercentage = 0;
      
      if (selectedPlanId && sellingPlansData.groups) {
        for (const group of sellingPlansData.groups) {
          for (const plan of group.plans) {
            if (plan.id === selectedPlanId && plan.price_adjustments.length > 0) {
              const adj = plan.price_adjustments[0];
              if (adj.value_type === 'percentage') {
                discountPercentage = adj.value;
                subscriptionPrice = variantPrice - (variantPrice * adj.value / 100);
              } else if (adj.value_type === 'fixed_amount') {
                subscriptionPrice = variantPrice - adj.value;
                // Calculate percentage for fixed amount
                discountPercentage = Math.round((adj.value / variantPrice) * 100);
              } else if (adj.value_type === 'price') {
                subscriptionPrice = adj.value;
                // Calculate percentage for fixed price
                discountPercentage = Math.round(((variantPrice - adj.value) / variantPrice) * 100);
              }
              break;
            }
          }
        }
      }
      
      subscribePriceEl.textContent = formatMoney(subscriptionPrice);
      subscribePriceEl.dataset.subscribePrice = subscriptionPrice;
      
      // Update the discount badge
      const discountBadge = card.querySelector('.schedule__badge');
      if (discountBadge) {
        discountBadge.dataset.discountPercentage = discountPercentage;
        if (discountPercentage > 0) {
          discountBadge.textContent = 'Save ' + discountPercentage + '%';
          discountBadge.style.display = '';
        } else {
          discountBadge.style.display = 'none';
        }
      }
    }
    
    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }
    
    function repopulateO2() {
      if (!o2 || !o1) {
        updateVariantId();
        return;
      }
      const selectedO1 = o1.value;
      const values = [...new Set(variants.filter(v => v.available && v.option1 === selectedO1).map(v => v.option2))];
      const prev = o2.value;
      o2.innerHTML = values.map(v => `<option value="${v}">${v}</option>`).join('');
      if (values.includes(prev)) o2.value = prev;
      updateVariantId();
    }
    
    // Schedule option handling
    function handleScheduleChange(e) {
      // Prevent clicks on delivery select from triggering schedule change
      if (e.target.closest('.delivery__schedule')) {
        return;
      }
      
      const target = e.target.closest('.schedule__option') || e.target.closest('.schedule__option-wrapper');
      if (!target) return;
      
      const radio = target.querySelector('input[type="radio"]');
      if (!radio) return;
      
      // Check the radio
      radio.checked = true;
      
      // Update active class on options and wrappers
      card.querySelectorAll('.schedule__option:not(.schedule__option-wrapper .schedule__option), .schedule__option-wrapper').forEach(opt => opt.classList.remove('active'));
      
      // Add active to the correct element
      if (target.classList.contains('schedule__option-wrapper')) {
        target.classList.add('active');
      } else {
        target.classList.add('active');
      }
      
      // Update selling plan value
      if (radio.value === 'subscribe') {
        // Set the selling plan from dropdown
        if (sellingPlanInput) {
          const planId = deliverySelect ? deliverySelect.value : radio.dataset.sellingPlan;
          sellingPlanInput.value = planId || '';
          console.log('Selling plan set to:', sellingPlanInput.value);
        }
      } else {
        if (sellingPlanInput) {
          sellingPlanInput.value = '';
          console.log('Selling plan cleared');
        }
      }
    }
    
    // Delivery schedule dropdown change
    function handleDeliveryChange() {
      if (!sellingPlanInput || !deliverySelect) return;
      
      const subscribeRadio = card.querySelector('input[type="radio"][value="subscribe"]');
      if (subscribeRadio && subscribeRadio.checked) {
        sellingPlanInput.value = deliverySelect.value;
      }
      
      // Update subscription price and badge based on selected plan
      const currentVariant = updateVariantId();
      const variantPrice = currentVariant ? currentVariant.price : (onetimePriceEl ? parseInt(onetimePriceEl.dataset.onetimePrice) : 0);
      
      updatePricesAndBadge(variantPrice);
    }
    
    // Add to cart with Ajax for subscriptions
    function handleFormSubmit(e) {
      updateVariantId();
      
      // Check if subscription is selected
      const subscribeRadio = card.querySelector('input[type="radio"][value="subscribe"]:checked');
      
      if (subscribeRadio && sellingPlanInput && sellingPlanInput.value) {
        e.preventDefault();
        e.stopPropagation();
        
        const submitBtn = formEl.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.setAttribute('aria-busy', 'true');
          submitBtn.disabled = true;
        }
        
        const variantId = parseInt(idInput.value);
        const sellingPlan = parseInt(sellingPlanInput.value);
        
        const data = {
          id: variantId,
          quantity: 1,
          selling_plan: sellingPlan
        };
        
        console.log('Adding subscription to cart:', data);
        
        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(data)
        })
        .then(response => {
          console.log('Response status:', response.status);
          return response.json();
        })
        .then(result => {
          console.log('Cart add result:', result);
          if (result.id || result.key) {
            // Success - redirect to cart
            window.location.href = '/cart';
          } else if (result.status === 422 || result.message) {
            // Error handling
            console.error('Error adding to cart:', result);
            if (submitBtn) {
              submitBtn.setAttribute('aria-busy', 'false');
              submitBtn.disabled = false;
            }
            alert(result.message || result.description || 'Error adding item to cart');
          } else {
            // Unknown response but might be success, try redirect
            window.location.href = '/cart';
          }
        })
        .catch(error => {
          console.error('Fetch error:', error);
          if (submitBtn) {
            submitBtn.setAttribute('aria-busy', 'false');
            submitBtn.disabled = false;
          }
          alert('Error adding item to cart. Please try again.');
        });
        
        return false;
      }
      // If one-time purchase, let the default form submission handle it
    }
    
    // Event listeners
    o1 && o1.addEventListener('change', repopulateO2);
    o2 && o2.addEventListener('change', () => { updateVariantId(); });
    
    // Add listeners to schedule options and wrapper (but not delivery schedule)
    card.querySelectorAll('.schedule__option:not(.schedule__option-wrapper .schedule__option), .schedule__option-wrapper').forEach(opt => {
      opt.addEventListener('click', handleScheduleChange);
    });
    
    // Also listen to radio changes directly
    card.querySelectorAll('.schedule__options input[type="radio"]').forEach(radio => {
      radio.addEventListener('change', handleScheduleChange);
    });
    
    if (deliverySelect) {
      deliverySelect.addEventListener('change', handleDeliveryChange);
    }
    
    formEl.addEventListener('submit', handleFormSubmit);
    
    // Initialize
    repopulateO2();
    
    // Set initial selling plan for subscription (default selection)
    const initialSubscribeRadio = card.querySelector('input[type="radio"][value="subscribe"]:checked');
    if (initialSubscribeRadio && sellingPlanInput && deliverySelect) {
      sellingPlanInput.value = deliverySelect.value;
    }
  });
});
{% endif %}
</script>

