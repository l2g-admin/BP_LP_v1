<style>
  #{{section.id}} {
      {%- assign half_padding_top = section.settings.padding_top | divided_by: 2.0 -%}
      {%- assign half_padding_bottom = section.settings.padding_bottom | divided_by: 2.0 -%}
    padding-top: {{ half_padding_top }}em;
    padding-bottom: {{ half_padding_bottom }}em;
    background:  linear-gradient(0deg, rgba(190, 70, 42, 0.70) 0%, rgba(190, 70, 42, 0.70) 100%), linear-gradient(0deg, #BE462A 0%, #BE462A 100%);
    position: relative;
    overflow: hidden;

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: url('{{ section.settings.bg_texture | image_url: width: 1800 }}');
      background-size: cover;
      background-position: center;
      opacity: 0.3;
      z-index: 1;
    }

    & * {
        color: {{ section.settings.text_color }};
        position: relative;
        z-index: 2;
    }

    & .presale__container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
 
    }

    & .presale__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 2rem;
      max-width: 800px;
      border-radius: 32px;
      border: 1px solid   #FFF;
      background: rgba(255, 255, 255, 0.01);
      backdrop-filter: blur(15px);
      padding: 3rem 2rem;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    & .presale__title {
      margin: 0;
      font-size: clamp(28px, 5vw + 1rem, 48px);
 
      line-height: 1.2;
      text-wrap: balance;
    }

    & .presale__subtitle {
      color: {{ section.settings.accent_color }};
      font-family: "Cormorant Garamond";
      font-style: italic;
      font-weight: 400;
    }

    & .presale__description {
      margin: 0;
      font-size: clamp(16px, 2.5vw, 18px);
      line-height: 1.6;
      opacity: 0.9;
      max-width: 600px;
    }

    & .presale__buttons {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      max-width: 400px;
    }

    & .btn__primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 2rem;
      background-color: {{ section.settings.primary_btn_color }};
      color: {{ section.settings.primary_btn_text_color }};
      border: none;
      border-radius: 2rem;
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      cursor: pointer;
      line-height: normal;
 
    }

    & .btn__secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 2rem;
      background: transparent;
      color: {{ section.settings.text_color }};
      border: 2px solid {{ section.settings.text_color }};
      border-radius: 2rem;
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      cursor: pointer;
      line-height: normal;
 
    }

    & .presale__shipping {
      margin-top: 1rem;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      opacity: 0.8;
      font-weight: 500;
    }
  }

  @media (min-width: 768px) {
    #{{section.id}} {
      & .presale__buttons {
        flex-direction: row;
        justify-content: center;
        max-width: none;
      }

      & .btn__primary,
      & .btn__secondary {
        min-width: 200px;
      }
    }
  }

  @media (min-width: 1024px) {
    #{{section.id}} {
      padding-top: {{ section.settings.padding_top }}em;
      padding-bottom: {{ section.settings.padding_bottom }}em;

      & .presale__container {
        min-height: 70vh;
  
      }

      & .presale__content {
        padding: 4rem 3rem;
        gap: 2.5rem;
      }

      & .presale__title {
        font-size: clamp(36px, 6vw + 1rem, 56px);
      }

      & .presale__description {
        font-size: 18px;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="container-sl">
    <div class="presale__container">
      <div class="presale__content">
        {% if section.settings.title %}
          <h2 class="presale__title">
            {% assign title_with_accent = section.settings.title | replace: '{accent}', '<span class="presale__subtitle">' | replace: '{/accent}', '</span>' %}
            {{ title_with_accent }}
          </h2>
        {% endif %}

        {% if section.settings.description %}
          <p class="presale__description">{{ section.settings.description }}</p>
        {% endif %}

        <div class="presale__buttons">
          {% if section.settings.primary_btn_text %}
            <a href="{{ section.settings.primary_btn_link }}" class="btn__primary">
              {{ section.settings.primary_btn_text }}
            </a>
          {% endif %}

          {% if section.settings.secondary_btn_text %}
            <a href="{{ section.settings.secondary_btn_link }}" class="btn__secondary">
              {{ section.settings.secondary_btn_text }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.shipping_text %}
          <p class="presale__shipping">{{ section.settings.shipping_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Ex Pre-Sale",
  "tag": "section",
  "class": "section section-exclusive-presale",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Exclusive Pre-Sale for {accent}Healthcare Providers{/accent}"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Available exclusively to verified healthcare providers. Login or register to access wholesale pricing and secure early inventory."
    },
    {
      "type": "text",
      "id": "primary_btn_text",
      "label": "Primary Button Text",
      "default": "LOGIN TO ACCESS"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_btn_text",
      "label": "Secondary Button Text",
      "default": "REGISTER AS PROVIDER"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping Text",
      "default": "EXPECTED SHIPPING: WEEK OF DECEMBER 8TH, 2025"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_texture",
      "label": "Background Texture (optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (for italics)",
      "default": "#FCD5CC"
    },
    {
      "type": "color",
      "id": "primary_btn_color",
      "label": "Primary Button Color",
      "default": "#1a2b5c"
    },
    {
      "type": "color",
      "id": "primary_btn_text_color",
      "label": "Primary Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_btn_hover_color",
      "label": "Primary Button Hover Color",
      "default": "#0f1a3a"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    }
  ],
  "presets": [
    {
      "name": "C Ex Pre-Sale"
    }
  ]
}
{% endschema %}