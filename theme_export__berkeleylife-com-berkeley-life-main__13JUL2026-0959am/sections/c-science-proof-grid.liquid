      "default": "#080b2b"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Action link color",
      "default": "#D54F2F"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Metric value color",
      "default": "#00BED6"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Metric caption color",
      "default": "rgba(255, 255, 255, 0.6)"
    },
    {
      "type": "color",
      "id": "intro_background_color",
      "label": "Left column background",
      "default": "#1B1C29"
    },
    {
      "type": "color",
      "id": "metrics_background_color",
      "label": "Right column background",
      "default": "rgba(27, 28, 41, 0.42)"
    },
    {
      "type": "color",
      "id": "metrics_border_color",
      "label": "Right column border color",
      "default": "rgba(255, 255, 255, 0.35)"
    },
    {
      "type": "header",
      "content": "CTA Button (Right Column)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Button Background Color",
      "default": "#D54F2F"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
