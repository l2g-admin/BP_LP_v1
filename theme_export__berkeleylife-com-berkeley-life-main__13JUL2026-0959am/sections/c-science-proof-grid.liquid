      "info": "Leave empty to use the default clinical trials content."
    },
    {
      "type": "color",
      "id": "action_drawer_bg_color",
      "label": "Action drawer background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "action_drawer_text_color",
