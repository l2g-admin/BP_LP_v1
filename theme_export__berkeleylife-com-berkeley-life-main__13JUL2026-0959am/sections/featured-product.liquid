{% comment %}theme-check-disable TemplateLength{% endcomment %}
{%- liquid
  assign product = section.settings.product

  assign initialSlide = 0

  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign hide_variants = section.settings.hide_variants
  assign productSticker = product.metafields.my_fields.product_sticker
-%}

<section class="md:mt-8 md:px-8 px-4 mt-4 py-8 md:py-12 bg-white">
  <div id="ProductGrid" class="max-w-screen-xl mx-auto  grid grid-cols-1 {% if product.media.size > 0 %}md:grid-cols-2{% else %}product--no-media{% endif %} gap-4 md:gap-8 items-start justify-start">

    <div id="ProductImages" class="md:sticky top-5 md:col-span-1 w-full col-span-2 relative">
          {%- assign has_frontrow_banner = section.blocks | where: 'type', 'frontrow_banner' | first -%}
          {%- unless has_frontrow_banner -%}
            <span class="absolute z-10 p-2 px-4 text-xs font-bold tracking-widest text-center uppercase rounded-full top-4 left-4 bg-brand text-cream"> {{ section.settings.callout }} </span>
          {%- endunless -%}


      {% if product.media.size == 1 %}
        {%- comment -%}Only one image — same on mobile and desktop{%- endcomment -%}
        <div class="relative w-full h-auto">
          {% if product.metafields.custom.featured_image != blank %}
            {% render 'product-media', media: product.metafields.custom.featured_image, position: 1, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom %}
          {% else %}
          {% render 'product-media', media: product.media[0], position: 1, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom %}
          {% endif %}
          {%- if productSticker != blank -%}
            {% render 'image', image: productSticker, classes: 'w-20 rounded-2xl absolute top-4 md:top-10 left-4 md:left-10 z-10', img_size: "10vw" %}
          {%- endif -%}

          {%- comment -%}FrontRow Banner Block - Single Image{%- endcomment -%}
          {%- assign frontrow_banner_block = section.blocks | where: 'type', 'frontrow_banner' | first -%}
          {%- if frontrow_banner_block -%}
            <div>
              {% render 'frontrow-banner', product_type: frontrow_banner_block.settings.product_type %}
            </div>
          {%- endif -%}
        </div>

      {% elsif product.media.size > 1 %}

        {%- comment -%}
          MOBILE: full swiper (all images)
          DESKTOP: first image hero + remaining images in 2-col grid
        {%- endcomment -%}

        {%- comment -%}MOBILE swiper — hidden on md+{%- endcomment -%}
        <script src="{{ 'product-swiper.js' | asset_url }}" type="module"></script>
        <product-swiper class="relative flex flex-col-reverse items-start w-full md:hidden" data-initial-slide="{{ initialSlide }}" data-section-id="{{ section.id }}" {% if hide_variants %}data-hide-variants{% endif %} {% if section.settings.enable_zoom %}data-zoom{% endif %}>
          {%- comment -%}Empty thumb slot (no thumbnails){%- endcomment -%}
          <div class="hidden w-full h-full">
            <div class="thumb-swiper-container relative pt-1">
              <ul role="list" class="swiper-wrapper w-full"></ul>
            </div>
          </div>

          {%- comment -%}Main swiper slides{%- endcomment -%}
          <div class="w-full overflow-hidden">
            <div class="product-swiper-container pb-20 relative">
              <ul role="list" class="swiper-wrapper w-full">
                {%- for media in product.media -%}
                  {%- assign media_belongs_to_other_variants = false -%}
                  {%- if media.id == product.selected_or_first_available_variant.featured_media.id -%}
                    {%- assign media_belongs_to_other_variants = false -%}
                  {%- elsif variant_images contains media.src -%}
                    {%- assign media_belongs_to_other_variants = true -%}
                  {%- endif -%}
                  {%- unless hide_variants == true and media_belongs_to_other_variants == true -%}
                    <li class="swiper-slide" data-media-id="{{ section.id }}-{{ media.id }}" data-position="{{ forloop.index0 }}">
                      {% render 'product-media', media: media, position: forloop.index, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom %}
                    </li>
                  {%- endunless -%}
                {%- endfor -%}
              </ul>
              <div class="swiper-pagination"></div>

              {%- comment -%}FrontRow Banner Block - Inside Swiper Container{%- endcomment -%}
              {%- assign frontrow_banner_block = section.blocks | where: 'type', 'frontrow_banner' | first -%}
              {%- if frontrow_banner_block -%}
                {% render 'frontrow-banner', product_type: frontrow_banner_block.settings.product_type %}
              {%- endif -%}
            </div>
          </div>
          {%- if productSticker != blank -%}
            {% render 'image', image: productSticker, classes: 'w-20 absolute top-4 left-4 z-10', img_size: "10vw" %}
          {%- endif -%}
        </product-swiper>

        {%- comment -%}DESKTOP grid layout — hidden on mobile{%- endcomment -%}

        <div class="hidden md:block relative">
          {%- if productSticker != blank -%}
            {% render 'image', image: productSticker, classes: 'w-20 rounded-2xl absolute top-10 left-10 z-10', img_size: "10vw" %}
          {%- endif -%}

          {%- assign desktop_position = 0 -%}
          {%- for media in product.media -%}
            {%- assign media_belongs_to_other_variants = false -%}
            {%- if media.id == product.selected_or_first_available_variant.featured_media.id -%}
              {%- assign media_belongs_to_other_variants = false -%}
            {%- elsif variant_images contains media.src -%}
              {%- assign media_belongs_to_other_variants = true -%}
            {%- endif -%}
            {%- unless hide_variants == true and media_belongs_to_other_variants == true -%}
              {%- assign desktop_position = desktop_position | plus: 1 -%}
              {%- if desktop_position == 1 -%}
                <div class="w-full mb-4">
                   {% if product.metafields.custom.featured_image != blank %}
                   <img src="{{ product.metafields.custom.featured_image | image_url }}"> 
                    {% else %}
                            {% render 'product-media', media: media, position: desktop_position, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom, extra: 'rounded-2xl' %}
                    {% endif %}
                </div>
              {%- elsif desktop_position == 2 -%}
                <div class="grid grid-cols-2 gap-4">
                  <div>{% render 'product-media', extra: 'rounded-2xl', media: media, position: desktop_position, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom %}</div>
              {%- else -%}
                  <div>{% render 'product-media', extra: 'rounded-2xl', media: media, position: desktop_position, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom %}</div>
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
          {%- if desktop_position >= 2 -%}</div>{%- endif -%}

          {%- comment -%}FrontRow Banner Block - Desktop Grid{%- endcomment -%}
          {%- assign frontrow_banner_block = section.blocks | where: 'type', 'frontrow_banner' | first -%}
          {%- if frontrow_banner_block -%}
            {% render 'frontrow-banner', product_type: frontrow_banner_block.settings.product_type %}
          {%- endif -%}

        </div>

      {% endif %}
    </div>


    <div class="md:sticky top-5 p-4">
      <div id="ProductInfo-{{ section.id }}" class="space-y-4">
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- when 'text' -%}
            <p class="{% if block.settings.text_style == 'uppercase' %} uppercase{% elsif block.settings.text_style == 'subtitle' %} {% endif %}" {{ block.shopify_attributes }}>
              {{- block.settings.text -}}
            </p>
            {%- when 'highlights' -%}
            <div class="font-secondaryHeader h5 flex items-center gap-4" {{ block.shopify_attributes }}>
             <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
<circle cx="5.5" cy="5.5" r="5.5" fill="#FF4E24"/>
<path d="M6.072 7.45409H5.12471V6.12632H3.88235V5.21009H5.12471V3.88232H6.072V5.21009H7.31435V6.12632H6.072V7.45409Z" fill="#F6F3F0"/>
</svg>
 {{- block.settings.highlight -}}
            </div>
          {%- when 'title' -%}
            <h1 class="h3 border-b border-brand pb-4" {{ block.shopify_attributes }}>
              {{ product.title | escape }}
            </h1>
          {%- when 'price' -%}
            <div class="sr-only no-js-hidden" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
              {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'text-lg' -%}
            </div>

          {%- when 'description' -%}
            {%- if product.description != blank -%}
              <div {{ block.shopify_attributes }}>
                <details class="group" {% if block.settings.open %}open{% endif %}>
                  <summary class="py-4 border-b border-gray-200 border-solid">
                    <h2 class="flex items-center gap-2">
                      <span class="subhead flex-grow">
                        {{ block.settings.heading | default: "Description" }}
                      </span>
                      <span class="shrink-0 group-open:rotate-180 w-4 transition-transform">{% render 'icon-caret' %}</span>
                    </h2>
                  </summary>
                  <div class="rte pt-4 space-y-4">
                    {{ product.description }}
                  </div>
                </details>
              </div>
            {%- endif -%}
          {%- when 'custom_liquid' -%}
            {{ block.settings.custom_liquid }}
          {%- when 'add_banner' -%}
              <div class="add-banner-container" {{ block.shopify_attributes }}>
                <style>
                  .add-banner-container {
                    background-color: {{ block.settings.bg_color | default: '#1B202B' }};
                    border-radius: 12px;
                    padding: 4px 16px 4px 16px;
                    margin: 16px 0;
                    text-align: center;
                    width: max-content;
                  }

                  .add-banner-text {
                    color: {{ block.settings.text_color | default: '#ffffff' }};
                    margin: 0;
                    line-height: revert;
                    font-size: 14px;
                  }

                  .add-banner-copy-wrapper {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                  }

                  .add-banner-content {
                    display: flex;
                    align-items: center;
                    gap: .5rem;
                  }

                  .add-banner-copy-code {
                    color: {{ block.settings.text_color | default: '#ffffff' }};
                    font-size: 14px;
                    letter-spacing: 0.05em;
                    margin: 0;
                  }

                  .add-banner-copy-btn {
                    background-color: {{ block.settings.copy_btn_bg_color | default: '#D44F2F' }};
                    color: {{ block.settings.copy_btn_text_color | default: '#ffffff' }};
                    border: none;
                    border-radius: 6px;
                     padding: 5px 10px;
                    font-size: 12px;
                    font-weight: 600;
                    cursor: pointer;
                    text-transform: uppercase;
                    transition: opacity 0.2s;
                  }

                  .add-banner-copy-btn:hover {
                    opacity: 0.85;
                  }

                  @media (max-width: 768px) {
                    .add-banner-container {
                      padding: 16px;
                    }
                  }
                </style>

                <div class="add-banner-content">
                  {%- if block.settings.banner_text != blank -%}
                    <p class="add-banner-text">{{ block.settings.banner_text }}</p>
                  {%- endif -%}
                  {%- if block.settings.enable_copy_code -%}
                    <div class="add-banner-copy-wrapper">
                      <button
                        type="button"
                        class="add-banner-copy-btn"
                        data-discount-code="{{ block.settings.discount_code }}"
                        onclick="navigator.clipboard.writeText(this.dataset.discountCode).then(function(){ this.textContent='Copied!'; setTimeout(function(){ this.textContent='Copy'; }.bind(this), 2000); }.bind(this))"
                      >
                        Copy
                      </button>
                    </div>
                  {%- endif -%}
                </div>
              </div>
          {%- when 'collapsible_tab' -%}
            {%- unless block.settings.hide_if_empty and block.settings.content == blank and block.settings.page.content == blank and block.settings.enable_clinical_drawer == false -%}
              <div {{ block.shopify_attributes }}>
                <details class="group" {% if block.settings.open %}open{% endif %}>
                  <summary class="gap-2 pb-4 border-b border-brand border-solid">
                    <h2 class="flex items-center gap-2">
                      {% render 'icon-accordion', icon: block.settings.icon %}
                      <span class="subhead flex-grow">
                        {{ block.settings.heading | default: block.settings.page.title }}
                      </span>
                      <span class="shrink-0  w-4 transition-transform"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
<circle cx="9" cy="9" r="9" fill="#4D233B"/>
<path class="group-open:hidden" d="M9.3913 5.47826V13.3043" stroke="#F6F3F0" stroke-linecap="round"/>
<path d="M13.3044 9.39131L5.4783 9.39131" stroke="#F6F3F0" stroke-linecap="round"/>
</svg>
</span>
                    </h2>
                  </summary>
                  <div class="rte pt-4 space-y-4">
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                  </div>
                  {%- if block.settings.enable_clinical_drawer -%}
                    <div class="pt-4">
                      <button
                        type="button"
                        class="clinical-drawer-trigger"
                        aria-haspopup="dialog"
                        data-drawer-target="ClinicalDrawerTab-{{ block.id }}"
                        style="{% if block.settings.ct_button_style == 'link' %}background:none;border:none;padding:0;color:inherit;text-decoration:underline;cursor:pointer;font-size:16px;font-weight:600;text-transform:uppercase;letter-spacing:0.02em;{% endif %}"
                      >
                        {{ block.settings.ct_button_text | default: 'Clinical Trials' }}
                      </button>
                    </div>
                  {%- endif -%}
                </details>
              </div>

              {%- if block.settings.enable_clinical_drawer -%}
                <div
                  id="ClinicalDrawerTab-{{ block.id }}"
                  class="clinical-drawer-overlay"
                  role="dialog"
                  aria-modal="true"
                  aria-label="{{ block.settings.ct_drawer_title }}"
                  tabindex="-1"
                >
                  <div
                    class="clinical-drawer-panel"
                    style="background-color: {{ block.settings.ct_bg_color }}; color: {{ block.settings.ct_text_color }};"
                  >
                    <div class="clinical-drawer-header" style="background-color: {{ block.settings.ct_bg_color }}; color: {{ block.settings.ct_text_color }};">
                      <h2 class="clinical-drawer-title" style="color: {{ block.settings.ct_text_color }};">
                        {{ block.settings.ct_drawer_title }}
                      </h2>
                      <button
                        type="button"
                        class="clinical-drawer-close"
                        aria-label="Close drawer"
                        data-drawer-close="ClinicalDrawerTab-{{ block.id }}"
                        style="color: {{ block.settings.ct_text_color }};"
                      >
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                    <div class="clinical-drawer-body">
                      <div class="clinical-drawer-content" style="color: {{ block.settings.ct_text_color }};">
                        {{ block.settings.ct_body }}
                      </div>
                    </div>
                  </div>
                </div>

                <script>
                  (function() {
                    const drawerId = 'ClinicalDrawerTab-{{ block.id }}';
                    const overlay = document.getElementById(drawerId);
                    if (!overlay) return;

                    const triggers = document.querySelectorAll('[data-drawer-target="' + drawerId + '"]');
                    const closeBtn = overlay.querySelector('[data-drawer-close="' + drawerId + '"]');
                    let scrollY = 0;

                    function openDrawer() {
                      scrollY = window.scrollY;
                      document.body.style.top = '-' + scrollY + 'px';
                      document.body.classList.add('clinical-drawer-no-scroll');
                      overlay.classList.add('is-open');
                      overlay.focus();
                    }

                    function closeDrawer() {
                      overlay.classList.remove('is-open');
                      document.body.classList.remove('clinical-drawer-no-scroll');
                      document.body.style.top = '';
                      window.scrollTo(0, scrollY);
                    }

                    triggers.forEach(function(trigger) {
                      trigger.addEventListener('click', openDrawer);
                    });

                    if (closeBtn) {
                      closeBtn.addEventListener('click', closeDrawer);
                    }

                    overlay.addEventListener('click', function(e) {
                      if (e.target === overlay) closeDrawer();
                    });

                    document.addEventListener('keydown', function(e) {
                      if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
                        closeDrawer();
                      }
                    });
                  })();
                </script>

                <style>
                  .clinical-drawer-trigger {
                    margin: 8px 0;
                    color: #080b2b;
                    display: inline-flex;
                    align-items: center;
                    cursor: pointer;
                    font-size: 16px;
                    letter-spacing: 0.02em;
                    text-transform: uppercase;
                    font-weight: 600;
                    text-decoration: underline;
                    background: none;
                    border: none;
                    padding: 0;
                    transition: opacity 0.2s ease;
                  }
                  .clinical-drawer-trigger:hover {
                    opacity: 0.7;
                  }
                  .clinical-drawer-overlay {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background: rgba(0, 0, 0, 0.5);
                    backdrop-filter: blur(2px);
                    z-index: 99999;
                    opacity: 0;
                    visibility: hidden;
                    transition: opacity 0.3s ease, visibility 0.3s ease;
                  }
                  .clinical-drawer-overlay.is-open {
                    opacity: 1;
                    visibility: visible;
                  }
                  .clinical-drawer-panel {
                    position: absolute;
                    top: 0;
                    right: 0;
                    width: 100%;
                    max-width: 500px;
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                    transform: translateX(100%);
                    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                    box-shadow: -4px 0 30px rgba(0, 0, 0, 0.15);
                  }
                  .clinical-drawer-overlay.is-open .clinical-drawer-panel {
                    transform: translateX(0);
                  }
                  .clinical-drawer-header {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    padding: 24px 40px;
                    flex-shrink: 0;
                    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
                    position: sticky;
                    top: 0;
                    z-index: 2;
                  }
                  .clinical-drawer-title {
                    font-size: 20px;
                    font-weight: 600;
                    margin: 0;
                    line-height: 1.3;
                    letter-spacing: 0.01em;
                    flex: 1;
                    padding-right: 16px;
                  }
                  .clinical-drawer-close {
                    background: none;
                    border: none;
                    cursor: pointer;
                    padding: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 50%;
                    transition: background 0.2s ease;
                    flex-shrink: 0;
                  }
                  .clinical-drawer-close:hover {
                    background: rgba(0, 0, 0, 0.06);
                  }
                  .clinical-drawer-body {
                    flex: 1;
                    overflow-y: auto;
                    -webkit-overflow-scrolling: touch;
                    overscroll-behavior: contain;
                  }
                  .clinical-drawer-content {
                    padding: 32px 40px;
                    font-size: 16px;
                    line-height: 1.65;
                  }
                  .clinical-drawer-content h1,
                  .clinical-drawer-content h2,
                  .clinical-drawer-content h3,
                  .clinical-drawer-content h4,
                  .clinical-drawer-content h5 {
                    margin-top: 1.5em;
                    margin-bottom: 0.5em;
                    line-height: 1.3;
                    color: inherit;
                    font-weight: 800;
                  }
                  .clinical-drawer-content h1:first-child,
                  .clinical-drawer-content h2:first-child,
                  .clinical-drawer-content h3:first-child {
                    margin-top: 0;
                  }
                  .clinical-drawer-content p {
                    margin-bottom: 1em;
                  }
                  .clinical-drawer-content ul {
                    list-style: circle;
                  }
                  .clinical-drawer-content ul,
                  .clinical-drawer-content ol {
                    margin-bottom: 1em;
                    padding-left: 1.5em;
                  }
                  .clinical-drawer-content li {
                    margin-bottom: 0.5em;
                  }
                  .clinical-drawer-content img {
                    max-width: 100%;
                    height: auto;
                    display: block;
                    margin: 1em auto;
                  }
                  .clinical-drawer-content a {
                    color: inherit;
                    text-decoration: underline;
                  }
                  body.clinical-drawer-no-scroll {
                    overflow: hidden !important;
                    position: fixed;
                    width: 100%;
                  }
                  #shopify-section-header,
                  sticky-header,
                  .header-wrapper {
                    transition: opacity 0.3s ease;
                  }
                  body.clinical-drawer-no-scroll #shopify-section-header,
                  body.clinical-drawer-no-scroll sticky-header,
                  body.clinical-drawer-no-scroll .header-wrapper {
                    opacity: 0 !important;
                    pointer-events: none !important;
                    z-index: 0 !important;
                  }
                  body.clinical-drawer-no-scroll .space-y-4>:not([hidden])~:not([hidden]) {
                    margin-top: 0 !important;
                  }
                  @media (max-width: 600px) {
                    .clinical-drawer-panel {
                      max-width: 100%;
                    }
                    .clinical-drawer-header {
                      padding: 20px 24px;
                    }
                    .clinical-drawer-content {
                      padding: 24px;
                    }
                  }
                </style>
              {%- endif -%}
            {%- endunless -%}
          {%- when 'popup' -%}
              <modal-opener class="product-popup-modal__opener no-js-hidden" data-modal="#PopupModal-{{ block.id }}" {{ block.shopify_attributes }}>
                <button id="ProductPopup-{{ block.id }}" class="product-popup-modal__button link" type="button" aria-haspopup="dialog">{{ block.settings.text | default: block.settings.page.title }}</button>
              </modal-opener>
              <a href="{{ block.settings.page.url }}" class="product-popup-modal__button link no-js">{{ block.settings.text }}</a>
          {%- when 'share' -%}
              {% render 'share', share_url: product.url, block: block, type: 'Product' %}
          {%- when 'variant_picker' -%}
            {%- unless product.has_only_default_variant -%}
                {%- if block.settings.picker_type == 'button' -%}
                  {%- if product.metafields.custom.disable_subscription_flyout != true or customer.b2b? -%}
                    <variant-radios
                      class="no-js-hidden"
                      data-section="{{ section.id }}"
                      data-url="{{ product.url }}"
                      {% if quickshop %}
                        data-update-url="false"
                      {% endif -%}
                      {{ block.shopify_attributes }}
                    >
                      <fieldset class="!my-8 space-y-1 text-sm">
                        <div class="flex flex-wrap gap-4">
                          {% if customer.b2b? %}
                            {% comment %} Wholesale Variants {% endcomment %}
                            <legend class="block text-2xl">
                              <span>One Time Purchase:</span>
                            </legend>
                            <div class="flex flex-wrap w-full gap-2 gap-y-6">
                              {%- for variant in product.variants -%}
                                {%- if variant.metafields.custom.b2bonly.value == true
                                  or variant.metafields.custom.both_d2c_b2b.value == true
                                -%}
                                  {% unless variant.metafields.custom.subscription_30_days == true %}
                                    <label
                                      class="relative gap-4 p-4 bg-transparent border-2 rounded-full cursor-pointer w-fit option-container border-brand"
                                      for="variant-{{ variant.id }}-otp"
                                    >
                                      <div class="relative inline-flex items-center justify-between flex-grow w-full gap-2">
                                        {% if variant.metafields.custom.b2b_savings_amount != blank %}
