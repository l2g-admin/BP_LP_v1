                      <!-- JavaScript: Add 'selected' class to the container of the checked radio -->
                      <script>
                        document.addEventListener('DOMContentLoaded', function () {
                          const options = document.querySelectorAll('.option-container');
                          const variantSelect = document.querySelector("select[name='variant_selling_plan']");

                          // Function to update selected state on all option containers
                          function updateSelected() {
                            options.forEach((option) => {
                              const radio = option.querySelector('input[type="radio"]');
                              if (radio.checked) {
                                option.classList.add('selected');
                              } else {
                                option.classList.remove('selected');
                              }
                            });
                          }

                          // Function to handle mutual exclusivity between radios and select
                          function handleMutualExclusivity(event) {
                            if (event.target.tagName === 'SELECT') {
                              // If select dropdown was changed, deselect all radio buttons
                              document
                                .querySelectorAll('input[name="variant_selling_plan"][type="radio"]')
                                .forEach((radio) => {
                                  radio.checked = false;
                                });
                              // Remove selected class from all option containers
                              options.forEach((option) => {
                                option.classList.remove('selected');
                              });
                            } else if (event.target.type === 'radio') {
                              // If radio button was changed, clear the select dropdown
                              if (variantSelect) {
                                variantSelect.value = '';
                              }
                            }
                            updateSelected();
                          }

                          // Automatically select the first radio if none are selected
                          function selectFirstRadio() {
                            const firstRadio = options[0]?.querySelector('input[type="radio"]');
                            if (firstRadio && !document.querySelector('input[type="radio"]:checked')) {
                              firstRadio.checked = true;
                            }
                          }

                          // Attach change event to every radio input
                          options.forEach((option) => {
                            const radio = option.querySelector('input[type="radio"]');
                            radio.addEventListener('change', handleMutualExclusivity);
                          });

                          // Attach change event to select dropdown if it exists
                          if (variantSelect) {
                            variantSelect.addEventListener('change', handleMutualExclusivity);
                          }

                          // Run on initial load
                          selectFirstRadio();
                          updateSelected();
                        });
                      </script>

