                  visibility: hidden;
                  z-index: -1;
                  margin: 0 auto;
                  top: 0;
                  left: 0;
                  overflow: auto;
                  width: 100%;
                  padding: 30px;
                  background: rgba(var(--color-overlay-rgb), 0.7);
                  backdrop-filter: blur(3px);
                  height: 100%;
                }
                .product-popup-modal[open] {
                  opacity: 1;
                  visibility: visible;
                  z-index: 101;
                }
                .product-popup-modal__button {
                  margin: 20px 0 30px;
                  color: #080b2b;
                  display: flex;
                  align-items: center;
                  cursor: pointer;
                  font-size: 16px;
                  letter-spacing: -0.01em;
                  text-transform: uppercase;
                  font-weight: bold;
                  text-decoration: underline;
                }
                .product-popup-modal__button svg {
                  height: 12px;
                  width: auto;
                  margin-right: 9px;
                  fill: var(--color-accent);
                }
                .product-popup-modal__button span {
                  font-size: 0.8125rem;
                  letter-spacing: 0.02em;
                }
                .product-popup-modal__button.no-js {
                  display: none;
                }
                .no-js .product-popup-modal__button.no-js {
                  display: flex;
                }
                .product-popup-modal__toggle {
                  position: absolute;
                  top: 50%;
                  right: 30px;
                  margin-top: 15px;
                }
                .product-popup-modal__content {
                  overflow: auto;
                  max-height: 90vh;
                  max-width: clamp(300px, 90vw, 800px);
                  margin: 0 auto;
                  left: 50%;
                  transform: translate3d(-50%, -50%, 0);
                  width: 100%;
                  position: absolute;
                  top: 50%;
                  display: flex;
                  flex-direction: column;
                  box-shadow: 0px 4px 40px rgba(0, 0, 0, 0.25);
                }
                .product-popup-modal__content-header {
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  text-align: center;
                  position: sticky;
                  background-color: var(--bg-body, #fff);
                  top: 0;
                  left: 0;
                  flex-shrink: 0;
                }
                .product-popup-modal__content-header h5 {
                  color: inherit;
                  margin: 0;
                }
                .product-popup-modal__content scroll-shadow {
                  flex: 1;
                  display: flex;
                  width: 100%;
                  overflow: hidden;
                }
                .product-popup-modal__content img {
                  display: block;
                  max-width: 500px;
                  @media (max-width: 768px) {
                    max-width: 310px;
                  }
                  margin: 0 auto;
                }
                .product-popup-modal__content-info {
                  padding: 25px;
                  background-color: var(--bg-body, #fff);
                  width: 100%;
                  color: var(--color-body);
                }
                @media only screen and (min-width: 768px) {
                  .product-popup-modal__content-info {
                    padding: 20px;
                  }
                }
                .product-popup-modal__content-info table:last-child {
                  margin-bottom: 0;
                }
                .product-popup-modal {
                  transition: all 0.25s cubic-bezier(0.104, 0.204, 0.492, 1);
                }
              </style>
              {%- if block.settings.title != '' -%}
                <modal-opener class="product-popup-modal__opener no-js-hidden" data-modal="#PopupModal-{{ block.id }}">
                  <button
                    id="ProductPopup-{{ block.id }}"
                    class="product-popup-modal__button"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    <span>{{ block.settings.title }}</span>
                  </button>
                </modal-opener>
                <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal">
                  <div
                    role="dialog"
                    aria-label="{{ block.settings.title }}"
                    aria-modal="true"
                    class="product-popup-modal__content"
                    tabindex="-1"
                  >
                    <div class="product-popup-modal__content-header">
                      <button
                        id="ModalClose-{{ block.id }}"
                        type="button"
                        class="product-popup-modal__toggle"
                        aria-label="{{ 'accessibility.close' | t }}"
                      >
                        {% render 'svg-icons' with 'close' %}
                      </button>
                    </div>
                    <scroll-shadow>
                      <div class="product-popup-modal__content-info">
                        {%- liquid
                          assign image = block.settings.content
                          assign sizes = image.src.width | append: 'x' | append: image.src.height
                          render 'responsive-image', image: image, sizes: sizes
                        -%}
                      </div>
                    </scroll-shadow>
                  </div>
                </modal-dialog>
              {%- endif -%}
          {%- when 'clinical_drawer' -%}
              <div {{ block.shopify_attributes }}>
                <button
                  type="button"
                  class="clinical-drawer-trigger"
                  aria-haspopup="dialog"
                  data-drawer-target="ClinicalDrawer-{{ block.id }}"
                  style="{% if block.settings.button_style == 'link' %}background:none;border:none;padding:0;color:inherit;text-decoration:underline;cursor:pointer;font-size:16px;font-weight:600;text-transform:uppercase;letter-spacing:0.02em;{% endif %}"
                >
                  {{ block.settings.button_text | default: 'Learn More' }}
                </button>
              </div>

              {%- comment -%} Clinical Drawer Overlay + Panel {%- endcomment -%}
              <div
                id="ClinicalDrawer-{{ block.id }}"
                class="clinical-drawer-overlay"
                role="dialog"
                aria-modal="true"
                aria-label="{{ block.settings.drawer_title }}"
                tabindex="-1"
              >
                <div
                  class="clinical-drawer-panel"
                  style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};"
                >
                  <div class="clinical-drawer-header" style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};">
                    <h2 class="clinical-drawer-title" style="color: {{ block.settings.text_color }};">
                      {{ block.settings.drawer_title }}
                    </h2>
                    <button
                      type="button"
                      class="clinical-drawer-close"
                      aria-label="Close drawer"
                      data-drawer-close="ClinicalDrawer-{{ block.id }}"
                      style="color: {{ block.settings.text_color }};"
                    >
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  </div>
                  <div class="clinical-drawer-body">
                    <div class="clinical-drawer-content" style="color: {{ block.settings.text_color }};">
                      {{ block.settings.body }}
                    </div>
                  </div>
                </div>
              </div>

              <style>
                .clinical-drawer-trigger {
                  margin: 8px 0;
                  color: #080b2b;
                  display: inline-flex;
                  align-items: center;
                  cursor: pointer;
                  font-size: 16px;
                  letter-spacing: 0.02em;
                  text-transform: uppercase;
                  font-weight: 600;
                  text-decoration: underline;
                  background: none;
                  border: none;
                  padding: 0;
                  transition: opacity 0.2s ease;
                }
                .clinical-drawer-trigger:hover {
                  opacity: 0.7;
                }
                .clinical-drawer-overlay {
                  position: fixed;
                  top: 0;
                  left: 0;
                  width: 100%;
                  height: 100%;
                  background: rgba(0, 0, 0, 0.5);
                  backdrop-filter: blur(2px);
                  z-index: 99999;
                  opacity: 0;
                  visibility: hidden;
                  transition: opacity 0.3s ease, visibility 0.3s ease;
                }
                .clinical-drawer-overlay.is-open {
                  opacity: 1;
                  visibility: visible;
                }
                .clinical-drawer-panel {
                  position: absolute;
                  top: 0;
                  right: 0;
                  width: 100%;
                  max-width: 500px;
                  height: 100%;
                  display: flex;
                  flex-direction: column;
                  transform: translateX(100%);
                  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                  box-shadow: -4px 0 30px rgba(0, 0, 0, 0.15);
                }
                .clinical-drawer-overlay.is-open .clinical-drawer-panel {
                  transform: translateX(0);
                }
                .clinical-drawer-header {
                  display: flex;
                  align-items: center;
                  justify-content: space-between;
                  padding: 24px 40px;
                  flex-shrink: 0;
                  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
                  position: sticky;
                  top: 0;
                  z-index: 2;
                }
                .clinical-drawer-title {
                  font-size: 20px;
                  font-weight: 600;
                  margin: 0;
                  line-height: 1.3;
                  letter-spacing: 0.01em;
                  flex: 1;
                  padding-right: 16px;
                }
                .clinical-drawer-close {
                  background: none;
                  border: none;
                  cursor: pointer;
                  padding: 8px;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  border-radius: 50%;
                  transition: background 0.2s ease;
                  flex-shrink: 0;
                }
                .clinical-drawer-close:hover {
                  background: rgba(0, 0, 0, 0.06);
                }
                .clinical-drawer-body {
                  flex: 1;
                  overflow-y: auto;
                  -webkit-overflow-scrolling: touch;
                  overscroll-behavior: contain;
                }
                .clinical-drawer-content {
                  padding: 32px 40px;
                  font-size: 16px;
                  line-height: 1.65;
                }
                .clinical-drawer-content h1,
                .clinical-drawer-content h2,
                .clinical-drawer-content h3,
                .clinical-drawer-content h4,
                .clinical-drawer-content h5 {
                  margin-top: 1.5em;
                  margin-bottom: 0.5em;
                  line-height: 1.3;
                  color: inherit;
                  font-weight: 800;
                }
                .clinical-drawer-content h1:first-child,
                .clinical-drawer-content h2:first-child,
                .clinical-drawer-content h3:first-child {
                  margin-top: 0;
                }
                .clinical-drawer-content p {
                  margin-bottom: 1em;
                }
                .clinical-drawer-content ul {
                  list-style: circle;
                }
                .clinical-drawer-content ul,
                .clinical-drawer-content ol {
                  margin-bottom: 1em;
                  padding-left: 1.5em;
                }
                .clinical-drawer-content li {
                  margin-bottom: 0.5em;
                }
                .clinical-drawer-content img {
                  max-width: 100%;
                  height: auto;
                  display: block;
                  margin: 1em auto;
                }
                .clinical-drawer-content a {
                  color: inherit;
                  text-decoration: underline;
                }
                body.clinical-drawer-no-scroll {
                  overflow: hidden !important;
                  position: fixed;
                  width: 100%;
                }
                #shopify-section-header,
                sticky-header,
                .header-wrapper {
                  transition: opacity 0.3s ease;
                }
                body.clinical-drawer-no-scroll #shopify-section-header,
                body.clinical-drawer-no-scroll sticky-header,
                body.clinical-drawer-no-scroll .header-wrapper {
                  opacity: 0 !important;
                  pointer-events: none !important;
                  z-index: 0 !important;
                }
                body.clinical-drawer-no-scroll .space-y-4>:not([hidden])~:not([hidden]) {
                  margin-top: 0 !important;
                }
                @media (max-width: 600px) {
                  .clinical-drawer-panel {
                    max-width: 100%;
                  }
                  .clinical-drawer-header {
                    padding: 20px 24px;
                  }
                  .clinical-drawer-content {
                    padding: 24px;
                  }
                }
              </style>

              <script>
                (function() {
                  const drawerId = 'ClinicalDrawer-{{ block.id }}';
                  const overlay = document.getElementById(drawerId);
                  if (!overlay) return;

                  const triggers = document.querySelectorAll('[data-drawer-target="' + drawerId + '"]');
                  const closeBtn = overlay.querySelector('[data-drawer-close="' + drawerId + '"]');
                  let scrollY = 0;

                  function openDrawer() {
                    scrollY = window.scrollY;
                    document.body.style.top = '-' + scrollY + 'px';
                    document.body.classList.add('clinical-drawer-no-scroll');
                    overlay.classList.add('is-open');
                    overlay.focus();
                  }

                  function closeDrawer() {
                    overlay.classList.remove('is-open');
                    document.body.classList.remove('clinical-drawer-no-scroll');
                    document.body.style.top = '';
                    window.scrollTo(0, scrollY);
                  }

                  triggers.forEach(function(trigger) {
                    trigger.addEventListener('click', openDrawer);
                  });

                  if (closeBtn) {
                    closeBtn.addEventListener('click', closeDrawer);
                  }

                  // Close on overlay click (outside panel)
                  overlay.addEventListener('click', function(e) {
                    if (e.target === overlay) closeDrawer();
                  });

                  // Close on Escape key
                  document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
                      closeDrawer();
                    }
                  });
                })();
              </script>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {% assign popups = section.blocks | where: "type", "popup" %}
  {%- for block in popups -%}
    <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
      <div role="dialog" aria-label="{{ block.settings.text }}" aria-modal="true" class="product-popup-modal__content" tabindex="-1">
        <button id="ModalClose-{{ block.id }}" type="button" class="product-popup-modal__toggle" aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>
        <div class="product-popup-modal__content-info">
          <h1 class="h2">{{ block.settings.page.title }}</h1>
          {{ block.settings.page.content }}
        </div>
      </div>
    </modal-dialog>
  {%- endfor -%}
</section>

{%- comment -%}
  ============================================
  CONDITIONAL SCRIPTS BASED ON VARIANT PICKER TYPE
  ============================================
  If third_party_picker block is present, use the standard Shopify script.
  Otherwise, use the custom variant_selling_plan script for the default variant picker.
  ============================================
{%- endcomment -%}

{%- assign third_party_picker_block = section.blocks | where: 'type', 'third_party_picker' | first -%}

{%- if third_party_picker_block -%}
  {%- comment -%}
    ============================================
    STANDARD VARIANT/SELLING PLAN SCRIPT (Third Party Compatible)
    ============================================
    This script works with Shopify's standard form structure:
    - name="id" for variant ID (in the hidden input)
    - name="selling_plan" for subscription plan selection

    Compatible with 3rd party subscription apps.
    ============================================
  {%- endcomment -%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Standard Shopify form elements
      const variantInput = document.getElementById('SelectedVariantId');
      const addToCartButton = document.querySelector('.product-form__submit');
      const sellingPlanRadios = document.querySelectorAll('input[name="selling_plan"]');

      // Skip if no variant input found (3rd party apps may handle this)
      if (!variantInput) {
        console.log('Standard variant input not found - 3rd party app may be handling form');
        return;
      }

      // Update button text based on selling plan selection
      function updateButtonText() {
        if (!addToCartButton) return;

        const selectedSellingPlan = document.querySelector('input[name="selling_plan"]:checked');
        const sellingPlanValue = selectedSellingPlan ? selectedSellingPlan.value : '';

        if (sellingPlanValue && sellingPlanValue !== '') {
          addToCartButton.innerText = 'Subscribe';
        } else {
          addToCartButton.innerText = 'Add to Cart';
        }
      }

      // Attach change event to selling plan radios (if using built-in UI)
      sellingPlanRadios.forEach((radio) => {
        radio.addEventListener('change', updateButtonText);
      });

      // Initialize button text on load
      updateButtonText();

      // Listen for variant changes from variant-radios component
      document.addEventListener('variant:changed', function (event) {
        if (event.detail && event.detail.variant) {
          const variant = event.detail.variant;
          if (variantInput) {
            variantInput.value = variant.id;
          }
          if (addToCartButton) {
            addToCartButton.disabled = !variant.available;
            if (!variant.available) {
              addToCartButton.innerText = 'Sold Out';
            } else {
              updateButtonText();
            }
          }
        }
      });
    });
  </script>
{%- else -%}
  {%- comment -%}
    ============================================
    CUSTOM VARIANT/SELLING PLAN SCRIPT (Default)
    ============================================
    This script works with the custom variant_selling_plan combined field.
    Used by the default variant_picker block.
    ============================================
  {%- endcomment -%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const variantRadios = document.querySelectorAll("input[name='variant_selling_plan']");
      const variantSelect = document.querySelector("select[name='variant_selling_plan']");
      const variantInput = document.getElementById('SelectedVariantId');
      const addToCartButton = document.querySelector('.product-form__submit');

      // Create hidden input for selling plan if it doesn't already exist
      let sellingPlanInput = document.getElementById('SelectedSellingPlan');
      if (!sellingPlanInput) {
        sellingPlanInput = document.createElement('input');
        sellingPlanInput.setAttribute('type', 'hidden');
        sellingPlanInput.setAttribute('name', 'selling_plan');
        sellingPlanInput.setAttribute('id', 'SelectedSellingPlan');
        variantInput.parentNode.appendChild(sellingPlanInput);
      }

      function updateSellingPlan(event) {
        console.log('VARIANT CHANGE');

        // Parse the value into variantId and sellingPlanId
        const [variantId, sellingPlanId] = event.target.value.split('-');
        variantInput.value = variantId;

        if (sellingPlanId === 'otp') {
          sellingPlanInput.value = ''; // Clear selling plan if one-time purchase
        } else {
          sellingPlanInput.value = sellingPlanId; // Assign selected selling plan ID
        }

        console.log('SELLING PLAN ID', sellingPlanId);

        // Handle mutual exclusivity between radio buttons and select dropdown
        if (event.target.tagName === 'SELECT') {
          // If select dropdown was changed, deselect all radio buttons
          variantRadios.forEach((radio) => {
            radio.checked = false;
          });
          // Also remove the 'selected' class from all option containers
          document.querySelectorAll('.option-container').forEach((container) => {
            container.classList.remove('selected');
          });
        } else if (event.target.type === 'radio') {
          // If radio button was changed, clear the select dropdown
          if (variantSelect) {
            variantSelect.value = '';
          }
        }

        // Fetch variant data
        const selectedVariant = window.productVariants.find((variant) => variant.id == variantId);

        console.log('SELECTED VARIANT', selectedVariant);
        if (selectedVariant) {
          setTimeout(() => {
            if (selectedVariant.available) {
              console.log('SELLING PLAN IS AVAILABLE', sellingPlanId);
              console.log('ADD TO CART BUTTON', addToCartButton);

              // Update button text based on selection
              if (event.target.tagName === 'SELECT' && event.target.value !== '') {
                // If selection came from dropdown and has a value, it's a subscription
                addToCartButton.innerText = 'Subscribe';
              } else if (sellingPlanId === 'otp') {
                // If it's a one-time purchase (radio button)
                addToCartButton.innerText = 'Add to Cart';
              } else if (sellingPlanId) {
                // If it has a selling plan ID (regular subscription)
                addToCartButton.innerText = 'Subscribe';
              } else {
                addToCartButton.innerText = 'Add to Cart';
              }

              // Update the button's data attribute with the variant ID
              addToCartButton.dataset.productId = variantId;
              addToCartButton.disabled = false;
            } else {
              addToCartButton.innerText = 'Unavailable';
              addToCartButton.disabled = true;
            }

            console.log('Forced Button Update:', addToCartButton.innerText);
            console.log('Button Data Product ID:', addToCartButton.dataset.productId);
          }, 10);
        }
      }

      // Attach change event to every radio input
      variantRadios.forEach((radio) => {
        radio.addEventListener('change', updateSellingPlan);
      });

      // Attach change event to select dropdown if it exists
      if (variantSelect) {
        variantSelect.addEventListener('change', updateSellingPlan);
      }

      // Run update for the initially selected option on page load
      const initialChecked = document.querySelector("input[name='variant_selling_plan']:checked");
      const initialSelected = variantSelect ? variantSelect.value : null;

      if (initialChecked) {
        updateSellingPlan({ target: initialChecked });
      } else if (initialSelected && initialSelected !== '') {
        updateSellingPlan({ target: variantSelect });
      }
    });
  </script>
{%- endif -%}
