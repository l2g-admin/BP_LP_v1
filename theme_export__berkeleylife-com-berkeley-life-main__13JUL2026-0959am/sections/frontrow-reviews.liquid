{% comment %}
  FrontRow Reviews Section
  Displays customer testimonials and reviews from FrontRow Health
{% endcomment %}

{% if section.settings.product_type == 'menopause' %}
  {% assign product_id = '3784' %}
{% elsif section.settings.product_type == 'nitric-oxide' %}
  {% assign product_id = '3783' %}
{% else %}
  {% assign product_id = '' %}
{% endif %}

{% if product_id != '' %}
  <section class="fr-testimonials" id="fr-testimonials">
    <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=qual&product_id={{ product_id }}"></script>
    <iframe id="frontrow-testimonials-{{ product_id }}" class="iframe-frontrow-testimonials" frameborder="0" src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=qual&product_id={{ product_id }}"></iframe>
    
    <style>
      iframe.iframe-frontrow-testimonials { 
        width: 100%; 
      } 
      iframe.iframe-modal-testimonials { 
        z-index: 99999998; 
      }
    </style>
  </section>
{% endif %}

{% schema %}
{
  "name": "FrontRow Reviews",
  "tag": "section",
  "class": "frontrow-reviews-section",
  "settings": [
    {
      "type": "select",
      "id": "product_type",
      "label": "Product Type",
      "options": [
        {
          "value": "menopause",
          "label": "Menopause & Heart Health Support"
        },
        {
          "value": "nitric-oxide",
          "label": "Nitric Oxide Support"
        }
      ],
      "default": "menopause",
      "info": "Select which FrontRow reviews widget to display"
    }
  ],
  "presets": [
    {
      "name": "FrontRow Reviews"
    }
  ]
}
{% endschema %}
