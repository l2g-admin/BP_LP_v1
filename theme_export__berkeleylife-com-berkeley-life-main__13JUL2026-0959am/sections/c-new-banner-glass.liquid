<style>
  /* =========================================
     DESKTOP STYLES (Base / Desktop First)
     ========================================= */
  #{{ section.id }} {
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    {% endif %}
    background-color: {{ section.settings.bg_color }};
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.min_height_desktop }}px;
    position: relative;
    overflow: hidden;

    & .c-hero-box__container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      justify-content: center;
      position: relative;
      z-index: 2;
    }

    & .c-hero-box__content {
      background: {{ section.settings.box_bg_color }};
      backdrop-filter: blur({{ section.settings.blur_amount }}px);
      -webkit-backdrop-filter: blur({{ section.settings.blur_amount }}px);
      padding: 80px 48px;
      border-radius: 32px;
      text-align: center;
      position: relative;
      max-width: 850px;
      width: 100%;
      box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    }

    & .c-hero-box__eyebrow {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: {{ section.settings.text_color }};
      margin-bottom: 1.5rem;
    }

    & .c-hero-box__title {
      font-size: clamp(32px, 4vw, 54px);
      font-weight: 500;
      color: {{ section.settings.text_color }};
      line-height: 1.15;
      margin: 0;

      & span {
        font-family: "Cormorant Garamond", serif;
        font-style: italic;
        font-weight: 400;
        color: {{ section.settings.title_span_color }};
      }
    }

    & .c-hero-box__description {
      margin-top: 1.5rem;
      font-size: 16px;
      font-weight: 400;
      color: {{ section.settings.text_color }};
      line-height: 1.6;
      opacity: 0.85;
    }

    & .c-hero-box__cta {
      margin-top: 2rem;
      display: flex;
      justify-content: center;
      width: 50%;
      margin-left: auto;
      margin-right: auto;
    }

    & .c-hero-box__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 1rem 2.5rem;
      background-color: {{ section.settings.button_bg_color }};
      color: {{ section.settings.button_text_color }};
      border-radius: 9999px;
      font-style: normal;
      font-weight: 600;
      line-height: normal;
      letter-spacing: 1.6px;
      text-transform: uppercase;
      transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;

      &:hover {
        transform: translateY(-2px);
        background-color: {{ section.settings.button_bg_color | color_darken: 10 }};
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
      }
    }

    & .c-hero-box__floating-img {
      position: absolute;
      bottom: -15%;
      right: -5%;
      width: 180px;
      height: auto;
      object-fit: contain;
      z-index: 3;
      pointer-events: none;
      filter: drop-shadow(0 10px 15px rgba(0,0,0,0.15));
    }
  }

  /* =========================================
     MOBILE STYLES (max 991px)
     ========================================= */
  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      min-height: auto;

      & .c-hero-box__content {
        padding: 3.5rem 1.5rem;
      }

      & .c-hero-box__eyebrow {
        margin-bottom: 1rem;
      }

      & .c-hero-box__title {
        font-size: 32px;
      }

      & .c-hero-box__description {
        font-size: 15px;
        margin-top: 1rem;
      }

      & .c-hero-box__cta  {
        width: 100%;
        margin-top: 1.5rem;
         & .c-hero-box__button {
          padding: 0.75rem 2rem;
          width: fit-content;
          font-size: 11px;
        }
      }

      & .c-hero-box__floating-img {
        width: 100px;
        bottom: -10%;
        right: -5%;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="c-hero-box__container">
    <div class="c-hero-box__content">
      
      {% if section.settings.eyebrow != blank %}
        <span class="c-hero-box__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 class="c-hero-box__title">{{ section.settings.title | newline_to_br }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="c-hero-box__description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <div class="c-hero-box__cta">
          <a href="{{ section.settings.button_link }}" class="c-hero-box__button">
            {{ section.settings.button_text }}
          </a>
        </div>
      {% endif %}

      {% if section.settings.floating_image != blank %}
        <img src="{{ section.settings.floating_image | image_url: width: 400 }}" 
             alt="Floating Element" 
             class="c-hero-box__floating-img" 
             loading="lazy">
      {% endif %}
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C New Banner Glass",
  "settings": [
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Content Box"
    },
    {
      "type": "color_background",
      "id": "box_bg_color",
      "label": "Box Background Color (Use RGBA for transparency)",
      "default": "rgba(252, 246, 248, 0.85)"
    },
    {
      "type": "range",
      "id": "blur_amount",
      "min": 0, "max": 20, "step": 1, "default": 8, "unit": "px",
      "label": "Glass Blur Effect"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1f4c"
    },
    {
      "type": "color",
      "id": "title_span_color",
      "label": "Title Span Color",
      "default": "#1a1f4c"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "2026 CLINICAL REPORT"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "The 2026 State of Menopause\n& Heart Health"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#1a1f4c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Floating Element"
    },
    {
      "type": "image_picker",
      "id": "floating_image",
      "label": "Floating Image (Bottom Right)",
      "info": "Upload a PNG with transparent background (e.g., the capsules)."
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 200, "max": 900, "step": 10, "default": 450, "unit": "px",
      "label": "Min Height"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0, "max": 150, "step": 5, "default": 80, "unit": "px", "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 150, "step": 5, "default": 80, "unit": "px", "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 100, "step": 5, "default": 40, "unit": "px", "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 100, "step": 5, "default": 40, "unit": "px", "label": "Bottom Padding"
    }
  ],
  "presets": [
    {
      "name": "C New Banner Glass"
    }
  ]
}
{% endschema %}