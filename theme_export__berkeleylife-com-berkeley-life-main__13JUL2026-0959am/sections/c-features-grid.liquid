    },
    {
      "type": "text",
      "id": "sound_text_class",
      "label": "Sound Text CSS Class",
      "info": "Optional custom CSS class for sound text styling"
    },
    {
      "type": "header",
      "content": "Media (Center Column)"
    },
    {
      "type": "select",
      "id": "media_type",
