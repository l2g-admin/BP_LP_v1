  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo Card",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "card_background_image",
          "label": "Card Background Image"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<h2>Relief for every stage of Menopause</h2>"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Targeted daily support for energy, mood & heart health."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Women's Health"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_background_color",
          "label": "Button Background Color",
          "default": "#6B3A5B"
        },
        {
          "type": "text",
          "id": "trusted_text",
          "label": "Trusted By Text",
          "default": "Trusted by 3,000+ healthcare providers"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating Text",
          "default": "4.8 | BASED ON 221 TRUSTED REVIEWS"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image Inside Card"
        },
        {
          "type": "url",
          "id": "product_image_link",
          "label": "Product Image Link"
        }
      ]
    },
    {
      "type": "footer_banner_item",
      "name": "Footer Banner Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "SVG Icon Code"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Item Text",
          "default": "CLINICALLY BACKED"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Dual Promo Section",
      "blocks": [
        {
          "type": "promo_card"
        },
        {
          "type": "promo_card"
        },
        {
          "type": "footer_banner_item",
          "settings": {
            "text": "CLINICALLY BACKED"
          }
        },
        {
          "type": "footer_banner_item",
          "settings": {
            "text": "15% SUBSCRIBE & SAVE"
          }
        },
        {
          "type": "footer_banner_item",
          "settings": {
            "text": "MONEY BACK GUARANTEE"
          }
        }
      ]
    }
  ]
}
{% endschema %}