<div class="dual-promo-section" style="background-color: {{ section.settings.section_background_color }};">
  <div class="promo-cards-container">
    {% for block in section.blocks %}
      {% if block.type == 'promo_card' %}
        <div class="promo-card" style="background-image: url('{{ block.settings.card_background_image | img_url: 'master' }}');">
          <div class="promo-card-content">
            <div class="promo-title">{{ block.settings.title }}</div>
            <p class="promo-subtitle">{{ block.settings.subtitle }}</p>
            <a href="{{ block.settings.button_link }}" class="promo-button" style="background-color: {{ block.settings.button_background_color }};">
              {{ block.settings.button_text }} <span class="arrow">→</span>
            </a>

            <div class="trusted-by">
              <p class="trusted-text">{{ block.settings.trusted_text }}</p>
              <div class="rating">
                <span class="stars">★★★★★</span> <span class="rating-text">{{ block.settings.rating }}</span>
              </div>
            </div>

            <a href="{{ block.settings.product_image_link }}" class="product-image-link">
              <div class="product-image-container">
                <img src="{{ block.settings.product_image | img_url: 'medium' }}" alt="Product" class="product-image">
                <div class="blur-overlay"></div>
              </div>
            </a>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="footer-banner">
    <div class="footer-banner-content">
      {% for block in section.blocks %}
        {% if block.type == 'footer_banner_item' %}
          <div class="footer-item">
            <div class="footer-icon">{{ block.settings.icon_svg }}</div>
            <span class="footer-text">{{ block.settings.text }}</span>
          </div>
          {% unless forloop.last %}
            <div class="divider"></div>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .dual-promo-section {
    {% if section.settings.only_desktop %}
      display: block;
      @media(width <= 969px) {
        display: none;
      }
    {% else %}
      display: block;
    {% endif %}
    padding: 8px 64px 80px 64px;
    /* max-width: 1280px;
    margin-left: auto;
    margin-right: auto; */
  }

  .promo-cards-container {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .promo-card {
    flex: 1 0 0;
    /* height: 900px; */
    background-size: cover;
    background-position: center;
    border-radius: 32px;
    display: flex;
    flex-direction: column;
    /* justify-content: flex-end; */
    align-items: flex-start;
    padding: 64px;
    position: relative;
    color: white;
    overflow: hidden;
  }

  .promo-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.1) 100%);
    border-radius: 20px;
  }

  .promo-card-content {
    position: relative;
    z-index: 1;
    /* max-width: 80%; */
  }

  .promo-title {
    color: var(--Neutro-White, #FFF);

    /* TT Commons Pro/H1 */
    /* font-family: "TT Commons Pro"; */
    font-size: var(--Text-Sizes-Heading-TT-1, 52px);
    font-style: normal;
    font-weight: 400;
    max-width: 640px;
    line-height: 110%; /* 70.4px */
    margin-bottom: 16px;
  }

  .promo-title h2 em{
    color: var(--Neutro-White, #FFF);
    /* Cormorant/H1 */
    font-family: "Cormorant Garamond";
    font-size: var(--Text-Sizes-Heading-C1, 58px);
    font-style: italic;
    font-weight: 400;
    line-height: 100%;
  }

  .promo-subtitle {
    color: var(--Neutro-White, #FFF);

    /* Body Medium/x-lg */
    /* font-family: "TT Commons Pro"; */
    font-size: var(--Text-Sizes-Text-x-Large, 18px);
    font-style: normal;
    font-weight: 400;
    line-height: 140%; /* 33.6px */
    margin-bottom: 32px;

  }

  .promo-button {
    display: inline-flex;
    align-items: center;
    height: 60px;
    padding: 0 40px;
    border-radius: 42px;
    text-decoration: none;
    border: 2px solid transparent;
    color: #F6F3F0;
    /* button */
    /* font-family: "TT Commons Pro"; */
    font-size: var(--Text-Sizes-Text-Medium, 18px);
    font-style: normal;
    font-weight: 600;
    line-height: 150%; /* 27px */
  }

  .promo-button:hover {
    opacity: 0.9;
  }

  .promo-button .arrow {
    margin-left: 10px;
  }

  .trusted-by {
    display: flex;
    padding: 24px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 10px;
    margin-top: 30px;
    margin-bottom: 30px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    max-width: 470px;
    /* BG Blur */
    backdrop-filter: blur(15px);
  }

  .trusted-text {
    color: var(--Neutro-White, #FFF);
    /* Body/md */
    /* font-family: "TT Commons Pro"; */
    font-size: var(--Text-Sizes-Text-Medium, 18px);
    font-style: normal;
    font-weight: 400;
    line-height: 150%; /* 27px */
    /* margin-bottom: 5px; */
  }

  .rating {
    display: flex;
    align-items: center;
  }

  .stars {
    color: #D54F2F;
    margin-right: 10px;
    font-size: 1.1rem;
  }

  .rating-text {
    color: var(--Neutro-White, #FFF);
    /* TT Commons Pro/Tagline */
    /* font-family: "TT Commons Pro"; */
    font-size: var(--Text-Sizes-Text-Regular, 16px);
    font-style: normal;
    font-weight: 700;
    line-height: 120%; /* 19.2px */
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  .product-image-link {
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .product-image-link:hover {
    transform: scale(1.02);
  }

  .product-image-container {
    width: 320px;
    height: 200px;
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .product-image {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  /* Footer Banner Styles */
  .footer-banner {
    display: flex;
    padding: 48px 0;
    justify-content: center;
    align-items: center;
    gap: 80px;
    align-self: stretch;
    border-radius: var(--radius-md, 24px);
    background: var(--Text-Navy, #1B1C29);
  }

  .footer-banner-content {
    display: flex;
    gap: 80px;
    /* justify-content: space-between; */
    align-items: center;
    color: white;
  }

  .footer-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer-icon svg {
    width: 24px;
    height: 24px;
    fill: white;
  }

  .footer-text {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .divider {
    display: block !important;
    width: 2px;
    height: 24px;
    background: rgba(255, 255, 255, 0.20);
  }

  @media (max-width: 768px) {
    .promo-cards-container {
      flex-direction: column;
    }
    .promo-card {
      min-width: 100%;
    }
    .footer-banner-content {
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }
    .divider {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "C Dual Promo Section",
  "settings": [
    {
      "type":"checkbox",
      "id": "only_desktop",
      "label": "Only Desktop?",
      "default": true
