  
  {%- capture content -%}
  {%- for block in section.blocks -%}
    <span class="{% cycle 'text-brand', 'text-aqua', 'text-navy md:text-[94px] font-secondaryHeader', 'text-berkley_red', 'text-navy' %}">
    {{- block.settings.title  -}}
    </span>
  {%- endfor -%}
  {%- endcapture -%}
  
  <div class="py-4 overflow-hidden border-t motion-reduce:overflow-auto bg-bg border-brown text-text" style="--color-text: {{ section.settings.text_color | default: '#ffffff' }}; --color-bg: {{ section.settings.bg_color | default: '#000000' }}">
    <h2 class="{% if section.settings.show_title %}h5 text-center mb-4{% else %}sr-only{% endif %}">{{ section.settings.title | default: 'Marquee' }}</h2>
    <div class="flex uppercase select-none h2 ticker odd-ticker">
      {%- for i in (1..3) -%}
        <div class="table w-max shrink-0 h2 transform-gpu" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
          {{- content -}}
          {{- separator -}}
        </div>
      {%- endfor -%}
    </div>
  </div>
  
  {% schema %}
  {
    "name": "Marquee",
    "tag": "section",
    "max_blocks": 20,
    "settings": [
    ],
    "blocks": [
      {
        "type": "phrase",
        "name": "Phrase",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Marquee",
        "blocks": [
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Lorem"
            }
          },
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Ipsum"
            }
          },
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Dolor"
            }
          }
        ]
      }
    ]
  }
  {% endschema %}
  