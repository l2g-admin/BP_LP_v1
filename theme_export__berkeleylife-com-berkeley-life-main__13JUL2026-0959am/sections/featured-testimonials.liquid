{%-liquid
  assign show = true
  assign now = 'now' | date: '%s' | times: 1
  assign start_date = section.settings.start_date | default: 'now' | date: '%s' | times: 1
  assign end_date = section.settings.end_date | date: '%s' | times: 1
  if start_date > now
    assign show = false
  endif
  if end_date > 0 and end_date < now
    assign show = false
  endif
-%}
{%- if show -%}
<div
  class="relative w-full overflow-hidden"
  data-id="{{ section.id }}"
  style="--color-text: {{ section.settings.text_color | default: '#ffffff' }}; --color-bg: {{ section.settings.bg_color | default: '#090909' }}">

  {%- if section.settings.bg_image != blank -%}
    <div class="absolute inset-0">
      {%- render 'image',
        image: section.settings.bg_image,
        fit: 'object-cover',
        eager: section.settings.eager,
        classes: 'w-full h-full',
        img_size: '100vw',
        decorative: true
      -%}
    </div>
  {%- else -%}
    <div class="absolute inset-0 bg-navy"></div>
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    <div
      class="absolute inset-0"
      style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  {%- endif -%}

  <div class="relative max-w-screen-lg mx-auto px-6 md:px-16 {{ section.settings.mobile_spacing_top | prepend: 'pt-' }} {{ section.settings.mobile_spacing_bottom | prepend: 'pb-' }} {{ section.settings.spacing_top | prepend: 'md:pt-' }} {{ section.settings.spacing_bottom | prepend: 'md:pb-' }}">

    {%- if section.settings.heading != blank -%}
      <div class="text-center mb-10 md:mb-14">
        <{{ section.settings.heading_level | default: 'h2' }} class="{{ section.settings.heading_style | default: 'h2' }} text-white mb-8">
            {{ section.settings.heading | replace_first: "**", "<br><span class='text-brand  text-[34px] md:text-[50px] font-secondaryHeader'>" | replace: "**", "</span>"  }}
        </{{ section.settings.heading_level | default: 'h2' }}>
      </div>
    {%- endif -%}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div
            class="flex flex-col relative rounded-2xl p-4 md:p-6 space-y-5"
            style="background-color: #ffffff17; backdrop-filter: blur(8px);"
            {{ block.shopify_attributes }}>

            <span class="block text-6xl leading-none  absolute quote-mark font-serif" style="color: {{ section.settings.quote_mark_color | default: '#9b8ec4' }};">&ldquo;</span>

            {%- if block.settings.quote != blank -%}
              <div class="prose prose-invert text-white text-base leading-relaxed">{{ block.settings.quote }}</div>
            {%- endif -%}

            <div class="pt-2">
              {%- if block.settings.name != blank -%}
                <p class="font-secondaryHeader italic text-white text-xl">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.age != blank -%}
                <p class="subhead text-white/70 mt-1 text-white">{{ block.settings.age }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Featured Testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Review Headline"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading Hierarchy",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "p", "label": "Paragraph" }
      ]
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "subhead", "label": "Small Caps" }
      ]
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "checkbox",
      "id": "eager",
      "label": "Eager load background image?",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "unit": "%",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "color",
      "id": "quote_mark_color",
      "label": "Quote Mark Color",
      "default": "#9b8ec4"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing Top (desktop)",
      "unit": "x",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Spacing Bottom (desktop)",
      "unit": "x",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_spacing_top",
      "label": "Spacing Top (mobile)",
      "unit": "x",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_spacing_bottom",
      "label": "Spacing Bottom (mobile)",
      "unit": "x",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 12
    },
    {
      "type": "header",
      "content": "Scheduling",
      "info": "Enter a start date and/or end date to hide and show this section on a schedule."
    },
    {
      "type": "text",
      "id": "start_date",
      "label": "Start Date",
      "info": "Defaults to now"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date",
      "info": "Defaults to never",
      "placeholder": "2021-12-31 23:59 EST"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>Add your testimonial quote here.</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "name here"
        },
        {
          "type": "text",
          "id": "age",
          "label": "Age / Label",
          "default": "Age",
          "info": "Displayed in small caps below the name. Can be age, location, etc."
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card Background",
          "info": "Use a color with opacity via the hex field. Default is a dark semi-transparent purple-black."
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Featured Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
