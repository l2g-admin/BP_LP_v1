{%- comment -%}
  Section: C Featured Links
  Description: Renders a row of image cards with gradient overlays, tag labels, headings, and arrow CTAs linking to key pages.
  sl-id: sl-section-featured-links-v1
  Figma Desktop: https://www.figma.com/design/f1AWMl23NcBW13s8SML1B5/BKL?node-id=4138-17310&m=dev
  Figma Mobile: https://www.figma.com/design/f1AWMl23NcBW13s8SML1B5/BKL?node-id=4160-16555&m=dev
{%- endcomment -%}

{%- comment -%} ===== Styles ===== {%- endcomment -%}
{%- liquid
  assign text_color = settings.sl_c_featured_links_text | default: '#f6f3f0'
  assign gradient_color = settings.sl_c_featured_links_gradient_color | default: '#1b1c29'
  assign radius_mobile = settings.sl_c_featured_links_radius_mobile | default: 20
  assign radius_desktop = settings.sl_c_featured_links_radius_desktop | default: 40
-%}

{% style %}
  #shopify-section-{{ section.id }} .c-featured-links {
    --_text: {{ text_color }};
    --_gradient: {{ gradient_color }};
    --_radius: {{ radius_mobile }}px;
  }

  #shopify-section-{{ section.id }} .c-featured-links__list {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 24px 20px;
  }

  #shopify-section-{{ section.id }} .c-featured-links__list::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .c-featured-links__card {
    position: relative;
    flex: 1 0 0;
    min-width: 260px;
    height: 272px;
    border-radius: var(--_radius);
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  #shopify-section-{{ section.id }} .c-featured-links__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--_radius);
  }

  #shopify-section-{{ section.id }} .c-featured-links__image--desktop {
    display: block;
  }

  #shopify-section-{{ section.id }} .c-featured-links__image--mobile {
    display: block;
  }

  #shopify-section-{{ section.id }} .c-featured-links__image--mobile ~ .c-featured-links__image--desktop {
    display: none;
  }

  #shopify-section-{{ section.id }} .c-featured-links__gradient {
    position: absolute;
    inset: 0;
    border-radius: var(--_radius);
    background: linear-gradient(
      to bottom,
      rgba({{ gradient_color | color_extract: 'red' }}, {{ gradient_color | color_extract: 'green' }}, {{ gradient_color | color_extract: 'blue' }}, 0) 27%,
      rgba({{ gradient_color | color_extract: 'red' }}, {{ gradient_color | color_extract: 'green' }}, {{ gradient_color | color_extract: 'blue' }}, 0.78) 98%
    );
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .c-featured-links__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .c-featured-links__tag {
    font-size: 14px;
    line-height: 20px;
    text-transform: uppercase;
    color: var(--_text);
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .c-featured-links__heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .c-featured-links__heading {
    font-size: 20px;
    line-height: 1.2;
    color: var(--_text);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .c-featured-links__arrow {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .c-featured-links__arrow svg {
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .c-featured-links__card:hover .c-featured-links__arrow {
    transform: scale(1.1);
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .c-featured-links {
      --_radius: {{ radius_desktop }}px;
      padding: 0 48px;
    }

    #shopify-section-{{ section.id }} .c-featured-links__list {
      gap: 32px;
      max-width: 1280px;
      margin: 0 auto;
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .c-featured-links__card {
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .c-featured-links__image--mobile {
      display: none;
    }

    #shopify-section-{{ section.id }} .c-featured-links__image--mobile ~ .c-featured-links__image--desktop {
      display: block;
    }

    #shopify-section-{{ section.id }} .c-featured-links__content {
      padding: 32px;
      gap: 15.5px;
    }

    #shopify-section-{{ section.id }} .c-featured-links__heading {
      font-size: 30px;
      line-height: 36px;
      letter-spacing: -0.84px;
    }

    #shopify-section-{{ section.id }} .c-featured-links__arrow {
      width: 48px;
      height: 48px;
    }
  }
{% endstyle %}

{%- comment -%} ===== HTML ===== {%- endcomment -%}
<section
  {% if section.settings.sl_anchor_id != blank %}id="{{ section.settings.sl_anchor_id }}"{% endif %}
  class="c-section c-featured-links"
  data-sl-id="sl-section-featured-links-v1"
  data-section-id="{{ section.id }}"
>
  {%- if section.blocks.size > 0 -%}
    <div class="c-featured-links__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_card' -%}
          <a
            class="c-featured-links__card"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.mobile_image != blank -%}
              {{
                block.settings.mobile_image
                | image_url: width: 600
                | image_tag:
                  class: 'c-featured-links__image c-featured-links__image--mobile',
                  loading: 'lazy',
                  widths: '400,600',
                  sizes: '80vw'
              }}
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  class: 'c-featured-links__image c-featured-links__image--desktop',
                  loading: 'lazy',
                  widths: '400,600,800',
                  sizes: '(min-width: 768px) 50vw, 80vw'
              }}
            {%- endif -%}

            <div class="c-featured-links__gradient" aria-hidden="true"></div>

            <div class="c-featured-links__content">
              {%- if block.settings.tag != blank -%}
                <span class="c-featured-links__tag">{{ block.settings.tag }}</span>
              {%- endif -%}

              <div class="c-featured-links__heading-row">
                {%- if block.settings.heading != blank -%}
                  <h3 class="c-featured-links__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}

                <span class="c-featured-links__arrow" aria-hidden="true">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="48" height="48" rx="24" fill="white"/>
                    <path d="M21.3872 18.6729C21.488 18.6729 21.565 18.7033 21.6431 18.7812L26.5874 23.7256C26.6413 23.7795 26.6665 23.8215 26.6782 23.8496V23.8506C26.693 23.8861 26.7017 23.9259 26.7017 23.9746C26.7017 24.0233 26.693 24.0631 26.6782 24.0986V24.0996C26.6665 24.1277 26.6413 24.1697 26.5874 24.2236L21.6187 29.1924C21.5409 29.2702 21.4737 29.292 21.3931 29.2891C21.299 29.2856 21.2182 29.2537 21.1323 29.168C21.0542 29.0898 21.023 29.013 21.0229 28.9121C21.0229 28.8112 21.0542 28.7344 21.1323 28.6562L25.814 23.9746L21.1069 19.2676C21.0293 19.1899 21.0073 19.1236 21.0103 19.043C21.0137 18.9487 21.0463 18.8673 21.1323 18.7812C21.2102 18.7034 21.2866 18.6729 21.3872 18.6729Z" fill="#1B1C29" stroke="#1B1C29"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{%- comment -%} ===== Schema ===== {%- endcomment -%}
{% schema %}
{
  "name": "C Featured Links",
  "tag": "section",
  "class": "c-featured-links-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "Anchor ID",
      "info": "Optional anchor link ID for this section"
    }
  ],
  "blocks": [
    {
      "type": "link_card",
      "name": "Link Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Background Image (Mobile)",
          "info": "Optional. If empty, the desktop image is used on all screens."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag Label",
          "default": "OUR STORY"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Meet Berkeley Life"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Featured Links",
      "blocks": [
        {
          "type": "link_card",
          "settings": {
            "tag": "OUR STORY",
            "heading": "Meet Berkeley Life"
          }
        },
        {
          "type": "link_card",
          "settings": {
            "tag": "SCIENCE",
            "heading": "What Is Nitric Oxide (NO)?"
          }
        }
      ]
    }
  ]
}
{% endschema %}
