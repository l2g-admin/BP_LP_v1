{%- comment -%}
  C Product Featured Section
  - Two column layout (image left, product info right)
  - Product selection via schema
  - Override title/description with section settings
  - Subscription widget & Add to Cart functionality from main-product
{%- endcomment -%}

{%- liquid
  assign section_id = section.settings.custom_id | default: section.id
  
  assign selected_product = section.settings.product
  if selected_product == blank
    assign selected_product = collections.all.products.first
  endif

  assign display_title = section.settings.custom_title | default: selected_product.title
  assign display_description = section.settings.custom_description | default: selected_product.description

  assign product_form_id = 'product-form-' | append: section_id
-%}

<style>
  #{{ section_id }} {
    {%- assign half_padding_top = section.settings.padding_top | divided_by: 2.0 -%}
    {%- assign half_padding_bottom = section.settings.padding_bottom | divided_by: 2.0 -%}
    padding-top: {{ half_padding_top }}em;
    padding-bottom: {{ half_padding_bottom }}em;
    background-color: {{ section.settings.bg_color }};

    & h1, & h2, & h3, & h4, & h5, & h6,
    & p, & span, & li, & label, & legend  {
      color: {{ section.settings.text_color }};
    }

    & .oke-sr-count * {
      color: {{ section.settings.accent_color }} !important;
    }

    & .section__product__container {
      padding-block: 2rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    & .product__content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      align-items: flex-start;
    }

    & .product__image__container {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      justify-content: center;

      & img {
        width: 100%;
        height: auto;
        object-fit: contain;
        border-radius: 16px;
      }
    }

    & .product__secondary-images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;

      & img {
        width: 100%;
        height: auto;
        object-fit: cover;
        border-radius: 12px;
      }
    }

    & .product__info {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      width: 100%;
    }

    & .product__header {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    & .product__subtitle {
      font-size: clamp(12px, 2vw, 14px);
      text-transform: uppercase;
      margin: 0;
      letter-spacing: 1px;
    }

    & .product__title {
      font-size: clamp(28px, 5vw + 1rem, 42px);
      line-height: 1.2;
      margin: 0;
    }

    & .product__title--accent {
      color: {{ section.settings.accent_color }};
      font-family: "Cormorant Garamond";
      font-style: italic;
      font-weight: 400;
    }

    & .product__description {
      font-size: clamp(14px, 2.5vw, 16px);
      margin: 0;
      line-height: 1.6;
      opacity: 0.9;
    }

    & .product__benefits {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    & .product__benefit {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    & .product__benefit-dot {
      width: 11px;
      height: 11px;
      flex-shrink: 0;

      & svg {
        width: 11px;
        height: 11px;
      }
    }

    & .product__benefit-text {
      font-family: "Cormorant Garamond", serif;
      font-style: italic;
      font-size: clamp(16px, 3vw, 20px);
      line-height: 1.4;
      color: {{ section.settings.text_color }};
    }

    & .product__price {
      font-size: clamp(20px, 3vw, 28px);
      font-weight: 600;
      color: {{ section.settings.accent_color }};
      margin: 0;
    }

    & .product__price--compare {
      font-size: clamp(14px, 2vw, 18px);
      text-decoration: line-through;
      opacity: 0.5;
      margin-left: 0.5rem;
    }

    /* Variant/Subscription Picker Styles */
    & .variant-picker-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    & .variant-picker-container fieldset {
      border: none;
      padding: 0;
      margin: 0;
    }

    & .variant-picker-container legend {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    & .option-container {
      transition: background 0.2s, border-color 0.2s;
      position: relative;
      overflow: visible;
      background-color: {{ section.settings.option_bg_color }} !important;
      border-color: {{ section.settings.option_border_color }} !important;
    }

    & .option-container.selected {
      border-color: {{ section.settings.accent_color }} !important;
      background-color: white !important;
    }

    & .option-container__badge {
      position: absolute;
      top: -12px;
      right: 12px;
      padding: 4px 16px;
      font-weight: 500;
      background-color: {{ section.settings.accent_color }};
      color: white !important;
      border-radius: 8px;
      font-size: 11px;
      letter-spacing: 0.1em;
      line-height: 19px;
      z-index: 10;
      text-transform: capitalize;
    }

    & .subscription-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    & .subscription-list li {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 14px;
      margin-bottom: 4px;
    }

    & .subscription-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 0.5rem;
    }

    & .subscription-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border: 1px solid rgba(0, 0, 0, 0.15);
      border-radius: 4px;
      font-size: 12px;
      background: transparent;
      line-height: 1.3;
    }

    & .subscription-badge svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      opacity: 0.7;
    }

    /* Buy Button Styles */
    & .product__buy-button {
      display: inline-block;
      padding: 1rem 2rem;
      background-color: {{ section.settings.accent_color }};
      border-radius: 9999px;
      color: #ffffff !important;
      width: 100%;
      font-size: clamp(14px, 2vw, 16px);
      text-decoration: none;
      text-transform: capitalize;
      letter-spacing: 1px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: 2px solid {{ section.settings.accent_color }};
      cursor: pointer;
      text-align: center;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
      }

      &:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
      }
    }

    & .product__buy-button.loading {
      opacity: 0.7;
      pointer-events: none;
    }

    & .product-form__truemed {
      margin-top: 1rem;
    }

    & .product-form__trust-badge {
      margin-top: 1rem;
      display: flex;
      justify-content: center;
    }

    & .trust-badge__image {
      max-width: 100%;
      height: auto;
    }
  }

  @media (min-width: 1024px) {
    #{{ section_id }} {
      padding-top: {{ section.settings.padding_top }}em;
      padding-bottom: {{ section.settings.padding_bottom }}em;

      .section__product__container {
        & .product__content {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 4rem;
          align-items: center;
        }

        & .product__image__container {
          order: -1;
        }
      }
    }
  }

  /* Radio button styles for this section */
  #{{ section_id }} [type='checkbox'],
  #{{ section_id }} [type='radio'] {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    padding: 0;
    display: inline-block;
    vertical-align: middle;
    background-origin: border-box;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    flex-shrink: 0;
    height: 18px;
    width: 18px;
    color: #F3F3F3 !important;
    background-color: #F3F3F3 !important;
    border: none !important;
    --tw-shadow: 0 0 #0000;
    border-radius: 50%;
  }

  #{{ section_id }} [type='radio']:checked {
    background-color: #D9D9D9 !important;
    background-image: url("data:image/svg+xml,%3csvg viewBox='0 0 16 16' fill='black' xmlns='http://www.w3.org/2000/svg'%3e%3ccircle cx='8' cy='8' r='6'/%3e%3c/svg%3e") !important;
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
  }

  #{{ section_id }} [type=radio]:focus {
    --tw-ring-color: none !important;
  }
</style>

<section id="{{ section_id }}">
  <div class="section__product__container container-sl">
    <div class="product__content">
      {%- comment -%} Product Image - Left Side {%- endcomment -%}
      <div class="product__image__container">
        {%- if selected_product.featured_image != blank -%}
          {{
            selected_product.featured_image
            | image_url: width: 800
            | image_tag: alt: selected_product.featured_image.alt
            | default: selected_product.title, class: 'product__image', loading: 'lazy', width: 800, height: 'auto'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'product__image placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.show_secondary_images -%}
          <div class="product__secondary-images">
            {%- if section.settings.secondary_image_1 != blank -%}
              {{ section.settings.secondary_image_1 | image_url: width: 600 | image_tag: alt: section.settings.secondary_image_1.alt, loading: 'lazy' }}
            {%- endif -%}
            {%- if section.settings.secondary_image_2 != blank -%}
              {{ section.settings.secondary_image_2 | image_url: width: 600 | image_tag: alt: section.settings.secondary_image_2.alt, loading: 'lazy' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Product Info - Right Side {%- endcomment -%}
      <div class="product__info">
        <div class="product__header">
          {%- if section.settings.subtitle != blank -%}
            <p class="product__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}

          <h2 class="product__title">
            {%- if section.settings.use_accent_title -%}
              {% assign title_with_accent = display_title
                | replace: '{accent}', '<span class="product__title--accent">'
                | replace: '{/accent}', '</span>'
              %}
              {{ title_with_accent }}
            {%- else -%}
              {{ display_title }}
            {%- endif -%}
          </h2>

          {%- for block in section.blocks -%}
            {%- if block.type == 'okendo_reviews' -%}
              <div {{ block.shopify_attributes }}>
                <a href="{{ block.settings.reviews_link | default: '#' }}" class="okendo-reviews-link">
                  {% render 'okendo-reviews-product-rating-summary', product: selected_product %}
                </a>
                {%- if block.settings.show_divider -%}
                  <hr style="border: none; border-top: 1px solid {{ section.settings.accent_color }}; margin: 0.5rem 0 0;">
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- if display_description != blank -%}
            <div class="product__description">{{ display_description }}</div>
          {%- endif -%}

          {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
          {%- if benefit_blocks.size > 0 -%}
            <div class="product__benefits">
              {%- for block in benefit_blocks -%}
                <div class="product__benefit" {{ block.shopify_attributes }}>
                  <span class="product__benefit-dot"><svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none"><circle cx="5.5" cy="5.5" r="5.5" fill="{{ section.settings.accent_color }}"/><path d="M6.07246 7.45458H5.12517V6.12681H3.88281V5.21058H5.12517V3.88281H6.07246V5.21058H7.31481V6.12681H6.07246V7.45458Z" fill="{{ section.settings.bg_color }}"/></svg></span>
                  <span class="product__benefit-text">{{ block.settings.text }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
        {%- comment -%} Variant & Subscription Picker {%- endcomment -%}
        {%- unless selected_product.has_only_default_variant -%}
          <div class="variant-picker-container">
            <variant-radios
              class="no-js-hidden"
              data-section="{{ section_id }}"
              data-url="{{ selected_product.url }}"
              data-update-url="false"
            >
              {%- comment -%} Check if product has selling plans (subscriptions) {%- endcomment -%}
              {%- if selected_product.selling_plan_groups.size > 0 -%}
                <fieldset class="space-y-3 text-sm">
                  <legend class="block mb-2 text-xl font-semibold">
                    <span>Purchase Options:</span>
                  </legend>

                  <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    {%- for variant in selected_product.variants -%}
                      {%- comment -%} Skip B2B only variants for non-B2B customers {%- endcomment -%}
                      {%- if variant.metafields.custom.b2bonly.value == true and customer.b2b? == false -%}
                        {%- continue -%}
                      {%- endif -%}

                      {%- if variant.selling_plan_allocations.size > 0 -%}
                        {%- comment -%} Subscription Options {%- endcomment -%}
                        {%- for allocation in variant.selling_plan_allocations -%}
                          {%- assign subscription_price = allocation.price_adjustments.first.price -%}
                          {%- assign one_time_price = variant.price -%}
                          {%- assign savings_amount = one_time_price | minus: subscription_price -%}
                          {%- assign savings_percentage = savings_amount | times: 100 | divided_by: one_time_price -%}

                          <label
                            class="relative option-container inline-flex flex-grow items-center border border-transparent rounded-lg p-4 cursor-pointer w-full"
                            for="{{ section_id }}-variant-{{ variant.id }}-plan-{{ allocation.selling_plan.id }}"
                          >
                            {%- if variant.metafields.custom.is_most_popular_subscription == true -%}
                              <div class="option-container__badge">
                                MOST POPULAR
                              </div>
                            {%- endif -%}
                            <input
                              type="radio"
                              id="{{ section_id }}-variant-{{ variant.id }}-plan-{{ allocation.selling_plan.id }}"
                              name="variant_selling_plan"
                              value="{{ variant.id }}-{{ allocation.selling_plan.id }}"
                              form="{{ product_form_id }}"
                              class="mr-4"
                              {% if selected_product.selected_or_first_available_variant.id == variant.id
                                and selected_product.selected_selling_plan.id == allocation.selling_plan.id
                              %}
                                checked
                              {% endif %}
                            >
                            <div class="flex flex-col">
                              <h3 class="text-lg">{{ variant.title }} Supply Subscription</h3>
                              {%- if section.settings.use_badge_tags -%}
                                <div class="subscription-badges">
                                  <span class="subscription-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                      <path d="M12.9375 3.9375C13.2482 3.9375 13.5 4.18934 13.5 4.5V5.0625H15.9316C16.1557 5.06249 16.3748 5.1297 16.5605 5.25488C16.7463 5.38015 16.8906 5.55791 16.9746 5.76562L17.96 8.22852C17.9659 8.24339 17.9681 8.25937 17.9727 8.27441C17.9782 8.2925 17.9846 8.31029 17.9883 8.3291C17.993 8.35319 17.9945 8.37728 17.9961 8.40137C17.9969 8.41337 18 8.4253 18 8.4375V12.9375C18 13.2359 17.8819 13.5224 17.6709 13.7334C17.4599 13.9444 17.1734 14.0625 16.875 14.0625H15.6758C15.4257 15.0325 14.5481 15.75 13.5 15.75C12.4519 15.75 11.5743 15.0325 11.3242 14.0625H7.80078C7.55073 15.0325 6.67312 15.75 5.625 15.75C4.57688 15.75 3.69927 15.0325 3.44922 14.0625H2.25C1.95163 14.0625 1.66508 13.9444 1.4541 13.7334C1.24312 13.5224 1.125 13.2359 1.125 12.9375V5.0625C1.125 4.76413 1.24312 4.47758 1.4541 4.2666C1.66508 4.05562 1.95163 3.9375 2.25 3.9375H12.9375ZM5.625 12.375C5.00368 12.375 4.5 12.8787 4.5 13.5C4.5 14.1213 5.00368 14.625 5.625 14.625C6.24632 14.625 6.75 14.1213 6.75 13.5C6.75 12.8787 6.24632 12.375 5.625 12.375ZM13.5 12.375C12.8787 12.375 12.375 12.8787 12.375 13.5C12.375 14.1213 12.8787 14.625 13.5 14.625C14.1213 14.625 14.625 14.1213 14.625 13.5C14.625 12.8787 14.1213 12.375 13.5 12.375ZM2.25 10.6875V12.9375H3.44922C3.69927 11.9675 4.57688 11.25 5.625 11.25C6.67312 11.25 7.55073 11.9675 7.80078 12.9375H11.3242C11.4764 12.347 11.8599 11.851 12.375 11.5527V10.6875H2.25ZM13.5 11.25C14.5481 11.25 15.4257 11.9675 15.6758 12.9375H16.875V9H13.5V11.25ZM2.25 9.5625H12.375V5.0625H2.25V9.5625ZM13.5 7.875H16.6064L15.9316 6.1875H13.5V7.875Z" fill="currentColor"/>
                                    </svg>
                                    Free US Shipping
                                  </span>
                                  <span class="subscription-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                      <path d="M3.4043 2.25098C3.55188 2.25874 3.69107 2.32463 3.79102 2.43457L15.041 14.8096C15.1906 14.9743 15.2296 15.2115 15.1396 15.415C15.0496 15.6187 14.8476 15.75 14.625 15.75H3.375C3.07663 15.75 2.79008 15.6319 2.5791 15.4209C2.36812 15.2099 2.25 14.9234 2.25 14.625V3.375C2.25 3.07663 2.36812 2.79008 2.5791 2.5791C2.79008 2.36812 3.07663 2.25 3.375 2.25L3.4043 2.25098ZM3.375 6.75V14.625H13.3535L6.19434 6.75H3.375ZM12.375 1.125C12.6857 1.125 12.9375 1.37684 12.9375 1.6875V2.25H14.625C14.9234 2.25 15.2099 2.36812 15.4209 2.5791C15.6319 2.79008 15.75 3.07663 15.75 3.375V12.4619C15.7498 12.7724 15.498 13.0244 15.1875 13.0244C14.877 13.0244 14.6252 12.7724 14.625 12.4619V6.75H9.4834C9.1729 6.74981 8.9209 6.49804 8.9209 6.1875C8.9209 5.87696 9.1729 5.62519 9.4834 5.625H14.625V3.375H12.9375V3.9375C12.9375 4.24816 12.6857 4.5 12.375 4.5C12.0643 4.5 11.8125 4.24816 11.8125 3.9375V3.375H6.41602C6.10536 3.375 5.85352 3.12316 5.85352 2.8125C5.85352 2.50184 6.10536 2.25 6.41602 2.25H11.8125V1.6875C11.8125 1.37684 12.0643 1.125 12.375 1.125ZM3.375 5.625H5.17188L3.375 3.64844V5.625Z" fill="currentColor"/>
                                    </svg>
                                    Pause or cancel at any time
                                  </span>
                                </div>
                              {%- else -%}
                                <ul class="mt-1 text-sm subscription-list">
                                  <li>Save {{ savings_percentage | round: 1 }}%</li>
                                  {%- assign first_char = variant.title | slice: 0, 1 -%}
                                  {%- assign first_number = first_char | plus: 0 -%}
                                  <li>
                                    {{ variant.title }} supply delivered every&nbsp;
                                    {%- if first_number > 1 -%}
                                      {{ first_number }} months
                                    {%- else -%}
                                      1 month
                                    {%- endif -%}
                                  </li>
                                  {% for item in shop.metaobjects.subscription_callout.values %}
                                    <li>{{ item.callout_title }}</li>
                                  {% endfor %}
                                </ul>
                              {%- endif -%}
                            </div>
                            <div
                              class="flex flex-col self-start ml-auto mt-2"
                              
                            >
                              <span class="ml-auto font-semibold">{{ subscription_price | money }}</span>
                              <span class="ml-auto text-xs line-through opacity-50">{{ one_time_price | money }}</span>
                            </div>
                          </label>
                        {%- endfor -%}

                        {%- comment -%} One-time purchase option {%- endcomment -%}
                        {%- unless variant.metafields.custom.disable_one_time_purchase -%}
                          <label
                            class="option-container border w-full border-transparent rounded-lg p-4 cursor-pointer"
                            for="{{ section_id }}-variant-{{ variant.id }}-otp"
                          >
                            <div class="inline-flex items-center justify-between flex-grow w-full">
                              <input
                                type="radio"
                                id="{{ section_id }}-variant-{{ variant.id }}-otp"
                                name="variant_selling_plan"
                                value="{{ variant.id }}-otp"
                                form="{{ product_form_id }}"
                                class="mr-4"
                                {% if selected_product.selected_or_first_available_variant.id == variant.id
                                  and selected_product.selected_selling_plan == null
                                %}
                                  checked
                                {% endif %}
                              >
                              <div class="flex flex-col">
                                <h3 class="text-lg">One-time Purchase</h3>
                              </div>
                              <span class="ml-auto font-semibold" >
                                {{- variant.price | money -}}
                              </span>
                            </div>
                          </label>
                        {%- endunless -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- else -%}
                {%- comment -%} Regular variant picker (no subscriptions) {%- endcomment -%}
                {%- for option in selected_product.options_with_values -%}
                  <fieldset class="space-y-2 text-sm">
                    <legend class="block font-bold tracking-widest uppercase mb-2">
                      <span>{{ option.name }}</span>
                    </legend>
                    <div class="flex flex-wrap gap-2">
                      {%- for value in option.values -%}
                        {%- assign valid_variant = false -%}
                        {%- for variant in selected_product.variants -%}
                          {%- if variant.options contains value -%}
                            {%- if variant.metafields.custom.b2bonly.value != true -%}
                              {%- assign valid_variant = true -%}
                              {%- break -%}
                            {%- elsif customer.b2b? -%}
                              {%- assign valid_variant = true -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endif -%}
                        {%- endfor -%}

                        {%- if valid_variant -%}
                          <div class="inline-flex">
                            <input
                              class="sr-only peer"
                              type="radio"
                              id="{{ section_id }}-{{ option.name }}-{{ forloop.index0 }}"
                              name="{{ option.name }}"
                              value="{{ value | escape }}"
                              form="{{ product_form_id }}"
                              {% if option.selected_value == value %}
                                checked
                              {% endif %}
                            >
                            <label
                              class="px-4 py-2 text-sm font-bold tracking-wide uppercase bg-transparent border-2 border-gray-300 rounded-full cursor-pointer peer-checked:border-current peer-checked:bg-white"
                              for="{{ section_id }}-{{ option.name }}-{{ forloop.index0 }}"
                            >
                              {{ value }}
                            </label>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              {%- endif -%}
            </variant-radios>
          </div>
        {%- endunless -%}

        {%- comment -%} Add to Cart Form {%- endcomment -%}
        <product-form class="product-form">
          <div data-product-form-errors role="alert" hidden>
            <span data-product-form-error-msg></span>
          </div>

          {%- form 'product',
            selected_product,
            data-productid: selected_product.id,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              id="SelectedVariantId-{{ section_id }}"
              value="{{ selected_product.selected_or_first_available_variant.id }}"
            >

            {%- comment -%} Hidden selling plan input (populated by JS) {%- endcomment -%}
            <input
              type="hidden"
              name="selling_plan"
              id="SelectedSellingPlan-{{ section_id }}"
              value=""
            >

            <div class="product-form__buttons">
              <button
                type="submit"
                name="add"
                data-product-handle="{{ selected_product.handle }}"
                data-product-id="{{ selected_product.selected_or_first_available_variant.id }}"
                data-section-id="{{ section_id }}"
                data-disableFlyout="true"
                data-metadata="
                  [
                    {% for variant in selected_product.variants %}
                      {%- if variant.metafields.custom.b2bonly.value != true or customer.b2b? -%}
                      {
                        "id": {{ variant.id }},
                        "is_most_popular_subscription": "{{ variant.metafields.custom.is_most_popular_subscription | escape }}",
                        "disable_one_time_purchase": "{{ variant.metafields.custom.disable_one_time_purchase | escape }}"
                      }{% unless forloop.last %},{% endunless %}
                      {%- endif -%}
                    {% endfor %}
                  ]
                "
                {% unless selected_product.selected_or_first_available_variant.available %}
                  disabled
                {% endunless %}
                class="product-form__submit product__buy-button"
                id="AddToCart-{{ section_id }}"
              >
                {%- if selected_product.selected_or_first_available_variant.available -%}
                  {%- if selected_product.selected_selling_plan or selected_product.requires_selling_plan -%}
                    {{ 'products.product.subscribe' | t | default: 'Subscribe' }}
                  {%- else -%}
                    {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
                  {%- endif -%}
                {%- else -%}
                  {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
                {%- endif -%}
              </button>
            </div>

            {%- if section.settings.show_truemed -%}
              <div class="product-form__truemed">
                {% render 'truemed-widget' %}
              </div>
            {%- endif -%}

            {%- if section.settings.trust_badge != blank -%}
              <div class="product-form__trust-badge">
                {{
                  section.settings.trust_badge
                  | image_url: width: 600
                  | image_tag: alt: 'Trust Badge', loading: 'lazy', class: 'trust-badge__image'
                }}
              </div>
            {%- endif -%}
          {%- endform -%}
        </product-form>
      </div>
    </div>
  </div>
</section>

{%- comment -%} JavaScript for variant/selling plan selection {%- endcomment -%}
<script type="application/json" id="ProductVariantsJson-{{ section_id }}">
  {{ selected_product.variants | json }}
</script>

<script>
  (function () {
    // Store variants globally for this section
    const sectionId = '{{ section_id }}';
    window.productVariantsBySection = window.productVariantsBySection || {};

    try {
      const variantsJson = document.getElementById('ProductVariantsJson-' + sectionId);
      if (variantsJson) {
        window.productVariantsBySection[sectionId] = JSON.parse(variantsJson.textContent);
      }
    } catch (e) {
      console.error('Error parsing variants:', e);
    }
  })();

  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section_id }}';
    const container = document.getElementById(sectionId);
    if (!container) return;

    const variantRadios = container.querySelectorAll("input[name='variant_selling_plan']");
    const variantInput = container.querySelector('#SelectedVariantId-{{ section_id }}');
    const sellingPlanInput = container.querySelector('#SelectedSellingPlan-{{ section_id }}');
    const addToCartButton = container.querySelector('.product-form__submit');
    const priceDisplay = container.querySelector('[data-product-price]');
    const optionContainers = container.querySelectorAll('.option-container');

    // Get product variants from global store
    const productVariants = window.productVariantsBySection[sectionId] || [];

    function updateSelected() {
      optionContainers.forEach((option) => {
        const radio = option.querySelector('input[type="radio"]');
        if (radio && radio.checked) {
          option.classList.add('selected');
        } else {
          option.classList.remove('selected');
        }
      });
    }

    function updateSellingPlan(event) {
      if (!event.target.value) return;

      // Parse the value into variantId and sellingPlanId (same as main-product)
      const [variantId, sellingPlanId] = event.target.value.split('-');

      if (variantInput) {
        variantInput.value = variantId;
      }

      if (sellingPlanInput) {
        if (sellingPlanId === 'otp') {
          sellingPlanInput.value = '';
        } else {
          sellingPlanInput.value = sellingPlanId;
        }
      }

      // Find the selected variant
      const selectedVariant = productVariants.find((v) => v.id == variantId);

      if (selectedVariant) {
        setTimeout(() => {
          if (selectedVariant.available) {
            // Update button text based on selection
            if (sellingPlanId === 'otp') {
              addToCartButton.innerText = "{{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}";
            } else if (sellingPlanId) {
              addToCartButton.innerText = "{{ 'products.product.subscribe' | t | default: 'Subscribe' }}";
            } else {
              addToCartButton.innerText = "{{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}";
            }

            // Update the button's data attribute with the variant ID
            addToCartButton.dataset.productId = variantId;
            addToCartButton.disabled = false;
          } else {
            addToCartButton.innerText = "{{ 'products.product.sold_out' | t | default: 'Unavailable' }}";
            addToCartButton.disabled = true;
          }

          // Update price display
          if (priceDisplay) {
            const formattedPrice = Shopify.formatMoney
              ? Shopify.formatMoney(selectedVariant.price)
              : '$' + (selectedVariant.price / 100).toFixed(2);
            priceDisplay.textContent = formattedPrice;
          }
        }, 10);
      }

      updateSelected();
    }

    // Attach change event to variant radios
    variantRadios.forEach((radio) => {
      radio.addEventListener('change', updateSellingPlan);
    });

    // Select first radio if none selected and run initial update
    function initializeSelection() {
      const checkedRadio = container.querySelector('input[name="variant_selling_plan"]:checked');
      if (checkedRadio) {
        updateSellingPlan({ target: checkedRadio });
      } else {
        const firstRadio = container.querySelector('input[name="variant_selling_plan"]');
        if (firstRadio) {
          firstRadio.checked = true;
          updateSellingPlan({ target: firstRadio });
        }
      }
    }

    // Initialize
    initializeSelection();
    updateSelected();

    // Custom Add to Cart handler for this section
    const addToCartBtn = document.getElementById('AddToCart-{{ section_id }}');
    const productForm = container.querySelector('form[data-type="add-to-cart-form"]');

    if (addToCartBtn && productForm) {
      addToCartBtn.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        if (addToCartBtn.disabled || addToCartBtn.classList.contains('loading')) return;

        addToCartBtn.classList.add('loading');
        addToCartBtn.setAttribute('aria-disabled', 'true');

        const formData = new FormData(productForm);

        fetch(window.routes?.cart_add_url || '/cart/add.js', {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            Accept: 'application/json',
          },
          body: formData,
        })
          .then((response) => response.json())
          .then((response) => {
            if (response.status) {
              console.error('Error adding to cart:', response.description);
              return;
            }

            // Open the cart drawer
            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer) {
              cartDrawer.render();
              cartDrawer.open();
            }
          })
          .catch((error) => console.error('Add to cart failed:', error))
          .finally(() => {
            addToCartBtn.classList.remove('loading');
            addToCartBtn.removeAttribute('aria-disabled');
          });
      });
    }
  });
</script>

