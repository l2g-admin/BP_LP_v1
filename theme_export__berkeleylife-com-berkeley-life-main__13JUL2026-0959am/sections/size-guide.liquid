{%- comment -%}This section is a grid of collections{%- endcomment -%}

{%- liquid
  assign show = true
  if product
    assign show = false
    assign block_settings = section.blocks | map: 'settings'
    assign block_products = block_settings | map: 'product'
    if block_products contains product.handle
      assign show = true
    endif
  endif
-%}

{%- if show -%}

<div id="{% if product %}SizeGuide{% else %}SizeGuide--{{ section.id }}{% endif %}" class="md:px-8 md:py-8 px-4 py-4">
  <div class="scroll-m-40 max-w-screen-xl mx-auto" id="{{ section.settings.title | escape | handleize }}">
    {%- unless section.settings.title == blank -%}
      <h2 class="h3 mb-4">{{ section.settings.title }}</h2>
    {%- endunless -%}
    <div class="md:grid-cols-2 gap-x-8 gap-y-4 md:border-b grid items-center grid-cols-1 py-8 border-t border-b-0 border-gray-200 border-solid">
      {%- unless section.settings.image == blank -%}
        <div>
          {% render 'image', image: section.settings.image, classes: 'object-contain mx-auto' %}
        </div>
      {%- endunless -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="md:border-t-0 md:border-l md:pl-8 md:pt-0 md:border-gray-200 flex flex-col justify-center min-h-full gap-4 pt-4 border-t border-transparent border-solid"
        role="list"
        >
        {%- for block in section.blocks -%}
          {%- unless block.settings.product == blank -%}
            <li>
              <details class="group" open>
                <summary class="py-2 border-b border-gray-200 border-solid">
                  <span class="flex items-center justify-between">
                    <span class="text-sm tracking-widest uppercase">{{ block.settings.product.title }}</span>
                    <span class="shrink-0 group-open:rotate-180 w-4 transition-transform">{% render 'icon-caret' %}</span>
                  </span>
                </summary>
                <div class="my-4 p-4{% if block.settings.product.featured_image %} flex flex-col md:flex-row gap-4 items-center{% endif %}{% if block.settings.product.handle == product.handle %} bg-gray-200 rounded-lg{% endif %}">
                  {%- if block.settings.product.featured_image -%}
                    <div class="md:w-24 md:shrink-0 grow-0 w-40 h-auto max-w-full">
                      {% render 'image', image: block.settings.product.featured_image, classes: 'object-contain' %}
                      {%- assign dimension = block.settings.product.metafields.dimension -%}
                      {%- if dimension -%}
                      <div class="mt-2 text-xs text-center opacity-50">
                        {%- if dimension.width -%}
                          <span class="after:content-['x'] after:inline-block last-of-type:after:hidden">
                            {{ dimension.width.value }}
                          </span>
                        {%- endif -%}
                        {%- if dimension.height -%}
                          <span class="after:content-['x'] after:inline-block last-of-type:after:hidden">
                            {{ dimension.height.value }}
                          </span>
                        {%- endif -%}
                        {%- if dimension.depth -%}
                          <span class="after:content-['x'] after:inline-block last-of-type:after:hidden">
                            {{ dimension.depth.value }}
                          </span>
                        {%- endif -%}
                      </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  <div class="space-y-4">
                    {%- if block.settings.description -%}
                      <p class="md:text-base text-sm">{{ block.settings.description }}</p>
                    {%- endif -%}
                    <a href="{% if block.settings.product.handle == product.handle %}#{% else %}{{ block.settings.product.url }}{% endif %}" class="md:text-sm block text-xs font-bold leading-3 tracking-widest uppercase">Shop It</a>
                  </div>
                </div>
              </details>
            </li>
          {%- endunless -%}
        {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Size Guide",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Lorem Headline",
      "label": "Title"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Size Guide",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
