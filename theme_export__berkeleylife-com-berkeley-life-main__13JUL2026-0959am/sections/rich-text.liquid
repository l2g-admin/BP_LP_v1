<div {% if section.settings.full_width %}class="relative bg-bg rich-text-principal"{% else %}class="max-w-screen-xl px-4 mx-auto my-8 md:px-8"{% endif %} style="--color-text: {{ section.settings.text_color | default: '#000000' }}; --color-bg: {{ section.settings.bg_color | default: '#FFFFFF' }}">
  <div class="{{ section.settings.mobile_spacing_bottom | prepend: 'pb-' }} {{ section.settings.mobile_spacing_top | prepend: 'pt-' }} {{ section.settings.spacing_top | prepend: 'md:pt-' }} {{ section.settings.spacing_bottom | prepend: 'md:pb-' }} max-w-screen-xl mx-auto px-4 md:px-8 text-center bg-bg text-text">
    {%- if section.settings.bg_image != blank -%}
      <div class="absolute inset-0 z-0">
        {% render 'image', image: section.settings.bg_image, classes: 'h-full w-full' %}
      </div>
    {%- endif -%}
    <div class="relative max-w-screen-lg px-4 mx-auto space-y-4 md:px-12 rich-text md:space-y-6 rich-text-texts">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
          <{{ block.settings.heading_level | default: 'p' }} class="{{ block.settings.heading_style }}" {{ block.shopify_attributes }}>
            {{ block.settings.heading | replace_first: "**", "<span class='text-brand h1 font-secondaryHeader'>" | replace: "**", "</span>" }}
          </{{ block.settings.heading_level | default: 'p' }}>
          {%- when 'text' -%}
            {% if section.settings.hover_state %}
              <div class="rte list_div {{ block.settings.text_style }}  {% if block.settings.columns %}md:columns-2 text-left{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text | replace_first: "**", "<span class='text-aqua hover-word font-secondaryHeader'>" | replace_first: "**", "</span>" | replace_first: "**", "<span class='text-brand font-secondaryHeader'>" | replace_first: "**", "</span>" | replace_first: "((", "<span class='relative hover-product-text'>" | replace_first: "))", "</span>" }}</div>
             {% else %}
          <div class="rte relative list_div {{ block.settings.text_style }}  {% if block.settings.columns %}md:columns-2 text-left{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text | replace_first: "**", "<span class='text-[#FD7757] font-secondaryHeader'>" | replace_first: "**", "</span>" | replace_first: "**", "<span class='text-[#FD7757] font-secondaryHeader'>" | replace_first: "**", "</span>" | replace_first: "((", "<span class='relative hover-product-text'>" | replace_first: "))", "</span>"  }}</div>
             
              {% if section.settings.show_hover_product %}
                <div class="border-white  product md:border-0 bg-[#EBE8E6] text-navy  md:left-[40%] md:translate-none  w-full mx-auto  md:w-[60%] md:fixed z-20  p-4 overflow-hidden  border-2 rounded-3xl"style="--color-text: {{ section.settings.text_color | default: '#000000' }}; --color-bg: {{ section.settings.bg_color | default: '#FFFFFF' }}">
                  <div class="relative mx-auto space-y-4 md:space-y-6 ">
                          {%  if section.settings.product != blank %}
                          <div class="grid items-center grid-cols-1 text-left md:grid-cols-2 gap-x-4">
                              <div class="flex justify-center gap-x-4">
                                {%- assign product_form_id = 'product-form-' | append: section.settings.product.id -%}
                                  <product-form class="hidden mb-4 product-form md:block">
                                      <div
                                      data-product-form-errors
                                      role="alert"
                                      hidden>
                                      <span data-product-form-error-msg></span>
                                      </div>
                                      {%- form 'product', section.settings.product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                                      <input
                                          type="hidden"
                                          name="id"
                                          value="{{ section.settings.product.selected_or_first_available_variant.id }}">
                                      <div class="product-form__buttons">
                                          <div class="flex gap-2 mt-2 mb-2">
                                          <button
                                              aria-label="Add to cart"
                                              type="submit"
                                              name="add"
                                              class="product-form__submit text-navy bg-white rounded-full p-2  w-fit !items-baseline"
                                              {% if section.settings.product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                                              {%- if section.settings.product.selected_or_first_available_variant.available -%}
                                              {% render 'icon-plus', classes: 'w-4' %}
                                              {%- else -%}
                                                  {{ 'products.product.sold_out' | t }}
                                              {%- endif -%}                            </button>
                                          </div>
              
                                      </div>
                                      {%- endform -%}
                                  </product-form>
                                <div class="space-y-2 text-center md:text-left">
                                  <h4 class="text-2xl tracking-[-0.72px;]"> {{ section.settings.product.title }}</h4>
                                  <div class="text-2xl !tracking-[-0.72px] text-brand font-secondaryHeader"> {{ section.settings.product.price | money }}</div>
                                  <div class="text-sm"> {{ section.settings.product.description | truncatewords: 15 }}</div>
                                </div>
                                </div>
                               <div class="w-3/4 mx-auto mt-8 md:mt-0">
                                <div class="hover-product-image-container"">
                                  {% if section.settings.hover_image != blank %}
                                    <img src="{{ section.settings.hover_image | img_url: '500x' }}" alt="Hover Image" class="hover-image">
                                  {% else %}
                                    {% render 'image', image: section.settings.product.featured_image %}
                                  {% endif %}
                                </div>
                                  <product-form class="mx-auto mt-4 md:hidden product-form">
                                    <div
                                    data-product-form-errors
                                    role="alert"
                                    hidden>
                                    <span data-product-form-error-msg></span>
                                    </div>
                                    {%- form 'product', section.settings.product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                                    <input
                                        type="hidden"
                                        name="id"
                                        value="{{ section.settings.product.selected_or_first_available_variant.id }}">
                                    <div class="product-form__buttons">
                                        <div class="flex justify-center gap-2 mt-2 mb-2">
                                        <button
                                            aria-label="Add to cart"
                                            type="submit"
                                            name="add"
                                            class="product-form__submit !text-brand button--text  w-fit !items-baseline"
                                            {% if section.settings.product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                                            {%- if section.settings.product.selected_or_first_available_variant.available -%}
                                              {{ 'products.product.add_to_cart' | t }}
                                            {%- else -%}
                                                {{ 'products.product.sold_out' | t }}
                                            {%- endif -%}                            </button>
                                        </div>
            
                                    </div>
                                    {%- endform -%}
                                </product-form>
                               </div>
                          </div>
                          {% endif %}
                        </div>
                  </div>
              {% endif %}
          {% endif %}
          {%- when 'clamped_text' -%}
            <div class="text-lg truncate-text-container" {{ block.shopify_attributes }}>
              <input type="checkbox" id="toggle-read-more-{{ forloop.index }}" class="read-more-toggle">
              <div class="truncate-text" aria-hidden="true">
                {{ block.settings.clamped_text }}
              </div>
              <label for="toggle-read-more-{{ forloop.index }}" class="read-more-label"></label>
            </div>
        {%- when 'button' -%}
        {%- if customer.b2b? and block.settings.b2b_button_link != blank and block.settings.b2b_button_label != blank -%}
          <a
            href="{{ block.settings.b2b_button_link }}"
            class="{{ block.settings.button_style }} mx-2"
            {{ block.shopify_attributes }}>
            {{ block.settings.b2b_button_label | escape }}
          </a>
        {% else %}
                   <a
            {%- if block.settings.button_link == blank %}
            aria-disabled="true"
            {% else %}
            href="{{ block.settings.button_link }}"
            {% endif %}
            class="{{ block.settings.button_style }} mx-2"
            {{ block.shopify_attributes }}>
            {{ block.settings.button_label | escape }}
          </a>
        {% endif %}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% if section.settings.hover_state %}
  <style>
    span.hover-product-text {
      cursor:pointer;  
      }
  </style>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const section = document.querySelector(".rich-text");
    
      if (!section) return;
    
      let maxHeight = 0;
      let intervalId;
      let lastOrientation = window.orientation;
    
      // Function to monitor and lock the height dynamically
      function monitorSectionHeight() {
        const currentHeight = section.offsetHeight;
    
        // Update the maximum height if the current height exceeds it
        if (currentHeight > maxHeight) {
          maxHeight = currentHeight;
          section.style.minHeight = `${maxHeight}px`;
        }
      }
    
      // Function to reset height and reinitialize monitoring
      function resetHeight() {
        maxHeight = 0; // Reset max height
        section.style.minHeight = ""; // Clear min-height
        clearInterval(intervalId); // Clear any ongoing interval
        intervalId = setInterval(monitorSectionHeight, 100); // Restart monitoring
      }
    
      // Detect if the device is a mobile device
      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    
      // Initial height monitoring
      intervalId = setInterval(monitorSectionHeight, 100);
    
      // Attach resize handler for desktops and handle rotation for mobile
      if (isMobile) {
        window.addEventListener("resize", () => {
          if (window.orientation !== lastOrientation) {
            // Trigger reset only if the orientation has changed
            lastOrientation = window.orientation;
            resetHeight();
          }
        });
      } else {
        // For desktops, reset on every resize
        window.addEventListener("resize", resetHeight);
      }
    
      // Stop monitoring when the user leaves the page
      window.addEventListener("beforeunload", () => clearInterval(intervalId));
    });
    
    
    const gif = document.createElement('img');
    gif.src = 'https://cdn.shopify.com/s/files/1/0671/0945/3979/files/Benefits-PhotoGif.gif?v=1732097676'; // The path to your GIF
    gif.style.position = 'absolute';
    gif.style.display = 'none'; // Initially hidden
    gif.style.zIndex = '1000';
    gif.style.width = '200px';
    document.body.appendChild(gif);
  
    let textInterval; // Global interval variable for text cycling
    let isMobile = window.innerWidth <= 768; // Initial mobile check
  
    const words = ["gut health", "full body health", "sexual health", "skin health"];
  
    function moveGifToCursor(e) {
      gif.style.left = e.pageX - 50 + 'px'; // Adjust position
      gif.style.top = e.pageY - 150 + 'px';
    }
  
    function handleMouseEnter(e) {
      // Show the GIF and position it near the cursor
      gif.style.display = 'block';
      moveGifToCursor(e);
      document.addEventListener('mousemove', moveGifToCursor); // Update position on cursor move
  
      const closestSpan = document.querySelector('span.hover-word');
      if (closestSpan) {
        let textIndex = 0; // Reset index
        textInterval = setInterval(() => {
          closestSpan.innerText = words[textIndex % words.length];
          textIndex++;
        }, 500);
      }
    }
  
    function handleMouseLeave() {
      // Hide the GIF and stop updating the position
      gif.style.display = 'none';
      document.removeEventListener('mousemove', moveGifToCursor);
  
      // Stop the text rotation by clearing the interval
      clearInterval(textInterval);
    }
  
    function enableMobileBehavior() {
      // Automatically cycle text
      const closestSpan = document.querySelector('span.hover-word');
      if (closestSpan) {
        clearInterval(textInterval); // Clear any existing interval
        textInterval = setInterval(() => {
          let textIndex = (parseInt(closestSpan.dataset.index || '0') + 1) % words.length;
          closestSpan.innerText = words[textIndex];
          closestSpan.dataset.index = textIndex; // Store the current index
        }, 500);
      }
  
      // Ensure GIF is hidden
      gif.style.display = 'none';
  
      // Remove hover event listeners
      document.querySelectorAll('span.hover-product-text').forEach(word => {
        word.removeEventListener('mouseenter', handleMouseEnter);
        word.removeEventListener('mouseleave', handleMouseLeave);
      });
    }
  
    function enableDesktopBehavior() {
      // Stop automatic text cycling
      clearInterval(textInterval);
  
      // Reattach hover-related behavior
      document.querySelectorAll('span.hover-product-text').forEach(word => {
        word.addEventListener('mouseenter', handleMouseEnter);
        word.addEventListener('mouseleave', handleMouseLeave);
      });
    }
  
    function handleResize() {
      const newIsMobile = window.innerWidth <= 768;
      if (newIsMobile !== isMobile) {
        isMobile = newIsMobile; // Update the state
  
        if (isMobile) {
          enableMobileBehavior();
        } else {
          enableDesktopBehavior();
        }
      }
    }
  
    document.addEventListener('DOMContentLoaded', function () {
      if (isMobile) {
        enableMobileBehavior();
      } else {
        enableDesktopBehavior();
      }
  
      // Listen for screen size changes
      window.addEventListener('resize', handleResize);
    });
  </script>
  

{% endif %}

{% if section.settings.show_hover_product %}
  <script>
    // Check if the viewport is desktop size
    if (window.innerWidth > 768) { // Adjust the breakpoint as needed for your project
      const product = document.querySelector('.product');
      product.style.position = 'absolute';
      product.style.display = 'none'; // Initially hidden
      product.style.zIndex = '10';

      document.addEventListener('DOMContentLoaded', function () {
        // Attach event listeners to spans with the specific style
        document.querySelectorAll('span.hover-product-text').forEach(word => {
          word.addEventListener('mouseenter', function() {
            console.log("mouse enter");
            // Show the product and position it near the cursor
            product.style.display = 'block';
          });
        });

        // Close the product if the user clicks outside
        document.addEventListener('click', function(event) {
          // Check if the clicked element is outside the product and the span
          if (!product.contains(event.target) && !event.target.closest('span.hover-product-text')) {
            product.style.display = 'none'; // Hide the product
          }
        });
      });
    }
  </script>
{% endif %}

<style>
  .truncate-text-container {
      position: relative;
  }
  
  .truncate-text {
      display: -webkit-box;
      -webkit-line-clamp: 2; /* Show only 2 lines */
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: all 0.3s ease-in-out;
  }
  
  .read-more-toggle {
      display: none;
  }
  
  .read-more-toggle:checked ~ .truncate-text {
      -webkit-line-clamp: unset;
      overflow: visible;
  }
  
  .read-more-label {
      display: inline-block;
      margin-top: 10px;
      color: var(--color-text);
      cursor: pointer;
      text-decoration: underline;
      font-size: 1rem;
  }
  
  .read-more-toggle:checked ~ .read-more-label::after {
      content: ' Read Less';
  }
  
  .read-more-label::after {
      content: ' Read More';
  }
  </style>

