  
  {%- capture content -%}
  {%- for block in section.blocks -%}
    <div class="flex gap-8 {% unless forloop.first %} ml-8 {% endunless %} items-center">
    <span class="text-white">
    {{- block.settings.title  -}}
    </span>
<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
<rect width="28" height="28" fill="url(#pattern0_100_136)"/>
<defs>
<pattern id="pattern0_100_136" patternContentUnits="objectBoundingBox" width="1" height="1">
<use xlink:href="#image0_100_136" transform="scale(0.0111111)"/>
</pattern>
<image id="image0_100_136" width="90" height="90" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
</defs>
</svg>

    </div>
  {%- endfor -%}
  {%- endcapture -%}

  
  <div class="py-4 overflow-hidden border-t motion-reduce:overflow-auto bg-purple text-cream marquee-section-outer" style="--color-text: {{ section.settings.text_color | default: '#ffffff' }}; --color-bg: {{ section.settings.bg_color | default: '#000000' }}">
    <h2 class="{% if section.settings.show_title %}h5 text-center mb-4{% else %}sr-only{% endif %}">{{ section.settings.title | default: 'Marquee' }}</h2>
    <div class="flex uppercase gap-8 select-none ticker odd-ticker marquee-ticker-wrapper">
      {%- for i in (1..9) -%}
        <div style="position: initial;" class=" w-max flex item shrink-0 subhead transform-gpu" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
          {{- content -}}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <script>
    (function() {
      var section = document.currentScript.closest('section') || document.currentScript.parentElement;
      if (!section) return;
      var observer = new MutationObserver(function() {
        if (document.body.classList.contains('clinical-drawer-no-scroll')) {
          section.style.display = 'none';
        } else {
          section.style.display = '';
        }
      });
      observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>
  
  {% schema %}
  {
    "name": "Marquee - Small",
    "tag": "section",
    "max_blocks": 20,
    "settings": [
    ],
    "blocks": [
      {
        "type": "phrase",
        "name": "Phrase",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Marquee - Small",
        "blocks": [
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Lorem"
            }
          },
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Ipsum"
            }
          },
          {
            "type": "phrase",
            "settings": {
              "title": "Callout Dolor"
            }
          }
        ]
      }
    ]
  }
  {% endschema %}
  