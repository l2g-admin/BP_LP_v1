{%-liquid
  assign show = true
  assign now = 'now' | date: '%s' | times: 1
  assign start_date = section.settings.start_date | default: 'now' | date: '%s' | times: 1
  assign end_date = section.settings.end_date | date: '%s' | times: 1
  if start_date > now
    assign show = false
  endif
  if end_date > 0 and end_date < now
    assign show = false
  endif
-%}
{%- if show -%}
<div style="--color-text: {{ section.settings.text_color | default: '#090909' }}; --color-bg: {{ section.settings.bg_color | default: '#F6F3F0' }}" class="bg-bg text-text">

  {%- if section.settings.heading != blank -%}
    <div class="border-t border-brand max-w-[1000px] mx-auto">
    <div class=" text-center md:w-1/2 mx-auto px-6 {{ section.settings.heading_spacing_top | prepend: 'pt-' }} {{ section.settings.heading_spacing_bottom | prepend: 'pb-' }}">
      <{{ section.settings.heading_level | default: 'h2' }} class="{{ section.settings.heading_style | default: 'h2' }} max-w-3xl mx-auto {{ section.settings.heading_spacing_top | prepend: 'pb-' }}">

          {{ section.settings.heading | replace_first: "**", "<span class='text-brand text-[34px] md:text-[46px] font-secondaryHeader'>" | replace: "**", "</span>" }}

      </{{ section.settings.heading_level | default: 'h2' }}>
    </div>
  </div>
  {%- endif -%}

  <div class="relative py-12 w-full ">

    {%- if section.settings.bg_image != blank -%}
      <div class="absolute inset-0 overflow-hidden">
        {%- render 'image',
          image: section.settings.bg_image,
          fit: 'object-cover',
          eager: section.settings.eager,
          classes: 'w-full h-full',
          img_size: '100vw',
          decorative: true
        -%}
      </div>
      {%- if section.settings.bg_overlay_opacity > 0 -%}
        <div class="absolute inset-0" style="background-color: {{ section.settings.bg_overlay_color | default: '#000000' }}; opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};"></div>
      {%- endif -%}
    {%- else -%}
      <div class="absolute inset-0 bg-navy"></div>
    {%- endif -%}

    <div class="relative max-w-screen-lg mx-auto px-6 md:px-16 {{ section.settings.spacing_top | prepend: 'py-' }}">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            <div
              class="flex flex-col rounded-2xl overflow-hidden backdrop-blur-sm p-2"
              style="background-color: {{ block.settings.card_bg | default: 'rgba(240,235,235,0.85)' }};"
              {{ block.shopify_attributes }}>

              {%- if block.settings.image != blank -%}
                <div class="{{ block.settings.image_ratio | default: 'aspect-[4/3]' }} relative w-full overflow-hidden">
                  {%- render 'image',
                    image: block.settings.image,
                    fit: 'object-cover',
                    classes: 'w-full h-full rounded-2xl',
                    img_size: '(min-width: 768px) 33vw, 100vw'
                  -%}
                </div>
              {%- endif -%}

              <div class="flex flex-col flex-1 p-4 space-y-2">
                {%- if block.settings.heading != blank -%}
                  <p class="font-secondaryHeader lowercase text-brand text-[24px] italic">{{ block.settings.heading }}</p>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="prose prose-sm text-text">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>

</div>
{%- endif -%}

{% schema %}
{
  "name": "Content Cards",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "2-in-1 Support Uniquely Formulated for Women 45+"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading Hierarchy",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "p", "label": "Paragraph" }
      ]
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "subhead", "label": "Small Caps" }
      ]
    },
    {
      "type": "range",
      "id": "heading_spacing_top",
      "label": "Heading Padding Top",
      "unit": "x",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing_bottom",
      "label": "Heading Padding Bottom",
      "unit": "x",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "checkbox",
      "id": "eager",
      "label": "Eager load background image?",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "bg_overlay_opacity",
      "label": "Overlay Opacity",
      "unit": "%",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 0
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Cards Section Padding",
      "unit": "x",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color (outside image area)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "header",
      "content": "Scheduling",
      "info": "Enter a start date and/or end date to hide and show this section on a schedule."
    },
    {
      "type": "text",
      "id": "start_date",
      "label": "Start Date",
      "info": "Defaults to now"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date",
      "info": "Defaults to never",
      "placeholder": "2021-12-31 23:59 EST"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Content Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Image Ratio",
          "default": "aspect-[4/3]",
          "options": [
            { "value": "aspect-square", "label": "Square" },
            { "value": "aspect-[4/3]", "label": "Wide (4:3)" },
            { "value": "aspect-[3/2]", "label": "Wide (3:2)" },
            { "value": "aspect-[16/9]", "label": "Wider (16:9)" },
            { "value": "aspect-[3/4]", "label": "Portrait" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Card Heading",
          "default": "nitric oxide support"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Card Description",
          "default": "<p>Add a description for this card here.</p>"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card Background Color",
          "info": "Use rgba values via custom CSS if you need transparency. Default is a semi-transparent blush."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Content Cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
