{%- comment -%}This section is a grid of collections{%- endcomment -%}
<div class="md:px-8 md:py-8 max-w-screen-lg px-4 py-4 mx-auto">

  <div class="md:px-8 md:grid-cols-2 gap-x-12 gap-y-4 grid items-center grid-cols-1 px-4 py-12 border-t border-b border-gray-100 border-solid">
    {%- unless section.settings.title == blank and section.settings.link_url == blank and section.settings.image == blank -%}
      <div class="md:text-left max-w-prose space-y-4 text-center">
        {%- if section.settings.image -%}
        <div>
          {% render 'image', image: section.settings.image, classes: 'object-contain' %}
        </div>
        {%- endif -%}
        <h2 class="h3">{{ section.settings.title }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.link_url != blank -%}
          <a data-pre="opacity-0 delay-700" data-post="opacity-100" class="motion-safe:transition-all motion-safe:duration-1000 decoration-1 underline-offset-2 hover:decoration-2 relative z-10 block text-sm font-bold tracking-widest underline uppercase transition-all" href="{{ section.settings.link_url }}">{{ section.settings.link_text | default: "Shop" }}</a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    {%- if section.blocks.size > 0 -%}
      <ul data-parent class="divide-solid divide-y divide-gray-100"
      role="list"
      >
      {%- for block in section.blocks -%}
        <li data-pre="opacity-0 -translate-x-8" data-post="opacity-100 translate-x-0" class="motion-safe:transition-all motion-safe:duration-700 py-6{% if block.settings.image %} flex items-center{% endif %}">
          {%- if block.settings.image -%}
            <div class="md:w-24 md:h-24 grow-0 shrink-0 w-16 h-16 mr-4 rounded-full">
              <div class="aspect-square w-full h-full">
                {% render 'image', image: block.settings.image, classes: 'object-contain' %}
            </div>
          </div>
          {%- endif -%}
          <div>
            {%- if block.settings.title -%}
              <h3 class="h5">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.subheading -%}
              <p class="md:text-base text-sm">{{ block.settings.subheading }}</p>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Text With List",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Lorem Headline",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Optional Link"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Optional Link Text"
    }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Lorem Headline",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text With List",
      "blocks": [
        {
          "type": "list_item"
        },
        {
          "type": "list_item"
        },
        {
          "type": "list_item"
        }
      ]
    }
  ]
}
{% endschema %}
