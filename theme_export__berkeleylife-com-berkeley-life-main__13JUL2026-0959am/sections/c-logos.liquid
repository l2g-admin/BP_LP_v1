<style>
      #{{ section.id }} {
        {%- assign half_padding_top = section.settings.padding_top | divided_by: 2.0 -%}
        {%- assign half_padding_bottom = section.settings.padding_bottom | divided_by: 2.0 -%}
        font-size: 16px;
        padding-top: {{ section.settings.padding_top }}em;
        padding-bottom: {{ section.settings.padding_bottom }}em;
        background-color: {{ section.settings.bg_color }};




        @media (max-width: 768px) {
          padding-top: {{ half_padding_top }}em;
          padding-bottom: {{ half_padding_bottom }}em;
        }

        & * {
          color: {{ section.settings.text_color }};
          font-weight: normal;
        }

        & .container__marquee {
          display: flex;
        }

        & .container__marquee__left {
          display: flex;
        }

        & .container__middle {
          width: 22%;
          flex: 0 0 auto;
          @media (max-width: 768px){
            width: 8%;
          }
        }

      }

      #{{ section.id }} .c-section-top {
        align-items: {{ section.settings.section_top_alignment }};
        text-align: {{ section.settings.text_alignment }};
        margin-bottom: 1.5em;
        margin-left: 0;
        margin-right: 0;
      }

      #{{ section.id }} .c-l-stars-div {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.2em;
      }

      #{{ section.id }} .c-l-wrapper {
        display: flex;
        overflow: hidden;
        position: relative;
        user-select: none;
        --gap: {{ section.settings.image_gap }}em;
        gap: var(--gap);
        padding-top: {{ section.settings.marquee_padding_top }}em;
        padding-bottom: {{ section.settings.marquee_padding_bottom }}em;
      }

      #{{ section.id }} .c-l-marquee-content {
        flex-shrink: 0;
        display: flex;
        justify-content: space-around;
        min-width: 100%;
        gap: var(--gap);
        animation: {{ section.id }}-scroll {{ section.settings.marquee_speed }}s linear infinite;
      }

      #{{ section.id }} .c-l-image-div {
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 600;
        gap: 0.5em;
        filter: {% if section.settings.grayscale_logo_colors == true %}grayscale(100%){% endif %} {% if section.settings.invert_logo_colors == true %}invert(100%){% endif %};
      }

      #{{ section.id }} .c-l-separator {
        display: flex;
        justify-content: center;
        align-items: center;
        align-self: center;
        flex-shrink: 0;
        width: 8px;
        height: 8px;
        background-color: {{ section.settings.text_color }};
        border-radius: 50%;
        opacity: 0.5;
      }

      #{{ section.id }} .c-l-image {
        width: 132px;
        max-width: 100%;
        max-height: 132px;
        height: auto;
        object-fit: contain;
        display: block;
      }

      #{{ section.id }} .c-l-middle {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        gap: 0.75em;
        width: {{ section.settings.container_width }}em;
        height: 100%;
        transform: translateX(-50%);
        background-color: {{ section.settings.bg_middle_color }};
        & * {
          text-transform: capitalize !important;
        }
      }

      #{{ section.id }} .c-l-middle svg {
        width: 15px;
        color: {{ section.settings.text_color }};
      }

      #{{ section.id }} .c-l-middle p {
        color: {{ section.settings.text_color }};
        text-align: center;
        font-size: 18px;
        line-height: 150%;
        letter-spacing: 0.2em;
        font-weight: 700;
        text-transform: capitalize;
        @media (max-width:768px){
          font-size: 12px;
          margin:10px
        }
      }

      #{{ section.id }} .container-text {
        display: flex;
        flex-direction: column;
      }

      #{{ section.id }} .block-heading {
        margin: 0;
        font-size: 40px;
      }

      #{{ section.id }} .block-para {
        margin: 0;
        font-size: 16px;
      }

      @keyframes {{ section.id }}-scroll {
        from { transform: translateX(0); }
        to { transform: translateX(calc({{ section.settings.direction }} - var(--gap))); }
      }

      {% if section.settings.toggle_pause_on_hover %}
        #{{ section.id }} .c-l-marquee-content {
          animation-play-state: running;
        }
        #{{ section.id }} .c-l-wrapper:hover .c-l-marquee-content {
          animation-play-state: paused;
        }
      {% endif %}


    #{{ section.id }} .container__marquee{
      display:flex;
      align-items:center;
      gap: var(--gap);
    }

    #{{ section.id }} .c-l-middle{

      transform: none;
      width: 100%;
      flex: 0 0 auto;
    }

    #{{ section.id }} .container__marquee__left{
      display:flex;
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
    }

    #{{ section.id }} .c-l-marquee-content{
      flex-shrink: 0;
      display:flex;
      align-items: center;
      min-width:100%;
      gap: var(--gap);
    }


  #{{ section.id }} .container__marquee__left{
    position: relative;
    overflow: hidden;
  }


  #{{ section.id }} .container__marquee__left::before,
  #{{ section.id }} .container__marquee__left::after{
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(24px, 6vw, 60px);
    pointer-events: none;
    z-index: 2;
  }


  #{{ section.id }} .container__marquee__left::before{
    left: 0;
    background: linear-gradient(
      to right,
      {{ section.settings.bg_color }} 0%,
      transparent 100%
    );
  }


  #{{ section.id }} .container__marquee__left::after{
    right: 0;
    background: linear-gradient(
      to left,
      {{ section.settings.bg_color }} 0%,
      transparent 100%
    );
  }




      @media (max-width: 1200px) {
      #{{ section.id }} {
        & .container__marquee {
          gap: 1em;
        }
        & .c-l-marquee-content {
          gap: 5rem;}

        & .container__middle {
          flex: 0 0 auto;
          width: 26%;
          * {
            width: max-content;
          }
        }
        & .container__middle {
          gap: 0 !important;
        }
        & .c-l-wrapper {
         gap: 0 !important;
        }
      }

        #{{ section.id }} .c-l-middle {
          gap: 0.4em;
        }
      }

  @media (max-width: 768px){
    #{{ section.id }} .container__marquee__left::before,
    #{{ section.id }} .container__marquee__left::after{
      width: clamp(16px, 8vw, 40px);
    }
    
    #{{ section.id }} {
       
      & .container__middle {
          flex: 0 0 auto;
          margin-left: 12px;
          width: 5%;
          * {
            width: inherit;
          }
        }
    }
  }

  @media (max-width: 1024px){
     #{{ section.id }} .container__marquee__left {
      gap: 5rem;
    }
  }
</style>

<section id="{{ section.id }}" class="c-section">
  <div class="{% if section.settings.full_width == false %}container{% endif %}">
    {%- if section.settings.section_top_subheading != empty -%}
    <div class="c-section-top">
      {%- if section.settings.section_top_subheading != empty -%}
        <p class="c-section-top-subheading">{{ section.settings.section_top_subheading }}</p>
      {%- endif -%}
      {%- if section.settings.section_top_heading != empty -%}
        <h2>{{ section.settings.section_top_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.section_top_paragraph != empty -%}
        <div class="c-t-80">{{ section.settings.section_top_paragraph }}</div>
      {%- endif -%}
    </div>
    {%endif%}
    <div class="c-l-wrapper">
      <div class="container__marquee">
        {% if section.settings.show_middle == true %}
          <div class="container__middle">
            <div class="c-l-middle">
              <p class="">{{ section.settings.heading }}</p>
            </div>
          </div>
        {% endif %}
        <div class="container__marquee__left">
          {% for i in (1..2) %}
            <div
              class="c-l-marquee-content"
              {% if forloop.index == 2 %}
                aria-hidden="true"
              {% endif %}
            >
              {% for block in section.blocks %}
                <div class="c-l-image-div" {{ block.shopify_attributes }}>
                  {% if block.settings.block_image %}
                    {{
                      block.settings.block_image
                      | image_url: width: 1200
                      | image_tag: loading: 'eager', height: 'auto', class: 'c-l-image'
                    }}
                  {% endif %}
                  <div class="container-text">
                    <h5 class="block-heading text-[40px] md:text-[40px] font-secondaryHeader">{{ block.settings.text }}</h5>
                    <p style="font-size: 16px; font-weight: 400;">{{ block.settings.para }}</p>
                  </div>
                </div>
                {% if section.settings.show_separators %}
                  <div class="c-l-separator"></div>
                {% endif %}
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Logos",
  "blocks": [
    {
      "name": "Logo",
      "type": "Logo",
      "limit": 50,
      "settings": [
        {
          "type": "image_picker",
          "id": "block_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "para",
          "label": "Paragraph"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_middle",
      "label": "Show middle section",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_separators",
      "label": "Show separators between logos",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AS SEEN ON:"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 1,
      "max": 9,
      "step": 0.1,
      "default": 1.9,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Images gap",
      "min": 0,
      "max": 9,
      "step": 0.1,
      "default": 6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "image_gap_mobile",
      "label": "Images gap mobile",
      "min": 0,
      "max": 9,
      "step": 0.1,
      "default": 4,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Middle container width",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "sec",
      "label": "Marquee Speed",
      "default": 60
    },
    {
      "type": "range",
      "id": "marquee_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 2,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "marquee_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 2,
      "unit": "rem"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Marquee Direction",
      "default": "-100%",
      "options": [
        {
          "label": "Left",
          "value": "-100%"
        },
        {
          "label": "Right",
          "value": "100%"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "toggle_pause_on_hover",
      "label": "Toggle Pause on Hover",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width?",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "grayscale_logo_colors",
      "label": "Grayscale logos",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "invert_logo_colors",
      "label": "Invert logo colors",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_middle_color",
      "label": "Background middle color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Section Top"
    },
    {
      "type": "text",
      "id": "section_top_subheading",
      "label": "Subheading",
      "default": "subheading"
    },
    {
      "type": "text",
      "id": "section_top_heading",
      "label": "Heading",
      "default": "My heading"
    },
    {
      "type": "richtext",
      "id": "section_top_paragraph",
      "label": "Paragraph",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare.</p>"
    },
    {
      "type": "select",
      "id": "section_top_alignment",
      "label": "Section Top Alignment",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 2,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 2,
      "unit": "rem"
    }
  ],
  "presets": [
    {
      "name": "C Logos"
    }
  ]
}
{% endschema %}
