{%- comment -%}
  Section: Prime Countdown
  Description: Thin wrapper for the c-prime-countdown snippet so it can be added as a standalone section.
  sl-id: sl-section-prime-countdown-v1
{%- endcomment -%}

{%- liquid
  assign sl_id = 'sl-section-prime-countdown-v1'
-%}

<section
  id="{{ section.id }}"
  class="c-prime-countdown-section"
  data-section-id="{{ section.id }}"
  data-sl-id="{{ sl_id }}"
  data-section-type="c-prime-countdown"
  {%- if section.settings.sl_anchor_id != blank %} data-anchor="{{ section.settings.sl_anchor_id }}"{% endif %}
>
  {%- render 'c-prime-countdown',
    uid: section.id,
    title: section.settings.title,
    end_date: section.settings.end_date,
    end_label: section.settings.end_label,
    days_label: section.settings.days_label,
    hours_label: section.settings.hours_label,
    minutes_label: section.settings.minutes_label,
    seconds_label: section.settings.seconds_label,
    bg_color: section.settings.bg_color,
    title_color: section.settings.title_color,
    number_color: section.settings.number_color,
    label_color: section.settings.label_color,
    accent_color: section.settings.accent_color,
    padding_top: section.settings.padding_top,
    padding_bottom: section.settings.padding_bottom,
    padding_top_mobile: section.settings.padding_top_mobile,
    padding_bottom_mobile: section.settings.padding_bottom_mobile,
    border_radius: section.settings.border_radius
  -%}
</section>

{% schema %}
{
  "name": "C Prime Countdown",
  "tag": "section",
  "class": "c-prime-countdown-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "Anchor ID",
      "info": "HTML anchor for internal navigation"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Prime Savings Match Ends"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date",
      "default": "2026-06-26T23:59:00-05:00",
      "info": "Use ISO format, e.g. 2026-06-26T23:59:00-05:00"
    },
    {
      "type": "text",
      "id": "end_label",
      "label": "End label",
      "default": "June 26 · 11:59PM"
    },
    {
      "type": "header",
      "content": "Unit labels"
    },
    {
      "type": "text",
      "id": "days_label",
      "label": "Days label",
      "default": "Days"
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "Hours label",
      "default": "Hrs"
    },
    {
      "type": "text",
      "id": "minutes_label",
      "label": "Minutes label",
      "default": "Min"
    },
    {
      "type": "text",
      "id": "seconds_label",
      "label": "Seconds label",
      "default": "Sec"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1B1E2A"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#8A8E99"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Unit label color",
      "default": "#8A8E99"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (dots & end label)",
      "default": "#D54F2F"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 28
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Border radius",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "C Prime Countdown"
    }
  ]
}
{% endschema %}
