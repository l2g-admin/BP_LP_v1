<script>
  (function () {
    var sectionEl = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!sectionEl) return;

    var accordionTriggers = sectionEl.querySelectorAll('.c-product-atc-offer__accordion-trigger');
    accordionTriggers.forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var accordion = trigger.closest('.c-product-atc-offer__accordion');
        if (!accordion) return;

        var isOpen = accordion.classList.contains('c-product-atc-offer__accordion--open');
        accordion.classList.toggle('c-product-atc-offer__accordion--open', !isOpen);
        trigger.setAttribute('aria-expanded', (!isOpen).toString());
      });
    });

    var form = document.getElementById('ProductAtcOfferForm-{{ section.id }}');
    var submitButton = document.getElementById('ProductAtcOfferSubmit-{{ section.id }}');
    var messageEl = document.getElementById('ProductAtcOfferMessage-{{ section.id }}');

    function showMessage(state, text) {
      if (!messageEl) return;
      messageEl.hidden = false;
      messageEl.dataset.state = state;
      messageEl.textContent = text;
    }

    function clearMessage() {
      if (!messageEl) return;
      messageEl.hidden = true;
      messageEl.textContent = '';
      messageEl.removeAttribute('data-state');
    }

    function refreshCartUi(cartDrawer) {
      if (cartDrawer) {
        if (typeof cartDrawer.render === 'function') cartDrawer.render();
        if (typeof cartDrawer.open === 'function') cartDrawer.open();
        return;
      }

      var cartNotification = document.querySelector('cart-notification');
      if (cartNotification && typeof cartNotification.open === 'function') {
        cartNotification.open();
      }
    }

    async function applyPromoCodeWithoutRedirect(promoCode) {
      var beforeRes = await fetch('/cart.js', {
        method: 'GET',
        headers: {
          Accept: 'application/json'
        }
      });
      var beforeCart = await beforeRes.json();
      var beforeTotal = beforeCart.total_discount || 0;
      var beforeCount = (beforeCart.cart_level_discount_applications || []).length;

      await fetch('/discount/' + encodeURIComponent(promoCode), {
        method: 'GET',
        redirect: 'follow'
      });

      var afterRes = await fetch('/cart.js', {
        method: 'GET',
        headers: {
          Accept: 'application/json'
        }
      });
      var afterCart = await afterRes.json();
      var afterTotal = afterCart.total_discount || 0;
      var afterDiscounts = afterCart.cart_level_discount_applications || [];
      var applied = afterTotal > beforeTotal || afterDiscounts.length > beforeCount;

      if (applied) {
        sessionStorage.setItem('discount_success', 'Discount code applied!');
        document.body.dispatchEvent(new CustomEvent('render-cart'));
      }

      return {
        applied: applied,
        cart: afterCart
      };
    }

    if (form && submitButton) {
      form.addEventListener('submit', async function (event) {
      event.preventDefault();
      if (submitButton.disabled || submitButton.getAttribute('aria-busy') === 'true') return;

      clearMessage();
      submitButton.disabled = true;
      submitButton.setAttribute('aria-busy', 'true');

      var formData = new FormData(form);
      var promoCode = form.dataset.promoCode || '';
      var redirectTarget = form.dataset.redirectTarget || '/checkout';
      var atcBehavior = form.dataset.atcBehavior || 'sidecart';

      try {
        var addResponse = await fetch((window.routes && window.routes.cart_add_url) || '/cart/add.js', {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            Accept: 'application/json'
          },
          body: formData
        });
        var response = await addResponse.json();

        if (response.status) {
          showMessage('error', response.description || 'Unable to add this item to cart.');
          return;
        }

        if (atcBehavior === 'cart') {
          if (promoCode) {
            window.location.href = '/discount/' + encodeURIComponent(promoCode) + '?redirect=' + encodeURIComponent(redirectTarget);
            return;
          }

          window.location.href = redirectTarget;
          return;
        }

        if (promoCode) {
          var promoResult = await applyPromoCodeWithoutRedirect(promoCode);

          if (!promoResult.applied) {
            showMessage('error', 'Added to cart, but the promo code could not be applied.');
          }
        }

        showMessage('success', promoCode ? 'Added to cart and promo code applied.' : 'Added to cart.');

        var cartDrawer = document.querySelector('cart-drawer');
        refreshCartUi(cartDrawer);
      } catch (error) {
        showMessage('error', 'Something went wrong. Please try again.');
      } finally {
        submitButton.disabled = false;
        submitButton.removeAttribute('aria-busy');
      }
      });
    }
  })();
</script>

