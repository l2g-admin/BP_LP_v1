<style>
  #{{section.id}} {
    background-color: {{ section.settings.background_color }};
    
    & .section__testimonial__container {
      padding-block: {{ section.settings.padding_top }}rem {{ section.settings.padding_bottom }}rem;
 
      display: flex;
      flex-direction: column;
      gap: 2rem;

      & .testimonial__header__texts {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        margin-inline: auto;
        max-width: 640px;
      }

      & .testimonial__title {
        font-size: clamp(32px, 6vw + 1rem, 54px);
        text-wrap: balance;
        text-align: center;
        line-height: normal;
        margin: 0;
        color: {{ section.settings.title_color }};
      }

      & .testimonial__title--span {
        color: {{ section.settings.accent_color }};
        font-family: "Cormorant Garamond";
      }

      & .testimonial__title--span {
        font-weight: 300;
        font-style: italic;
      }

      & .testimonial__description {
        max-width: 650px;
        font-weight: 300;
        text-align: center;
        font-size: clamp(18px, 2.5dvw, 20px);
        margin: 0;
        color: {{ section.settings.description_color }};
        line-height: 150%;
      }

      & .swiper-slide {
        height: auto;
      }

      & .testimonial__card {
        border-radius: 1rem;
        padding: 32px;
        background-color: {{ section.settings.card_background_color }};
        height: 100%;
      }

      & .testimonial__card__content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        overflow: hidden;
        height: 100%;
      }

      & .card__stars {
        display: flex;
        align-items: center;
      }

      & .card__title {
        font-size: clamp(1.2rem, 5.5dvw, 1.75rem);
        font-weight: 300;
        font-style: italic;
        margin: 0;
        font-family: "Cormorant Garamond";
        color: {{ section.settings.card_title_color }};
      }

      & .card__description {
        font-size: clamp(0.85rem, 4dvw, 1rem);
        font-weight: 300;
        margin: 0;
        line-height: 1.4;
        color: {{ section.settings.card_text_color }};
      }

      & .card__author {
        font-size: clamp(1rem, 4.5dvw, 1.25rem);
        font-weight: 300;
        font-style: italic;
        margin: 0;
        color: {{ section.settings.card_author_color }};
        font-family: "Cormorant Garamond";
      }
    }
  }
</style>

<section id="{{section.id}}">
  <div class="section__testimonial__container container-sl">
    <div class="testimonial__header__texts">
      <h2 class="testimonial__title">
        {% assign title_with_accent = section.settings.title | replace: '{accent}', '<span class="testimonial__title--span">' | replace: '{/accent}', '</span>' %}
        {{ title_with_accent }}
      </h2>
      <p class="testimonial__description">{{ section.settings.description }}</p>
    </div>
    
    {% if section.blocks.size > 0 %}
      <div class="testimonial__cards">
        <section id="swiper" class="swiper swiper__cards__testimonial">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'testimonial_card' %}
                  <div class="swiper-slide" {{ block.shopify_attributes }}>
                    <div class="testimonial__card">
                      <div class="testimonial__card__content">
                        <div class="card__stars">
                          {% for i in (1..5) %}
                            {% render 'c-orange-star' %}
                          {% endfor %}
                        </div>
                        <h3 class="card__title">{{ block.settings.title }}</h3>
                        <p class="card__description">{{ block.settings.description }}</p>
                        <span class="card__author">{{ block.settings.author }}</span>
                      </div>
                    </div>
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </section>
      </div>
    {% endif %}
  </div>
</section>

<script type="module">
  import Swiper from 'https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.mjs';

  let swiper = null;

  const initSwiper = () => {
    swiper = new Swiper('.swiper__cards__testimonial', {
      slidesPerView: 1.2,
      spaceBetween: 16,
      breakpoints: {
        768: {
          slidesPerView: 2.2,
          spaceBetween: 24,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 32,
        },
      },
    });
  };

  initSwiper();
</script>

