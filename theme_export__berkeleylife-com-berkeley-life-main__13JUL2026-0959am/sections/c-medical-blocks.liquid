<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital@1&display=swap');

  /* =========================================
     DESKTOP STYLES (Base / Desktop First)
     ========================================= */
  #{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    color: {{ section.settings.text_color }};
    overflow: hidden;

    & .c-advisory__container {

    }

    /* --- HEADER --- */
    & .c-advisory__header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 4rem auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    & .c-advisory__eyebrow {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: {{ section.settings.accent_color }};
      margin: 0 0 1rem 0;
    }

    & .c-advisory__title {
      font-size: clamp(36px, 4vw, 48px);
      line-height: 1.15;
      color: {{ section.settings.title_color }};
      margin: 0 0 1.5rem 0;

      & span {
        font-family: "Cormorant Garamond", serif;
        font-style: italic;
        color: {{ section.settings.accent_color }};
        font-size: clamp(40px, 4.5vw, 54px);
      }
    }

    & .c-advisory__subtitle {
      font-size: clamp(15px, 1.5vw, 17px);
      line-height: 1.6;
      margin: 0;
      color: {{ section.settings.text_color }};
    }

    /* --- GRID --- */
    & .c-advisory__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }

    /* --- CARD --- */
    & .c-advisory__card {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    & .c-advisory__img-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 16px;
      overflow: hidden;
      background-color: #e0e0e0; /* Fallback */
    }

    & .c-advisory__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      /* filter: grayscale(100%); */
    }

    & .c-advisory__content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }

    & .c-advisory__name {
      font-size: clamp(18px, 1.5vw, 22px);
      color: {{ section.settings.title_color }};
      margin: 0 0 0.5rem 0;
      line-height: 1.2;
    }

    & .c-advisory__role {
      font-size: 14px;
      font-style: normal;
      font-weight: 700;
      line-height: 120%; /* 16.8px */
      letter-spacing: 2.1px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: {{ section.settings.accent_color }};
      margin: 0 0 1rem 0;
      line-height: 1.4;
    }

    & .c-advisory__bio {
      font-size: 14px;
      line-height: 1.6;
      color: {{ section.settings.text_color }};
      margin: 0;
    }
  }

  /* =========================================
     MOBILE STYLES (max 991px)
     ========================================= */
  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;



      & .c-advisory__header {
        margin-bottom: 3rem;
      }

      & .c-advisory__title {
        font-size: 32px;
      }

      & .c-advisory__grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      & .c-advisory__card {
        flex-direction: row; /* Imagen a la izq, texto a la der */
        align-items: flex-start;
        gap: 1.25rem;
      }

      & .c-advisory__img-wrap {
        width: clamp(100px, 30vw, 130px);
        flex-shrink: 0; /* Evita que la imagen se aplaste */
      }

      & .c-advisory__name {
        font-size: 18px;
        margin-bottom: 0.25rem;
      }

      & .c-advisory__role {
        font-size: 10px;
        margin-bottom: 0.5rem;
      }

      & .c-advisory__bio {
        font-size: 13px;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="container-sl">
    <div class="c-advisory__container">
      <div class="c-advisory__header">
        {% if section.settings.eyebrow != blank %}
          <p class="c-advisory__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="c-advisory__title">{{ section.settings.title | newline_to_br }}</h2>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <p class="c-advisory__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>

      <div class="c-advisory__grid">
        {% for block in section.blocks %}
          <div class="c-advisory__card" {{ block.shopify_attributes }}>
            <div class="c-advisory__img-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 400 }}"
                  alt="{{ block.settings.name | escape }}"
                  class="c-advisory__img"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'c-advisory__img' }}
              {% endif %}
            </div>

            <div class="c-advisory__content">
              <h3 class="c-advisory__name">{{ block.settings.name }}</h3>
              <p class="c-advisory__role">{{ block.settings.role }}</p>
              <p class="c-advisory__bio">{{ block.settings.bio }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Medical Blocks",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title & Name Color",
      "default": "#1a1f4c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Orange)",
      "default": "#d25435"
    },
    {
      "type": "header",
      "content": "Header Texts"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "BACKED BY EXPERTISE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Our Scientific & <span>Medical\nAdvisory Board</span>",
      "info": "Wrap text in <span></span> to apply the italic serif font and accent color."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Leading experts in nutrition, exercise physiology, men's health, and cardiovascular science stand behind Berkeley Life."
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px",
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px",
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "px",
      "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Board Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Dr. Name Surname"
        },
        {
          "type": "textarea",
          "id": "role",
          "label": "Credentials / Role",
          "default": "PROFESSOR, UNIVERSITY"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio / Description",
          "default": "Clinical academic awarded internationally, he researches how nutrition and nitric oxide impact cardiovascular and metabolic health."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Medical Blocks",
      "blocks": [
        {
          "type": "member",
          "settings": {
            "name": "Dr. Mario Siervo",
            "role": "PROFESSOR, CURTIN UNIVERSITY",
            "bio": "Clinical academic awarded internationally, he researches how nutrition and nitric oxide impact cardiovascular and metabolic health."
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Dr. Chris Easton",
            "role": "PHD, EXERCISE PHYSIOLOGY",
            "bio": "10+ years studying physical performance — from everyday athletes to Olympic competitors."
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Greg McKettrick",
            "role": "RPH · MEN'S HEALTH SPECIALIST",
            "bio": "Pharmacist with 30+ years in men's health. Creator of the Penile Rehabilitation Protocol."
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Dr. Haroldo Magariños",
            "role": "PHD · ORAL-GUT HEALTH EXPERT",
            "bio": "Dentist and microbiome specialist, co-founder of Revolution Gut Health."
          }
        }
      ]
    }
  ]
}
{% endschema %}
