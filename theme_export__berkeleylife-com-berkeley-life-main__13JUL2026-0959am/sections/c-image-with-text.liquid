{%- liquid
  assign show = true
  assign now = 'now' | date: '%s' | times: 1
  assign start_date = section.settings.start_date | default: 'now' | date: '%s' | times: 1
  assign end_date = section.settings.end_date | date: '%s' | times: 1
  if start_date > now
    assign show = false
  endif
  if end_date > 0 and end_date < now
    assign show = false
  endif
-%}
<style>
  #coupon-card {
    width: 70%;
    margin: 24px auto;
    padding: 20px 20px 24px;
    bottom:1rem;
    @media (max-width:576px){
      padding: 24px 16px 24px;
      bottom:-10rem;
      width: 100%;
    }
    @media (max-width:420px){
      padding: 24px 16px 24px;
      bottom:-10rem;
      width: 100%;
    }
    background: #F6F2EF;
    border-radius: 18px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    font-family: Helvetica, 'Helvetica Neue', Arial, sans-serif;
    color: #1e2430;
    text-align: center;
    &.coupon {
      & .coupon__title {
        font-size: 18px;
        font-style: normal;
        font-weight: 600;
        line-height: 120%; /* 21.6px */
        letter-spacing: 1.8px;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      & .coupon__codebox {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 2px solid #D44F2F;
        border-radius: 10px;
        padding: 10px;
        gap: 10px;
        margin-bottom: 16px;
        background: white;
      }

      & .coupon__code {
        flex: 1;
        text-align: center;
        font-size: 18px;
        font-style: normal;
        font-weight: 700;
        line-height: 150%; 
      }

      & .coupon__copy {
        flex-shrink: 0;
        border: 0;
        border-radius: 8px;
        padding: 10px 24px;
        background: #d9d9de;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        transition: filter 0.2s ease;
        font-size: 16px;
        font-style: normal;
        font-weight: 700;
        text-transform: uppercase;
      }
      & .coupon__copy:hover {
        filter: brightness(0.95);
      }

      & .coupon__cta {
        display: block;
        margin: 8px 0 12px;
        padding: 14px 16px;
        background: #D44F2F;
        color: #F6F3F0;
        text-decoration: none;
        font-weight: 800;
        border-radius: 28px;
        text-transform: uppercase;
        font-size: 18px;
        font-style: normal;
        font-weight: 700;
        line-height: 150%;  
        text-transform: uppercase;
      }

      & .coupon__note {
        font-size: 14px;
        font-style: italic;
        font-weight: 400;
        line-height: 150%; 
        color: #080B2B;
      }
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media(max-width:768px){
    .bg-bg{
      margin-top:-8px;
    }
  }
</style>

{%- if show -%}
  <div
    class="bg-bg"
    style="--color-text: {{ section.settings.text_color | default: '#090909' }}; --color-bg: {{ section.settings.bg_color | default: '#F6F3F0' }}"
  >
    <style>
      .align-self-center {
        align-self: center;
      }
      .h-60 {
        height: 60%;
      }
      .justify-self-center {
        justify-self: center;
      }

      @media (min-width: 769px) {
        .tag-desktop {
          display: block;
        }
        .tag-mobile {
          display: none;
        }
        .grid-container {
          max-width: 1280px;
        }
      }
      @media (max-width: 768px) {
        .tag-desktop {
          display: none;
        }
        .tag-mobile {
          display: block;
        }
      }
    </style>
    <div class="justify-self-center {% unless section.settings.full_width %} px-4 {{ section.settings.mobile_spacing_bottom | prepend: 'pb-' }} {{ section.settings.mobile_spacing_top | prepend: 'pt-' }} {{ section.settings.spacing_top | prepend: 'md:pt-' }} {{ section.settings.spacing_bottom | prepend: 'md:pb-' }}{% endunless %} bg-bg text-text">
      <div class="{{ section.settings.split }} grid grid-cols-1 grid-container">
        <div class="align-self-center {% if section.settings.mobile_hidden %}hidden md:block {% endif %} {% if section.settings.layout == 'text_first' %} md:order-1 {% endif %} {% if section.settings.layout == 'text_first_both' %} order-1 {% endif %}">
          <div class="{{ section.settings.image_ratio }} relative h-full w-full {% unless section.settings.full_width %} md:w-[85%] h-60 {% endunless %}">
            <style>
              .rounded-16 {
                border-radius: 16px;
              }
            </style>
            {%- liquid
              if section.settings.video_file != blank
                render 'video-autoplay', id: section.id, video: section.settings.video_file, fit: section.settings.image_cover
              else
                if section.settings.image != blank
                  render 'image', image: section.settings.image, fit: section.settings.image_cover, eager: section.settings.eager, classes: 'rounded-16'
                else
                  echo 'image' | placeholder_svg_tag: 'placeholder-svg'
                endif
              endif
            -%}

            {%- for block in section.blocks -%}
              {% case block.type %}
                {% when 'coupon-card' %}
                  <div id="coupon-card" class="coupon absolute left-1/2 transform -translate-x-1/2 z-10" {{ block.shopify_attributes }}>
                    <h3 class="coupon__title">{{ block.settings.coupon_title | default: 'Claim 15% off and restore your energy & glow' }}</h3>

                    <div class="coupon__codebox">
                      <span id="couponCode" class="coupon__code" aria-label="Discount code">{{ block.settings.coupon_code | default: 'ALMONDS15' }}</span>
                      <button id="copyBtn" class="coupon__copy" type="button" aria-label="Copy discount code">{{ block.settings.copy_button_text | default: 'Copy' }}</button>
                    </div>

                    <a href="{{ block.settings.coupon_link | default: '#' }}" class="coupon__cta">{{ block.settings.cta_text | default: 'Get my 15% discount now' }}</a>

                    <p class="coupon__note">{{ block.settings.coupon_note | default: '$49.99 for a 1-Month Supply. Discount applied at checkout.' }}</p>

                    <!-- Mensaje accesible (no visible) -->
                    <span id="copyStatus" class="sr-only" aria-live="polite"></span>
                  </div>
              {% endcase %}
            {%- endfor -%}
          </div>
        </div>

        <div
          data-parent
          class="flex flex-col {% if section.settings.border %}border-2 border-navy rounded-[46px] {% endif %} {% if section.settings.justify_top %} md:!pt-0 {% else %} justify-center {% endif %} p-4 md:p-8 md:px-16 h-full space-y-6 w-full max-w-4xl {{ section.settings.text_align | default: 'text-left' }}"
        >
          {% if section.settings.tag_image != blank %}
            <div class="tag-desktop">
              {{ section.settings.tag_image }}
            </div>
          {% endif %}
          {% if section.settings.tag_image_mobile != blank %}
            <div class="tag-mobile">
              {{ section.settings.tag_image_mobile }}
            </div>
          {% endif %}
          {%- for block in section.blocks -%}
            {% case block.type %}
              {% when 'trusted' %}
                <style>
                  .trusted-stars {
                    color: #d44f2f;
                    font-size: 24px;
                  }
                </style>
                <span>
                  {{-
                    block.settings.trusted_text
                    | replace_first: '**', "<span class='trusted-stars'>"
                    | replace_first: '**', '</span>'
                  -}}
                </span>
              {%- when 'heading' -%}
                <{{ block.settings.heading_level | default: 'p' }}
                  data-pre="opacity-0 translate-y-8"
                  data-post="opacity-100 translate-y-0"
                  class="motion-safe:transition-all motion-safe:duration-700 {{ block.settings.heading_style }}"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.cursive_color == 'text-white' %}
                    {{
                      block.settings.heading
                      | replace_first: '**', "<span class='text-white text-[50px] md:text-[71px] font-secondaryHeader'>"
                      | replace: '**', '</span>'
                    }}
                  {% else %}
                    {{
                      block.settings.heading
                      | replace_first: '**', "<span class='text-brand text-[50px] md:text-[71px] font-secondaryHeader'>"
                      | replace_first: '**', '</span>'
                      | replace_first: '**', "<span class='text-brand text-[50px] md:text-[71px] font-secondaryHeader'>"
                      | replace_first: '**', '</span>'
                    }}
                  {% endif %}
                </{{ block.settings.heading_level | default: 'p' }}>
              {%- when 'richtext' -%}
                <div
                  data-pre="opacity-0 translate-y-8"
                  data-post="opacity-100 translate-y-0"
                  class="prose motion-safe:transition-all motion-safe:duration-700 {{ block.settings.text_size }} {% if block.settings.enable_border %}border-b border-black/30 pb-2{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <style>
                    .prose a {
                      text-decoration: underline;
                    }
                  </style>
                  {{ block.settings.richtext }}
                </div>
              {%- when 'text' -%}
                <style>
                  .text-paragraph{
                    color: {{block.settings.color}};
                  }
                </style>
                <div
                  data-pre="opacity-0 translate-y-8"
                  data-post="opacity-100 translate-y-0"
                  class="text-paragraph bold-text custom-bullets prose{% if block.settings.columns %} grid grid-cols-2 gap-y-8 gap-x-4 {% endif %} motion-safe:transition-all motion-safe:duration-700 list_div"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                {%- if customer.b2b? -%}
                  {% if block.settings.b2b_button_link != blank %}
                    <div
                      data-text="{{ block.settings.b2b_button_label }}"
                      data-pre="opacity-0 translate-y-8"
                      data-post="opacity-100 translate-y-0"
                      class="{%if block.settings.mobile_hide %} hidden md:block {%endif%} {{ section.settings.text_align | default: 'text-left' }} motion-safe:transition-all motion-safe:duration-700"
                    >
                      <a
                        {%- if block.settings.b2b_button_link != blank %}
                          href="{{ block.settings.b2b_button_link }}"
                        {% endif %}
                        class="{{ block.settings.button_style }} {% if block.settings.button_style == 'button--text' %}!text-brand {% else %} md:px-24  {% endif %} "
                        {{ block.shopify_attributes }}
                      >
                        {{ block.settings.b2b_button_label | escape }}
                      </a>
                    </div>
                  {%- endif -%}
                {% else %}
                  {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                    <div
                      data-text="{{ block.settings.button_label }}"
                      data-pre="opacity-0 translate-y-8"
                      data-post="opacity-100 translate-y-0"
                      class="{%if block.settings.mobile_hide %} hidden md:block {%endif%} {{ section.settings.text_align | default: 'text-left' }} motion-safe:transition-all motion-safe:duration-700"
                    >
                      <a
                        {%- if block.settings.button_link != blank %}
                          href="{{ block.settings.button_link }}"
                        {% endif %}
                        class="{{ block.settings.button_style }} {% if block.settings.button_style == 'button--text' %}!text-brand {% else %} md:px-24  {% endif %} "
                        {% if block.settings.button_link == blank %}
                          aria-disabled="true"
                        {% endif %}
                        {{ block.shopify_attributes }}
                      >
                        {{ block.settings.button_label | escape }}
                      </a>
                    </div>
                  {%- endif -%}
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<script>
  (function () {
    const btn = document.getElementById('copyBtn');
    const codeEl = document.getElementById('couponCode');
    const status = document.getElementById('copyStatus');
    const ORIGINAL_TEXT = btn.textContent;

    async function copyText(text) {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          // Fallback: textarea oculto
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'fixed';
          ta.style.top = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        return true;
      } catch {
        return false;
      }
    }

    btn.addEventListener('click', async () => {
      const ok = await copyText(codeEl.textContent.trim());
      if (ok) {
        btn.textContent = 'Copied!';
        status.textContent = 'Code copied to clipboard';
        btn.style.background = '#c7f0c2'; // feedback visual
        setTimeout(() => {
          btn.textContent = ORIGINAL_TEXT;
          btn.style.background = '#d9d9de';
          status.textContent = '';
        }, 1600);
      } else {
        status.textContent = 'Copy failed. Please select and copy manually.';
        alert('Copy failed. Please copy manually.');
      }
    });
  })();
</script>

