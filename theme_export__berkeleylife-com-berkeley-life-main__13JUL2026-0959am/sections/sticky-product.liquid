<div class="hidden md:block top-product  border-navy bg-cream/80 bottom-20 md:bottom-[5%] left-1/2 md:left-[80%] md:translate-none -translate-x-1/2  md:w-[33%] fixed z-20 w-[90%] bg-cream p-4 overflow-hidden  border-2 rounded-3xl"style="--color-text: {{ section.settings.text_color | default: '#000000' }}; --color-bg: {{ section.settings.bg_color | default: '#FFFFFF' }}">
    <div class="relative mx-auto space-y-4 md:space-y-6 ">
            {%  if section.settings.product != blank %}
            {%- comment -%} Find the correct variant based on metafields {%- endcomment -%}
            {%- assign display_variant = section.settings.product.selected_or_first_available_variant -%}
            {%- for variant in section.settings.product.variants -%}
              {%- if variant.metafields.custom.one_time_purchase == true -%}
                {%- assign display_variant = variant -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            <div class="grid items-center grid-cols-1 md:grid-cols-3 gap-x-4">
                <div class="col-span-2 scroll-flex">
                  <div class="scroll-flex-second">
                    <h4 class="text-2xl"> {{ section.settings.product.title }}</h4>
                    <div class="text-2xl !tracking-wider text-brand font-secondaryHeader"> {{ display_variant.price | money }}</div>
                  </div>
                    <div class="text-md hide-scroll"> {{ section.settings.product.description |truncatewords: 10 }}</div>

                    {%- assign product_form_id = 'product-form-' | append: section.settings.product.id -%}
                    <div>
                    <product-form class="mb-4 product-form">
                        <div
                        data-product-form-errors
                        role="alert"
                        hidden>
                        <span data-product-form-error-msg></span>
                        </div>
                        {%- form 'product', section.settings.product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                        <input
                            type="hidden"
                            name="id"
                            value="{{ section.settings.product.selected_or_first_available_variant.id }}">
                        <div class="product-form__buttons">
                            <div class="flex gap-2 mt-2 mb-2">
                              {% capture product_rating %}
                                {% render 'okendo-reviews-product-rating-summary', product: section.settings.product %}
                              {% endcapture %}
                            
                            {%- if section.settings.redirect_on_add and section.settings.redirect_url != blank -%}
                              <a
                                aria-label="Add to cart"
                                href="{{ section.settings.redirect_url }}"
                                class="hide-scroll button--text text-base !text-brand w-fit !items-baseline">
                                {%- if display_variant.available -%}
                                  {{ 'products.product.add_to_cart' | t }}
                                {%- else -%}
                                  {{ 'products.product.sold_out' | t }}
                                {%- endif -%}
                              </a>
                              <a
                                aria-label="Add to cart"
                                href="{{ section.settings.redirect_url }}"
                                class="hidden show-scroll rounded-full bg-white p-2 text-base !text-brand w-fit !items-baseline">
                                {%- if display_variant.available -%}
                                  {% render 'icon-plus', classes: "w-4 text-navy" %}
                                {%- else -%}
                                  {{ 'products.product.sold_out' | t }}
                                {%- endif -%}
                              </a>
                            {%- else -%}
                            <button
                                aria-label="Add to cart"
                                type="submit"
                                name="add"
                                class="hide-scroll product-form__submit button--text text-base !text-brand  w-fit !items-baseline"
                                data-product-handle="{{ section.settings.product.handle }}"
                                data-product-id="{{ section.settings.product.selected_or_first_available_variant.id }}"
                                data-subscription="{% if section.settings.product.selling_plan_groups.size > 0 %}true{% else %}false{% endif %}"
                                data-productrating="{{ product_rating | strip_newlines | escape }}"
                                data-featuredImage="https:{{ section.settings.product.featured_media | image_url }}"
                                data-disableFlyout="{{ section.settings.product.metafields.custom.disable_subscription_flyout }}"
                                data-metadata='[
                                  {% for variant in section.settings.product.variants %}
                                    {
                                      "id": {{ variant.id }},
                                      "is_most_popular_subscription": "{{ variant.metafields.custom.is_most_popular_subscription | escape }}",
                                      "disable_one_time_purchase": "{{ variant.metafields.custom.disable_one_time_purchase | escape }}"
                                    }{% unless forloop.last %},{% endunless %}
                                  {% endfor %}
                                ]'
                                {% if section.settings.product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                                {%- if section.settings.product.selected_or_first_available_variant.available -%}
                                {{ 'products.product.add_to_cart' | t }}
                                {%- else -%}
                                    {{ 'products.product.sold_out' | t }}
                                {%- endif -%}                         
                               </button>
                               <button
                                aria-label="Add to cart"
                                type="submit"
                                name="add"
                                class="hidden show-scroll product-form__submit rounded-full bg-white p-2 text-base !text-brand  w-fit !items-baseline"
                                data-product-handle="{{ section.settings.product.handle }}"
                                data-product-id="{{ section.settings.product.selected_or_first_available_variant.id }}"
                                data-subscription="{% if section.settings.product.selling_plan_groups.size > 0 %}true{% else %}false{% endif %}"
                                data-productrating="{{ product_rating | strip_newlines | escape }}"
                                data-featuredImage="https:{{ section.settings.product.featured_media | image_url }}"
                                data-disableFlyout="{{ section.settings.product.metafields.custom.disable_subscription_flyout }}"
                                data-metadata='[
                                  {% for variant in section.settings.product.variants %}
                                    {
                                      "id": {{ variant.id }},
                                      "is_most_popular_subscription": "{{ variant.metafields.custom.is_most_popular_subscription | escape }}",
                                      "disable_one_time_purchase": "{{ variant.metafields.custom.disable_one_time_purchase | escape }}"
                                    }{% unless forloop.last %},{% endunless %}
                                  {% endfor %}
                                ]'
                                {% if section.settings.product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                                {%- if section.settings.product.selected_or_first_available_variant.available -%}
                               {%  render 'icon-plus', classes: "w-4 text-navy"%}
                                {%- else -%}
                                    {{ 'products.product.sold_out' | t }}
                                {%- endif -%}                            
                              </button>
                            {%- endif -%}
                            </div>

                        </div>
                        {%- endform -%}
                    </product-form>
                  </div>
                 </div>
                 <div class="w-1/3 md:w-full hide-scroll">
                    {% render 'image', image:section.settings.product.featured_image %}
                </div>
            </div>
            {% endif %}
          </div>
    </div>

    {% comment %} Mobile {% endcomment %}

        <a class=" md:hidden  bottom-20  left-1/2 -translate-x-1/2   fixed z-20 rounded-full inline-flex items-center justify-center  px-4 py-3  text-center tracking-widest font-bold  cursor-pointer md:px-12 button--tertiary text-base uppercase   w-[90%]" href="{{ section.settings.product.url }}">
          {%- if section.settings.product.selected_or_first_available_variant.available -%}
          Shop Now
          {%- else -%}
              {{ 'products.product.sold_out' | t }}
              {%- endif -%}  
            </a>                             
<script>

    document.addEventListener("DOMContentLoaded", function () {
      const topProduct = document.querySelector('.top-product');
      const hideScrollElements = document.querySelectorAll('.hide-scroll');
      const showScrollElements = document.querySelectorAll('.show-scroll');
      const scrollGrid = document.querySelector('.scroll-flex');
      const scrollGrid2 = document.querySelector('.scroll-flex-second');

      // Function to check if the user has scrolled 10% of the page
      function hasScrolledTenPercent() {
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const pageHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        return (scrollTop / pageHeight) >= 0.1;
      }
  
      // Function to toggle visibility of .hide-scroll and .show-scroll elements
      function toggleScrollVisibility() {
        if (hasScrolledTenPercent()) {
          hideScrollElements.forEach(el => el.classList.add('hidden'));
          showScrollElements.forEach(el => el.classList.remove('hidden'));
          scrollGrid.classList.add("flex","justify-between", "items-center", "col-span-3", "gap-4");
          scrollGrid.classList.remove( "col-span-2");
          scrollGrid2.classList.add("flex", "gap-4");
        } else {
          hideScrollElements.forEach(el => el.classList.remove('hidden'));
          showScrollElements.forEach(el => el.classList.add('hidden'));
          scrollGrid.classList.remove("flex", "items-center", "col-span-3", "gap-4");
          scrollGrid.classList.add( "col-span-2");
          scrollGrid2.classList.remove("flex");
        }
      }
  
     
  
      // Run checks on scroll
      window.addEventListener('scroll', () => {
        toggleScrollVisibility();
      });
  
      // Initial checks in case the page is loaded scrolled
      toggleScrollVisibility();
    });
  </script>
  

{% schema %}
{
  "name": "Sticky Product",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Redirect Settings"
    },
    {
      "type": "checkbox",
      "id": "redirect_on_add",
      "label": "Redirect after add to cart",
      "default": false,
      "info": "When enabled, clicking add to cart will redirect to the specified URL instead of opening the flyout"
    },
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Redirect URL",
      "info": "Select the page to redirect to after clicking add to cart"
    }
  ],

  "presets": [
    {
      "name": "Sticky Product"
    }
  ]
}
{% endschema %}