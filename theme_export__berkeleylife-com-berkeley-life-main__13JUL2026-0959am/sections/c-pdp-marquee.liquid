{%- comment -%}
  Section: C PDP Marquee
  Description: Desktop marquee banner with repeated white text blocks and a configurable SVG divider.
  sl-id: sl-section-pdp-marquee-v1
  Figma: https://www.figma.com/design/f1AWMl23NcBW13s8SML1B5/BKL?node-id=5268-3996
{%- endcomment -%}

{%- liquid
  assign sl_id = 'sl-section-pdp-marquee-v1'
  assign section_id = section.settings.sl_anchor_id | default: section.id
  assign marquee_duration = section.settings.marquee_duration | default: 40
-%}

{%- capture marquee_items -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.text != blank -%}
      <span class="c-pdp-marquee__item" {{ block.shopify_attributes }}>
        <span class="c-pdp-marquee__text">{{ block.settings.text | escape }}</span>
      </span>
      <span class="c-pdp-marquee__divider" aria-hidden="true">
        {{ section.settings.divider_html }}
      </span>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

<section
  id="{{ section_id }}"
  class="c-pdp-marquee"
  data-section-id="{{ section.id }}"
  data-sl-id="{{ sl_id }}"
  data-section-type="c-pdp-marquee"
  style="--c-pdp-marquee-duration: {{ marquee_duration }}s; --c-pdp-marquee-text-color: {{ section.settings.text_color | default: '#ffffff' }}; --c-pdp-marquee-background: {{ section.settings.background_color | default: '#1b1c29' }};"
>
  <div class="c-pdp-marquee__container page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="c-pdp-marquee__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    <div class="c-pdp-marquee__scroller">
      <div class="c-pdp-marquee__track" aria-label="{{ section.settings.eyebrow | escape }}">
        <div class="c-pdp-marquee__group">
          {{ marquee_items }}
        </div>
        <div class="c-pdp-marquee__group" aria-hidden="true">
          {{ marquee_items }}
        </div>
      </div>
    </div>
  </div>
</section>

{% style %}
  #{{ section_id }} {
    background: var(--c-pdp-marquee-background);
    color: var(--c-pdp-marquee-text-color);
    overflow: hidden;
    padding-block: 14px;
  }

  #{{ section_id }} .c-pdp-marquee__container {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  #{{ section_id }} .c-pdp-marquee__eyebrow {
    flex: 0 0 auto;
    margin: 0;
    font-family: "TT Commons", sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: inherit;
    white-space: nowrap;
  }

  #{{ section_id }} .c-pdp-marquee__scroller {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    mask-image: linear-gradient(90deg, transparent 0, #000 84px, #000 calc(100% - 84px), transparent 100%);
  }

  #{{ section_id }} .c-pdp-marquee__scroller::-webkit-scrollbar {
    display: none;
  }

  #{{ section_id }} .c-pdp-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    min-width: 100%;
  }

  #{{ section_id }} .c-pdp-marquee__group {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    width: max-content;
  }

  #{{ section_id }} .c-pdp-marquee__item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
  }

  #{{ section_id }} .c-pdp-marquee__text {
    display: inline-flex;
    align-items: center;
    font-family: "TT Commons", sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: inherit;
    white-space: nowrap;
    padding-inline: 8px;
  }

  #{{ section_id }} .c-pdp-marquee__divider {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    margin-inline: 4px;
  }

  #{{ section_id }} .c-pdp-marquee__divider svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  @media (min-width: 768px) {
    #{{ section_id }} {
      padding-block: 14px;
    }

    #{{ section_id }} .c-pdp-marquee__container {
      gap: 24px;
    }

    #{{ section_id }} .c-pdp-marquee__eyebrow {
      font-size: 19px;
      letter-spacing: 0.24em;
    }

    #{{ section_id }} .c-pdp-marquee__scroller {
      overflow: hidden;
    }

    #{{ section_id }} .c-pdp-marquee__track {
      animation: c-pdp-marquee-scroll var(--c-pdp-marquee-duration, 40s) linear infinite;
      will-change: transform;
    }

    #{{ section_id }} .c-pdp-marquee__text {
      font-size: 18px;
      letter-spacing: 0.24em;
      padding-inline: 10px;
    }

    #{{ section_id }} .c-pdp-marquee__divider {
      width: 32px;
      height: 32px;
      margin-inline: 6px;
    }

    #{{ section_id }} .c-pdp-marquee__divider svg {
      width: 20px;
      height: 20px;
    }
  }

  @media (min-width: 1200px) {
    #{{ section_id }} .c-pdp-marquee__text {
      font-size: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .c-pdp-marquee__track {
      animation: none;
    }
  }

  @keyframes c-pdp-marquee-scroll {
    0% {
      transform: translate3d(0, 0, 0);
    }

    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }
{% endstyle %}

