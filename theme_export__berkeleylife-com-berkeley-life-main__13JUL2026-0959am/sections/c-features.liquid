<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital@1&display=swap');

  /* =========================================
     DESKTOP STYLES (Base / Desktop First)
     ========================================= */
  #{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    color: {{ section.settings.text_color }};
    text-align: center;
    overflow: hidden;

    & .c-cta2__container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* --- HEADER --- */
    & .c-cta2__header {
      margin-bottom: 3.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    & .c-cta2__title {
      font-size: clamp(32px, 4vw, 48px);
      font-style: normal;
 
        line-height: 100%;
      margin: 0 0 1.5rem 0;
      color: {{ section.settings.title_color }};

      & span {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(36px, 4.5vw, 54px);
        color: {{ section.settings.accent_color }};
        font-style: italic;
      }
    }

    & .c-cta2__subtitle {
      font-size: clamp(16px, 1.5vw, 18px);
      font-style: normal;
      font-weight: 400;
       line-height: 150%; 
      margin: 0;
      max-width: 750px;
      color: {{ section.settings.text_color }};
      opacity: 0.9;
    }

    /* --- FEATURES GRID --- */
    & .c-cta2__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      width: 100%;
      margin-bottom: 3.5rem;
    }

    & .c-cta2__card {
      
      border: 1px solid {{ section.settings.card_border }};
      border-radius: 12px;
      padding: 2rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    & .c-cta2__icon {
      width: 24px;
      height: 24px;
      color: {{ section.settings.accent_color }};
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;

      & svg {
        width: 100%;
        height: 100%;
        fill: currentColor;
      }
    }

    & .c-cta2__card-title {
      font-size: clamp(16px, 2vw, 18px);
      margin: 0 0 0.25rem 0;
      color: {{ section.settings.title_color }};
      font-style: normal;
        font-weight: 700;
        line-height: 150%; 
    }

    & .c-cta2__card-text {
       font-size: clamp(16px, 2vw, 18px);
      margin: 0;
      color: {{ section.settings.text_color }};
      opacity: 0.8;
    }

    /* --- CTA BUTTON --- */
    & .c-cta2__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background-color: {{ section.settings.accent_color }};
      color: #ffffff;
      padding: 16px 36px;
      border-radius: 30px;
      text-decoration: none;
      font-size: 15px;
      transition: opacity 0.3s ease, transform 0.3s ease;

      &:hover {
        opacity: 0.9;
        transform: translateY(-2px);
      }
    }
  }

  /* =========================================
     MOBILE STYLES (max 991px)
     ========================================= */
  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;

      & .c-cta2__container {
        padding: 0 1rem;
      }

      & .c-cta2__title {
        font-size: 32px;
      }

      & .c-cta2__header {
        margin-bottom: 2.5rem;
      }

      & .c-cta2__grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 2.5rem;
      }

      & .c-cta2__card {
        padding: 1.5rem 0.5rem;
      }

  

      & .c-cta2__card-text {
        font-size: 13px;
      }

      & .c-cta2__btn {
        width: 100%;
      }
    }
  }

  @media screen and (max-width: 480px) {
    #{{ section.id }} {
      & .c-cta2__grid {
        grid-template-columns: 1fr;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="c-cta2__container">
    
    <div class="c-cta2__header">
      {% if section.settings.title != blank %}
        <h2 class="c-cta2__title">{{ section.settings.title | newline_to_br }}</h2>
      {% endif %}
      
      {% if section.settings.subtitle != blank %}
        <p class="c-cta2__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="c-cta2__grid">
      {% for block in section.blocks %}
        <div class="c-cta2__card" {{ block.shopify_attributes }}>
          <div class="c-cta2__icon">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 1L14.65 3.23L18.12 2.72L18.94 6.07L22 7.76L20.83 11L22 14.24L18.94 15.93L18.12 19.28L14.65 18.77L12 21L9.35 18.77L5.88 19.28L5.06 15.93L2 14.24L3.17 11L2 7.76L5.06 6.07L5.88 2.72L9.35 3.23L12 1Z" />
                <path d="M10 14.5L7.5 12L8.9 10.6L10 11.7L15.1 6.6L16.5 8L10 14.5Z" fill="{{ section.settings.card_bg }}" />
              </svg>
            {% endif %}
          </div>
          <h3 class="c-cta2__card-title">{{ block.settings.title }}</h3>
          <p class="c-cta2__card-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.btn_text != blank %}
      <a href="{{ section.settings.btn_link }}" class="c-cta2__btn">
        {{ section.settings.btn_text }}
      </a>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "C Features",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1c1d24"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Main Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Orange)",
      "default": "#d25435"
    },
    {
      "type": "header",
      "content": "Card Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#23242c"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card Border",
      "default": "#3d3e48"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Make Blood Flow the\nFoundation of <span>Your Practice</span>",
      "info": "Wrap text in <span></span> to apply the italic serif font and accent color."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Berkeley Life gives you the science, the products, and the clinical support to help your patients see and feel real results—measurable in seconds with at-home test strips."
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Set Up Your Account"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0, "max": 150, "step": 5, "default": 80, "unit": "px", "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 150, "step": 5, "default": 80, "unit": "px", "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 100, "step": 5, "default": 50, "unit": "px", "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 100, "step": 5, "default": 50, "unit": "px", "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG (Optional)",
          "info": "Paste raw SVG code. If blank, a default badge icon is used."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Main Text (e.g. '20% off')",
          "default": "20% off"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Sub Text (e.g. 'first order')",
          "default": "first order"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "20% off", "text": "first order" } },
        { "type": "feature", "settings": { "title": "Wholesale", "text": "pricing" } },
        { "type": "feature", "settings": { "title": "Clinical resources", "text": "included" } },
        { "type": "feature", "settings": { "title": "GMP certified", "text": "products" } }
      ]
    }
  ]
}
{% endschema %}