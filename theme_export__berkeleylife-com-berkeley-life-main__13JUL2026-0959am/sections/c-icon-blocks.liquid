<style>

  /* =========================================
     DESKTOP STYLES (Base / Desktop First)
     ========================================= */
  #{{ section.id }} {
    position: relative;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    color: {{ section.settings.text_color }};
    overflow: hidden;

    /* Background Image & Overlay */
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}

    & .c-ben__overlay {
      position: absolute;
      inset: 0;
      background-color: {{ section.settings.bg_color }};
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      z-index: 1;
    }

    & .c-ben__container {
      position: relative;
      z-index: 2;

      display: flex;
      flex-direction: column;
    }

    /* --- HEADER --- */
    & .c-ben__header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 4rem;
      margin-bottom: 4rem;
    }

    & .c-ben__header-left {
      flex: 1;
      max-width: 600px;
    }

    & .c-ben__eyebrow {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: {{ section.settings.accent_color }};
      margin: 0 0 1rem 0;
    }

    & .c-ben__title {
      font-size: clamp(36px, 4vw, 48px);
      line-height: 1.15;
      margin: 0;
      color: {{ section.settings.title_color }};

      /* Span special styling */
      & span {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(40px, 4.5vw, 54px);
        color: {{ section.settings.accent_color }};
        font-style: italic;
      }
    }

    & .c-ben__header-right {
      flex: 1;
      max-width: 500px;
    }

    & .c-ben__desc {
      font-size: clamp(18px, 1.5vw, 20px);
      font-style: normal;
      font-weight: 400;
      line-height: 150%;
      margin: 0;
      color: {{ section.settings.text_color }};
      opacity: 0.9;
    }

    /* --- GRID --- */
    & .c-ben__grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    /* --- CARDS --- */
    & .c-ben__card {
      background: {{ section.settings.card_bg }};
      border: 1px solid {{ section.settings.card_border }};
      border-radius: 12px;
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      transition: transform 0.3s ease;

      &:hover {
        transform: translateY(-5px);
      }
    }

    & .c-ben__card-icon {
      width: 32px;
      height: 32px;
      color: {{ section.settings.accent_color }};
      margin-bottom: 1.5rem;
      flex-shrink: 0;

      & svg {
        width: 100%;
        height: 100%;
        fill: none;
        stroke: currentColor;
      }
    }

    & .c-ben__card-content {
      display: flex;
      flex-direction: column;
    }

    & .c-ben__card-title {
      font-size: clamp(18px, 1.5vw, 24px);
      color: {{ section.settings.title_color }};
      margin: 0 0 0.75rem 0;
      font-style: normal;
      font-weight: 500;
      line-height: 120%;
    }

    & .c-ben__card-text {
      font-size: clamp(14px, 1.5vw, 16px);
      font-style: normal;
      font-weight: 400;
      line-height: 150%;
      color: {{ section.settings.text_color }};
      opacity: 0.8;
      margin: 0;
    }

    /* --- ACTIONS (Buttons) --- */
    & .c-ben__actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }

    & .c-ben__btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background-color: {{ section.settings.accent_color }};
      color: #ffffff;
      padding: 16px 36px;
      border-radius: 30px;
      text-decoration: none;
      font-size: 15px;
      transition: opacity 0.3s ease, transform 0.3s ease;

      &:hover {
        opacity: 0.9;
        transform: translateY(-2px);
      }
    }

    & .c-ben__btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: {{ section.settings.accent_color }};
      text-decoration: none;
      border-bottom: 1px solid currentColor;
      padding-bottom: 4px;
      transition: opacity 0.3s ease;

      &:hover {
        opacity: 0.7;
      }

      & svg {
        width: 14px;
        height: 14px;
        fill: none;
        stroke: currentColor;
        transition: transform 0.3s ease;
      }

      &:hover svg {
        transform: translateX(4px);
      }
    }
  }

  /* =========================================
     MOBILE STYLES (up to 991px)
     ========================================= */
  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;

      & .c-ben__container {

      }

      & .c-ben__header {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
      }

      & .c-ben__title {
        font-size: 36px;
      }

      & .c-ben__grid {
        grid-template-columns: 1fr;
        gap: 1rem;
        margin-bottom: 2.5rem;
      }

      /* Card layout on mobile (Icon Left, Text Right) */
      & .c-ben__card {
        flex-direction: row;
        align-items: flex-start;
        gap: 1.25rem;
        padding: 1.5rem;
      }

      & .c-ben__card-icon {
        margin-bottom: 0;
        width: 28px;
        height: 28px;
      }

      & .c-ben__actions {
        flex-direction: column;
        gap: 1.5rem;
      }

      & .c-ben__btn-primary {
        width: 100%;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="c-ben__overlay"></div>
  <div class="container-sl">
    <div class="c-ben__container">
      <div class="c-ben__header">
        <div class="c-ben__header-left">
          {% if section.settings.eyebrow != blank %}
            <p class="c-ben__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}
          {% if section.settings.title != blank %}
            <h2 class="c-ben__title">{{ section.settings.title | newline_to_br }}</h2>
          {% endif %}
        </div>
        <div class="c-ben__header-right">
          {% if section.settings.description != blank %}
            <p class="c-ben__desc">{{ section.settings.description }}</p>
          {% endif %}
        </div>
      </div>

      <div class="c-ben__grid">
        {% for block in section.blocks %}
          <div class="c-ben__card" {{ block.shopify_attributes }}>
            <div class="c-ben__card-icon">
              {% if block.settings.custom_svg != blank %}
                {{ block.settings.custom_svg }}
              {% else %}
                <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% endif %}
            </div>
            <div class="c-ben__card-content">
              <h3 class="c-ben__card-title">{{ block.settings.title }}</h3>
              <p class="c-ben__card-text">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="c-ben__actions">
        {% if section.settings.btn_primary_text != blank %}
          <a href="{{ section.settings.btn_primary_link }}" class="c-ben__btn-primary">
            {{ section.settings.btn_primary_text }}
          </a>
        {% endif %}

        {% if section.settings.btn_secondary_text != blank %}
          <a href="{{ section.settings.btn_secondary_link }}" class="c-ben__btn-secondary">
            {{ section.settings.btn_secondary_text }}
            <svg viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

