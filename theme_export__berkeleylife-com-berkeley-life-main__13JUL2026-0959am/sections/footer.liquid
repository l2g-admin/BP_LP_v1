      "label": "SVG for Logo",
      "info": "This is preferred (without widthor height attribute)."
    },
    {
      "type": "html",
      "id": "mobile_svg",
      "label": "Mobile SVG for Logo",
      "info": "This is preferred (without widthor height attribute)."
    },
    {
      "type": "url",
      "id": "footer_url",
      "label": "Footer Logo Url"
    },
    {
      "type": "header",
      "content": "Newsletter Settings"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "default": true,
      "label": "Show newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_header",
      "label": "Newsletter Header"
    },
    {
      "type": "text",
      "id": "newsletter_description",
      "label": "Newsletter Description"
    },
    {
      "type": "header",
      "content": "Social Settings"
    },
    {
      "type": "checkbox",
