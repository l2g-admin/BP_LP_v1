{%- liquid
  assign section_id = section.settings.custom_id | default: section.id
  assign has_graph_image = false
  if section.settings.image_desktop != blank or section.settings.image_mobile != blank
    assign has_graph_image = true
  endif
-%}

<style>
  .heading-graph {
    text-align: center;
    margin-bottom: 2rem;
  }

  .graph-subtext {
    font-size: 22px;
  }

  @media (min-width: 768px) {
    .graph-subtext {
      font-size: 28px;
    }
  }

  #{{ section_id }} {
    --graph-cta-orange: #de532f;
  }

  #{{ section_id }} .graph-cta-group {
    gap: 1rem;
  }

  #{{ section_id }} .graph-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0.85rem 2rem;
    border-radius: 999px;
    border: 2px solid transparent;
    font-size: 1.1rem;
    line-height: 1;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  #{{ section_id }} .graph-cta.graph-cta--solid a {
    background-color: var(--graph-cta-orange);
    border-color: var(--graph-cta-orange);
    color: #ffffff;
  }

  #{{ section_id }} .graph-cta.graph-cta--outline a {
    background-color: transparent;
    border-color: var(--graph-cta-orange);
    color: var(--graph-cta-orange);
  }

  #{{ section_id }} .graph-cta.graph-cta--solid a:hover,
  #{{ section_id }} .graph-cta.graph-cta--solid a:focus-visible {
    background-color: #c64828;
    border-color: #c64828;
    transform: translateY(-1px);
  }

  #{{ section_id }} .graph-cta.graph-cta--outline a:hover,
  #{{ section_id }} .graph-cta.graph-cta--outline a:focus-visible {
    background-color: rgba(222, 83, 47, 0.08);
    transform: translateY(-1px);
  }

  @media screen and (max-width: 767px) {
    #{{ section_id }} .graph-cta-group {
      width: 100%;
      padding-right: 1rem;
      padding-left: 1rem;
    }

    #{{ section_id }} .graph-cta {
      width: 100%;
    }

    #{{ section_id }} .graph-cta a {
      width: 100%;
    }
  }

  #{{ section_id }} .graph-image {
    margin: 2rem auto;
    max-width: 100%;
  }

  #{{ section_id }} .graph-image img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0 auto;
  }

  #{{ section_id }} .graph-image--desktop {
    display: none;
  }

  #{{ section_id }} .graph-image--mobile {
    display: block;
  }

  @media (min-width: 768px) {
    #{{ section_id }} .graph-image--desktop {
      display: block;
    }

    #{{ section_id }} .graph-image--mobile {
      display: none;
    }
  }

  #{{ section_id }} .graph-image--desktop-only {
    display: none;
  }

  @media (min-width: 768px) {
    #{{ section_id }} .graph-image--desktop-only {
      display: block;
    }
  }

  #{{ section_id }} .graph-image--mobile-only {
    display: block;
  }

  @media (min-width: 768px) {
    #{{ section_id }} .graph-image--mobile-only {
      display: none;
    }
  }
</style>

<div id="{{ section_id }}"
  class="py-8 md:border-0 md:pb-12 bg-bg"
  style="--color-text: {{ section.settings.text_color | default: '#000000' }}; --color-bg: {{ section.settings.bg_color | default: '#FFFFFF' }}"
>
  <div id="chart-container" class="relative text-center overflow-hidden bg-bg text-text max-w-[1000px] mx-auto">
    <h3 class="c-title heading-graph">
      {{
        section.settings.title
        | replace_first: '**', "<span class='text-brand c-font-cormorant-title'>"
        | replace_first: '**', '</span>'
      }}
    </h3>
    {% if section.settings.paragraph != blank %}
      <p class="mb-8 text-center">
        {{ section.settings.paragraph }}
      </p>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="text-brand c-font-cormorant-title mb-8 graph-subtext">
        {{ section.settings.subtext }}
      </p>
    {% endif %}
    {%- if has_graph_image -%}
      {%- if section.settings.image_desktop != blank and section.settings.image_mobile != blank -%}
        <div class="graph-image graph-image--desktop">
          {{ section.settings.image_desktop | image_url: width: 2000 | image_tag: alt: section.settings.image_desktop.alt | default: 'Chart', loading: 'lazy', widths: '600, 900, 1200, 1600, 2000' }}
        </div>
        <div class="graph-image graph-image--mobile">
          {{ section.settings.image_mobile | image_url: width: 1200 | image_tag: alt: section.settings.image_mobile.alt | default: 'Chart', loading: 'lazy', widths: '400, 600, 800, 1200' }}
        </div>
      {%- elsif section.settings.image_desktop != blank -%}
        <div class="graph-image graph-image--desktop-only">
          {{ section.settings.image_desktop | image_url: width: 2000 | image_tag: alt: section.settings.image_desktop.alt | default: 'Chart', loading: 'lazy', widths: '600, 900, 1200, 1600, 2000' }}
        </div>
      {%- elsif section.settings.image_mobile != blank -%}
        <div class="graph-image graph-image--mobile-only">
          {{ section.settings.image_mobile | image_url: width: 1200 | image_tag: alt: section.settings.image_mobile.alt | default: 'Chart', loading: 'lazy', widths: '400, 600, 800, 1200' }}
        </div>
      {%- endif -%}
    {%- else -%}
    <div class="flex w-[90%] flex-wrap px-8 justify-center gap-x-12 gap-y-4 md:mt-12 text-center inputs">
      <div class="flex items-center justify-between gap-4">
        <label class="w-20 text-xs tracking-widest uppercase md:text-base" for="gender-select">Gender</label>
        <select
          id="gender-select"
          class="w-48 p-2 text-xs tracking-widest uppercase bg-transparent rounded-full md:text-base md:w-80"
        >
          <option value="choose">Choose One</option>
          {% if section.settings.gender_select_order == 'men_first' %}
            <option value="men">Men</option>
            <option value="women">Women</option>
          {% else %}
            <option value="women">Women</option>
            <option value="men">Men</option>
          {% endif %}
        </select>
      </div>
      <div class="flex items-center justify-between gap-4">
        <label class="w-20 text-xs tracking-widest uppercase md:text-base" for="age-input">Age</label>
        <select
          id="age-input"
          class="w-48 p-2 text-xs tracking-widest uppercase bg-transparent rounded-full md:text-base md:w-80"
        >
          <option value="choose">Choose One</option>
          <option value="20-29">20-29</option>
          <option value="30-39">30-39</option>
          <option value="40-49">40-49</option>
          <option value="50-59">50-59</option>
          <option value="60-69">60-69</option>
          <option value="70-79">70-79</option>
          <option value="80-89">80-89</option>
          <option value="90-100">90-100</option>
        </select>
      </div>
    </div>
    <div class="chart-container">
      <canvas id="chart-canvas"></canvas>
    </div>
    {%- endif -%}
    {% if section.blocks.size > 0 %}
      <div class="graph-cta-group flex flex-wrap items-center justify-center mx-auto">
        {% for block in section.blocks %}
          {% if block.settings.button_label != blank %}
            <div
              class="graph-cta text-center button w-fit {% if block.type == 'primary_button' %}graph-cta--solid{% else %}graph-cta--outline{% endif %}"
              {{ block.shopify_attributes }}
            >
              <a
                id="dynamic-button-{{ block.id }}"
                aria-label="{{ block.settings.button_label }}"
                href="{{ block.settings.button_link }}"
                {% if block.settings.use_dynamic_gender_link %}
                  data-dynamic-button="true"
                  data-default-link="{{ block.settings.button_link }}"
                  data-link-women="{{ block.settings.button_link_women }}"
                  data-link-men="{{ block.settings.button_link_men }}"
                {% endif %}
              >
                {{ block.settings.button_label }}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

