<style>
  /* Container for the chart */
  .chart-container {
    position: relative; /* Required for Chart.js responsiveness */
    width: 100%; /* Fixed width */
    height: 300px; /* Fixed height */
    margin-top: 2rem;
    margin-bottom: 2rem;
    margin-right: auto;
    margin-left: auto;
  }

  /* Ensure canvas does not auto-scale incorrectly */
  #chart-canvas {
    width: 100% !important; /* Forces it to take full container width */
    height: 100% !important; /* Forces it to take full container height */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function createChart() {
      console.log('Chart Data Loaded:', window.chartData);

      const canvas = document.getElementById('chart-canvas');
      const chartContainer = document.getElementById('chart-container');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      const chart = new Chart(ctx, {
        type: 'line',
        data: {
          datasets: [
            {
              label: 'Women',
              borderWidth: 2,
              borderColor: function (context) {
                const index = context.dataIndex;
                const dataset = context.dataset;

                // Ensure data exists and index is valid
                if (!dataset.data || index === undefined || !dataset.data[index]) {
                  return dataset.label === 'Women' ? '#ff6347' : '#080B2B'; // Default colors
                }

                const xValue = dataset.data[index].x;

                if (selectedAgeRange) {
                  const [low, high] = selectedAgeRange.split('-').map(Number);
                  if (xValue >= low && xValue <= high) {
                    return '#00BED6'; // Highlighted section in blue
                  }
                }

                return dataset.label === 'Women' ? '#ff6347' : '#080B2B'; // Default colors
              },
              backgroundColor: '#ff6347',
              data: window.chartData.women.map((point) => ({
                x: point.x,
                y: point.y,
                tooltipMessage: getCustomTooltipMessage('women', point.x),
              })),
              fill: false,
              tension: 0.4,
              pointRadius: 0,
              pointHoverRadius: 0,
              pointBackgroundColor: '#00BED6',
              pointBorderColor: '#00BED6',
              pointBorderWidth: 1,
              pointHitRadius: 7,
            },
            {
              label: 'Men',
              borderWidth: 2,
              borderColor: function (context) {
                const index = context.dataIndex;
                const dataset = context.dataset;

                // Ensure data exists and index is valid
                if (!dataset.data || index === undefined || !dataset.data[index]) {
                  return dataset.label === 'Women' ? '#ff6347' : '#080B2B'; // Default colors
                }

                const xValue = dataset.data[index].x;

                if (selectedAgeRange) {
                  const [low, high] = selectedAgeRange.split('-').map(Number);
                  if (xValue >= low && xValue <= high) {
                    return '#00BED6'; // Highlighted section in blue
                  }
                }

                return dataset.label === 'Women' ? '#ff6347' : '#080B2B'; // Default colors
              },
              backgroundColor: '#080B2B',
              data: window.chartData.men.map((point) => ({
                x: point.x,
                y: point.y,
                tooltipMessage: getCustomTooltipMessage('men', point.x),
              })),
              fill: false,
              tension: 0.4,
              pointRadius: 0,
              pointHoverRadius: 0,
              pointBackgroundColor: '#00BED6',
              pointBorderColor: '#00BED6',
              pointBorderWidth: 1,
              pointHitRadius: 7,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'none',
          },
          scales: {
            x: {
              grid: {
                color: (context) => {
                  return context.tick.value % 10 === 0 ? '#cccccc' : '#e5e3e2';
                },
              },
              type: 'linear',
              title: {
                display: true,
                text: 'Age',
                font: {
                  size: 14,
                  style: 'italic',
                },
                padding: 15,
              },
              min: 20,
              max: 100,
              ticks: {
                stepSize: 5,
                callback: function (value, index, values) {
                  return value % 10 === 0 ? value : '';
                },
                font: { size: 12 },
              },
            },
            y: {
              grid: {
                color: (context) => {
                  return context.tick.value % 20 === 0 ? '#cccccc' : '#e5e3e2';
                },
              },
              beginAtZero: true,
              min: 0,
              max: 100,
              title: {
                display: true,
                text: 'Decline in N.O. Production (%)',
                font: {
                  size: 14,
                  style: 'italic',
                },
                padding: 30,
              },
              ticks: {
                stepSize: 10,
                callback: function (value, index, values) {
                  return value % 20 === 0 ? value : '';
                },
                font: { size: 12 },
              },
            },
          },
          plugins: {
            tooltip: {
              enabled: false,
            },
            legend: {
              position: 'right',
              align: 'center',
              labels: {
                boxHeight: 1,
                boxWidth: 30,
                padding: 15,
                font: {
                  size: 10,
                  weight: 'normal',
                },
              },
            },
          },
          layout: {
            padding: {
              right: 0,
            },
          },
        },
      });

      const ageDropdown = document.getElementById('age-input');
      const genderDropdown = document.getElementById('gender-select');

      function updateTooltip() {
        const selectedAgeRange = String(ageDropdown.value);
        const selectedGender = genderDropdown.value.toLowerCase();

        if (!selectedAgeRange.includes('-') || selectedGender === 'choose') {
          resetChart();
          return;
        }

        const [low, high] = selectedAgeRange.split('-').map(Number);
        const datasetIndex = selectedGender === 'women' ? 0 : 1;
        const dataset = chart.data.datasets[datasetIndex];

        // Find both low and high points
        const dataIndices = dataset.data
          .map((point, index) => (point.x === low || point.x === high ? index : -1))
          .filter((index) => index !== -1);

        // Highlight both points
        // Reset all datasets first
        chart.data.datasets.forEach((ds) => {
          ds.pointRadius = ds.data.map(() => 0);
        });

        // Then highlight the selected dataset
        dataset.pointRadius = dataset.data.map((_, index) => (dataIndices.includes(index) ? 6 : 0));

        // Update tooltip message
        showCustomTooltip({
          message: getCustomTooltipMessage(selectedGender, selectedAgeRange),
        });
        // Reset the line color for both datasets first
        chart.data.datasets.forEach((ds) => {
          ds.segment = {
            borderColor: ds.label === 'Women' ? '#ff6347' : '#080B2B', // Default colors
          };
        });

        dataset.segment = {
          borderColor: (ctx) => {
            const index = ctx.p1DataIndex; // First point of the segment
            const xValue = dataset.data[index]?.x;

            if (selectedAgeRange) {
              const [low, high] = selectedAgeRange.split('-').map(Number);
              if (xValue >= low + 1 && xValue < high + 1) {
                return '#00BED6'; // Highlighted segment
              }
            }
            return dataset.label === 'Women' ? '#ff6347' : '#080B2B'; // Default color
          },
        };

        if (window.gtag) {
          window.gtag('event', 'select_age_gender', {
            category: 'Graph Selection',
            label: `Age: ${selectedAgeRange}, Gender: ${selectedGender}`,
            gender: selectedGender,
            age_range: selectedAgeRange,
          });
          console.log(`GA Event Sent: Gender=${selectedGender}, Age Range=${selectedAgeRange}`);
        }

        // Force a re-render
        chart.update();
      }

      function resetChart() {
        chart.data.datasets.forEach((dataset) => {
          dataset.pointRadius = Array(dataset.data.length).fill(0);
        });
        hideCustomTooltip();
        chart.update();
      }

      ageDropdown.addEventListener('change', updateTooltip);
      genderDropdown.addEventListener('change', updateTooltip);

      function getCustomTooltipMessage(gender, ageRange) {
        if (typeof ageRange !== 'string') return 'Invalid age range';
        const [low, high] = String(ageRange).split('-').map(Number);

        if (gender === 'women') {
          if (low === 20) return 'N.O. levels are at 90-100% – if you maintain a healthy lifestyle.';
          if (low === 30)
            return 'N.O. levels start to fall, draining energy, disrupting hormones, and slowing metabolism.';
          if (low === 40)
            return 'At 40, N.O. levels plummet, driving weight gain, mood swings, and poor sleep during perimenopause.';
          if (low === 50)
            return 'Menopause triggers a sharp N.O. decline, impacting heart health and diminishing sexual function.';
          if (low === 60)
            return 'Healthy N.O. levels are necessary to regulate blood pressure, sex drive, energy, and cognitive abilities.';
          if (low === 70)
            return 'By 70, N.O. production plummets to 10-15% of youthful levels, impacting cognition and heart health.';
        } else if (gender === 'men') {
          if (low === 20) return 'N.O. levels stay at 80-100% – if you maintain a healthy lifestyle';
          if (low === 30) return "At 30 years old, N.O. levels plummet for men, reducing men's energy and performance.";
          if (low === 40)
            return 'Continued sharp decline in N.O. levels with rising blood pressure and dwindling energy reserves.';
          if (low === 50)
            return 'Declining N.O. levels restrict blood flow, impairing heart health and sexual function.';
          if (low === 60)
            return 'Healthy N.O. levels are necessary to regulate blood pressure, sex drive, energy, and cognitive abilities.';
          if (low === 70)
            return 'By 70, N.O. production plummets to 10-15% of youthful levels, impacting cognition and heart health.';
        }
        return 'Is your blood pressure creeping up?';
      }

      function showCustomTooltip({ message }) {
        let tooltipEl = document.getElementById('custom-tooltip');

        if (!tooltipEl) {
          tooltipEl = document.createElement('div');
          tooltipEl.id = 'custom-tooltip';
          tooltipEl.style.position = 'absolute';
          tooltipEl.style.backgroundColor = '#FDFEFF';
          tooltipEl.style.color = '#333333';
          tooltipEl.style.padding = '10px';
          tooltipEl.style.border = '2px solid #000000';
          tooltipEl.style.borderRadius = '40px';
          tooltipEl.style.fontSize = '14px';
          tooltipEl.style.fontWeight = 'regular';
          tooltipEl.style.boxShadow = '0px 4px 6px rgba(0, 0, 0, 0.1);';
          tooltipEl.style.pointerEvents = 'none';
          tooltipEl.style.display = 'none';
          chartContainer.appendChild(tooltipEl);
        }

        // Position tooltip in upper right corner of the chart container
        tooltipEl.style.left = '37%';
        tooltipEl.style.top = '40%';
        tooltipEl.style.display = 'block';
        tooltipEl.innerText = message;
      }

      function hideCustomTooltip() {
        const tooltipEl = document.getElementById('custom-tooltip');
        if (tooltipEl) tooltipEl.style.display = 'none';
      }
    }

    createChart();
  });

  function initializeDynamicButtons() {
    const sectionRoot = document.getElementById('{{ section_id }}');
    if (!sectionRoot) return;

    const genderSelect = sectionRoot.querySelector('#gender-select');
    const dynamicButtons = sectionRoot.querySelectorAll('[data-dynamic-button="true"]');

    if (!genderSelect || dynamicButtons.length === 0) return;

    function syncDynamicButtonLinks(activeGender) {
      dynamicButtons.forEach((button) => {
        const defaultLink = button.dataset.defaultLink || '#';
        const linkWomen = button.dataset.linkWomen;
        const linkMen = button.dataset.linkMen;

        if (activeGender === 'women' && linkWomen) {
          button.href = linkWomen;
        } else if (activeGender === 'men' && linkMen) {
          button.href = linkMen;
        } else {
          button.href = defaultLink;
        }
      });
    }

    syncDynamicButtonLinks(genderSelect.value);
    genderSelect.addEventListener('change', function (event) {
      syncDynamicButtonLinks(event.target.value);
    });
  }

  initializeDynamicButtons();
</script>

