<style>
  #{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background-color: {{ section.settings.section_bg_color }};
    --c-routine-text: {{ section.settings.text_color }};
    display: flex;
    justify-content: center;

    & .c-routine__wrapper {
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
      box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    /* Background Image with Gradient Overlay */
    & .c-routine__bg {
      position: absolute;
      inset: 0;
      z-index: 0;

      & img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    & .c-routine__content {
      position: relative;
      z-index: 1;
      padding: 4rem 4rem 3rem 4rem;
      display: flex;
      flex-direction: column;
    }

    /* --- HEADER --- */
    & .c-routine__header {
      margin-bottom: 2.5rem;
    }

    & .c-routine__title {
      font-size: clamp(32px, 3.5vw, 42px);
      color: var(--c-routine-text);
      margin: 0 0 0.5rem 0;
      line-height: 1.2;
    }

    & .c-routine__subtitle {
      font-size: 16px;
      color: color-mix(in srgb, var(--c-routine-text) 80%, transparent);
      margin: 0;
    }

    /* --- MAIN CARD (#1 Match) --- */
    & .c-routine__main-card {
      
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
        background: rgba(255, 255, 255, 0.05);
      padding: 2rem;
      display: flex;
      align-items: center;
      gap: 3rem;
      margin-bottom: 3.5rem;
    }

    & .c-routine__main-img-box {
      flex: 0 0 350px;
      background-color: #ffffff;
      border-radius: 12px;
      padding: 2rem;
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;

      & img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }

    & .c-routine__main-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      color: var(--c-routine-text);
    }

    & .c-routine__match-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 24px;
      margin-bottom: 1rem;

      & svg {
        width: 24px;
        height: 24px;
        fill: var(--c-routine-text);
      }
    }

    & .c-routine__prod-title {
      font-size: 28px;
      margin: 0 0 1.5rem 0;
      color: var(--c-routine-text);
    }

    & .c-routine__features {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    & .c-routine__feature-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: color-mix(in srgb, var(--c-routine-text) 90%, transparent);
      line-height: 1.4;

      & svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        margin-top: 2px;
        color: var(--c-routine-text);
      }
    }

    & .c-routine__price-wrap {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 1.5rem;
    }

    & .c-routine__price-current {
      font-size: 24px;
      color: var(--c-routine-text);
    }

    & .c-routine__price-compare {
      font-size: 16px;
      color: color-mix(in srgb, var(--c-routine-text) 60%, transparent);
      text-decoration: line-through;
    }

    & .c-routine__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background-color: {{ section.settings.accent_color }};
      color: #ffffff;
      padding: 16px 32px;
      border-radius: 30px;
      text-decoration: none;
      font-size: 16px;
      transition: opacity 0.3s ease;
      width: fit-content;

      &:hover {
        opacity: 0.85;
      }
    }

    /* --- ADD-ONS --- */
    & .c-routine__addons-header {
      margin-bottom: 1.5rem;
    }

    & .c-routine__addons-title {
      font-size: 22px;
      color: var(--c-routine-text);
      margin: 0 0 0.25rem 0;
    }

    & .c-routine__addons-subtitle {
      font-size: 14px;
      color: color-mix(in srgb, var(--c-routine-text) 80%, transparent);
      margin: 0;
    }

    & .c-routine__addons-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    & .c-routine__addon-card {
       
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
background: rgba(255, 255, 255, 0.05);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: border-color 0.3s ease;
      cursor: pointer;
    }

    & .c-routine__addon-card.is-checked {
      border-color: {{ section.settings.accent_color }};
    }

    & .c-routine__checkbox {
      width: 22px;
      height: 22px;
      border: 2px solid rgba(255, 255, 255, 0.5);
      border-radius: 4px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;

      & svg {
        width: 14px;
        height: 14px;
        fill: none;
        stroke: #ffffff;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.2s ease;
      }
    }

    & .c-routine__addon-card.is-checked .c-routine__checkbox {
      background-color: {{ section.settings.accent_color }};
      border-color: {{ section.settings.accent_color }};

      & svg {
        opacity: 1;
        transform: scale(1);
      }
    }

    & .c-routine__addon-img-box {
      width: 100px;
      height: 100px;
      background-color: #ffffff;
      border-radius: 8px;
      padding: 0.5rem;
      flex-shrink: 0;

      & img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }

    & .c-routine__addon-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      color: var(--c-routine-text);
    }

    & .c-routine__addon-title {
      font-size: clamp(18px, 2vw, 24px);
      margin:  0.5rem 0;
      line-height: 1.2;
    }

    & .c-routine__addon-desc {
      font-size: clamp(14px, 1.5vw, 16px);
      color: color-mix(in srgb, var(--c-routine-text) 80%, transparent);
      line-height: 1.4;
      margin: 0 0 1rem 0;
    }

    & .c-routine__addon-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
    }

    & .c-routine__addon-prices {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    & .c-routine__addon-price {
      font-size: 16px;
    }

    & .c-routine__addon-compare {
      font-size: 12px;
      color: color-mix(in srgb, var(--c-routine-text) 60%, transparent);
      text-decoration: line-through;
    }

    & .c-routine__addon-btn {
      background: transparent;
      border: 1px solid var(--c-routine-text);
      color: var(--c-routine-text);
      padding: 6px 20px;
      border-radius: 20px;
      font-size: 12px;
      text-decoration: none;
      transition: background-color 0.3s ease, color 0.3s ease;

      &:hover {
        background-color: var(--c-routine-text);
        color: var(--c-routine-text-contrast, #000000);
      }
    }

    & .c-routine__addon-card.is-checked .c-routine__addon-btn {
      background-color: var(--c-routine-text);
      color: var(--c-routine-text-contrast, #000000);
    }

    /* --- FOOTER BAR --- */
    & .c-routine__footer {
      background-color: {{ section.settings.footer_bg }};
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 2rem;
      gap: 2rem;
      margin-top: 1.5rem;
      border-radius: 16px;
    }

    & .c-routine__footer-item {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #ffffff;

      & span {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
      }
    }

    & .c-routine__footer-divider {
      width: 1px;
      height: 20px;
      background-color: rgba(255, 255, 255, 0.2);
    }
  }

  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;

 

      & .c-routine__content {
        padding: 2.5rem 1rem;
      }

      & .c-routine__main-card {
        flex-direction: column;
        padding: 1.5rem;
        gap: 1.5rem;
      }

      & .c-routine__main-img-box {
        flex: auto;
        width: 100%;
        padding: 1.5rem;
        max-height: 300px;
      }

      & .c-routine__main-info {
        width: 100%;
      }

      & .c-routine__match-badge {
        font-size: 20px;
      }

      & .c-routine__prod-title {
        font-size: 24px;
      }

      & .c-routine__btn {
        width: 100%;
      }

      & .c-routine__addons-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      & .c-routine__addon-card {
        padding: 1.25rem;
        align-items: flex-start;
        flex-direction: column;
      }

      & .c-routine__addon-img-box {
        width: 80px;
        height: 80px;
      }

      & .c-routine__footer {
        flex-direction: column;
        gap: 1rem;
        padding: 2rem 1.5rem;
      }

      & .c-routine__footer-divider {
        display: none;
      }

      & .c-routine__footer-item {
        width: 100%;
        justify-content: flex-start;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="container-sl">
    <div class="c-routine__wrapper">
      <div class="c-routine__bg">
        {% if section.settings.bg_image != blank %}
          <img src="{{ section.settings.bg_image | image_url: width: 1600 }}" alt="" loading="lazy">
        {% endif %}
      </div>

      <div class="c-routine__content">
        <div class="c-routine__header">
          <h2 class="c-routine__title">{{ section.settings.title }}</h2>
          <p class="c-routine__subtitle">{{ section.settings.subtitle }}</p>
        </div>

        <div class="c-routine__main-card">
          <div class="c-routine__main-img-box">
            {% assign main_image = section.settings.main_image | default: section.settings.main_product.featured_image %}
            {% if main_image != blank %}
              <img
                src="{{ main_image | image_url: width: 600 }}"
                alt="{{ section.settings.main_title | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </div>

          <div class="c-routine__main-info">
            <div class="c-routine__match-badge">
              {% if section.settings.main_badge_icon != blank %}
                {{ section.settings.main_badge_icon }}
              {% endif %}
              <span>{{ section.settings.main_badge }}</span>
            </div>

            {% render 'okendo-reviews-product-rating-summary', product: section.settings.main_product %}

            <h3 class="c-routine__prod-title">{{ section.settings.main_title }}</h3>

            <ul class="c-routine__features">
              {% for block in section.blocks %}
                {% if block.type == 'main_feature' %}
                  <li class="c-routine__feature-item">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            {%- comment -%} Find the variant with one-time purchase enabled AND both D2C & B2B {%- endcomment -%}
            {%- assign main_variant = nil -%}
            {%- for variant in section.settings.main_product.variants -%}
              {%- if variant.metafields.custom.disable_one_time_purchase != true and variant.metafields.custom.both_d2c_b2b.value == true -%}
                {%- assign main_variant = variant -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless main_variant -%}
              {%- assign main_variant = section.settings.main_product.selected_or_first_available_variant -%}
            {%- endunless -%}
            {%- assign main_display_price = main_variant.price -%}
            {%- assign main_display_compare = main_variant.compare_at_price -%}
            {%- if main_display_price == 0 -%}
              {%- for variant in section.settings.main_product.variants -%}
                {%- if variant.price > 0 -%}
                  {%- assign main_display_price = variant.price -%}
                  {%- assign main_display_compare = variant.compare_at_price -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
            {% if section.settings.main_price != blank %}
              {% assign main_price_display = section.settings.main_price %}
            {% else %}
              {% assign main_price_display = main_display_price | money %}
            {% endif %}
            {% if section.settings.main_compare != blank %}
              {% assign main_compare_display = section.settings.main_compare %}
            {% elsif main_display_compare > main_display_price %}
              {% assign main_compare_display = main_display_compare | money %}
            {% endif %}
            {% assign main_btn_display = section.settings.main_btn_text | default: 'Add to Cart' %}

            <div class="c-routine__price-wrap">
              <span class="c-routine__price-current">{{ main_price_display }}</span>
              {% if main_compare_display != blank %}
                <span class="c-routine__price-compare">{{ main_compare_display }}</span>
              {% endif %}
            </div>

            {% if section.settings.main_product != blank %}
              {% if section.settings.redirect_to_pdp %}
                <a href="{{ section.settings.main_product.url }}" class="c-routine__btn">
                  {{ main_btn_display }}
                </a>
              {% else %}
                {%- assign main_form_id = 'MainProductForm-' | append: section.id -%}
                {%- form 'product', section.settings.main_product, id: main_form_id, class: 'c-routine__main-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                  <input
                    type="hidden"
                    name="id"
                    value="{{ main_variant.id }}"
                  >
                  <button
                    type="submit"
                    name="add"
                    class="c-routine__btn js-main-add-btn"
                    id="MainAddToCart-{{ section.id }}"
                    data-product-id="{{ main_variant.id }}"
                    data-disableFlyout="true"
                    {% unless main_variant.available %}disabled{% endunless %}
                  >
                    <span class="js-main-btn-text">
                      {%- if main_variant.available -%}
                        {{ main_btn_display }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
                      {%- endif -%}
                    </span>
                  </button>
                {%- endform -%}
              {% endif %}
            {% endif %}
          </div>
        </div>

        <div class="c-routine__addons-header">
          <h3 class="c-routine__addons-title">{{ section.settings.addons_title }}</h3>
          <p class="c-routine__addons-subtitle">{{ section.settings.addons_subtitle }}</p>
        </div>

        <div class="c-routine__addons-grid">
          {% for block in section.blocks %}
            {% if block.type == 'addon' %}
              {% assign addon_product = block.settings.product %}
              {%- assign addon_variant = addon_product.selected_or_first_available_variant -%}
              {%- if block.settings.variant_index != blank -%}
                {%- assign vi = block.settings.variant_index | plus: 0 -%}
                {%- assign picked_variant = addon_product.variants[vi] -%}
                {%- if picked_variant -%}
                  {%- assign addon_variant = picked_variant -%}
                {%- endif -%}
              {%- endif -%}
              {% assign addon_title = block.settings.title | default: addon_product.title %}
              {% assign addon_image = block.settings.image | default: addon_product.featured_image %}
              {%- assign addon_display_price = addon_variant.price -%}
              {%- assign addon_display_compare = addon_variant.compare_at_price -%}
              {%- if addon_display_price == 0 -%}
                {%- for variant in addon_product.variants -%}
                  {%- if variant.price > 0 -%}
                    {%- assign addon_display_price = variant.price -%}
                    {%- assign addon_display_compare = variant.compare_at_price -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {% if block.settings.price != blank %}
                {% assign addon_price = block.settings.price %}
              {% else %}
                {% assign addon_price = addon_display_price | money %}
              {% endif %}
              {% assign addon_compare = blank %}
              {% if block.settings.compare != blank %}
                {% assign addon_compare = block.settings.compare %}
              {% elsif addon_display_compare > addon_display_price %}
                {% assign addon_compare = addon_display_compare | money %}
              {% endif %}

              <div
                class="c-routine__addon-card js-addon-card {% if block.settings.is_checked %}is-checked{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% unless section.settings.redirect_to_pdp %}
                  <div class="c-routine__checkbox">
                    <svg viewBox="0 0 24 24">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                {% endunless %}

                <div class="c-routine__addon-img-box">
                  {% if addon_image != blank %}
                    <img
                      src="{{ addon_image | image_url: width: 200 }}"
                      alt="{{ addon_title | escape }}"
                      loading="lazy"
                    >
                  {% else %}
                    {{ 'product-2' | placeholder_svg_tag }}
                  {% endif %}
                </div>

                <div class="c-routine__addon-info">
                  {% render 'okendo-reviews-product-rating-summary', product: addon_product %}

                  <h4 class="c-routine__addon-title">{{ addon_title }}</h4>
                  <p class="c-routine__addon-desc">{{ block.settings.description }}</p>

                  <div class="c-routine__addon-bottom">
                    <div class="c-routine__addon-prices">
                      <span class="c-routine__addon-price">{{ addon_price }}</span>
                      {% if addon_compare != blank and addon_compare != addon_price %}
                        <span class="c-routine__addon-compare">{{ addon_compare }}</span>
                      {% endif %}
                    </div>
                    {% if addon_product != blank %}
                      {% if section.settings.redirect_to_pdp %}
                        <a href="{{ addon_product.url }}" class="c-routine__addon-btn">
                          Shop
                        </a>
                      {% else %}
                        {%- assign addon_form_id = 'AddonProductForm-' | append: block.id -%}
                        {%- form 'product', addon_product, id: addon_form_id, class: 'c-routine__addon-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ addon_variant.id }}"
                          >
                          <button
                            type="submit"
                            name="add"
                            class="c-routine__addon-btn js-addon-btn"
                            data-product-id="{{ addon_product.id }}"
                            data-variant-id="{{ addon_variant.id }}"
                            data-disableFlyout="true"
                            {% unless addon_variant.available %}disabled{% endunless %}
                          >
                            <span class="js-btn-text">Add</span>
                          </button>
                        {%- endform -%}
                      {% endif %}
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
        <div class="c-routine__footer">
      {% for block in section.blocks %}
        {% if block.type == 'footer_item' %}
          <div class="c-routine__footer-item" {{ block.shopify_attributes }}>
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg viewBox="0 0 24 24">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            {% endif %}
            <span>{{ block.settings.text }}</span>
          </div>
          {% unless forloop.last %}
            <div class="c-routine__footer-divider"></div>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section.id }}';
    const container = document.getElementById(sectionId);
    if (!container) return;

    function addToCart(form, button, onSuccess) {
      if (!form || !button) return;
      if (button.disabled || button.classList.contains('loading')) return;

      button.classList.add('loading');
      button.setAttribute('aria-disabled', 'true');

      const formData = new FormData(form);

      fetch(window.routes?.cart_add_url || '/cart/add.js', {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          Accept: 'application/json',
        },
        body: formData,
      })
        .then((response) => response.json())
        .then((response) => {
          if (response.status) {
            console.error('Error adding to cart:', response.description);
            return;
          }

          if (typeof onSuccess === 'function') onSuccess();

          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            cartDrawer.render();
            cartDrawer.open();
          }
        })
        .catch((error) => console.error('Add to cart failed:', error))
        .finally(() => {
          button.classList.remove('loading');
          button.removeAttribute('aria-disabled');
        });
    }

    // Addon card visual toggle (does not affect button state)
    const addonCards = container.querySelectorAll('.js-addon-card');
    addonCards.forEach((card) => {
      card.addEventListener('click', function (e) {
        if (e.target.closest('.js-addon-btn') || e.target.closest('a') || e.target.closest('form')) return;
        this.classList.toggle('is-checked');
      });
    });

    // Main product add to cart
    const mainForm = document.getElementById('MainProductForm-' + sectionId);
    const mainBtn = document.getElementById('MainAddToCart-' + sectionId);
    if (mainForm && mainBtn) {
      mainBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        addToCart(mainForm, mainBtn, function () {
          const btnText = mainBtn.querySelector('.js-main-btn-text');
          if (btnText) btnText.textContent = 'Added';
        });
      });
    }

    // Addon products add to cart
    const addonBtns = container.querySelectorAll('.js-addon-btn');
    addonBtns.forEach((btn) => {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const form = btn.closest('form');
        const card = btn.closest('.js-addon-card');
        addToCart(form, btn, function () {
          const btnText = btn.querySelector('.js-btn-text');
          if (btnText) btnText.textContent = 'Added';
          if (card) card.classList.add('is-checked');
        });
      });
    });
  });
</script>

