                                  >
                                    {% render 'swatch', handle: value %}
                                    <span class="sr-only">{{ value }}</span>
                                  </label>
                                {%- else -%}
                                  <label
                                    class="px-3 py-2 text-xs font-bold tracking-wide uppercase bg-transparent border border-transparent rounded-full cursor-pointer text-brand md:px-4 md:py-3 md:text-sm peer-checked:border-brand peer-focus-visible:outline-dashed peer-focus-visible:outline-2 peer-focus-visible:outline-current peer-focus-visible:outline-offset-2"
                                    for="{{ section.id }}-{{ option.name }}-{{ forloop.index0 }}"
                                  >
                                    {{ value }}
                                  </label>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      </fieldset>
                    {%- endfor -%}

                    {%- comment -%} === SELLING PLAN SELECTION (Standard Shopify Format) === {%- endcomment -%}
                    {%- comment -%} This section only shows if use_builtin_subscription_ui is true AND product has selling plans {%- endcomment -%}
                    {%- if use_builtin_subscription_ui and product.selling_plan_groups.size > 0 -%}
                      <fieldset class="mt-6 space-y-3 text-sm product-form__input" data-selling-plan-fieldset>
                        <legend class="block mb-2 text-2xl">
                          <span>Purchase Options:</span>
                        </legend>

                        {%- comment -%} One-time purchase option {%- endcomment -%}
                        {%- unless product.requires_selling_plan -%}
                          <label
                            class="selling-plan-option option-container flex items-center border border-transparent rounded-lg p-4 bg-[#ebe8e6] cursor-pointer"
                            for="selling-plan-none-{{ section.id }}"
                          >
                            <input
                              type="radio"
                              id="selling-plan-none-{{ section.id }}"
                              name="selling_plan"
                              value=""
                              form="product-form-{{ section.id }}"
                              class="mr-4"
                              {% unless product.selected_selling_plan %}
                                checked
                              {% endunless %}
                            >
                            <div class="flex flex-col">
                              <h3 class="text-lg">One-time Purchase</h3>
                            </div>
                            <span class="ml-auto text-[#D54F2F] font-semibold" data-otp-price>
                              {{ product.selected_or_first_available_variant.price | money }}
                            </span>
                          </label>
                        {%- endunless -%}

                        {%- comment -%} Subscription options {%- endcomment -%}
                        {%- for group in product.selling_plan_groups -%}
                          {%- for plan in group.selling_plans -%}
                            {%- assign plan_allocation = product.selected_or_first_available_variant.selling_plan_allocations
                              | where: 'selling_plan_id', plan.id
                              | first
                            -%}
                            {%- if plan_allocation -%}
                              {%- assign subscription_price = plan_allocation.per_delivery_price -%}
                              {%- assign one_time_price = product.selected_or_first_available_variant.price -%}
                              {%- assign savings_amount = one_time_price | minus: subscription_price -%}
                              {%- assign savings_percentage = savings_amount
                                | times: 100
                                | divided_by: one_time_price
                              -%}

                              <label
                                class="selling-plan-option option-container relative flex items-center border border-transparent rounded-lg p-4 bg-[#ebe8e6] cursor-pointer"
                                for="selling-plan-{{ plan.id }}-{{ section.id }}"
                                data-selling-plan-id="{{ plan.id }}"
                              >
                                {%- if forloop.first and forloop.parentloop.first -%}
                                  <div class="absolute top-[-14px] right-[10px] px-6 font-medium py-2 bg-[#1B1C29] text-white rounded-3xl text-xs tracking-widest leading-[19px]">
                                    MOST POPULAR
                                  </div>
                                {%- endif -%}
                                <input
                                  type="radio"
                                  id="selling-plan-{{ plan.id }}-{{ section.id }}"
                                  name="selling_plan"
                                  value="{{ plan.id }}"
                                  form="product-form-{{ section.id }}"
                                  class="mr-4"
                                  {% if product.selected_selling_plan.id == plan.id %}
                                    checked
                                  {% endif %}
                                >
                                <div class="flex flex-col">
                                  <h3 class="text-lg">{{ plan.name }}</h3>
                                  <ul class="mt-1 text-sm subscription-list">
                                    <li>Save {{ savings_percentage | round: 1 }}%</li>
                                    <li>{{ plan.description | default: 'Delivered on your schedule' }}</li>
                                    {% for item in shop.metaobjects.subscription_callout.values %}
                                      <li>{{ item.callout_title }}</li>
                                    {% endfor %}
                                  </ul>
                                </div>
                                <div class="flex flex-col self-start ml-auto text-[#D54F2F] mt-2">
                                  <span class="ml-auto font-semibold" data-subscription-price>
                                    {{- subscription_price | money -}}
                                  </span>
                                  <span class="ml-auto text-xs line-through opacity-50">
                                    {{- one_time_price | money -}}
                                  </span>
                                </div>
                              </label>
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endfor -%}
                      </fieldset>
                    {%- endif -%}

                    {%- comment -%} === PLACEHOLDER FOR 3RD PARTY SUBSCRIPTION APPS === {%- endcomment -%}
                    {%- comment -%}
                      Third-party apps like Recharge, Bold Subscriptions, Loop, Appstle, etc.
                      will automatically inject their subscription widgets here based on
                      the product's selling plan groups. The standard form structure above
                      (with name="id" and name="selling_plan") ensures compatibility.
                    {%- endcomment -%}
                    <div class="third-party-subscription-widget-placeholder" data-product-id="{{ product.id }}"></div>

                    <!-- CSS: Style the option container and selected state -->
                    <style>
                      .third-party-variant-picker .option-container {
                        transition: background 0.2s, border-color 0.2s;
                      }
                      .third-party-variant-picker .option-container.selected,
                      .third-party-variant-picker .option-container:has(input:checked) {
                        border-color: #1b1c29;
                        background-color: white;
                      }
                      .third-party-variant-picker .selling-plan-option input[type='radio'] {
                        accent-color: #1b1c29;
                      }
                    </style>

                    <!-- JavaScript: Handle variant and selling plan selection -->
                    <script>
                      document.addEventListener('DOMContentLoaded', function () {
                        const section = document.querySelector(
                          '[data-section="{{ section.id }}"][data-third-party-mode="true"]'
                        );
                        if (!section) return;

                        const sellingPlanOptions = section.querySelectorAll('.selling-plan-option');

                        // Update selected state for selling plan options
                        function updateSellingPlanSelected() {
                          sellingPlanOptions.forEach((option) => {
                            const radio = option.querySelector('input[type="radio"]');
                            if (radio && radio.checked) {
                              option.classList.add('selected');
                            } else {
                              option.classList.remove('selected');
                            }
                          });
                        }

                        // Attach change event to selling plan radios
                        sellingPlanOptions.forEach((option) => {
                          const radio = option.querySelector('input[type="radio"]');
                          if (radio) {
                            radio.addEventListener('change', updateSellingPlanSelected);
                          }
                        });

                        // Initialize on load
                        updateSellingPlanSelected();
                      });
                    </script>

                    <script type="application/json" id="ProductVariantsData-{{ section.id }}">
                      {{ product.variants | json }}
                    </script>

                    <script>
                      window.productVariants = window.productVariants || {};
                      window.productVariants['{{ section.id }}'] = JSON.parse(
                        document.getElementById('ProductVariantsData-{{ section.id }}').textContent
                      );
                    </script>
                  </variant-radios>
                {%- endif -%}
              {%- endunless -%}

            {%- when 'buy_buttons' -%}
              <div {{ block.shopify_attributes }}>
                {%- if quickshop -%}
                  <a href="{{ product.url }}" class="mb-2 button button--secondary button--full-width">View Details</a>
                {%- endif -%}

                {%- comment -%} Check if login is required and user is not logged in {%- endcomment -%}
                {%- if block.settings.require_login and customer == null -%}
                  {%- comment -%} Show login button when user is not authenticated {%- endcomment -%}
                  <div class="login-required-wrapper">
                    <a
                      href="{{ block.settings.login_redirect_url }}"
                      class="button button--full-width {% if block.settings.show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
                    >
                      {{ block.settings.login_button_text | default: 'Login to Purchase' }}
                    </a>
                  </div>
                {%- else -%}
                  {%- comment -%} Show normal buy buttons when logged in or login not required {%- endcomment -%}
                  {%- if block.settings.show_stock_info -%}
                    {% render 'product-stock-details', product: product, id: section.id, block: block %}
                  {%- endif -%}
                  <product-form class="mb-4 product-form">
                    <div
                      data-product-form-errors
                      role="alert"
                      hidden
                    >
                      <span data-product-form-error-msg></span>
                    </div>
                    {%- form 'product',
                      product,
                      data-productid: product.id,
                      id: product_form_id,
                      class: 'form',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      {%- if block.settings.gift_card_recipient_feature_active -%}
                        {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                      {%- endif -%}
                      {% if product.template_suffix == 'alternate-subscription' %}
                        {% if customer.b2b? %}
                          <input
                            type="hidden"
                            name="id"
                            id="SelectedVariantId"
                            value="{{ product.selected_or_first_available_variant.id }}"
                          >
                        {% else %}
                          <input
                            type="hidden"
                            name="id"
                            data-productid="{{ product.id }}"
                            data-productid="{{ product.id }}"
                            value="{{ product.selected_or_first_available_variant.id }}"
                          >
                        {% endif %}
                      {% else %}
                        <input
                          type="hidden"
                          name="id"
                          id="SelectedVariantId"
                          value="{{ product.selected_or_first_available_variant.id }}"
                        >
                      {% endif %}
                      <div class="product-form__buttons">
                        <div class="flex gap-2 mb-2">
                          {% if customer.b2b? %}
                            <div class="product-form__quantity" {{ block.shopify_attributes }}>
                              <label class="sr-only" for="Quantity-{{ section.id }}">
                                {{ 'products.product.quantity.label' | t }}
                              </label>
                              <quantity-input class="relative flex w-24 h-full border border-black rounded-full">
                                <button
                                  class="flex w-8 text-sm border-none no-js-hidden shrink-0"
                                  name="minus"
                                  type="button"
                                >
                                  <span class="sr-only">
                                    {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                                  </span>
                                  <span class="w-3 m-auto opacity-50 pointer-events-none">
                                    {%- render 'icon-minus' -%}
                                  </span>
                                </button>
                                <input
                                  class="w-full h-full p-1 text-base text-center bg-transparent border-none appearance-none focus:ring-0 grow"
                                  data-quantity
                                  type="number"
                                  name="quantity"
                                  id="Quantity-{{ section.id }}"
                                  min="1"
                                  value="1"
                                  form="product-form-{{ section.id }}"
                                >
                                <button
                                  class="flex w-8 text-sm border-none no-js-hidden shrink-0"
                                  name="plus"
                                  type="button"
                                >
                                  <span class="sr-only">
                                    {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                                  </span>
                                  <span class="w-3 m-auto opacity-50 pointer-events-none">
                                    {%- render 'icon-plus' -%}
                                  </span>
                                </button>
                              </quantity-input>
                            </div>
                          {% endif %}
                          {%- assign selected_variant = product.variants
                            | where: 'id', product.selected_or_first_available_variant.id
                            | first
                          -%}
                          <button
                            type="submit"
                            name="add"
                            data-product-handle="{{ product.handle }}"
                            data-product-id="{{ product.selected_or_first_available_variant.id }}"
                            data-disableFlyout="{{ product.metafields.custom.disable_subscription_flyout }}"
                            data-metadata="
                              [
                                {% for variant in product.variants %}
                                  {%- if variant.metafields.custom.b2bonly.value != true or customer.b2b? -%}
                                  {
                                    "id": {{ variant.id }},
                                    "is_most_popular_subscription": "{{ variant.metafields.custom.is_most_popular_subscription | escape }}",
                                    "disable_one_time_purchase": "{{ variant.metafields.custom.disable_one_time_purchase | escape }}"
                                  }{% unless forloop.last %},{% endunless %}
                                  {%- endif -%}
                                {% endfor %}
                              ]
                            "
                            {% if selected_variant and selected_variant.available == false %}
                              disabled
                            {% endif %}
                            class=" {% if product.metafields.custom.disable_subscription_flyout != true or customer.b2b? %} product-form__submit {% endif %} button button--full-width {% if block.settings.show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
                          >
                            {%- if selected_variant and selected_variant.available -%}
                              {%- if product.selected_selling_plan or product.requires_selling_plan -%}
                                {{ 'products.product.subscribe' | t }}
                              {%- else -%}
                                {{ 'products.product.add_to_cart' | t }}
                              {%- endif -%}
                            {%- else -%}
                              {{ 'products.product.sold_out' | t }}
                            {%- endif -%}
                          </button>
                        </div>
                        {%- if block.settings.show_dynamic_checkout -%}
                          {{ form | payment_button }}
                        {%- endif -%}
                      </div>
                    {%- endform -%}
                  </product-form>
                  <div {{ block.shopify_attributes }}>
                    {%- form 'product',
                      product,
                      data-productid: product.id,
                      id: 'product-form-installment',
                      class: 'installment caption-large'
                    -%}
                      <input
                        type="hidden"
                        name="id"
                        data-productid="{{ product.id }}"
                        value="{{ product.selected_or_first_available_variant.id }}"
                      >
                      {%- if block.settings.show_shoppay_widget -%}
                        {{ form | payment_terms }}
                      {%- endif -%}
                      {%- if block.settings.show_truemed_widget -%}
                        {% render 'truemed-widget' %}
                      {%- endif -%}
                    {%- endform -%}
                  </div>

                  {%- if block.settings.show_pickup -%}
                    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
                      | where: 'pick_up_enabled', true
                    -%}

                    <pickup-availability
                      class="relative block p-4 rounded-md no-js-hidden bg-black/5"
                      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
                        available
                      {% endif -%}
                      data-base-url="{{ shop.url }}{{ routes.root_url }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      data-has-only-default-variant="{{ product.has_only_default_variant }}"
                    >
                      <template>
                        <pickup-availability-preview>
                          <span class="w-6">{% render 'icon-unavailable' %}</span>
                          <div>
                            <p>{{ 'products.product.pickup_availability.unavailable' | t }}</p>
                            <button class="button--text">
                              {{ 'products.product.pickup_availability.refresh' | t }}
                            </button>
                          </div>
                        </pickup-availability-preview>
                      </template>
                    </pickup-availability>
                    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
                  {%- endif -%}
                {%- endif -%}
                {%- comment -%} End of login check {%- endcomment -%}
              </div>

            {%- when 'upsell' -%}
              {%- if block.settings.product and block.settings.product.available -%}
                <div class="grid items-center gap-4 rounded-3xl p-4 bg-[#EBE8E6] grid-cols-2 md:grid-cols-3 ">
                  <div class="col-span-1 md:col-span-2">
                    {%- if block.settings.title != blank -%}
                      <div class="block text-xs uppercase subhead text-navy ">
                        {{- block.settings.title -}}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="block text-sm text-navy ">
                        {{- block.settings.text -}}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.product.available -%}
                      {%- assign product_form_id = 'product-form-' | append: block.settings.product.id -%}
                      <product-form class="block mb-4 product-form">
                        <div
                          data-product-form-errors
                          role="alert"
                          hidden
                        >
                          <span data-product-form-error-msg></span>
                        </div>
                        {%- form 'product',
                          block.settings.product,
                          id: product_form_id,
                          class: 'form',
                          novalidate: 'novalidate',
                          data-type: 'add-to-cart-form'
                        -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ block.settings.product.selected_or_first_available_variant.id }}"
                          >
                          <div class="product-form__buttons">
                            <div class="flex gap-2 mt-2 mb-2">
                              <button
                                aria-label="Add to cart"
                                type="submit"
                                name="add"
                                class="bg-transparent border-2 button uppercase button--outline-brand !py-2 border-brand text-brand"
                                {% if block.settings.product.selected_or_first_available_variant.available == false %}
                                  disabled
                                {% endif %}
                              >
                                Buy Sample
                              </button>
                            </div>
                          </div>
                        {%- endform -%}
                      </product-form>
                    {% endif %}
                  </div>
                  <div class="">
                    {%- if block.settings.product.featured_image != blank -%}
                      <a href="{{ block.settings.product.url }}">
                        <div class="w-full mx-auto">
                          {% render 'image', image: block.settings.product.featured_image, classes: 'image' %}
                        </div>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

            {%- when 'c-upsell' -%}
              {%- if block.settings.product and block.settings.product.available -%}
                <style>
                  .c-upsell-container {
                    background: #ebe8e4;
                    border-radius: 16px;
                    border: var(--Stroke-Border-Width, 1px) solid var(--Text-Navy, #080b2b);
                    background: var(--Secondary-Dark-Cream, #ebe8e4);
                    padding: 20px;
                    position: relative;

                    display: flex;
                    flex-direction: column;
                    gap: 20px;
                  }

                  .c-upsell-badge {
                    position: absolute;
                    top: -8px;
                    left: 20px;
                    background-color: #1e293b;
                    color: white;
                    padding: 8px 16px;
                    border-radius: 20px;
                    font-size: 12px;
                    line-height: normal;
                    text-transform: uppercase;
                    letter-spacing: 0.6px;
                    z-index: 2;
                    border: 2px solid white;
                  }

                  .c-upsell-content {
                    display: flex;
                    flex-direction: row;
                    gap: 20px;
                    align-items: center;
                    margin-top: 8px;
                  }

                  .c-upsell-image {
                    width: 120px;
                    height: 120px;
                    flex-shrink: 0;
                    border-radius: 12px;
                    overflow: hidden;
                  }

                  .c-upsell-image img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    display: block;
                  }

                  .c-upsell-text {
                    flex: 1;
                    display: flex;
                    flex-direction: column;
                    gap: 8px;
                  }

                  .c-upsell-title {
                    color: #d95d39;
                    font-size: 24px;
                    font-weight: 400;
                    font-style: italic;
                    margin: 0;
                    line-height: 1.2;
                    font-family: 'Cormorant Garamond', serif;
                  }

                  .c-upsell-subtitle {
                    font-size: 18px;

                    margin: 0;
                    line-height: 1.3;
                  }

                  .c-upsell-button {
                    background-color: #d95d39;
                    color: white;
                    border: none;
                    border-radius: 50px;
                    padding: 10px 12px;
                    font-size: 14px;
                    font-weight: 700;
                    text-transform: uppercase;

                    cursor: pointer;
                    transition: all 0.3s ease;
                    margin-top: 8px;
                    align-self: flex-start;
                    text-decoration: none;
                    display: inline-block;
                    text-align: center;
                    line-height: normal;
                  }

                  .c-upsell-button:hover {
                    background-color: #b8432a;
                    transform: translateY(-2px);
                    box-shadow: 0 4px 12px rgba(217, 93, 57, 0.3);
                  }

                  @media (max-width: 768px) {
                    .c-upsell-content {
                      flex-direction: column;
                      text-align: center;
                      gap: 16px;
                    }

                    .c-upsell-image {
                      width: 100px;
                      height: 100px;
                      margin: 0 auto;
                    }

                    .c-upsell-title {
                      font-size: 20px;
                    }

                    .c-upsell-subtitle {
                      font-size: 16px;
                    }

                    .c-upsell-button {
                      align-self: center;
                    }
                  }
                </style>

                <div class="c-upsell-container" {{ block.shopify_attributes }}>
                  <div class="c-upsell-badge">{{ block.settings.badge_text | default: 'EXCLUSIVE TRIAL OFFER' }}</div>

                  <div class="c-upsell-content">
                    {% if block.settings.product.available %}
                      {%- assign product_form_id = 'c-upsell-image-form-' | append: block.settings.product.id -%}
                      <product-form class="c-upsell-image-form">
                        <div data-product-form-errors role="alert" hidden>
                          <span data-product-form-error-msg></span>
                        </div>
                        {%- form 'product',
                          block.settings.product,
                          id: product_form_id,
                          class: 'form',
                          novalidate: 'novalidate',
                          data-type: 'add-to-cart-form'
                        -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ block.settings.product.selected_or_first_available_variant.id }}"
                          >
                          <button
                            type="submit"
                            name="add"
                            class="c-upsell-image"
                          >
                            {% render 'image', image: block.settings.product.featured_image, classes: 'image' %}
                          </button>
                        {%- endform -%}
                      </product-form>
                    {% else %}
                      <div class="c-upsell-image">
                        {% render 'image', image: block.settings.product.featured_image, classes: 'image' %}
                      </div>
                    {% endif %}

                    <div class="c-upsell-text">
                      {%- if block.settings.title != blank -%}
                        <h3 class="c-upsell-title">{{ block.settings.title }}</h3>
                      {%- endif -%}
                      {%- if block.settings.subtitle != blank -%}
                        <p class="c-upsell-subtitle">{{ block.settings.subtitle }}</p>
                      {%- endif -%}

                      {%- if block.settings.product.available -%}
                        {%- assign product_form_id = 'c-upsell-form-' | append: block.settings.product.id -%}
                        <product-form class="c-upsell-form">
                          <div data-product-form-errors role="alert" hidden>
                            <span data-product-form-error-msg></span>
                          </div>
                          {%- form 'product',
                            block.settings.product,
                            id: product_form_id,
                            class: 'form',
                            novalidate: 'novalidate',
                            data-type: 'add-to-cart-form'
                          -%}
                            <input
                              type="hidden"
                              name="id"
                              value="{{ block.settings.product.selected_or_first_available_variant.id }}"
                            >
                            <button
                              type="submit"
                              name="add"
                              class="c-upsell-button"
                              {% if block.settings.product.selected_or_first_available_variant.available == false %}
                                disabled
                              {% endif %}
                            >
                              {{ block.settings.button_text | default: 'GET MY SAMPLE PACK' }}
                            </button>
                          {%- endform -%}
                        </product-form>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}

            {%- when 'callouts' -%}
              <div class="!font-headerMedium uppercase text-sm tracking-widest !mt-8">{{ block.settings.heading }}</div>
              <ul class="w-full flex justify-between !mt-1">
                {% assign callouts = product.metafields.custom.callouts
                  | remove: '"'
                  | remove: '['
                  | remove: ']'
                  | split: ','
                %}
                {% for callout in callouts %}
