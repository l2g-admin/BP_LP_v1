{%- unless quickshop -%}
  {%- comment -%}
    ============================================
    STICKY BUTTON - PENDING CLIENT APPROVAL
    ============================================
    This code adds a configurable sticky button that can be either:
    - Back to Top (default behavior)
    - Add to Cart (syncs with product variant selection)

    To activate: Add the "Sticky Button" block in the theme editor
    ============================================

    {%- assign sticky_button_block = section.blocks | where: "type", "sticky_button" | first -%}
    {%- assign sticky_button_type = sticky_button_block.settings.button_type | default: 'back_to_top' -%}

    <div
      aria-hidden="true"
      data-back-to-top
      class="fixed bottom-0 z-10 w-screen p-4 text-center transition-opacity opacity-0 pointer-events-none"
      style="{% if sticky_button_block.settings.bg_color != blank %}background-color: {{ sticky_button_block.settings.bg_color }};{% endif %}">

      {%- if sticky_button_type == 'add_to_cart' -%}
        {%- comment -%} Sticky Add to Cart Button {%- endcomment -%}
        <form method="post" action="{{ routes.cart_add_url }}" class="sticky-atc-form inline-block">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" class="sticky-variant-id">
          <input type="hidden" name="quantity" value="1">
          {%- if product.selected_or_first_available_variant.available -%}
            <button
              type="submit"
              class="max-w-full button md:px-12 button--primary w-80 sticky-atc-button"
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              <span class="sticky-atc-text">{{ sticky_button_block.settings.button_text | default: 'Add to Cart' }}</span>
              <span class="sticky-atc-price">{{ product.selected_or_first_available_variant.price | money }}</span>
            </button>
          {%- else -%}
            <button
              type="button"
              class="max-w-full button md:px-12 button--secondary w-80"
              disabled>
              <span>{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</span>
            </button>
          {%- endif -%}
        </form>

        <script>
          document.addEventListener('DOMContentLoaded', function() {
            // Sync sticky ATC with main variant selector
            const mainVariantInput = document.querySelector('input[name="id"]');
            const stickyVariantInput = document.querySelector('.sticky-variant-id');
            const stickyAtcButton = document.querySelector('.sticky-atc-button');
            const stickyAtcPrice = document.querySelector('.sticky-atc-price');

            if (mainVariantInput && stickyVariantInput) {
              // Create observer for variant changes
              const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                  if (mutation.type === 'attributes' && mutation.attributeName === 'value') {
                    const newVariantId = mainVariantInput.value;
                    stickyVariantInput.value = newVariantId;

                    // Update price if productVariants is available
                    if (window.productVariants && stickyAtcPrice) {
                      const selectedVariant = window.productVariants.find(v => v.id == newVariantId);
                      if (selectedVariant) {
                        stickyAtcPrice.textContent = Shopify.formatMoney(selectedVariant.price);

                        // Update button state based on availability
                        if (stickyAtcButton) {
                          stickyAtcButton.disabled = !selectedVariant.available;
                          if (!selectedVariant.available) {
                            stickyAtcButton.querySelector('.sticky-atc-text').textContent = '{{ "products.product.sold_out" | t | default: "Sold Out" }}';
                          } else {
                            stickyAtcButton.querySelector('.sticky-atc-text').textContent = '{{ sticky_button_block.settings.button_text | default: "Add to Cart" }}';
                          }
                        }
                      }
                    }
                  }
                });
              });

              observer.observe(mainVariantInput, { attributes: true });
            }

            // Handle form submission via AJAX
            const stickyForm = document.querySelector('.sticky-atc-form');
            if (stickyForm) {
              stickyForm.addEventListener('submit', function(e) {
                e.preventDefault();

                const formData = new FormData(stickyForm);

                fetch('/cart/add.js', {
                  method: 'POST',
                  body: formData
                })
                .then(response => response.json())
                .then(data => {
                  // Trigger cart update event
                  document.dispatchEvent(new CustomEvent('cart:refresh'));

                  // Open cart drawer if it exists
                  const cartDrawer = document.querySelector('cart-drawer');
                  if (cartDrawer && typeof cartDrawer.open === 'function') {
                    cartDrawer.open();
                  } else {
                    // Fallback: show notification or redirect to cart
                    const cartNotification = document.querySelector('cart-notification');
                    if (cartNotification) {
                      cartNotification.renderContents(data);
                    }
                  }
                })
                .catch(error => {
                  console.error('Error adding to cart:', error);
                });
              });
            }
          });
        </script>
      {%- else -%}
        {%- comment -%} Default Back to Top Button {%- endcomment -%}
        <button
          tabindex="-1"
          aria-hidden="true"
          type="button"
          class="max-w-full button md:px-12 button--primary w-80"
          onclick="window.scroll({top: 0, behavior: 'smooth' });">
          <span>{{ sticky_button_block.settings.button_text | default: 'Back to top' }}</span>
        </button>
      {%- endif -%}
    </div>
    <script type="module">
      import { backToTop } from "{{ 'backToTop.js' | asset_url }}"
      backToTop()
    </script>
  {%- endcomment -%}

  {%- comment -%} DEFAULT BACK TO TOP BUTTON (Active until client approval) {%- endcomment -%}
  <div
    aria-hidden="true"
    data-back-to-top
    class="fixed bottom-0 z-10 w-screen p-4 text-center transition-opacity opacity-0 pointer-events-none"
  >
    <button
      tabindex="-1"
      aria-hidden="true"
      type="button"
      class="max-w-full button md:px-12 button--primary w-80"
      onclick="window.scroll({top: 0, behavior: 'smooth' });"
    >
      <span>Back to top</span>
    </button>
  </div>
  <script type="module">
    import { backToTop } from "{{ 'backToTop.js' | asset_url }}";
    backToTop();
  </script>
{%- endunless -%}

