              >
                <div class="bf-timer__content">
                  <h3 class="bf-timer__title" style="color: {{ block.settings.timer_text_color }};">
                    {{ block.settings.timer_title }}
                  </h3>
                  <div class="bf-timer__countdown">
                    <div class="bf-timer__unit">
                      <div
                        class="bf-timer__number"
                        id="days-{{ block.id }}"
                        style="color: {{ block.settings.timer_text_color }};"
                      >
                        00
                      </div>
                      <div class="bf-timer__label" style="color: {{ block.settings.timer_text_color }};">Days</div>
                    </div>
                    <div class="bf-timer__separator" style="color: {{ block.settings.timer_text_color }};">:</div>
                    <div class="bf-timer__unit">
                      <div
                        class="bf-timer__number"
                        id="hours-{{ block.id }}"
                        style="color: {{ block.settings.timer_text_color }};"
                      >
                        00
                      </div>
                      <div class="bf-timer__label" style="color: {{ block.settings.timer_text_color }};">Hrs</div>
                    </div>
                    <div class="bf-timer__separator" style="color: {{ block.settings.timer_text_color }};">:</div>
                    <div class="bf-timer__unit">
                      <div
                        class="bf-timer__number"
                        id="minutes-{{ block.id }}"
                        style="color: {{ block.settings.timer_text_color }};"
                      >
                        00
                      </div>
                      <div class="bf-timer__label" style="color: {{ block.settings.timer_text_color }};">Min</div>
                    </div>
                    <div class="bf-timer__separator" style="color: {{ block.settings.timer_text_color }};">:</div>
                    <div class="bf-timer__unit">
                      <div
                        class="bf-timer__number"
                        id="seconds-{{ block.id }}"
                        style="color: {{ block.settings.timer_text_color }};"
                      >
                        00
                      </div>
                      <div class="bf-timer__label" style="color: {{ block.settings.timer_text_color }};">Sec</div>
                    </div>
                  </div>
                </div>
              </div>
              <script>
                var countDownDate{{ block.id }} = new Date("{{ block.settings.target_date }}").getTime();

                // Update the count down every 1 second
                var timer{{ block.id }} = setInterval(function() {

                  var now = new Date().getTime();
                  var distance = countDownDate{{ block.id }} - now;

                  var days = Math.floor(distance / (1000 * 60 * 60 * 24));
                  var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                  var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                  var seconds = Math.floor((distance % (1000 * 60)) / 1000);

                  document.getElementById("days-{{ block.id }}").innerHTML = days.toString().padStart(2, '0');
                  document.getElementById("hours-{{ block.id }}").innerHTML = hours.toString().padStart(2, '0');
                  document.getElementById("minutes-{{ block.id }}").innerHTML = minutes.toString().padStart(2, '0');
                  document.getElementById("seconds-{{ block.id }}").innerHTML = seconds.toString().padStart(2, '0');

                  // If the count down is finished, write some text
                  if (distance < 0) {
                    clearInterval(timer{{ block.id }});
                    document.getElementById("days-{{ block.id }}").innerHTML = "00";
                    document.getElementById("hours-{{ block.id }}").innerHTML = "00";
                    document.getElementById("minutes-{{ block.id }}").innerHTML = "00";
                    document.getElementById("seconds-{{ block.id }}").innerHTML = "00";
                  }
                }, 1000);
              </script>

