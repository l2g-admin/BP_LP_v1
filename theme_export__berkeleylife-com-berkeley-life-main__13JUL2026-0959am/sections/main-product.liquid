                                      {%- if matched_variant.metafields.custom.use_b2b_amount_for_d2c == true and matched_variant.metafields.custom.b2b_savings_amount != blank -%}
                                        <span class="normal-case tracking-normal font-semibold text-[10px] px-2 py-0.5 leading-none">
