{% comment %}theme-check-disable TemplateLength{% endcomment %}
{%- liquid
  assign quickshop = false
  if template.suffix == 'quickshop'
    assign quickshop = true
  endif

  comment
    If we're not on a PDP (product detail page), use the selected product from settings
  endcomment
  if product == blank and section.settings.product != blank
    assign product = section.settings.product
  endif

  assign initialSlide = 0
  for media in product.media
    if product.selected_or_first_available_variant.featured_media.id == media.id
      assign initialSlide = forloop.index0
    endif
  endfor

  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign hide_variants = section.settings.hide_variants
  assign productSticker = product.metafields.my_fields.product_sticker
-%}

<section class=" p-4 pt-0 md:pt-12 bg-cream text-navy {% unless quickshop %} md:p-12{% endunless %}">
  <div
    id="ProductGrid"
    class="new__styles max-w-screen-2xl mx-auto grid grid-cols-1 {% if product.media.size > 0 %}md:grid-cols-3{% else %}product--no-media{% endif %} gap-4 md:gap-8 items-start justify-start"
  >
    <div
      id="ProductImages"
      class="md:sticky md:flex md:justify-end relative {% if quickshop %}top-0{% else %}top-5{% endif %} w-full col-span-2 md:col-span-2"
    >
      {% if product.media.size == 1 %}
        {%- comment -%}Only one images{%- endcomment -%}
        <div class="relative w-full h-auto md:w-3/4">
          {% render 'product-media',
            media: product.media[0],
            position: forloop.index,
            loop: section.settings.enable_video_looping,
            modal_id: section.id,
            aspect: section.settings.image_ratio,
            zoom: section.settings.enable_zoom
          %}

          {%- comment -%}Corner Label{%- endcomment -%}
          {%- assign corner_label_block = section.blocks | where: 'type', 'corner_label' | first -%}
          {%- if corner_label_block and corner_label_block.settings.corner_image != blank -%}
            {%- assign corner_size = corner_label_block.settings.label_size | default: 80 -%}
            {%- assign corner_position = corner_label_block.settings.corner_position | default: 'top-left' -%}
            <div
              class="corner-label-wrapper corner-label-{{ corner_position }}"
              style="width: {{ corner_size }}px; height: {{ corner_size }}px;"
            >
              <img
                src="{{ corner_label_block.settings.corner_image | image_url: width: corner_size, height: corner_size }}"
                alt="Corner Label"
                class="corner-label-image"
                width="{{ corner_size }}"
                height="{{ corner_size }}"
              >
            </div>
          {%- endif -%}

          {%- if productSticker != blank -%}
            {% render 'image',
              image: productSticker,
              classes: 'w-20 absolute top-4 md:top-10 left-4 md:left-10 z-10',
              img_size: '10vw'
            %}
          {%- endif -%}

          {%- comment -%}FrontRow Banner Block - Single Image{%- endcomment -%}
          {%- assign frontrow_banner_block = section.blocks | where: 'type', 'frontrow_banner' | first -%}
          {%- if frontrow_banner_block -%}
            <div>
            {% render 'frontrow-banner', product_type: frontrow_banner_block.settings.product_type %}
            </div>
            
          {%- endif -%}

          {%- comment -%}Features block - positioned below single image{%- endcomment -%}
          {%- assign features_block = section.blocks | where: 'type', 'features' | first -%}
          {%- if features_block -%}
            <div
              class="hidden md:grid grid-cols-2 gap-8 mt-6   "
              style="width: 80%; grid-template-columns: 1fr 1fr;"
              {{ features_block.shopify_attributes }}
            >
              <div class="flex flex-col items-center text-center p-4 bg-white rounded-lg">
                <div class="w-12 h-12 mb-2 flex items-center justify-center rounded-full bg-orange-100">
                  {{ features_block.settings.feature_1_svg }}
                </div>
                <span class="text-sm font-medium text-navy">{{ features_block.settings.feature_1_text }}</span>
              </div>
              <div class="flex flex-col items-center text-center p-4 bg-white rounded-lg">
                <div class="w-12 h-12 mb-2 flex items-center justify-center rounded-full bg-orange-100">
                  {{ features_block.settings.feature_2_svg }}
                </div>
                <span class="text-sm font-medium text-navy">{{ features_block.settings.feature_2_text }}</span>
              </div>
            </div>
          {%- endif -%}
        </div>
      {% elsif product.media.size > 1 %}
        <script src="{{ 'product-swiper.js' | asset_url }}" type="module" defer="defer"></script>
        {%- assign features_block = section.blocks | where: 'type', 'features' | first -%}
        <product-swiper
          class="relative flex {% if section.settings.use_improved_layout %}{% elsif features_block %}flex-col{% else %}flex-col-reverse{% endif %} items-start w-full {% if section.settings.use_improved_layout %}md:w-full md:!flex-row{% else %}md:w-[80%]{% endif %}"
          data-initial-slide="{{ initialSlide }}"
          data-section-id="{{ section.id }}"
          {% if hide_variants %}
            data-hide-variants
          {% endif %}
          {% if section.settings.enable_zoom %}
            data-zoom
          {% endif %}
        >
          {%- comment -%}Thumb swiper instance{%- endcomment -%}
          <div class="hidden w-full max-h-[80vh] {% if section.settings.use_improved_layout %}md:block improved-thumb-width{% endif %}">
            <div class="pt-1 z-20 thumb-swiper-container {% unless section.settings.use_improved_layout %}!absolute{% endunless %} top-0 w-60 md:-left-32">
              <ul
                role="list"
                class="absolute flex gap-1 flex-col w-full overflow-y-scroll md:max-h-[80vh] swiper-wrapper top-"
              >
                {%- comment -%}If the `hide variants` setting is on, we want to check if this media matches any variants other than the current one, and then exclude it.{%- endcomment -%}
                {%- liquid
                  for media in product.media
                    assign media_belongs_to_other_variants = false
                    if media.id == product.selected_or_first_available_variant.featured_media.id
                      assign media_belongs_to_other_variants = false
                    elsif variant_images contains media.src
                      assign media_belongs_to_other_variants = true
                    endif
                    unless hide_variants == true and media_belongs_to_other_variants == true
                      echo '<li class="swiper-slide" data-media-id="'
                      echo section.id | append: '-' | append: media.id
                      echo '">'
                      render 'product-media-thumbnail', media: media, position: forloop.index, loop: section.settings.enable_video_looping, modal_id: section.id
                      echo '</li>'
                    endunless
                  endfor
                -%}
              </ul>
            </div>
          </div>

          {%- comment -%}Main swiper instance{%- endcomment -%}
          <div class="w-full {% if section.settings.use_improved_layout %}improved-swiper-offset{% endif %}">
            <div class="relative product-swiper-container">
              <ul role="list" class="w-full overflow-hidden swiper-wrapper">
                {%- comment -%}If the `hide variants` setting is on, we want to check if this media matches any variants other than the current one, and then exclude it.{%- endcomment -%}
                {%- liquid
                  for media in product.media
                    assign media_belongs_to_other_variants = false
                    if media.id == product.selected_or_first_available_variant.featured_media.id
                      assign media_belongs_to_other_variants = false
                    elsif variant_images contains media.src
                      assign media_belongs_to_other_variants = true
                    endif
                    unless hide_variants == true and media_belongs_to_other_variants == true
                      echo '<li class="swiper-slide" data-media-id="'
                      echo section.id | append: '-' | append: media.id | append: '" data-position="' | append: forloop.index0
                      echo '">'
                      render 'product-media', media: media, position: forloop.index, loop: section.settings.enable_video_looping, modal_id: section.id, aspect: section.settings.image_ratio, zoom: section.settings.enable_zoom
                      echo '</li>'
                    endunless
                  endfor
                -%}
              </ul>
              <!-- If we need pagination -->

              <span class="swiper-pagination !-bottom-4  absolute mb-4 md:mb-0"></span>

              {%- comment -%}FrontRow Banner Block - Inside Swiper Container{%- endcomment -%}
              {%- assign frontrow_banner_block = section.blocks | where: 'type', 'frontrow_banner' | first -%}
              {%- if frontrow_banner_block -%}
                {% render 'frontrow-banner', product_type: frontrow_banner_block.settings.product_type %}
              {%- endif -%}
            </div>
          </div>

          {%- comment -%}Corner Label{%- endcomment -%}
          {%- assign corner_label_block = section.blocks | where: 'type', 'corner_label' | first -%}
          {%- if corner_label_block and corner_label_block.settings.corner_image != blank -%}
            {%- assign corner_size = corner_label_block.settings.label_size | default: 80 -%}
            {%- assign corner_position = corner_label_block.settings.corner_position | default: 'top-left' -%}
            <div
              class="corner-label-wrapper corner-label-{{ corner_position }}"
              style="width: {{ corner_size }}px; height: {{ corner_size }}px;"
            >
              <img
                src="{{ corner_label_block.settings.corner_image | image_url: width: corner_size, height: corner_size }}"
                alt="Corner Label"
                class="corner-label-image"
                width="{{ corner_size }}"
                height="{{ corner_size }}"
              >
            </div>
          {%- endif -%}

          {%- if productSticker != blank -%}
            {% render 'image',
              image: productSticker,
              classes: 'w-20 absolute top-4 md:top-10 left-4 md:left-10 z-10',
              img_size: '10vw'
            %}
          {%- endif -%}

          {%- comment -%}Features block - positioned below swiper images{%- endcomment -%}
          {%- assign features_block = section.blocks | where: 'type', 'features' | first -%}
          {%- if features_block -%}
            <div
              class="hidden md:grid grid-cols-2 gap-8 mt-6 "
              style="margin: 0 auto; margin-top: 1rem; width: 75%; grid-template-columns: 1fr 1fr;"
              {{ features_block.shopify_attributes }}
            >
              <div class="flex flex-col items-center text-center p-4 bg-white rounded-lg">
                <div class="w-12 h-12 mb-2 flex items-center justify-center rounded-full bg-orange-100">
                  {{ features_block.settings.feature_1_svg }}
                </div>
                <span class="text-sm font-medium text-navy">{{ features_block.settings.feature_1_text }}</span>
              </div>
              <div class="flex flex-col items-center text-center p-4 bg-white rounded-lg">
                <div class="w-12 h-12 mb-2 flex items-center justify-center rounded-full bg-orange-100">
                  {{ features_block.settings.feature_2_svg }}
                </div>
                <span class="text-sm font-medium text-navy">{{ features_block.settings.feature_2_text }}</span>
              </div>
            </div>
          {%- endif -%}


        </product-swiper>
      {% endif %}
    </div>

    <div class="md:p-4 md:sticky top-5 md:pt-0">
      <div id="ProductInfo-{{ section.id }}" class="space-y-4 {% if customer.b2b? %} b2b {% endif %}">
        {% liquid
          if section.settings.show_breadcrumbs
            render 'breadcrumbs', classes: 'text-sm'
          endif
          assign product_form_id = 'product-form-' | append: section.id
        %}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'title' -%}
              <div class="z-10 top-10 md:left-10" {{ block.shopify_attributes }}>
                <h1 class="product-h1 text-navy{% if block.settings.use_custom_title and block.settings.custom_title != blank %} custom__title{% endif %}">
                  {% if block.settings.use_custom_title and block.settings.custom_title != blank %}
                    {{ block.settings.custom_title }}
                  {% else %}
                    {% assign split_title = product.title | split: ' ' %}
                    {% for word in split_title %}
                      {% if forloop.first %}
                        <span class="block w-full">
                          {{ word }}
                        </span>
                      {% else %}
                        <span class="italic font-secondaryHeader">
                          {{ word }}
                        </span>
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </h1>
              </div>
            {%- when 'text' -%}
              <p
                class="{% if block.settings.text_style == 'uppercase' %} subhead {% elsif block.settings.text_style == 'subtitle' %} {% endif %}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </p>

            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="text-base " {{ block.shopify_attributes }}>
                  {{ product.description }}
                </div>
              {%- endif -%}
            {%- when 'modal' -%}
              <style>
                .product-popup-modal {
                  box-sizing: border-box;
                  opacity: 0;
                  position: fixed;
                  visibility: hidden;
                  z-index: -1;
                  margin: 0 auto;
                  top: 0;
                  left: 0;
                  overflow: auto;
                  width: 100%;
                  padding: 30px;
                  background: rgba(var(--color-overlay-rgb), 0.7);
                  backdrop-filter: blur(3px);
                  height: 100%;
                }
                .product-popup-modal[open] {
                  opacity: 1;
                  visibility: visible;
                  z-index: 101;
                }
                .product-popup-modal__button {
                  margin: 20px 0 30px;
                  color: #080b2b;
                  display: flex;
                  align-items: center;
                  cursor: pointer;
                  font-size: 16px;
                  letter-spacing: -0.01em;
                  text-transform: uppercase;
                  font-weight: bold;
                  text-decoration: underline;
                }
                .product-popup-modal__button svg {
                  height: 12px;
                  width: auto;
                  margin-right: 9px;
                  fill: var(--color-accent);
                }
                .product-popup-modal__button span {
                  font-size: 0.8125rem;
                  letter-spacing: 0.02em;
                }
                .product-popup-modal__button.no-js {
                  display: none;
                }
                .no-js .product-popup-modal__button.no-js {
                  display: flex;
                }
                .product-popup-modal__toggle {
                  position: absolute;
                  top: 50%;
                  right: 30px;
                  margin-top: 15px;
                }
                .product-popup-modal__content {
                  overflow: auto;
                  max-height: 90vh;
                  max-width: clamp(300px, 90vw, 800px);
                  margin: 0 auto;
                  left: 50%;
                  transform: translate3d(-50%, -50%, 0);
                  width: 100%;
                  position: absolute;
                  top: 50%;
                  display: flex;
                  flex-direction: column;
                  box-shadow: 0px 4px 40px rgba(0, 0, 0, 0.25);
                }
                .product-popup-modal__content-header {
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  text-align: center;
                  position: sticky;
                  background-color: var(--bg-body, #fff);
                  top: 0;
                  left: 0;
                  flex-shrink: 0;
                }
                .product-popup-modal__content-header h5 {
                  color: inherit;
                  margin: 0;
                }
                .product-popup-modal__content scroll-shadow {
                  flex: 1;
                  display: flex;
                  width: 100%;
                  overflow: hidden;
                }
                .product-popup-modal__content img {
                  display: block;
                  max-width: 500px;
                  @media (max-width: 768px) {
                    max-width: 310px;
                  }
                  margin: 0 auto;
                }
                .product-popup-modal__content-info {
                  padding: 25px;
                  background-color: var(--bg-body, #fff);
                  /* overflow-y: scroll; */
                  width: 100%;
                  color: var(--color-body);
                }
                @media only screen and (min-width: 768px) {
                  .product-popup-modal__content-info {
                    padding: 20px;
                  }
                }
                .product-popup-modal__content-info table:last-child {
                  margin-bottom: 0;
                }

                .product-popup-modal {
                  transition: all 0.25s cubic-bezier(0.104, 0.204, 0.492, 1);
                }
              </style>
              {%- if block.settings.title != '' -%}
                <modal-opener class="product-popup-modal__opener no-js-hidden" data-modal="#PopupModal-{{ block.id }}">
                  <button
                    id="ProductPopup-{{ block.id }}"
                    class="product-popup-modal__button"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    <span>{{ block.settings.title }}</span>
                  </button>
                </modal-opener>
                <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal">
                  <div
                    role="dialog"
                    aria-label="{{ block.settings.title }}"
                    aria-modal="true"
                    class="product-popup-modal__content"
                    tabindex="-1"
                  >
                    <div class="product-popup-modal__content-header">
                      <button
                        id="ModalClose-{{ block.id }}"
                        type="button"
                        class="product-popup-modal__toggle"
                        aria-label="{{ 'accessibility.close' | t }}"
                      >
                        {% render 'svg-icons' with 'close' %}
                      </button>
                    </div>
                    <scroll-shadow>
                      <div class="product-popup-modal__content-info">
                        {%- liquid
                          assign image = block.settings.content
                          assign sizes = image.src.width | append: 'x' | append: image.src.height
                          render 'responsive-image', image: image, sizes: sizes
                        -%}
                      </div>
                    </scroll-shadow>
                  </div>
                </modal-dialog>
              {%- endif -%}

            {%- when 'custom_liquid' -%}
              {{ block.settings.custom_liquid }}
            {%- when 'collapsible_tab' -%}
              {%- unless block.settings.hide_if_empty
                and block.settings.content == blank
                and block.settings.page.content == blank
              -%}
                <div {{ block.shopify_attributes }}>
                  <details
                    class="group {% if block.settings.disable %} pointer-events-none {% endif %}"
                    {% if block.settings.open %}
                      open
                    {% endif %}
                  >
                    <summary class="gap-2 py-2 border-b border-solid border-navy">
                      <h2 class="flex items-center gap-2">
                        <span class="flex-grow text-2xl ">
                          {{ block.settings.heading | default: block.settings.page.title }}
                        </span>
                        {% unless block.settings.disable %}
                          {%- if block.settings.icon_type == 'c-arrow' -%}
                            <span class="group-open:rotate-180 transition-transform duration-300">
                              {% render 'c-arrow' %}
                            </span>
                          {%- else -%}
                            {% render 'icon-plus', classes: 'w-4' %}
                          {%- endif -%}
                        {% endunless %}
                      </h2>
                    </summary>
                    <div class="pt-4 space-y-4 {% if block.settings.uppercase %} capitalize {% endif %}">
                      {{ block.settings.content }}
                      {{ block.settings.page.content }}
                    </div>
                  </details>
                </div>
              {%- endunless -%}
            {%- when 'ingredients' -%}
              {%- unless product.metafields.custom.ingredients == blank -%}
                <div {{ block.shopify_attributes }}>
                  <details
                    class="group"
                    {% if block.settings.open %}
                      open
                    {% endif %}
                  >
                    <summary class="gap-2 py-2 border-b border-solid border-navy">
                      <h2 class="flex items-center gap-2">
                        <span class="flex-grow text-2xl ">
                          {{ block.settings.heading | default: block.settings.page.title }}
                        </span>
                        {% render 'icon-plus', classes: 'w-4' %}
                      </h2>
                    </summary>
                    <div class="pt-4 space-y-4">
                      {% if product.metafields.custom.ingredients != blank %}
                        {% assign ingredients = product.metafields.custom.ingredients.value %}
                        <ul>
                          {% for ingredient in ingredients %}
                            <li class="my-2 ingredient">{{ ingredient }}</li>
                          {% endfor %}
                        </ul>
                      {% else %}
                        {{ block.settings.content }}
                      {% endif %}
                    </div>
                  </details>
                </div>
              {%- endunless -%}
            {%- when 'proven_results' -%}
              {%- unless product.metafields.custom.clinically_proven_benefits == blank -%}
                <div {{ block.shopify_attributes }}>
                  <details
                    class="group"
                    {% if block.settings.open %}
                      open
                    {% endif %}
                  >
                    <summary class="gap-2 py-2 border-b border-solid border-navy">
                      <h2 class="flex items-center gap-2">
                        <span class="flex-grow text-2xl ">
                          {{ block.settings.heading | default: block.settings.page.title }}
                        </span>
                        {% render 'icon-plus', classes: 'w-4' %}
                      </h2>
                    </summary>
                    <div class="pt-4 space-y-4">
                      {%- if block.settings.show_clinical_trials -%}
                        <div style="margin-bottom: 8px;">
                          {%- render 'clinical-drawer',
                            drawer_id: block.id,
                            button_text: block.settings.clinical_button_text,
                            drawer_title: block.settings.clinical_drawer_title,
                            drawer_body: block.settings.clinical_drawer_body,
                            bg_color: block.settings.clinical_drawer_bg_color,
                            text_color: block.settings.clinical_drawer_text_color
                          -%}
                        </div>
                      {%- endif -%}
                      {% if product.metafields.custom.clinically_proven_benefits != blank %}
                        {% assign results = product.metafields.custom.clinically_proven_benefits.value %}
                        <ul>
                          {% for result in results %}
                            <li class="my-2 ingredient">{{ result }}</li>
                          {% endfor %}
                        </ul>
                      {% else %}
                        {{ block.settings.content }}
                      {% endif %}
                    </div>
                  </details>
                </div>

              {%- endunless -%}

            {%- when 'c-proven-results' -%}
              {%- unless product.metafields.custom.clinically_proven_benefits == blank -%}
                <style>
                  .c-proven-results-tabs {
                    display: flex;
                    gap: 0;
                    margin-bottom: 24px;
                    border-radius: 0;
                    overflow: visible;
                    border: none;
                  }

                  .c-proven-tab {
                    flex: 1;
                    background: transparent;
                    border: none;
                    padding: 0.5rem;
                    color: var(--Text-Navy, #080b2b);

                    font-size: 14px;
                    font-style: normal;
                    font-weight: 600;
                    line-height: 120%;
                    letter-spacing: 0.7px;
                    text-transform: uppercase;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    position: relative;
                    text-align: left !important;
                    text-decoration: none;
                  }

                  .c-proven-tab:last-child {
                    border-right: none;
                  }

                  .c-proven-tab.active {
                    background: transparent;
                    color: var(--Main-Orange, #d44f2f);
                    font-family: 'Cormorant Garamond';
                    font-size: 20px;
                    font-style: italic;
                    font-weight: 500;
                    line-height: 100%;
                    letter-spacing: normal;
                    text-transform: none;
                    text-decoration: underline;
                  }

                  .c-proven-tab:hover:not(.active) {
                    background: transparent;
                    opacity: 0.7;
                  }

                  .c-proven-tab-content {
                    display: none;
                    animation: fadeIn 0.3s ease-in-out;
                  }

                  .c-proven-tab-content.active {
                    display: block;
                  }

                  .c-proven-results-title {
                    color: #d95d39;
                    font-family: 'Cormorant Garamond', serif;
                    font-style: italic;
                    font-size: 32px;
                    font-weight: 400;
                    margin: 0 0 16px 0;
                    line-height: 1.2;
                  }

                  .c-proven-results-subtitle {
                    color: #080b2b;
                    font-size: 20px;
                    font-weight: 600;
                    margin: 0 0 20px 0;
                    line-height: 1.3;
                  }

                  .c-proven-results-text {
                    color: #4a5568;
                    font-size: 16px;
                    line-height: 1.6;
                    margin-bottom: 20px;
                  }

                  .c-proven-results-list {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                  }

                  .c-proven-results-list li {
                    color: #080b2b;
                    font-size: 16px;
                    line-height: 1.5;
                    margin-bottom: 12px;
                    padding-left: 24px;
                    position: relative;
                  }

                  @keyframes fadeIn {
                    from {
                      opacity: 0;
                      transform: translateY(10px);
                    }
                    to {
                      opacity: 1;
                      transform: translateY(0);
                    }
                  }

                  @media (max-width: 768px) {
                    .c-proven-results-container {
                      padding: 20px;
                    }

                    .c-proven-tab {
                      padding: 12px 16px;
                      font-size: 12px;
                    }

                    .c-proven-tab.active {
                      font-size: 20px;
                    }

                    .c-proven-results-title {
                      font-size: 28px;
                    }

                    .c-proven-results-subtitle {
                      font-size: 18px;
                    }
                  }
