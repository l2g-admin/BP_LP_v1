{% assign should_loop = false %}

{%- if section.blocks.size > 1 -%}
  {% assign should_loop = true %}
{%- endif -%}
<div class="bg-cream md:bg-bg" style="--color-text: {{ section.settings.text_color | default: '#252525' }}; --color-bg: {{ section.settings.background_color | default: '#F6F5EE' }}" >
<div class="max-w-screen-xl p-4 py-8 mx-auto md:py-20 md:p-8 pd:px-12 text-navy hot-spot_component " >
  <div class="grid {% if section.settings.border %} border-t-2 border-b-2 py-12 border-black {% endif %} items-center md:grid-cols-3 {% if section.settings.center_mobile %} grid-cols-1 text-center md:text-left {% else %} grid-cols-2 {% endif %} ">
  {%- if section.settings.static_content != blank -%}
        <div class="col-span-1 hot-spot__static-content h2">
            {{ section.settings.static_content | replace_first: "**", "<span class='text-brand font-secondaryHeader'>" | replace: "**", "</span>" }}
        </div>
      {%- endif -%}
    <div class="relative col-span-1 hot-spot__image-wrapper">

          {% render 'image', image: section.settings.image, classes: "block object-right mx-auto"  %}
   
    {%- if section.blocks.size > 1 -%}
              {% comment %} This is used to hold styles to apply to pagination dots after Swiper is initiated {% endcomment %}
      <div class="hidden pagination-mappings md:block">
        {%- for block in section.blocks -%}
          <div data-classes="hot-spot__pagination-button" data-inline-styles="--color-bg: #F6F5EE; left: {{block.settings.hot_spot_left_offset}}%; top: {{block.settings.hot_spot_top_offset}}%;" data-label="{{block.settings.hot_spot_label}}"></div>
        {%- endfor -%}
      </div>
      {% comment %} These buttons will be overridden by Swiper, but are helpful to see where dots are placed in Customizer{% endcomment %}
      <div class="swiper-pagination ">
        {%- for block in section.blocks -%}
          <button aria-label="Hot spot control" class="hot-spot__pagination-button md:left-[{{block.settings.hot_spot_left_offset}}%] md:top-[{{block.settings.hot_spot_left_offset}}%]  " style="--color-bg: #00BED6;"></button>
        {%- endfor -%}
      </div>

    {%- endif -%}
  </div>
  <div class="justify-center col-span-2 p-4 hot-spot__content-wrapper md:col-span-1">


    {%- if section.blocks.size >= 1 -%}
      <div class=" {% if section.blocks.size > 1 %}swiper hot-spot__slides-wrapper {% endif %} {% if section.settings.static_content != blank %}mb-8{% endif %}">
        <ul class="text-navy swiper-wrapper hot-spot__slides md:text-text" role="list">
          {%- for block in section.blocks -%}
            <li class="swiper-slide hot-spot__slide">
              {%- if block.settings.heading != blank -%}
                <div class="mb-4 text-lg tracking-widest hot-spot__slide-heading" >
                  {{ block.settings.heading }}
                </div>
              {%- endif -%}

              {%- if block.settings.content != blank -%}
                <div class="text-xl hot-spot__slide-content {% if section.settings.center_mobile %} text-center md:text-left {% endif %}">{{block.settings.content}}</div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
    <div class="w-full button button--tertiary md:px-12">
        <a aria-label="{{ section.settings.button_link }}" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    </div>

  </div>
</div>
</div> 
  
</div>

{%- if section.blocks.size > 1 -%}
  <script type="module">
    const sectionID = '#shopify-section-{{ section.id }}'
    const selector = `${sectionID} .hot-spot__slides-wrapper`
    const rootElement = document.querySelector(selector)
    const shouldLoop = '{{should_loop}}' === 'true';
    async function initTabbedSlider() {
      const { Swiper } = await import('https://unpkg.com/swiper@8/swiper-bundle.esm.browser.min.js')
      const tabbedSliderSwiper = new Swiper(selector,  {
        direction: 'horizontal',
        loop: shouldLoop,
        slidesPerView: 'auto',
        spaceBetween: 10,
        pagination: {
          el: `${sectionID} .swiper-pagination`,
          clickable: true,
          renderBullet: function (index, className) {
            const mappings = document.querySelectorAll(`${sectionID} .pagination-mappings div`);

            // Data for desktop
            const desktopClasses = mappings[index].dataset.classes;
            const desktopStyles = mappings[index].dataset.inlineStyles;
            const desktopLabel = mappings[index].dataset.label;

            // Check whether to use mobile or desktop
            if (desktopClasses) {
              return (`
                <div class="block ${className} " style="${desktopStyles}">
                  <button aria-label="Hot spot control" class="${desktopClasses}"></button>
                </div>
   
              `);
            }
          }

        },

        a11y: {
          enabled: true,
          slideRole: 'listitem'
        }
      })
    }
    function reveal() {
      const handleIntersection = (entries, observer) => {
        if (!entries[0].isIntersecting) return;
        observer.unobserve(rootElement);
        initTabbedSlider()
      }
      new IntersectionObserver(handleIntersection.bind(rootElement), {rootMargin: '0px 0px 200px 0px'}).observe(rootElement);
    }

    reveal();
  </script>
{%- endif -%}

{% schema %}
  {
    "name": "Hot Spot",
    "class": "hot-spot",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "text",
        "id": "static_content",
        "label": "Heading",
      },
     
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#F6F5EE"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#252525"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "t:sections.image-with-text.blocks.button.settings.button_label.label",
        "info": "t:sections.image-with-text.blocks.button.settings.button_label.info"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "t:sections.image-with-text.blocks.button.settings.button_link.label"
      },
      {
        "type": "checkbox",
        "id": "center_mobile",
        "default": true,
        "label": "Center Align Mobile"
      },
      {
        "type": "checkbox",
        "id": "border",
        "default": false,
        "label": "Add Top and Bottom border"
      }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "range",
            "id": "hot_spot_left_offset",
            "label": "Hot Spot Left Offset",
            "default": 50,
            "min": 0,
            "max": 100,
            "unit": "%",
            "step": 5
          },
          {
            "type": "range",
            "id": "hot_spot_top_offset",
            "label": "Hot Spot Top Offset",
            "default": 50,
            "min": 0,
            "max": 100,
            "unit": "%",
            "step": 5
          },
          {
            "type": "text",
            "id": "hot_spot_label",
            "label": "Hot Spot Label"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "NITRIC OXIDE FOUNDATION"
          },
          {
            "type": "richtext",
            "id": "content",
            "label": "Content"
        }
        ]
      }
    ],
    "presets": [
      {
        "name": "Hot Spot",
        "blocks": [
          {
            "type": "slide"
          },
          {
            "type": "slide"
          }
        ]
      }
    ]
  }
{% endschema %}