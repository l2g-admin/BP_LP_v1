{%- comment -%}
  Define CSS variables for dynamic padding settings from the schema.
  These are scoped to the unique section ID.
{%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} {
    --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;

    /* Color Palette (approximated from images) */
    --color-text-dark: #080B2B; /* Dark blue-ish grey */
    --color-accent: #D44F2F; /* Orange */
    --color-button-text: #FFFFFF;

    /* Typography (approximated) */
    --font-serif: "Georgia", "Times New Roman", Times, serif;
    --font-sans: "Helvetica Neue", Helvetica, Arial, sans-serif;

    /* Layout */
    --grid-gap-desktop: 30px;
    --grid-gap-mobile: 45px; /* Needs more space for vertical arrow */
  }

  .how-to-section {
    padding-top: var(--padding-top-mobile);
    padding-bottom: var(--padding-bottom-mobile);
    background-color: #FFFFFF; /* Assuming a white background */
    font-family: var(--font-sans);
  }

  @media (min-width: 769px) {
    .how-to-section {
      padding-top: var(--padding-top-desktop);
      padding-bottom: var(--padding-bottom-desktop);
    }

    .how-to-section__step{
      margin-left: 10px;
    }

    .how-to-section__heading {
        max-width: none !important;
        font-size: 54px !important; /* 40px */
        font-weight: 500 !important;
    }

    .how-to-section__heading .highlight {
        font-size: 64px !important;
        font-weight: 400 !important;
    }
  }

  .how-to-section__container {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 15px;
    padding-right: 15px;
  }

  .how-to-section__header {
    max-width: 768px;
    justify-self: center;
    text-align: center;
    margin-bottom: 50px;
  }

  .how-to-section__heading {
    font-size: 40px; /* 40px */
    font-weight: 500;
    max-width: 310px;
    line-height: 1.2;
    color: var(--color-text-dark);
    margin: 0;
  }

  .how-to-section__heading .highlight {
    font-size: 48px;
    font-weight: 400;
    font-family: 'cormorant-garamond', serif;
    font-style: italic;
    line-height: 1.0;
    color: var(--color-accent);
    margin-left: 0.5rem;
  }

  .how-to-section__subheading {
    font-size: 20px; /* 18px */
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-text-dark);
    margin-top: 10px;
  }

  .how-to-section__grid {
    display: grid;
    grid-template-columns: 1fr; /* Mobile-first: single column */
    gap: var(--grid-gap-mobile);
  }

  @media (min-width: 769px) {
    .how-to-section__grid {
      grid-template-columns: repeat(4, 1fr); /* 4 columns on desktop */
      gap: var(--grid-gap-desktop);
    }
  }

  @media (max-width: 768px) {
    .how-to-section__grid--mobile-scroll {
      --mobile-scroll-edge-gap: 15px;
      --mobile-scroll-card-gap: 36px;
      display: flex;
      gap: var(--mobile-scroll-card-gap);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: var(--mobile-scroll-edge-gap);
      margin-left: calc(-1 * var(--mobile-scroll-edge-gap));
      margin-right: calc(-1 * var(--mobile-scroll-edge-gap));
      padding-left: var(--mobile-scroll-edge-gap);
      padding-right: var(--mobile-scroll-edge-gap);
      padding-bottom: 6px;
      scrollbar-width: none;
    }

    .how-to-section__grid--mobile-scroll::-webkit-scrollbar {
      display: none;
    }

    .how-to-section__grid--mobile-scroll .how-to-section__step {
      flex: 0 0 calc(100% - 44px);
      scroll-snap-align: start;
      margin-top: 0;
    }

    .how-to-section__grid--mobile-scroll .how-to-section__step:not(:last-child)::after {
      content: '→';
      top: 50%;
      left: 100%;
      transform: translate(calc(var(--mobile-scroll-card-gap) / 2 - 14px), -50%);
      font-size: 1.5rem;
      line-height: 1;
      padding-top: 0;
      z-index: 1;
    }
  }

  .how-to-section__step {
    position: relative;
    margin-top: 12px;
    border: 1px solid var(--color-accent);
    border-radius: 12px;
    padding: 30px 20px;
    text-align: left;
    /* Ensure all boxes match height in a grid row on desktop */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  /* Arrows: Mobile */
  .how-to-section__step:not(:last-child)::after {
    content: '↓';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    font-size: 2rem;
    color: var(--color-accent);
    padding-top: 5px; /* Space between box and arrow */
  }

  .how-to-section__test-strips{
    display:flex;
    flex-direction: column;
    margin-top:40px;
    place-self: center;
    align-items: flex-start;
    gap: 8px;
  }

  .how-to-section__color-element{
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1 0 0;
  }

  /* Arrows: Desktop */
  @media (min-width: 769px) {
    .how-to-section__step:not(:last-child)::after {
      content: '→';
      top: 50%;
      left: 100%; /* Start at the right edge of the box */
      transform: translate(0, -50%);
      padding-left: calc(var(--grid-gap-desktop) / 2 - 10px); /* Center in gap */
      padding-top: 0;
    }

    .how-to-section__test-strips{
      display:flex;
      flex-direction: row;
      width: 100%;
      margin-top:40px;
      align-items: flex-start;
      gap: 32px;
      align-self: stretch;
    }

    .how-to-section__color-element{
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      flex: 1 0 0;
    }

    .how-to-section__color-box-very-low{
    
    width: 100% !important;
    
  }

  .how-to-section__color-box-low{
    
    width: 100% !important;
  }

  .how-to-section__color-box-threshold{
    width: 100% !important;
    
  }

  .how-to-section__color-box-target{
    width: 100% !important;
   
  }

  .how-to-section__color-box-high{
   
    width: 100% !important;
    
  }
  }

  

  .how-to-section__color-box-very-low{
    height: 30px;
    align-self: stretch;
    width: 150px;
    background: #F6DAE1;
  }

  .how-to-section__color-box-low{
    height: 30px;
    width: 150px;
    align-self: stretch;
    background: #F7B3C4;
  }

  .how-to-section__color-box-threshold{
    height: 30px;
    width: 150px;
    align-self: stretch;
    background: #F491A2;
  }

  .how-to-section__color-box-target{
    height: 30px;
    width: 150px;
    align-self: stretch;
    background: #EF4F97;
  }

  .how-to-section__color-box-high{
    height: 30px;
    width: 150px;
    align-self: stretch;
    background: #D41968;
  }

  .how-to-section__color-text{
    align-self: stretch;
    color: #080B2B;
    text-align: center;
    align-content: center;
    font-size: 14px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 16.8px */
    letter-spacing: 0.7px;
    text-transform: uppercase;
  }

  .how-to-section__step-number {
    font-family: "cormorant-garamond";
    font-size: 72px; /* 40px */
    font-weight: 400;
    font-style:italic;
    color: var(--color-accent);
  }

  .how-to-section__step-title {
    font-size: 14px; /* 40px */
    font-weight: 600;
    letter-spacing: 0.7px;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .how-to-section__step-subheading {
    font-size: 18px; /* 18px */
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 15px 0 10px;
  }

  .how-to-section__step-text {
    font-size: 1rem; /* 16px */
    color: var(--color-text-dark);
    line-height: 1.5;
    margin: 0;
  }

  .how-to-section__button-wrapper {
    text-align: center;
    margin-top: 60px;
  }

  .how-to-section__button {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-button-text);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 50px; /* Pill shape */
    transition: background-color 0.3s ease;
  }

  .how-to-section__button:hover {
    background-color: #c96841; /* Darker orange on hover */
  }

</style>

<div id="shopify-section-{{ section.id }}" class="how-to-section">
  <div class="how-to-section__container">

    {%- comment -%}
      SECTION HEADER
    {%- endcomment -%}
    <div class="how-to-section__header">
      {%- if section.settings.heading_main != blank or section.settings.heading_highlight != blank -%}
        <h2 class="how-to-section__heading">
          {{ section.settings.heading_main }}
          {%- if section.settings.heading_highlight != blank -%}
            <span class="highlight">{{ section.settings.heading_highlight | escape }}</span>
          {%- endif -%}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="how-to-section__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      STEPS GRID
    {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="how-to-section__grid{% if section.settings.enable_mobile_horizontal_scroll %} how-to-section__grid--mobile-scroll{% endif %}">
        {%- for block in section.blocks -%}
          <div class="how-to-section__step" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <span class="how-to-section__step-number">{{ block.settings.heading | escape }}</span>
            {%- endif -%}

            {%- if block.settings.box_title != blank -%}
              <span class="how-to-section__step-title">{{ block.settings.box_title | escape }}</span>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
              <p class="how-to-section__step-subheading">{{ block.settings.subheading | escape }}</p>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="how-to-section__step-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_strip_colors -%}
      <div class="how-to-section__test-strips">
        <div class="how-to-section__color-element">
          <div class="how-to-section__color-box-very-low">
          </div>
          <span class="how-to-section__color-text">
            VERY LOW
          </span>
        </div>

        <div class="how-to-section__color-element">
          <div class="how-to-section__color-box-low">
          </div>
          <span class="how-to-section__color-text">
            LOW
          </span>
        </div>

        <div class="how-to-section__color-element">
          <div class="how-to-section__color-box-threshold">
          </div>
          <span class="how-to-section__color-text">
            THRESHOLD
          </span>
        </div>

        <div class="how-to-section__color-element">
          <div class="how-to-section__color-box-target">
          </div>
          <span class="how-to-section__color-text">
            TARGET
          </span>
        </div>

        <div class="how-to-section__color-element">
          <div class="how-to-section__color-box-high">
          </div>
          <span class="how-to-section__color-text">
            HIGH
          </span>
        </div>
      </div>
    {% endif %}
    {%- comment -%}
      BUTTON
    {%- endcomment -%}
    {%- assign use_scroll = false -%}
    {%- if section.settings.enable_scroll_to and section.settings.scroll_target != blank -%}
      {%- assign use_scroll = true -%}
    {%- endif -%}
    {%- assign show_button = false -%}
    {%- if section.settings.button_text != blank -%}
      {%- if use_scroll or section.settings.button_link != blank -%}
        {%- assign show_button = true -%}
      {%- endif -%}
    {%- endif -%}
    {%- if show_button -%}
      <div class="how-to-section__button-wrapper">
        <a
          href="{% if use_scroll %}{{ section.settings.scroll_target }}{% else %}{{ section.settings.button_link }}{% endif %}"
          class="how-to-section__button{% if use_scroll %} how-to-section__button--scroll{% endif %}"
          {% if use_scroll %}data-scroll-target="{{ section.settings.scroll_target | escape }}"{% endif %}
        >
          {{ section.settings.button_text | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{%- if section.settings.enable_scroll_to and section.settings.scroll_target != blank -%}
  <script>
    (function () {
      var section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;
      var trigger = section.querySelector('.how-to-section__button--scroll');
      if (!trigger) return;

      function easeInOutCubic(t) {
        return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      }

      function smoothScrollTo(targetY, duration) {
        var startY = window.pageYOffset;
        var diff = targetY - startY;
        var startTime;

        function step(timestamp) {
          if (!startTime) startTime = timestamp;
          var elapsed = timestamp - startTime;
          var progress = Math.min(elapsed / duration, 1);
          var eased = easeInOutCubic(progress);
          window.scrollTo(0, startY + diff * eased);
          if (elapsed < duration) {
            window.requestAnimationFrame(step);
          }
        }

        window.requestAnimationFrame(step);
      }

      trigger.addEventListener('click', function (e) {
        var selector = trigger.getAttribute('data-scroll-target');
        if (!selector) return;
        var target = document.querySelector(selector);
        if (!target) return;
        e.preventDefault();

        var headerOffset = 0;
        var header = document.querySelector('.shopify-section-header, header.site-header, .header-wrapper');
        if (header) headerOffset = header.offsetHeight;

        var rect = target.getBoundingClientRect();
        var targetY = rect.top + window.pageYOffset - headerOffset - 20;

        smoothScrollTo(targetY, 900);
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "C Steps Boxes",
  "class": "how-to-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading_main",
      "label": "Heading",
      "default": "How to Use Berkeley Life"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Test Strips"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Simple steps. Quick results."
    },
    {
      "type": "checkbox",
      "id": "show_strip_colors",
      "label": "Show strip colors?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_horizontal_scroll",
      "label": "Enable mobile horizontal scroll for step boxes",
      "default": false,
      "info": "When enabled, mobile shows the step boxes in one horizontal row with swipe/scroll."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SEE RESULTS IN SECONDS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Used when 'Scroll to selector' is disabled."
    },
    {
      "type": "checkbox",
      "id": "enable_scroll_to",
      "label": "Scroll to selector instead of link",
      "default": false
    },
    {
      "type": "text",
      "id": "scroll_target",
      "label": "Scroll target selector",
      "info": "CSS selector. Use #my-id for an ID or .my-class for a class (e.g. #buy-now, .product-form)."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "box_title",
          "label": "Step Title",
          "default": "COLLECT"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading (Bold)",
          "default": "Place the test strip on your tongue"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Saliva reacts naturally with the test pad."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Steps Boxes",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "heading": "01",
            "subheading": "Place the test strip on your tongue",
            "text": "Saliva reacts naturally with the test pad."
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "02",
            "subheading": "Wait 5 seconds, then fold the test strip in half",
            "text": "The color will change based on your Nitric Oxide levels."
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "03",
            "subheading": "Compare your color",
            "text": "Use the guide on the package to see your level."
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "04",
            "subheading": "Track over time",
            "text": "Test regularly to see how diet, exercise, and supplements improve your levels."
          }
        }
      ]
    }
  ]
}
{% endschema %}