        <div style="flex:1;">

          <label style="display:block; font-size:13px; color:#0a0e27; margin-bottom:5px;">First Name *</label>

          <input type="text" name="firstname" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; font-size:14px; box-sizing:border-box;">

        </div>

        <div style="flex:1;">

          <label style="display:block; font-size:13px; color:#0a0e27; margin-bottom:5px;">Last Name *</label>

          <input type="text" name="lastname" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; font-size:14px; box-sizing:border-box;">

        </div>

      </div>

      <div style="margin-bottom:15px;">

