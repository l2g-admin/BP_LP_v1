        <input type="email" name="email" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; font-size:14px; box-sizing:border-box;">

      </div>

      <div style="margin-bottom:20px;">

        <label style="display:block; font-size:13px; color:#0a0e27; margin-bottom:5px;">State *</label>

        <select name="state_dropdown" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; font-size:14px; box-sizing:border-box; background:#fff;">

