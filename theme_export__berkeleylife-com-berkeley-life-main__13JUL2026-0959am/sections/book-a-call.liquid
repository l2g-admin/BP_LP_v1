      function generatePassword() {

        return 'BL-' + Math.random().toString(36).slice(2, 10) + Math.random().toString(36).slice(2, 6).toUpperCase() + '!';

      }

      document.getElementById('book-a-call-form').addEventListener('submit', function(e) {

        e.preventDefault();

        var form = document.getElementById('book-a-call-form');

        var errorDiv = document.getElementById('form-error');

        var submitBtn = form.querySelector('button[type="submit"]');

        var firstname = form.querySelector('[name="firstname"]').value.trim();

        var lastname = form.querySelector('[name="lastname"]').value.trim();

        var email = form.querySelector('[name="email"]').value.trim();

        var stateValue = form.querySelector('[name="state_dropdown"]').value;

        errorDiv.style.display = 'none';

        if (!firstname || !lastname || !email || !stateValue) {

          errorDiv.textContent = 'Please fill in all required fields.';

          errorDiv.style.display = 'block';

          return;

        }

        submitBtn.textContent = 'Submitting...';

        submitBtn.disabled = true;

        // Build redirect URL with pre-filled HubSpot meeting parameters

        var baseUrl = stateToUrl[stateValue];

        var redirectUrl = baseUrl

          + '&firstname=' + encodeURIComponent(firstname)

          + '&lastname=' + encodeURIComponent(lastname)

          + '&email=' + encodeURIComponent(email);

        var mutation = `
          mutation customerCreate($input: CustomerCreateInput!) {
            customerCreate(input: $input) {
              customer {
                id
                email
                firstName
                lastName
              }
              customerUserErrors {
                code
                message
              }
            }
          }
        `;

        var variables = {

          input: {

            firstName: firstname,

            lastName: lastname,

            email: email,

            password: generatePassword(),

            acceptsMarketing: true

          }

        };

        // STEP 1: Create Shopify customer with keepalive so the request
        // completes even if the page navigates away

        fetch('https://berkeleylife.com/api/2024-10/graphql.json', {

          method: 'POST',

          headers: {

            'Content-Type': 'application/json',

            'X-Shopify-Storefront-Access-Token': '296004d6a1c7d6a783301d88c0458b21'

          },

          body: JSON.stringify({ query: mutation, variables: variables }),

          keepalive: true

        })

        .catch(function() {

          // Silently continue even if Shopify customer creation fails

        })

        // STEP 2: Redirect to HubSpot meeting link with pre-filled data

        .then(function() {

          document.getElementById('book-a-call-form').style.display = 'none';

          document.getElementById('form-success').style.display = 'block';

          setTimeout(function() {

            window.location.href = redirectUrl;

          }, 1500);

        });

      });

