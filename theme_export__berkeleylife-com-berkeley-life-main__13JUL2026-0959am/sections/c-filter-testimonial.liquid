<style>
  #{{section.id}} {
    background-color: {{ section.settings.section_bg_color }};
    border-radius: 80px 80px 0 0;
    & .section__mp__testimonial__container {
      padding-block: 4rem;

      & .testimonial__content {
        display: flex;
        flex-direction: column;
        gap: 2rem;

        &.container-sl .testimonial__hero__texts {
          width: unset;
          max-width: unset;
          margin-inline: unset;
        }

        & .testimonial__hero__texts {
          width: 90%;
          max-width: 1200px;
          margin-inline: auto;
          overflow: hidden;

          display: flex;
          flex-direction: column;
          gap: 2rem;

          & .testimonial__hero__header__top {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            align-items: center;
          }
        }

        & .testimonial__title {
          font-size: clamp(32px, 6vw + 1rem, 54px);
          text-align: center;

          margin: 0;

          width: 100%;
          color: {{ section.settings.title_color }};

          line-height: 120%;

            & span {
              font-style: italic;
              font-weight: 300;
              font-size: clamp(32px, 6vw + 1rem, 54px);
              font-family: "Cormorant Garamond";
              color: #FCD5CC !important;
              }
        }

        & .testimonial__description {
          font-size: clamp(16px, 3vw, 18px);
          text-align: center;
          margin: 0;
          color: {{ section.settings.title_color }};
          line-height: 150%;
          font-weight: 300;
        }

        & .btns__container {
          width: 100%;
          overflow-x: auto;
          padding-bottom: 1rem;
          cursor: grab;
          scroll-behavior: smooth;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: thin;
          scrollbar-color: {{ section.settings.filter_btn_border }} transparent;

          &:active {
            cursor: grabbing;
          }

          &::-webkit-scrollbar {
            height: 6px;
          }

          &::-webkit-scrollbar-track {
            background: transparent;
          }

          &::-webkit-scrollbar-thumb {
            background-color: {{ section.settings.filter_btn_border }};
            border-radius: 3px;
          }

          @media (min-width: 1024px) {
            padding-inline: 2rem;
          }
        }

        & .btns__filter {
          width: max-content;
          margin-inline: auto;
          display: flex;
          justify-content: flex-start;
          gap: .3rem;

          @media (min-width: 1024px) {
            justify-content: center;
          }
        }

        & .btn__filter {
          padding: 1rem 2rem;
          cursor: pointer;
          border-radius: 9999px;
          color: {{ section.settings.filter_btn_color }};
          border: thin solid {{ section.settings.filter_btn_border }};
          font-size: 16px;

          background-color: transparent;
          transition: all 0.3s ease-in-out;

          &.btn__filter--selected {
            background-color: {{ section.settings.filter_btn_selected_bg }};
            color: {{ section.settings.filter_btn_selected_color }};
          }
        }

        & .swiper__testimonials {
          padding-bottom: 3rem;
        }

        & .swiper-wrapper {
          box-sizing: border-box;
        }

        & .swiper-slide {
          height: auto !important;
          aspect-ratio: 9/16;
          box-sizing: border-box;

          &.swiper-slide-hidden {
            display: none;
          }
        }

        & .swiper-pagination-bullet.swiper-pagination-bullet-active {
          background-color: {{ section.settings.pagination_active_color }};
        }

        & .social-proof__media__container {
          border-radius: 1rem;
          position: relative;
          width: 100%;
          display: flex;
          aspect-ratio: 9/16;
          overflow: hidden;
        }

        & .social-proof__img,
        & .social-proof__video {
          width: 100%;
          height: auto;
          object-fit: cover;
          object-position: center;
          cursor: pointer;
        }

        & .overlay__media__container {
          box-sizing: border-box;
          position: absolute;
          bottom: 0;
          inset: 0;
          width: 100%;
          display: flex;
          flex-direction: column;
          cursor: pointer;
        }

        & .overlay__play {
          flex-grow: 1;
          display: flex;
          justify-content: center;
          align-items: center;
        }

        & .icon-hide {
          display: none;
        }

        & .overlay__content {
          position: absolute;
          padding: min(1.25rem, 6dvw);
          bottom: 0;
          inset-inline: 0;
          display: flex;
          flex-direction: column;
          gap: .5rem;
          overflow: hidden;
          margin-top: auto;
          user-select: none;
          pointer-events: none;
        }

        & .overlay__quote {
          margin: 0;
          font-size: clamp(18px, 4vw, 20px);
          font-weight: 300;
          color: {{ section.settings.overlay_text_color }};
        }

        & .overlay__footer {
          display: flex;
          flex-direction: column;
          gap: 0.25rem;
        }

        & .overlay__footer__author__info {
          display: flex;
          gap: 0.5rem;
          align-items: center;
        }

        & .overlay__verified__text {
          font-size: var(--Text-Sizes-Text-Small, 14px);
          font-style: italic;
          font-weight: 400;
          line-height: 150%;
          color: {{ section.settings.overlay_text_color }};


        }

        & .overlay__profile__img {
          flex-shrink: 0;
          width: 40px;
          height: 40px;
          border-radius: 50%;
          object-fit: cover;
        }

        & .overlay__author {
          margin: 0;
          font-size: clamp(20px, 4vw, 24px);
          font-family: "Cormorant Garamond";
          font-style: italic;
          font-weight: 300;
          color: {{ section.settings.overlay_text_color }};
        }

        & .social-proof__texts__container {
          border-radius: 1rem;
          padding: 48px 30px;
          display: flex;
          align-items: center;
          justify-content: flex-start;
          box-sizing: border-box;
          backdrop-filter: blur(6px);
          background-color: {{ section.settings.text_card_bg_color }};
          height: 100%;
          user-select: none;
          pointer-events: none;
          overflow: hidden;
          @media (max-width: 768px) {
            padding: 24px;
          }
        }

        & .social-proof__texts__content {
          box-sizing: border-box;
          display: flex;
          flex-direction: column;
          gap: 2rem;
          width: 100%;
        }

        & .social-proof__texts__stars {
          display: flex;
          gap: 2px;

          & > svg {
            flex-shrink: 0;
          }
        }

        & .social-proof__texts__title {
          margin: 0;
          font-family: "Cormorant Garamond";
          font-size: clamp(28px, 5vw, 32px);
          font-style: italic;
          font-weight: 500;
          line-height: 100%;
          color: {{ section.settings.text_card_text_color }};
        }

        & .social-proof__texts__description {
          margin: 0;
          font-size: clamp(18px, 3.75dvw, 20px);
          color: {{ section.settings.text_card_text_color }};
          font-style: normal;
          font-weight: 400;
          line-height: 140%;
          text-wrap: balance;
        }

        & .social-proof__texts__footer {
          display: flex;
          flex-direction: row;
          align-items: center;
          gap: 0.8rem;
          @media (max-width: 768px) {
            flex-direction: column;
            align-items: flex-start;
          }
          & .container__proof_veri {
            display: flex;
            align-items: center;
            gap: 0.5rem;
          }
        }

        & .text__footer__author {
          margin: 0;
          font-family: "Cormorant Garamond";
          font-style: italic;
          font-weight: 300;
          font-size: clamp(20px, 3.75dvw, 24px);
          color: {{ section.settings.verified_badge_color }};
        }

        & .text__footer__span {
          font-size: 14px;
          font-weight: 300;
          font-style: italic;
          margin-top: 2px;
          line-height: normal;
          letter-spacing: 0.8px;

          color: {{ section.settings.verified_badge_color }} !important;
        }

        & .testimonial__cta {
          margin-top: 2rem;
          display: flex;
          flex-direction: column;
          gap: 1rem;
          align-items: center;
        }

        & .btn__cta {
          background-color: {{ section.settings.cta_bg_color }};
          color: {{ section.settings.cta_text_color }};
          border-radius: 1rem;
          padding: 1rem 2rem;
          text-decoration: none;
          display: inline-block;
           border-radius: 9999px;
          font-size: clamp(14px, 2vw, 16px);
          text-decoration: none;
          text-transform: capitalize;
          letter-spacing: 0.5px;
          font-weight: 400;

        }

        & .testimonial__guarantee {
          display: flex;
          align-items: center;
          gap: 0.5rem;
          font-size: 1rem;
        }

        & .guarantee__span {
          font-weight: 600;
          font-size: 0.875rem;
        }
      }
    }
  }
</style>

<section id="{{section.id}}">
  <div class="section__mp__testimonial__container">
    <div class="testimonial__content{% if section.settings.use_container_sl %} container-sl{% endif %}">
      <div class="testimonial__hero__texts">
        {%- if section.settings.testimonial_title != blank or section.settings.testimonial_description != blank -%}
          <div class="testimonial__hero__header__top">
            {% if section.settings.testimonial_title != blank %}
              <h2 class="testimonial__title">{{ section.settings.testimonial_title }}</h2>
            {% endif %}
            {% if section.settings.testimonial_description != blank %}
              <p class="testimonial__description">{{ section.settings.testimonial_description }}</p>
            {% endif %}
          </div>
        {%- endif -%}
        <div class="btns__container">
          <div class="btns__filter">
            <button class="btn__filter btn__filter--selected" data-filter="all">
              {{ section.settings.all_reviews_text | default: 'ALL REVIEWS' }}
            </button>
            {% for block in section.blocks %}
              {% if block.type == 'filter_button' %}
                <button class="btn__filter" data-filter="{{ block.settings.filter_id }}" {{ block.shopify_attributes }}>
                  {{ block.settings.filter_text }}
                </button>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="swiper__container">
        <div class="swiper swiper__testimonials">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'video_testimonial' %}
                {%- liquid
                  assign filters_array = ''
                  if block.settings.card_filter_1 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_1 | append: ','
                  endif
                  if block.settings.card_filter_2 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_2 | append: ','
                  endif
                  if block.settings.card_filter_3 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_3 | append: ','
                  endif
                  if block.settings.card_filter_4 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_4 | append: ','
                  endif
                  if block.settings.card_filter_5 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_5 | append: ','
                  endif
                  assign filters_array = filters_array | remove_last: ','
                -%}
                <article
                  class="swiper-slide"
                  data-filters="{{ filters_array }}"
                  {{ block.shopify_attributes }}
                >
                  <div class="social-proof__media__container">
                    {%- if block.settings.video != blank -%}
                      <video
                        class="social-proof__video"
                        {% if block.settings.video_controls %}
                          controls
                        {% endif %}
                        playsinline
                      >
                        {%- for source in block.settings.video.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- elsif block.settings.image != blank -%}
                      <img
                        src="{{ block.settings.image | image_url: width: 600 }}"
                        alt="{{ block.settings.image_alt | escape }}"
                        class="social-proof__img"
                        loading="lazy"
                        width="600"
                        height="1067"
                      >
                    {%- endif -%}

                    {%- if block.settings.quote != blank or block.settings.author != blank -%}
                      <div class="overlay__media__container">
                        {%- if block.settings.video != blank and block.settings.show_play_button -%}
                          <div class="overlay__play">
                            {%- render 'icon-play-button' -%}
                          </div>
                        {%- endif -%}
                        <div class="overlay__content">
                          {%- if block.settings.quote != blank -%}
                            <p class="overlay__quote">{{ block.settings.quote }}</p>
                          {%- endif -%}
                          {%- if block.settings.author != blank -%}
                            <div class="overlay__footer">
                              <div class="overlay__footer__author__info">
                                {%- render 'icon-verified', color: block.settings.verified_color -%}
                                <h3 class="overlay__author">{{ block.settings.author }}</h3>
                              </div>
                              {%- if block.settings.show_verified_text -%}
                                <span class="overlay__verified__text">{{ block.settings.verified_text }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                </article>
              {% elsif block.type == 'text_testimonial' %}
                {%- liquid
                  assign filters_array = ''
                  if block.settings.card_filter_1 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_1 | append: ','
                  endif
                  if block.settings.card_filter_2 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_2 | append: ','
                  endif
                  if block.settings.card_filter_3 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_3 | append: ','
                  endif
                  if block.settings.card_filter_4 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_4 | append: ','
                  endif
                  if block.settings.card_filter_5 != blank
                    assign filters_array = filters_array | append: block.settings.card_filter_5 | append: ','
                  endif
                  assign filters_array = filters_array | remove_last: ','
                -%}
                <article
                  class="swiper-slide"
                  data-filters="{{ filters_array }}"
                  {{ block.shopify_attributes }}
                >
                  <div class="social-proof__texts__container">
                    <div class="social-proof__texts__content">
                      {%- if block.settings.show_stars -%}
                        <div class="social-proof__texts__stars">
                          {%- for i in (1..block.settings.stars_count) -%}
                            {% render 'c-orange-star' %}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                      {%- if block.settings.text_title != blank -%}
                        <h3 class="social-proof__texts__title">{{ block.settings.text_title }}</h3>
                      {%- endif -%}
                      {%- if block.settings.text_quote != blank -%}
                        <p class="social-proof__texts__description">{{ block.settings.text_quote }}</p>
                      {%- endif -%}

                      {%- if block.settings.text_author != blank -%}
                        <div class="social-proof__texts__footer">
                          <h3 class="text__footer__author">{{ block.settings.text_author }}</h3>
                          {%- if block.settings.show_verified -%}
                            <div class="container__proof_veri">
                              {%- render 'icon-verified' -%}
                              <span class="text__footer__span">{{ block.settings.verified_text }}</span>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
          {% if section.settings.show_pagination %}
            <div class="swiper-pagination"></div>
          {% endif %}
        </div>
      </div>
      <div class="testimonial__cta">
        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link }}" class="btn__cta">{{ section.settings.cta_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script type="module">
  import Swiper from 'https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.mjs';

  let swiper = null;

  const initSwiper = () => {
    swiper = new Swiper('#{{section.id}} .swiper__testimonials', {
      slidesPerView: 1.1,
      spaceBetween: 16,
      slidesOffsetBefore: 16,
      slidesOffsetAfter: 16,
      pagination: {
        clickable: true,
        el: '.swiper-pagination',
      },
      breakpoints: {
        768: {
          slidesPerView: 2.2,
          spaceBetween: 24,
          slidesOffsetBefore: 24,
          slidesOffsetAfter: 24,
        },
        1024: {
          slidesPerView: 3.3,
          spaceBetween: 24,
          slidesOffsetBefore: 24,
          slidesOffsetAfter: 24,
        },
      },
    });
  };

  // DOM - Use section-specific selectors
  const sectionId = '{{section.id}}';
  const $section = document.getElementById(sectionId);
  const $btnsFilter = $section.querySelectorAll('.btn__filter');
  const $cardsSlides = $section.querySelectorAll('.swiper-slide');

  // Métodos
  const handleSelectBtnFilter = (e) => {
    const btnFilter = e.currentTarget;
    const filter = btnFilter.dataset.filter;

    $btnsFilter.forEach((btn) => {
      btn.classList.remove('btn__filter--selected');
    });
    btnFilter.classList.add('btn__filter--selected');

    showCardsSlides(filter);
  };

  const showCardsSlides = (filter) => {
    $cardsSlides.forEach((card) => {
      if (filter === 'all') {
        card.classList.remove('swiper-slide-hidden');
      } else {
        // Get the filters from data-filters attribute (comma-separated)
        const cardFilters = card.dataset.filters ? card.dataset.filters.split(',') : [];
        // Check if the selected filter is in the card's filters array
        if (cardFilters.includes(filter)) {
          card.classList.remove('swiper-slide-hidden');
        } else {
          card.classList.add('swiper-slide-hidden');
        }
      }
    });

    // UPDATE SWIPER AND RESET POSITION
    if (swiper) {
      swiper.slideTo(0, 0); // Reset to first slide instantly (0ms duration)
      swiper.update();
    }
  };

  
  initSwiper();

  
  const handlePlayVideo = (videoContainer) => {
    const video = videoContainer.querySelector('.social-proof__video');
    const playIcon = videoContainer.querySelector('.overlay__play');
    const overlay = videoContainer.querySelector('.overlay__media__container');

    if (!video) return;

    const toggleVideo = () => {
      if (video.paused) {
        video.play();
        if (playIcon) playIcon.classList.add('icon-hide');
      } else {
        video.pause();
        if (playIcon) playIcon.classList.remove('icon-hide');
      }
    };

    video.addEventListener('click', toggleVideo);
    video.addEventListener('ended', () => {
      if (playIcon) playIcon.classList.remove('icon-hide');
    });
    if (overlay) {
      overlay.addEventListener('click', toggleVideo);
    }
  };

  const $videosContainer = $section.querySelectorAll('.social-proof__media__container');
  $videosContainer.forEach(handlePlayVideo);

   
  $btnsFilter.forEach((btn) => btn.addEventListener('click', handleSelectBtnFilter));

  // Drag to scroll functionality for desktop
  const $btnsContainer = $section.querySelector('.btns__container');
  
  if ($btnsContainer) {
    let isDown = false;
    let startX;
    let scrollLeft;

    $btnsContainer.addEventListener('mousedown', (e) => {
      // Ignore if clicking on a button
      if (e.target.closest('.btn__filter')) return;
      
      isDown = true;
      $btnsContainer.style.cursor = 'grabbing';
      startX = e.pageX - $btnsContainer.offsetLeft;
      scrollLeft = $btnsContainer.scrollLeft;
    });

    $btnsContainer.addEventListener('mouseleave', () => {
      isDown = false;
      $btnsContainer.style.cursor = 'grab';
    });

    $btnsContainer.addEventListener('mouseup', () => {
      isDown = false;
      $btnsContainer.style.cursor = 'grab';
    });

    $btnsContainer.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - $btnsContainer.offsetLeft;
      const walk = (x - startX) * 2; // Scroll speed multiplier
      $btnsContainer.scrollLeft = scrollLeft - walk;
    });
  }
</script>

