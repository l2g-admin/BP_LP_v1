<script>
  document.addEventListener("DOMContentLoaded", function() {
    // --- Set header height CSS variable ---
    const header = document.querySelector('.c-header__main');
    function updateHeaderHeight() {
      if (header) {
        const bottom = header.getBoundingClientRect().bottom + window.scrollY;
        document.documentElement.style.setProperty('--header-height', bottom + 'px');
      }
    }
    updateHeaderHeight();
    window.addEventListener('resize', updateHeaderHeight);

    // --- Mobile Drawer Toggle ---
    const toggleBtn = document.querySelector('.js-menu-toggle');
    const closeBtn = document.querySelector('.js-menu-close');
    const mobileMenu = document.querySelector('.js-mobile-menu');
    const extendedIcons = document.querySelector('.c-header__icons-extended');

    function lockScroll() {
      const scrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';
    }

    function unlockScroll() {
      const scrollY = document.body.style.top;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      document.body.style.overflow = '';
      window.scrollTo(0, parseInt(scrollY || '0') * -1);
    }

    function openMenu() {
      mobileMenu.classList.add('is-open');
      lockScroll();
      if (closeBtn) closeBtn.style.display = 'block';
      if (toggleBtn) toggleBtn.style.display = 'none';
      if (extendedIcons) {
        // Trigger reflow to ensure animation plays
        extendedIcons.offsetHeight;
        extendedIcons.classList.add('is-visible');
      }
    }

    function closeMenu() {
      mobileMenu.classList.remove('is-open');
      unlockScroll();
      if (closeBtn) closeBtn.style.display = 'none';
      if (toggleBtn) toggleBtn.style.display = '';
      if (extendedIcons) extendedIcons.classList.remove('is-visible');
    }

    if (toggleBtn) toggleBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    // --- Patch PredictiveSearch for megamenu section ---
    document.querySelectorAll('#shopify-section-{{ section.id }} predictive-search').forEach(ps => {
      if (ps.getResultsMaxHeight) {
        ps.getResultsMaxHeight = function() {
          const section = document.getElementById('shopify-section-{{ section.id }}');
          if (section) {
            this.resultsMaxHeight = window.innerHeight - section.getBoundingClientRect().bottom;
          } else {
            this.resultsMaxHeight = 400;
          }
          return this.resultsMaxHeight;
        };
      }
    });

    // --- Mobile Accordions ---
    const accordions = document.querySelectorAll('.js-accordion-btn');
    
    accordions.forEach(btn => {
      btn.addEventListener('click', function() {
        const content = this.nextElementSibling;
        
        // Toggle Active Class
        this.classList.toggle('is-active');

        // Toggle Max-Height for animation
        if (content.style.maxHeight) {
          content.style.maxHeight = null;
        } else {
          content.style.maxHeight = content.scrollHeight + "px";
        }
      });
    });
  });
</script>

