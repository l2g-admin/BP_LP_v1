        },
        {
          "type": "text",
          "id": "text_content",
          "label": "Badge Text",
          "default": "Black Friday 25% Off"
        }
      ]
    },
   {
      "type": "register_btn",
      "name": "Register Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "CREATE ACCOUNT"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link",
       
        }
      ]
    },
    {
      "type": "login_btn",
      "name": "Login Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "LOG IN"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link",
         
        }
      ]
    },
    {
      "type": "bf_timer",
      "name": "Black Friday Timer",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "timer_title",
          "label": "Timer Title",
          "default": "BLACK FRIDAY OFFER ENDS IN:"
        },
        {
          "type": "text",
          "id": "target_date",
          "label": "Target Date & Time",
          "default": "December 1, 2024 23:59:59",
          "info": "Format: Month Day, Year HH:MM:SS (e.g., 'December 1, 2024 23:59:59' or 'Dec 1 2024 11:59 PM')"
        },
        {
          "type": "color",
          "id": "timer_bg_color",
          "label": "Timer Background Color",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "timer_text_color",
          "label": "Timer Text Color",
          "default": "#ffffff"
