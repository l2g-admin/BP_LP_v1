{%- comment -%}
  Section: C Results Glass Card
  Description: Centered card section with heading, description, background image, and icon content blocks.
  sl-id: sl-section-results-glass-card-v1
  Figma: https://www.figma.com/design/f1AWMl23NcBW13s8SML1B5/BKL?node-id=4686-3219&m=dev
{%- endcomment -%}

{%- liquid
  assign sl_id = 'sl-section-results-glass-card-v1'
  assign section_heading = section.settings.heading
  assign section_description = section.settings.description
-%}

{% style %}
  #{{ section.id }} {
    --sl-c-results-glass-card-text: {{ section.settings.text_color }};
    --sl-c-results-glass-card-card-bg: {{ section.settings.card_bg_color }};
    --sl-c-results-glass-card-overlay: {{ section.settings.overlay_color }};
    --sl-c-results-glass-card-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --sl-c-results-glass-card-row-bg: {{ section.settings.row_bg_color | color_modify: 'alpha', section.settings.row_bg_opacity | divided_by: 100.0 }};
    --sl-c-results-glass-card-row-border: {{ section.settings.row_border_color | color_modify: 'alpha', section.settings.row_border_opacity | divided_by: 100.0 }};
    --sl-c-results-glass-card-block-min-width: {{ section.settings.mobile_block_width }}px;
    --sl-c-results-glass-card-icon-size: {{ section.settings.icon_size }}px;
    --sl-c-results-glass-card-gap: {{ section.settings.block_gap }}px;
    --sl-c-results-glass-card-radius: {{ section.settings.card_radius }}px;
    --sl-c-results-glass-card-inner-radius: {{ section.settings.inner_radius }}px;
    --sl-c-results-glass-card-section-pad-t: {{ section.settings.padding_top_mobile }}px;
    --sl-c-results-glass-card-section-pad-b: {{ section.settings.padding_bottom_mobile }}px;
    --sl-c-results-glass-card-card-pad: 28px;

    color: var(--sl-c-results-glass-card-text);
    position: relative;
    padding: var(--sl-c-results-glass-card-section-pad-t) 16px var(--sl-c-results-glass-card-section-pad-b);
  }

  #{{ section.id }} .c-results-glass-card__anchor {
    position: absolute;
    top: -80px;
  }

  #{{ section.id }} .c-results-glass-card__container {
    max-width: 1320px;
    margin: 0 auto;
  }

  #{{ section.id }} .c-results-glass-card__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--sl-c-results-glass-card-radius);
    padding: var(--sl-c-results-glass-card-card-pad);
  }

  #{{ section.id }} .c-results-glass-card__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #{{ section.id }} .c-results-glass-card__background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  #{{ section.id }} .c-results-glass-card__background-fallback {
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 20% 20%, #27305c 0%, #0f1532 50%, #0a1028 100%);
  }

  #{{ section.id }} .c-results-glass-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--sl-c-results-glass-card-overlay);
    opacity: var(--sl-c-results-glass-card-overlay-opacity);
    mix-blend-mode: multiply;
  }

  #{{ section.id }} .c-results-glass-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #{{ section.id }} .c-results-glass-card__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #{{ section.id }} .c-results-glass-card__heading {
    margin: 0;
    color: var(--sl-c-results-glass-card-text);
    font-size: 34px;
    line-height: 1.2;
    font-weight: 500;
  }

  #{{ section.id }} .c-results-glass-card__heading p {
    margin: 0;
  }

  #{{ section.id }} .c-results-glass-card__heading em,
  #{{ section.id }} .c-results-glass-card__heading i {
    font-family: "Cormorant Garamond", serif;
    font-style: italic;
    font-weight: 500;
  }

  #{{ section.id }} .c-results-glass-card__description {
    margin: 0;
    color: var(--sl-c-results-glass-card-text);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: 0.03em;
  }

  #{{ section.id }} .c-results-glass-card__description p {
    margin: 0;
  }

  #{{ section.id }} .c-results-glass-card__row {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--sl-c-results-glass-card-gap);
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    padding: 20px;
    border: 1px solid var(--sl-c-results-glass-card-row-border);
    border-radius: var(--sl-c-results-glass-card-inner-radius);
    background: var(--sl-c-results-glass-card-row-bg);
    backdrop-filter: blur(20px);
  }

  #{{ section.id }} .c-results-glass-card__row::-webkit-scrollbar {
    height: 8px;
  }

  #{{ section.id }} .c-results-glass-card__row::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.35);
    border-radius: 999px;
  }

  #{{ section.id }} .c-results-glass-card__block {
    min-width: var(--sl-c-results-glass-card-block-min-width);
    width: var(--sl-c-results-glass-card-block-min-width);
    display: flex;
    flex-direction: column;
    gap: 18px;
    flex: 0 0 auto;
  }

  #{{ section.id }} .c-results-glass-card__icon {
    width: var(--sl-c-results-glass-card-icon-size);
    height: var(--sl-c-results-glass-card-icon-size);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: var(--sl-c-results-glass-card-text);
  }

  #{{ section.id }} .c-results-glass-card__icon img,
  #{{ section.id }} .c-results-glass-card__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #{{ section.id }} .c-results-glass-card__block-title {
    margin: 0;
    color: var(--sl-c-results-glass-card-text);
    font-size: 24px;
    line-height: 1.2;
    font-weight: 500;
  }

  #{{ section.id }} .c-results-glass-card__block-description {
    margin: 0;
    color: var(--sl-c-results-glass-card-text);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: 0.03em;
  }

  #{{ section.id }} .c-results-glass-card__block-description p {
    margin: 0;
  }

  @media (min-width: 768px) {
    #{{ section.id }} {
      --sl-c-results-glass-card-section-pad-t: {{ section.settings.padding_top_desktop }}px;
      --sl-c-results-glass-card-section-pad-b: {{ section.settings.padding_bottom_desktop }}px;
      --sl-c-results-glass-card-card-pad: 48px;

      padding-left: 24px;
      padding-right: 24px;
    }

    #{{ section.id }} .c-results-glass-card__content {
      gap: 48px;
    }

    #{{ section.id }} .c-results-glass-card__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 48px;
    }

    #{{ section.id }} .c-results-glass-card__heading {
      max-width: 768px;
      font-size: 48px;
    }

    #{{ section.id }} .c-results-glass-card__description {
      max-width: 440px;
      text-align: right;
      font-size: 18px;
    }

    #{{ section.id }} .c-results-glass-card__row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--sl-c-results-glass-card-gap);
      overflow: visible;
      padding: 32px;
    }

    #{{ section.id }} .c-results-glass-card__block {
      min-width: 0;
      width: auto;
      flex: 1 1 auto;
    }
  }

  @media (min-width: 978px) {
    #{{ section.id }} .c-results-glass-card__card {
      padding: 64px;
    }
  }

  @media (min-width: 1200px) {
    #{{ section.id }} .c-results-glass-card__description {
      font-size: 18px;
    }
  }

  @media (min-width: 1980px) {
    #{{ section.id }} .c-results-glass-card__container {
      max-width: 1520px;
    }
  }
{% endstyle %}

<section
  id="{{ section.id }}"
  class="c-results-glass-card"
  data-section-id="{{ section.id }}"
  data-sl-id="{{ sl_id }}"
  data-section-type="c-results-glass-card"
>
  {%- if section.settings.sl_anchor_id != blank -%}
    <span id="{{ section.settings.sl_anchor_id | escape }}" class="c-results-glass-card__anchor" aria-hidden="true"></span>
  {%- endif -%}

  <div class="c-results-glass-card__container">
    <div class="c-results-glass-card__card">
      <div class="c-results-glass-card__background" aria-hidden="true">
        {%- if section.settings.background_image != blank -%}
          {{
            section.settings.background_image
            | image_url: width: 2400
            | image_tag:
              class: 'c-results-glass-card__background-image',
              loading: 'lazy',
              widths: '800, 1200, 1600, 2000, 2400',
              sizes: '(min-width: 1200px) 1280px, 100vw',
              alt: ''
          }}
        {%- else -%}
          <div class="c-results-glass-card__background-fallback"></div>
        {%- endif -%}
        <div class="c-results-glass-card__overlay"></div>
      </div>

      <div class="c-results-glass-card__content">
        <div class="c-results-glass-card__header">
          {%- if section_heading != blank -%}
            <div class="c-results-glass-card__heading rte">{{ section_heading }}</div>
          {%- endif -%}
          {%- if section_description != blank -%}
            <div class="c-results-glass-card__description rte">{{ section_description }}</div>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="c-results-glass-card__row" role="list">
            {%- for block in section.blocks -%}
              <article class="c-results-glass-card__block" role="listitem" {{ block.shopify_attributes }}>
                <div class="c-results-glass-card__icon" aria-hidden="true">
                  {%- if block.settings.icon_html != blank -%}
                    {{ block.settings.icon_html }}
                  {%- elsif block.settings.icon_image != blank -%}
                    {{ block.settings.icon_image | image_url: width: 128 | image_tag: loading: 'lazy', alt: block.settings.heading | escape }}
                  {%- endif -%}
                </div>

                {%- if block.settings.heading != blank -%}
                  <h3 class="c-results-glass-card__block-title">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <div class="c-results-glass-card__block-description rte">{{ block.settings.description }}</div>
                {%- endif -%}
              </article>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Results Glass Card",
  "tag": "section",
  "class": "c-results-glass-card-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "Anchor ID",
      "info": "HTML anchor for internal navigation"
    },
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Daily Support. <em>Clinically Proven</em>. Measurable Results.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Everything about this kit is designed to make blood flow support effortless and measurable.</p>"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card fallback background",
      "default": "#0f1532"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#0c0e21"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 65
    },
    {
      "type": "color",
      "id": "row_bg_color",
      "label": "Blocks row background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "row_bg_opacity",
      "label": "Blocks row background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 10
    },
    {
      "type": "color",
      "id": "row_border_color",
      "label": "Blocks row border color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "row_border_opacity",
      "label": "Blocks row border opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Outer card corner radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "inner_radius",
      "label": "Inner row corner radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "Block gap",
      "min": 8,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_block_width",
      "label": "Mobile block width",
      "min": 220,
      "max": 420,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "box_content",
      "name": "Box Content",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "html",
          "id": "icon_html",
          "label": "Icon HTML",
          "info": "Optional. If set, this will override Icon image."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Simple Daily Habit"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>An easy-to-take daily formula designed to fit your routine and support healthy blood flow.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "C Results Glass Card",
      "blocks": [
        {
          "type": "box_content",
          "settings": {
            "heading": "Simple Daily Habit",
            "description": "<p>An easy-to-take daily formula designed to fit seamlessly into your routine and support healthy blood flow and long-term health.</p>"
          }
        },
        {
          "type": "box_content",
          "settings": {
            "heading": "Clinically Proven Support",
            "description": "<p>Backed by clinical studies and shown to significantly increase Nitric Oxide levels, supporting heart health, energy, sexual wellness, cognitive function, and healthy aging.</p>"
          }
        },
        {
          "type": "box_content",
          "settings": {
            "heading": "Measurable Results at Home",
            "description": "<p>Includes Nitric Oxide Test Strips so you can track your NO levels and see your progress in real time.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
