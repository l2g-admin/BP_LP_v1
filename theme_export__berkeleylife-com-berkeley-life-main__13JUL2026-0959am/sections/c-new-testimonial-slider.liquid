<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500;1,600&display=swap');

  /* =========================================
     DESKTOP STYLES (Base / Desktop First)
     ========================================= */
  #{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;

    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-blend-mode: multiply;
    {% endif %}

    & .c-testimonial__container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.5rem;
      position: relative;
      z-index: 2;
    }

    /* --- HEADER --- */
    & .c-testimonial__header {
      text-align: center;
      margin-bottom: 3rem;
    }

    & .c-testimonial__eyebrow {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: {{ section.settings.eyebrow_color }};
      margin: 0 0 1rem 0;
    }

    & .c-testimonial__title {
      font-size: clamp(32px, 4vw, 46px);
      line-height: 1.2;
      margin: 0;
      color: {{ section.settings.title_color }};
    }

    /* --- CARD (fixed shell) --- */
    & .c-testimonial__card {
      background: {{ section.settings.card_bg }};
      border-radius: 16px;
      padding: 4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
  
      width: 100%;
    }

    /* --- SLIDER (inside card) --- */
    & .swiper {
      width: 100%;
      overflow: hidden;
    }

    & .swiper-slide {
      opacity: 0 !important;
      transition: opacity 0.4s ease;

      &.swiper-slide-active {
        opacity: 1 !important;
      }
    }

    & .c-testimonial__slide-content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    & .c-testimonial__stars {
      display: flex;
      gap: 4px;
      color: {{ section.settings.accent_color }};
      margin-bottom: 2rem;

      & svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }
    }

    & .c-testimonial__quote {
      font-size: clamp(16px, 2vw, 20px);
      line-height: 1.6;
      color: {{ section.settings.card_text }};
      margin: 0 0 3rem 0;
    }

    /* --- AUTHOR --- */
    & .c-testimonial__author {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
    }

    & .c-testimonial__author-img {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      object-fit: cover;
    }

    & .c-testimonial__author-name {
      font-family: "Cormorant Garamond", serif;
      font-style: italic;
      font-size: clamp(20px, 2.5vw, 24px);
      color: {{ section.settings.accent_color }};
      margin: 0;
    }

    /* --- PAGINATION --- */
    &  .swiper-pagination {
      position: static;
      bottom: 0;
      margin-top: 2.5rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
    }

    & .swiper-pagination-bullet {
      width: 60px;
      height: 4px;
      border-radius: 2px;
      background: {{ section.settings.pagination_color }} !important;
      margin: 0 !important;
      opacity: 1;
      transition: background 0.3s ease;
      cursor: pointer;
    }

    & .swiper-pagination-bullet-active {
      background: {{ section.settings.pagination_active_color }} !important;
    }
  }

  /* =========================================
     MOBILE STYLES (Max 991px)
     ========================================= */
  @media screen and (max-width: 991px) {
    #{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;

      & .c-testimonial__header {
        margin-bottom: 2rem;
      }

      & .c-testimonial__title {
        font-size: 28px;
      }

      & .c-testimonial__card {
        padding: 2.5rem 1.5rem;
      }

      & .c-testimonial__quote {
        font-size: 16px;
        margin-bottom: 2rem;
      }

      & .swiper-pagination-bullet {
        width: 40px;
      }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="c-testimonial__container">
    
    <div class="c-testimonial__header">
      {% if section.settings.eyebrow != blank %}
        <p class="c-testimonial__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      
      {% if section.settings.title != blank %}
        <h2 class="c-testimonial__title">{{ section.settings.title | newline_to_br }}</h2>
      {% endif %}
    </div>

    <div class="c-testimonial__card">
      <div class="swiper js-testimonial-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="c-testimonial__slide-content">
                <div class="c-testimonial__stars">
                  {% for i in (1..5) %}
                    {% render 'c-orange-star' %}
                  {% endfor %}
                </div>

                <p class="c-testimonial__quote">"{{ block.settings.quote }}"</p>

                <div class="c-testimonial__author">
                  {% if block.settings.author_image != blank %}
                    <img src="{{ block.settings.author_image | image_url: width: 120 }}" alt="{{ block.settings.author_name }}" class="c-testimonial__author-img" loading="lazy">
                  {% else %}
                    <div class="c-testimonial__author-img" style="background-color:#ccc;"></div>
                  {% endif %}

                  <span class="c-testimonial__author-name">{{ block.settings.author_name }}</span>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="swiper-pagination js-test-pagination-{{ section.id }}"></div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperSelector = '.js-testimonial-swiper-{{ section.id }}';
    const swiperContainer = document.querySelector(swiperSelector);

    if (swiperContainer) {
      new Swiper(swiperSelector, {
        slidesPerView: 1,
        spaceBetween: 0,
        grabCursor: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        autoHeight: true,
        pagination: {
          el: '.js-test-pagination-{{ section.id }}',
          clickable: true,
        }
      });
    }
  });
</script>

