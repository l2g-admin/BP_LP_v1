{%- comment -%}
  Section: C Page Top Bar
  Description: Page-specific announcement strip rendered between announcement bar and header.
  sl-id: sl-section-page-top-bar-v1
{%- endcomment -%}

{%- liquid
  assign sl_id = 'sl-section-page-top-bar-v1'
  assign should_show = false

  if request.page_type == 'page' and section.settings.target_page != blank and section.settings.text != blank
    if section.settings.target_page.url == request.path
      assign should_show = true
    endif
  endif
-%}

{%- if should_show -%}
  <section
    id="{{ section.id }}"
    class="c-page-top-bar"
    data-section-id="{{ section.id }}"
    data-sl-id="{{ sl_id }}"
    data-section-type="c-page-top-bar"
    {% if section.settings.sl_anchor_id != blank %}data-anchor-id="{{ section.settings.sl_anchor_id | escape }}"{% endif %}
  >
    <div class="c-page-top-bar__container page-width">
      {%- if section.settings.link != blank -%}
        <a class="c-page-top-bar__message" href="{{ section.settings.link }}">
          {{ section.settings.text }}
        </a>
      {%- else -%}
        <div class="c-page-top-bar__message">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>
  </section>

  {% style %}
    #shopify-section-c-header-banner-o {
      display: none !important;
    }

    #{{ section.id }} {
      --sl-c-page-top-bar-bg-color: {{ section.settings.bg_color | default: '#111111' }};
      --sl-c-page-top-bar-text-color: {{ section.settings.text_color | default: '#ffffff' }};
      --sl-c-page-top-bar-padding-y: {{ section.settings.padding_y | default: 10 }}px;
      --sl-c-page-top-bar-font-size: {{ section.settings.font_size | default: 12 }}px;
      --sl-c-page-top-bar-letter-spacing: {{ section.settings.letter_spacing | default: 1.2 }}px;

      background-color: var(--sl-c-page-top-bar-bg-color);
      color: var(--sl-c-page-top-bar-text-color);
    }

    #{{ section.id }} .c-page-top-bar__container {
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding-top: var(--sl-c-page-top-bar-padding-y);
      padding-bottom: var(--sl-c-page-top-bar-padding-y);
    }

    #{{ section.id }} .c-page-top-bar__message {
      color: inherit;
      font-size: var(--sl-c-page-top-bar-font-size);
      letter-spacing: var(--sl-c-page-top-bar-letter-spacing);
      line-height: 1.35;
      text-transform: uppercase;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    #{{ section.id }} a.c-page-top-bar__message:hover,
    #{{ section.id }} a.c-page-top-bar__message:focus-visible {
      opacity: 0.8;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    @media (min-width: 768px) {
      #{{ section.id }} {
        --sl-c-page-top-bar-font-size: {{ section.settings.font_size_tablet | default: 13 }}px;
      }
    }

    @media (min-width: 978px) {
      #{{ section.id }} {
        --sl-c-page-top-bar-font-size: {{ section.settings.font_size_laptop | default: 14 }}px;
      }
    }

    @media (min-width: 1200px) {
      #{{ section.id }} {
        --sl-c-page-top-bar-font-size: {{ section.settings.font_size_desktop | default: 14 }}px;
      }
    }

    @media (min-width: 1980px) {
      #{{ section.id }} {
        --sl-c-page-top-bar-font-size: {{ section.settings.font_size_large | default: 15 }}px;
      }
    }
  {% endstyle %}
{%- endif -%}

{% schema %}
{
  "name": "C Page Top Bar",
  "tag": "section",
  "class": "c-page-top-bar-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "Anchor ID",
      "info": "HTML anchor for internal navigation"
    },
    {
      "type": "page",
      "id": "target_page",
      "label": "Target page",
      "info": "Only render this bar on the selected page"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Message",
      "default": "<p>Limited-time message for this page</p>"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 6,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Vertical padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "px",
      "label": "Letter spacing",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size (mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size_tablet",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size (tablet)",
      "default": 13
    },
    {
      "type": "range",
      "id": "font_size_laptop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size (laptop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size (desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_large",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font size (1980px+)",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "C Page Top Bar"
    }
  ]
}
{% endschema %}
