<style>
  #{{section.id}} {
      {%- assign half_padding_top = section.settings.padding_top | divided_by: 2.0 -%}
      {%- assign half_padding_bottom = section.settings.padding_bottom | divided_by: 2.0 -%}
    padding-top: {{ half_padding_top }}em;
    padding-bottom: {{ half_padding_bottom }}em;
    background-color: {{ section.settings.bg_color }};
    border-radius: {{ section.settings.border_radius_top }}px {{ section.settings.border_radius_top }}px 0 0;
    position: relative;
    overflow: hidden;

    & * {
        color: {{ section.settings.text_color }};
        position: relative;
        z-index: 2;
    }

    & *:not(.hero__title) {

    }

 
    & .comparison__section {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      border-radius: 32px;
    border: 2px solid var(--Text-Navy, #080B2B);
    padding: 40px 20px;
    }

    & .comparison__hero {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    & .hero__title {
      margin: 0;
            font-size: clamp(32px, 6vw + 1rem, 54px);

      line-height: 110%;
 
      & * {
             font-size: clamp(32px, 6vw + 1rem, 54px);

        line-height: 110%;
        font-weight: 600;
      }
    }

    & .hero__subtitle {
      margin: 0;
       font-size: clamp(36px, 6vw + 1rem, 54px);
      font-style: italic;
      color: {{ section.settings.accent_color }};
      font-family: 'Cormorant Garamond', serif;
      line-height: 120%;
    }

    & .hero__description {
      margin: 0;
      font-size: 1rem;
      line-height: 1.6;
      max-width: 600px;
      margin-inline: auto;
    }

    & .comparison__cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    & .comparison__card {
      border-radius: 24px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      position: relative;
      overflow: hidden;
      color: {{ section.settings.card_text_color }} !important;

      & * {
        color: {{ section.settings.card_text_color }} !important;
      }
    }

    & .card__image {
      position: absolute;
      top: 0rem;
      right: -2rem;
      width: 100px;
      height: 100px;
      border-radius: 12px;
      overflow: hidden;
      z-index: 3;
 

      & img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }
    }

    & .comparison__card--negative {
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    }

    & .comparison__card--positive {
      background: linear-gradient(135deg, {{ section.settings.accent_color }} 0%, #c2410c 100%);
      overflow: visible;
    }

    & .card__header {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    & .card__title {
      font-size: 24px;
      font-style: italic;
        font-weight: 500;
        line-height: 100%;
      margin: 0;

      font-family: 'Cormorant Garamond', serif;
    }

    & .card__subtitle {
      margin: 0;
      font-size: 14px;
      font-style: normal;
      font-weight: 600;
      line-height: 120%;  
      letter-spacing: 0.7px;
      text-transform: uppercase;
    }

    & .card__items {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    & .card__item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      font-size: 14px;
      line-height: 1.5;
    }

    & .card__icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      margin-top: 2px;
      display: flex;
      align-items: center;
      justify-content: center;

      & svg {
        width: 100%;
        height: 100%;
        fill: currentColor;
      }
    }

    & .card__icon--negative {
      color: #ef4444;
    }

    & .card__icon--positive {
      color: #22c55e;
    }

    & .comparison__cta {
      text-align: center;
      position: relative;
      top: 4rem;
    }

    & .cta__button {
      display: inline-block;
      padding: 1rem 2.5rem;
      background: {{ section.settings.accent_color }};
      color: #ffffff;
      text-decoration: none;
      border-radius: 50px;
 
      font-size: 16px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
      }
    }
  }

  @media screen and (width >= 1024px) {
    #{{section.id}} {
      padding-top: {{ section.settings.padding_top }}em;
      padding-bottom: {{ section.settings.padding_bottom }}em;

      & .comparison__cards {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        align-items: center;
      }

      & .comparison__card {
        padding: 2.5rem;
      }

      & .card__title {
        font-size: 32px;
      }
 

      & .card__item {
        font-size: 16px;
      }

      & .card__image {
        width: 150px;
        height: 150px;
        top: -2.5rem;
        right: -3.5rem;
      }

      & .hero__description {
        font-size: 18px;
      }
    }
  }

  @media screen and (width >= 1024px) {
    #{{section.id}} {
      & .comparison__section {
        gap: 4rem;
         padding: 80px;
      }

       & .comparison__cta {
        top: 7rem;
        }
    }
  }
</style>

<section id="{{ section.id }}">
  <div class="container-sl">
    <div class="comparison__section">
      <div class="comparison__hero">
        <div class="container__header__top">
          {% if section.settings.hero_title != blank %}
            <h2 class="hero__title">{{ section.settings.hero_title }}</h2>
          {% endif %}

          {% if section.settings.hero_subtitle != blank %}
            <h2 class="hero__subtitle">{{ section.settings.hero_subtitle }}</h2>
          {% endif %}
        </div>

        {% if section.settings.hero_description != blank %}
          <p class="hero__description">{{ section.settings.hero_description }}</p>
        {% endif %}
      </div>

      <div class="comparison__cards">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'comparison_card' %}
              <div
                class="comparison__card comparison__card--{{ block.settings.card_type }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.image != blank %}
                  <div class="card__image">
                    {{
                      block.settings.image
                      | image_url: width: 200
                      | image_tag: loading: 'lazy', alt: block.settings.title
                    }}
                  </div>
                {% endif %}

                <div class="card__header">
                  {% if block.settings.title != blank %}
                    <h4 class="card__title">{{ block.settings.title }}</h4>
                  {% endif %}
                  {% if block.settings.subtitle != blank %}
                    <p class="card__subtitle">{{ block.settings.subtitle }}</p>
                  {% endif %}
                </div>

                {% if block.settings.items != blank %}
                  <div class="card__items">
                    {% assign items_array = block.settings.items | split: '|' %}
                    {% for item in items_array %}
                      {% if item != blank %}
                        <div class="card__item">
                          <div class="card__icon card__icon--{{ block.settings.card_type }}">
                            {% if block.settings.card_type == 'negative' %}
                              {% render 'c-x' %}
                            {% else %}
                              {% render 'c-check' %}
                            {% endif %}
                          </div>
                          <span>{{ item | strip }}</span>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>

      {% if section.settings.cta_text != blank %}
        <div class="comparison__cta">
          <a href="{{ section.settings.cta_link | default: '#' }}" class="cta__button">
            {{ section.settings.cta_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "C Comparison Cards",
  "blocks": [
    {
      "type": "comparison_card",
      "name": "Comparison Card",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "card_type",
          "label": "Card Type",
          "options": [
            {
              "value": "negative",
              "label": "Negative (Regular Gum)"
            },
            {
              "value": "positive",
              "label": "Positive (Our Product)"
            }
          ],
          "default": "negative"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Regular Gum"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Card Subtitle"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image (Top Right Corner)"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Card Items",
          "info": "Separate each item with a | (pipe) character",
          "default": "Contains artificial sweeteners and harsh ingredients that disrupt good bacteria|Masks bad breath instead of addressing the root cause|Offers no support for Nitric Oxide production or oral microbiome balance|Short-term freshness without long-term health benefits"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Main Title",
      "default": "Why Regular Gum Can't Support"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "True Oral + Nitric Oxide Health"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Most gums mask bad breath or add artificial sweeteners — but they do nothing to nourish your oral microbiome or boost Nitric Oxide. Balance Gum does both, combining probiotics and plant-based nitrates for real, science-backed benefits."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "SHOP BALANCE GUM"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Styling Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D44F2F"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius_top",
      "label": "Top Border Radius",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6,
      "unit": "rem"
    }
  ],
  "presets": [
    {
      "name": "C Comparison Cards",
      "blocks": [
        {
          "type": "comparison_card",
          "settings": {
            "card_type": "negative",
            "title": "Regular Gum",
            "items": "Contains artificial sweeteners and harsh ingredients that disrupt good bacteria|Masks bad breath instead of addressing the root cause|Offers no support for Nitric Oxide production or oral microbiome balance|Short-term freshness without long-term health benefits"
          }
        },
        {
          "type": "comparison_card",
          "settings": {
            "card_type": "positive",
            "title": "Our Balance Prebiotic Nitrate Gum",
            "items": "Plant-based nitrates fuel beneficial oral bacteria to generate Nitric Oxide naturally|Includes clinically researched probiotics to restore oral microbiome balance|Supports healthy gums, fresh breath, and full-body energy — all sugar-free|Backed by science and designed for daily use, anytime, anywhere"
          }
        }
      ]
    }
  ]
}
{% endschema %}
