<script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>

<cart-drawer class="fixed inset-0 z-50 flex justify-end invisible w-full h-full translate-x-full opacity-0 bg-opacity-20 motion-safe:transition-transform motion-safe:duration-700 motion-safe:transform" data-classes-post="visible opacity-100 translate-x-0" data-classes-pre="invisible opacity-0 translate-x-full">
  <div class="w-full h-full max-w-md pb-8 overflow-auto bg-cream text-navy" id="CartDrawer" aria-label="Cart Drawer" role="dialog" tabindex="-1">
    <button class="fixed z-10 w-10 h-10 p-2 top-4 right-4" data-close-cart-drawer>
      <span class="w-full h-full">
        {% render 'icon-close' %}
      </span>
      <span class="sr-only">
        Close Cart Drawer
      </span>
    </button>
    <div hx-get="/cart?view=bare" hx-select="#CartPage" hx-trigger="load, render-cart from:body delay:200ms" class="w-full" hx-swap="innerHTML" >
    </div>
  </div>
</cart-drawer>

<script>
  const DISCOUNT_CONFIG = {
    enabled: {{ section.settings.show_discount_input | json }},
    placeholder: {{ section.settings.discount_placeholder | default: 'Discount code' | json }},
    buttonText: {{ section.settings.discount_button_text | default: 'Apply' | json }}
  };

  function createDiscountForm() {
    if (!DISCOUNT_CONFIG.enabled) return;

    const subtotal = document.querySelector('#main-cart-footer .js-contents');
    if (!subtotal) return;

    // Don't duplicate
    if (subtotal.parentElement.querySelector('.discount-code-form')) return;

    const wrapper = document.createElement('div');
    wrapper.className = 'discount-code-form mb-4';
    wrapper.innerHTML = `
      <div class="discount-tags flex flex-wrap gap-2 mb-3"></div>
      <div class="flex gap-2">
        <input
          type="text"
          class="discount-input flex-1 px-4 py-2 text-sm border rounded border-navy/30 bg-transparent placeholder:text-navy/50 focus:outline-none focus:border-navy"
          placeholder="${DISCOUNT_CONFIG.placeholder}"
          aria-label="${DISCOUNT_CONFIG.placeholder}"
        >
        <button
          type="button"
          class="discount-btn px-4 py-2 text-sm font-medium border rounded border-navy text-navy hover:bg-navy hover:text-cream transition-colors"
        >
          ${DISCOUNT_CONFIG.buttonText}
        </button>
      </div>
      <p class="hidden mt-2 text-xs text-red-600 discount-error"></p>
      <p class="hidden mt-2 text-xs text-green-700 discount-success"></p>
    `;

    subtotal.parentElement.insertBefore(wrapper, subtotal);

    const input = wrapper.querySelector('.discount-input');
    const button = wrapper.querySelector('.discount-btn');
    const errorEl = wrapper.querySelector('.discount-error');
    const successEl = wrapper.querySelector('.discount-success');
    const tagsEl = wrapper.querySelector('.discount-tags');

    function hideMessages() {
      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
      successEl.classList.add('hidden');
    }

    function showSuccess(msg) {
      successEl.textContent = msg;
      successEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
    }

    function renderTags(discounts) {
      tagsEl.innerHTML = discounts.map(d => `
        <span class="inline-flex items-center gap-1 px-3 py-1 text-xs border rounded-full border-navy/20 bg-navy/5">
          <svg aria-hidden="true" focusable="false" class="w-3 h-3" viewBox="0 0 12 12">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z" fill="currentColor"/>
          </svg>
          ${d.title} (-${Shopify.formatMoney ? Shopify.formatMoney(d.total_allocated_amount) : ('$' + (d.total_allocated_amount / 100).toFixed(2))})
        </span>
      `).join('');
    }

    async function applyDiscount() {
      const code = input.value.trim();
      if (!code) return;

      hideMessages();
      button.disabled = true;
      button.textContent = '...';

      try {
        // Capture cart state before applying
        const beforeRes = await fetch('/cart.js');
        const beforeCart = await beforeRes.json();
        const beforeTotal = beforeCart.total_discount;
        const beforeCount = (beforeCart.cart_level_discount_applications || []).length;

        await fetch('/discount/' + encodeURIComponent(code), { method: 'GET', redirect: 'follow' });

        // Compare cart state after applying
        const afterRes = await fetch('/cart.js');
        const afterCart = await afterRes.json();
        const afterTotal = afterCart.total_discount;
        const afterDiscounts = afterCart.cart_level_discount_applications || [];

        const applied = afterTotal > beforeTotal || afterDiscounts.length > beforeCount;

        button.disabled = false;
        button.textContent = DISCOUNT_CONFIG.buttonText;

        if (applied) {
          input.value = '';
          renderTags(afterDiscounts);
          sessionStorage.setItem('discount_success', 'Discount code applied!');
          document.body.dispatchEvent(new CustomEvent('render-cart'));
        } else {
          showError('Invalid discount code or not applicable.');
        }
      } catch (err) {
        showError('Something went wrong. Please try again.');
        button.disabled = false;
        button.textContent = DISCOUNT_CONFIG.buttonText;
      }
    }

    button.addEventListener('click', applyDiscount);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        applyDiscount();
      }
    });

    // Show persisted success message if exists
    const pendingMsg = sessionStorage.getItem('discount_success');
    if (pendingMsg) {
      showSuccess(pendingMsg);
      sessionStorage.removeItem('discount_success');
    }

    // Load applied discounts on init
    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => renderTags(cart.cart_level_discount_applications || []))
      .catch(() => {});
  }

  // Inject after each HTMX swap (initial load + cart updates)
  document.body.addEventListener('htmx:afterSwap', createDiscountForm);
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_discount_input",
      "label": "Show discount code input",
      "default": true
    },
    {
      "type": "text",
      "id": "discount_placeholder",
      "label": "Discount input placeholder",
      "default": "Discount code"
    },
    {
      "type": "text",
      "id": "discount_button_text",
      "label": "Discount button text",
      "default": "Apply"
    }
  ]
}
{% endschema %}