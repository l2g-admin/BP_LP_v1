<style>
  .copy-code-box {
    background-color: #ffffff;
    border: 2px solid #D44F2F;
    border-radius: 16px;
    padding: 1.5rem;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .copy-code-box__title {
    font-size: clamp(14px, 3vw, 16px);
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #080B2B;
    margin: 0;
  }

  .copy-code-box__code-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #ffffff;
    border: 2px solid #D44F2F;
    border-radius: 8px;
    padding: 0.5rem 0.5rem 0.5rem 1.25rem;
    gap: 0.5rem;
  }

  .copy-code-box__code {
    font-size: clamp(18px, 4vw, 22px);
    font-weight: 600;
    letter-spacing: 2px;
    color: #080B2B;
    flex: 1;
    text-align: left;
  }

  .copy-code-box__copy-btn {
    background-color: #5C4B51;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .copy-code-box__copy-btn:hover {
    transform: scale(1.02);
    opacity: 0.9;
  }

  .copy-code-box__copy-btn.copied {
    background-color: #28a745;
  }

  .copy-code-box__cta-btn {
    display: inline-block;
    background-color: #D44F2F;
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    padding: 1rem 2rem;
    font-size: clamp(16px, 3vw, 18px);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    text-align: center;
  }

  .copy-code-box__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .copy-code-box__discount-text {
    font-size: clamp(14px, 3vw, 16px);
    color: #080B2B;
    margin: 0;
    line-height: 1.4;
  }

  .copy-code-box__discount-text strong {
    font-weight: 700;
  }

  .copy-code-box__discount-note {
    font-size: clamp(12px, 2.5vw, 14px);
    color: #080B2B;
    font-style: italic;
    margin: 0;
  }
</style>

<div class="copy-code-box">
  <h3 class="copy-code-box__title">YOUR EXCLUSIVE OFFER</h3>

  <div class="copy-code-box__code-wrapper">
    <span class="copy-code-box__code">MENO20</span>
    <button 
      type="button" 
      class="copy-code-box__copy-btn" 
      data-copy-code="MENO20"
      aria-label="Copy coupon code"
    >
      Copy
    </button>
  </div>

  <a href="/collections/menopause-support" class="copy-code-box__cta-btn">
    Shop Menopause Support
  </a>

  <p class="copy-code-box__discount-text">Paste at checkout to save <strong>20%</strong></p>
  <p class="copy-code-box__discount-note">*first-purchase discount</p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const copyButtons = document.querySelectorAll('[data-copy-code]');
    
    copyButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        const code = this.getAttribute('data-copy-code');
        const originalText = this.textContent;
        
        navigator.clipboard.writeText(code).then(() => {
          this.textContent = 'Copied!';
          this.classList.add('copied');
          
          setTimeout(() => {
            this.textContent = originalText;
            this.classList.remove('copied');
          }, 2000);
        }).catch(err => {
          // Fallback for older browsers
          const textarea = document.createElement('textarea');
          textarea.value = code;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          
          this.textContent = 'Copied!';
          this.classList.add('copied');
          
          setTimeout(() => {
            this.textContent = originalText;
            this.classList.remove('copied');
          }, 2000);
        });
      });
    });
  });
</script>
