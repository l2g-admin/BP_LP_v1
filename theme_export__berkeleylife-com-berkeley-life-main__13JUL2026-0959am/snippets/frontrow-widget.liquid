{% comment %}
  FrontRow Widget - Dynamic
  Usage: {% render 'frontrow-widget', product_type: 'menopause' %}
  
  Parameters:
  - product_type: 'menopause' (3784) or 'nitric-oxide' (3783)
{% endcomment %}

{% if product_type == 'menopause' %}
  {% assign product_id = '3784' %}
{% elsif product_type == 'nitric-oxide' %}
  {% assign product_id = '3783' %}
{% else %}
  {% assign product_id = '' %}
{% endif %}

{% if product_id != '' %}
  <div id="frontrow-badge">
    <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=quant&product_id={{ product_id }}"></script>
    <iframe class="iframe-frontrow" id="iframe-frontrow-quant-{{ product_id }}" frameborder="0" src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=quant&product_id={{ product_id }}"></iframe>
  </div>

  <style>
    #iframe-frontrow-quant-{{ product_id }} {height: 0px;}
    #frontrow-badge{position:relative;display:flex;}.iframe-frontrow{width:100%;margin:0}.iframe-modal-frontrow{display:none;position:fixed;z-index:99999999;left:0;top:0;right:0;bottom:0;width:100%;height:100%;overflow:hidden}
  </style>
{% endif %}