{%- doc -%}
  C FrontRow Reviews — Embedded FrontRow Health testimonials widget

  Parameters:
  - product_type: 'menopause' | 'nitric-oxide' (required)
  - container_id: Unique id for the wrapper (default: 'c-frontrow-reviews')

  Usage:
    {% render 'c-frontrow-reviews', product_type: 'menopause' %}
{%- enddoc -%}

{%- liquid
  assign fr_product_type = product_type | default: 'menopause'
  assign fr_container_id = container_id | default: 'c-frontrow-reviews'

  if fr_product_type == 'menopause'
    assign fr_product_id = '3784'
  elsif fr_product_type == 'nitric-oxide'
    assign fr_product_id = '3783'
  else
    assign fr_product_id = ''
  endif
-%}

{%- if fr_product_id != '' -%}
  <div class="c-fr-reviews" id="{{ fr_container_id }}">
    <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=qual&product_id={{ fr_product_id }}"></script>
    <iframe
      id="frontrow-testimonials-{{ fr_product_id }}"
      class="c-fr-reviews__iframe"
      frameborder="0"
      src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=qual&product_id={{ fr_product_id }}"
    ></iframe>
  </div>
{%- endif -%}

{% stylesheet %}
  .c-fr-reviews {
    width: 100%;
  }

  .c-fr-reviews__iframe {
    width: 100%;
    border: 0;
  }

  iframe.iframe-modal-testimonials {
    z-index: 99999998;
  }
{% endstylesheet %}
