<quick-shop-opener data-url="{{ product_card_product.url }}?view=quickshop" class="peer-focus:opacity-100 peer-hover:opacity-100 hover:opacity-100 focus-within:opacity-100 no-js-hidden md:opacity-0 peer-focus-within:opacity-100 transition-opacity" data-modal="#PopupModal-{{ product_card_product.id }}">
  <button class="md:w-40 md:right-1/2 bottom-4 hover:bg-opacity-100 focus:bg-opacity-100 md:py-3 right-2 md:translate-x-1/2 absolute inline-flex items-center justify-center w-auto max-w-full p-4 text-sm text-black transition-colors bg-white bg-opacity-75 border border-black border-solid z-10 {{ classes }}" type="button" aria-haspopup="dialog" aria-label="Quick Shop, {{ product_card_product.title }}">
    <span class="md:inline-block hidden mr-2">
      Quick Shop
    </span>
    <span class="w-3 h-3">
      {% render 'icon-plus' %}
    </span>
  </button>
</quick-shop-opener>
<quick-shop-dialog id="PopupModal-{{ product_card_product.id }}" class="-z-10 open:z-20 open:visible transform-gpu bg-black/20 fixed inset-0 invisible w-full h-full p-8">
  <div role="dialog" aria-label="{{ block.settings.link_label }}" aria-modal="true" class="absolute left-1/2 -translate-x-1/2 w-10/12 md:w-full h-auto max-h-[var(--safe-height)] max-w-screen-lg mx-auto overflow-auto overscroll-contain bg-white md:p-8 rounded-lg shadow-xl" tabindex="-1">
    <div class="relative">
      <div class="top-4 md:top-0 sticky z-10 h-0 pr-2 overflow-visible text-right">
        <button id="ModalClose-{{ product_card_product.id }}" type="button" class="hover:border-black focus-visible:outline-none focus:border-black hover:bg-gray-50 w-8 h-8 p-2 transition-colors border border-gray-200 rounded-full" aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>
      </div>
      <div class="">
        <div id="PopupModal-{{ product_card_product.id }}-Render"></div>
      </div>
    </div>
  </div>
</quick-shop-dialog>
