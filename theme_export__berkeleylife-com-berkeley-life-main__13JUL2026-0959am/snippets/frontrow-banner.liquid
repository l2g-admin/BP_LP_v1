{%- comment -%}
  FrontRow Banner Snippet
  
  Usage:
  {% render 'frontrow-banner', product_type: 'menopause' %}
  {% render 'frontrow-banner', product_type: 'nitric-oxide' %}
  
  Parameters:
  - product_type: 'menopause' (product_id: 3784) or 'nitric-oxide' (product_id: 3783)
{%- endcomment -%}
{%- if product_type == 'menopause' -%}
  <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=sticker&product_id=3784"></script>
  <iframe data-state="max" class="iframe-frontrow-sticker" id="frontrow-sticker" frameborder="0" src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=sticker&product_id=3784"></iframe>
{%- elsif product_type == 'nitric-oxide' -%}
  <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=sticker&product_id=3783"></script>
  <iframe data-state="max" class="iframe-frontrow-sticker" id="frontrow-sticker" frameborder="0" src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=sticker&product_id=3783"></iframe>
{%- endif -%}

<style>
    .iframe.frontrow { display: none; position: fixed; left: 0; top: 0; z-index: 99999997; right: 0; bottom: 0; width: 100%; height: 100%; overflow: hidden; }
</style>
