{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by
  assign total_active_values = 0
  assign total_inactive_values = 0
  if results.url
    assign results_url = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif
-%}

<script src="{{ 'facet-filters.js' | asset_url }}" type="module"></script>

<facet-filters>
  <form id="FacetFiltersForm-Collection" hx-params="*" hx-get="{{ results_url }}" hx-target="#CollectionProductGrid" hx-select="#CollectionProductGrid" hx-trigger="change throttle:1s" hx-push-url="true" class="w-full" hx-swap="outerHTML focus-scroll:true" hx-indicator=".htmx-indicator">

    {%- assign trigger_classes =  "relative p-3 border border-gray-200 group-open:bg-brand group-open:text-white" -%}
    {%- assign drawer_classes = "absolute left-0 z-50 w-full md:w-80 md:max-w-sm bg-white p-4 shadow-lg opacity-0 group-open:opacity-100 transition-opacity flex justify-center md:justify-start md:rounded-lg md:top-full max-h-[40vh] overflow-y-auto" -%}
    {%- comment -%}This div is the horizontal scroll bar of filters {%- endcomment -%}
    <div class="overscroll-contain md:overscroll-none md:overflow-visible w-full overflow-x-auto" id="ScrollFilters">
      <div class="md:overflow-y-visible overflow-y-hidden" id="ScrollFilters">
        <div class="w-max md:px-8 md:flex-col flex gap-2 p-4">

        {%- if enable_sorting -%}
          <div class="md:flex-col md:items-stretch flex items-center gap-2">
            <h2 class="md:not-sr-only sr-only">
              <label for="SortBy">{{ 'sections.collection_template.sort_by_label' | t }}</label>
            </h2>
            <div>
              <select class="{{ trigger_classes }} focus:ring-0" name="sort_by" id="SortBy" aria-describedby="a11y-refresh-page-message">
                {%- for option in results.sort_options -%}
                  <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected="selected"{% endif %}>{{ option.name | escape }}</option>
                {%- endfor -%}
              </select>
            </div>
          </div>
        {%- endif -%}

        {%- if enable_filtering -%}
          <h2 class="md:not-sr-only flex items-center mr-2 sr-only">
            <span>
              {{ 'sections.collection_template.filter_by_label' | t }}
            </span>
          </h2>
          {%- for filter in results.filters -%}
            {%- assign total_active_values = total_active_values | plus: filter.active_values.size -%}
            {%- assign total_inactive_values = total_inactive_values | plus: filter.inactive_values.size -%}
            {%- case filter.type -%}
              {%- when 'boolean' -%}
                <details class="group md:relative" id="Details-{{ forloop.index }}-{{ section.id }}" hx-preserve>
                  <summary class="{{ trigger_classes }}" id="Summary-{{ forloop.index }}-{{ section.id }}">
                    <span class="flex items-center gap-2">
                      <span>{{ filter.label | escape }}</span>
                      <span class="group-open:rotate-180 block">{% render 'icon-caret' %}</span>
                    </span>
                  </summary>
                  <div class="{{ drawer_classes }}">
                    <fieldset class="md:mx-auto w-auto max-w-full">
                      {%- for value in filter.values -%}
                        <label data-filter-type="{{ filter.type }}" for="Filter-{{ filter.label | escape }}-{{ forloop.index }}" class="inline-flex items-center p-2">
                          <input type="checkbox"
                            class="text-brand peer disabled:text-gray-50 focus:ring-brand mr-1"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <span class="peer-disabled:text-gray-400">{{ filter.label }} ({{ value.count }})</span>
                        </label>
                      {%- endfor -%}
                    </fieldset>
                  </div>
                </details>
              {%- when 'list' -%}
              <details class="group md:relative" id="Details-{{ forloop.index }}-{{ section.id }}" hx-preserve>
                <summary class="{{ trigger_classes }}" id="Summary-{{ forloop.index }}-{{ section.id }}">
                  <span class="flex items-center gap-2">
                    <span>{{ filter.label | escape }}</span>
                    <span class="group-open:rotate-180 block">{% render 'icon-caret' %}</span>
                  </span>
                </summary>
                <div class="{{ drawer_classes }}">
                  <fieldset class="md:mx-auto w-auto max-w-full">
                    {%- for value in filter.values -%}
                      <label data-filter-type="{{ filter.type }}" for="Filter-{{ filter.label | escape }}-{{ forloop.index }}" class="inline-flex items-center p-2">
                        <input type="checkbox"
                          class="text-brand peer disabled:text-gray-50 focus:ring-brand mr-1"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        >
                        <span class="peer-disabled:text-gray-400">{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  </fieldset>
                </div>
                </details>
              {%- when 'price_range' -%}
                <details class="group md:relative" id="Details-{{ forloop.index }}-{{ section.id }}" hx-preserve>
                  <summary class="{{ trigger_classes }}" id="Summary-{{ forloop.index }}-{{ section.id }}">
                    <span class="flex items-center gap-2">
                      <span>{{ filter.label | escape }}</span>
                      <span class="group-open:rotate-180 block">{% render 'icon-caret' %}</span>
                    </span>
                  </summary>
                  <div class="{{ drawer_classes }}">
                    <fieldset class="md:mx-auto w-auto max-w-full">
                      <div class="grid grid-cols-[auto,auto,1fr,auto,auto,1fr] gap-2 items-center max-w-full md:max-w-sm md:mx-auto">
                        <label for="Filter-{{ filter.label | escape }}-GTE">From</label>
                        <span>{{ cart.currency.symbol }}</span>
                        <input
                          name="{{ filter.min_value.param_name }}"
                          id="Filter-{{ filter.label | escape }}-GTE"
                          {%- if filter.min_value.value -%}
                            {%- if uses_comma_decimals -%}value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                          {%- endif -%}
                          type="number"
                          placeholder="0"
                          min="0"
                          class="focus:border-brand focus:ring-brand"
                          {%- if uses_comma_decimals -%}max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"{% endif %}
                        >


                        <label for="Filter-{{ filter.label | escape }}-LTE">To</label>
                        <span>{{ cart.currency.symbol }}</span>
                        <input
                          name="{{ filter.max_value.param_name }}"
                          id="Filter-{{ filter.label | escape }}-LTE"
                          class="focus:border-brand focus:ring-brand"
                          {%- if filter.max_value.value -%}{%- if uses_comma_decimals -%}value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                          {%- endif -%}
                          type="number"
                          min="0"
                          {%- if uses_comma_decimals -%}
                            placeholder="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                            max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                          {%- else -%}
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          {% endif %}
                        >
                      </div>
                    </fieldset>
                  </div>
                </details>
              {%- else -%}
            {%- endcase -%}
          {%- endfor -%}
        {%- endif -%}
        </div>
      </div>
    </div>


    {%- comment -%}Active Filters{%- endcomment -%}
    {%- if enable_filtering -%}
    <div class="overscroll-contain w-full overflow-x-auto" id="CollectionActive" hx-swap-oob="true" >
      <div class="w-max md:w-full md:px-8 flex flex-wrap gap-2 px-4 pb-4 {% if total_active_values == 0 %}hidden{% endif %}">
        <a href="{{ results_url }}" class="p-1" hx-target="#CollectionProductGrid" hx-select="#CollectionProductGrid" hx-trigger="click" hx-get="{{ results_url }}" hx-swap="outerHTML" hx-push-url="true">

          <span class="text-sm">Clear All ({{ total_active_values }})</span>
        </a>
        {%- for filter in results.filters -%}
          {%- for value in filter.active_values -%}
            <a href="{{ value.url_to_remove }}" hx-target="#CollectionProductGrid" hx-select="#CollectionProductGrid" hx-trigger="click" hx-get="{{ filter.url_to_remove }}" hx-swap="outerHTML" hx-push-url="true" class="flex items-center p-1 px-2 text-sm bg-gray-100 rounded-full">
              <span class="flex items-center">
                <span>
                  {%- if filter.type == 'boolean' -%}
                    {{ filter.label | escape }}
                  {%- else -%}
                    {{ value.label | escape }}
                  {%- endif -%}
                </span>
                {% render 'icon-close-small' %}
                <span class="sr-only">Clear Filter</span>
              </span>
            </a>
          {%- endfor -%}
          {% if filter.type == "price_range" %}
            {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
              <a href="{{ filter.url_to_remove }}" hx-target="#CollectionProductGrid" hx-select="#CollectionProductGrid" hx-trigger="click" hx-get="{{ filter.url_to_remove }}" hx-swap="outerHTML" hx-push-url="true" class="flex items-center p-1 px-2 text-sm bg-gray-100 rounded-full">
                <span class="flex items-center">
                  {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}-{%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                  {% render 'icon-close-small' %}
                  <span class="sr-only">Clear Filter</span>
                </span>
              </a>
            {%- endif -%}
          {% endif %}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    <input type="submit" value="Submit" class="no-js block p-1" />

  </form>
</facet-filters>